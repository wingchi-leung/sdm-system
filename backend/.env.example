# backend 本地开发示例
# 仅用于“直接在 backend 目录运行 uvicorn”的场景。
# 如果你走根目录 docker compose，请优先维护根目录 .env，不要把它和这里混用。

# ============ 数据库 ============
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_password
MYSQL_DB=sdm_db

# ============ JWT / 登录安全 ============
JWT_SECRET=please-change-me-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080
DB_ECHO=false
REQUIRE_HTTPS_FOR_LOGIN=false
LOGIN_RATE_LIMIT_COUNT=10
LOGIN_RATE_LIMIT_WINDOW_SECONDS=60

# ============ CORS ============
# 本地开发（Web 前端）
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
# 生产示例（请按真实域名替换，不要保留 localhost）
# CORS_ORIGINS=https://admin.example.com,https://ops.example.com

# ============ 文件上传 / 本地存储 ============
STORAGE_TYPE=local
LOCAL_UPLOAD_DIR=uploads
STORAGE_BASE_URL=http://localhost:8000/uploads

# ============ 微信小程序 ============
WECHAT_APPID=your_appid
WECHAT_SECRET=your_secret
WECHAT_CONTENT_SECURITY_ENABLED=false
WECHAT_MEDIA_CALLBACK_TOKEN=your_callback_token

# ============ 微信支付 ============
WECHAT_PAY_MCH_ID=your_mch_id
WECHAT_PAY_API_V3_KEY=your_api_v3_key
WECHAT_PAY_SERIAL_NO=your_serial_no
WECHAT_PAY_PRIVATE_KEY_PATH=D:/path/to/apiclient_key.pem
WECHAT_PAY_PUBLIC_KEY_PATH=D:/path/to/wx_public_key.pem
WECHAT_PAY_PUBLIC_KEY_ID=your_public_key_id
WECHAT_PAY_NOTIFY_URL=https://api.your-domain.com/api/v1/payments/notify

# ============ 可选上传限制 ============
MAX_REQUEST_BODY_SIZE=10485760
MAX_POSTER_SIZE=5242880
ALLOWED_POSTER_TYPES=image/png,image/jpeg,image/jpg

# ============ 云对象存储（按需启用） ============
# OSS_ACCESS_KEY_ID=your_access_key_id
# OSS_ACCESS_KEY_SECRET=your_access_key_secret
# OSS_BUCKET=your-bucket-name
# OSS_ENDPOINT=oss-cn-hangzhou.aliyuncs.com
# OSS_CDN_DOMAIN=cdn.your-domain.com

# COS_SECRET_ID=your_secret_id
# COS_SECRET_KEY=your_secret_key
# COS_BUCKET=your-bucket-1250000000
# COS_REGION=ap-guangzhou
# COS_CDN_DOMAIN=cdn.your-domain.com
