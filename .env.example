# SDM System Docker 正式环境示例
# 复制为根目录 .env 后再填写真实值
# 适用范围：
# 1. docker-compose.yml
# 2. Docker 内 backend 容器环境变量
# 3. Docker 内 frontend 构建时环境变量

# ============ 镜像地址（私有仓库）============
BACKEND_IMAGE=registry.example.com/sdm/backend:latest
FRONTEND_IMAGE=registry.example.com/sdm/frontend:latest

# ============ 数据库（Docker MySQL）============
MYSQL_ROOT_PASSWORD=请改成强密码
MYSQL_USER=sdm_user
MYSQL_PASSWORD=请改成强密码
MYSQL_DB=sdm_db
MYSQL_HOST_PORT=3307

# ============ 后端安全配置 ============
JWT_SECRET=请使用至少32位随机字符串
SENSITIVE_RSA_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\n请替换为PKCS8私钥内容\n-----END PRIVATE KEY-----
SENSITIVE_RSA_PUBLIC_KEY=-----BEGIN PUBLIC KEY-----\n请替换为公钥内容\n-----END PUBLIC KEY-----
SENSITIVE_RSA_KEY_ID=v1
SENSITIVE_RSA_PRIVATE_KEYS_JSON=
SENSITIVE_RSA_PUBLIC_KEYS_JSON=
REQUIRE_ENCRYPTED_SENSITIVE_FIELDS=true
DB_ECHO=false
REQUIRE_HTTPS_FOR_LOGIN=true
LOGIN_RATE_LIMIT_COUNT=10
LOGIN_RATE_LIMIT_WINDOW_SECONDS=60

# ============ 对外访问地址 ============
API_BASE_URL=https://api.你的域名.com
STATIC_BASE_URL=https://api.你的域名.com
CORS_ORIGINS=https://web.你的域名.com,https://api.你的域名.com

# ============ 本地上传存储 ============
STORAGE_TYPE=local
LOCAL_UPLOAD_DIR=uploads

# ============ 微信小程序 ============
WECHAT_APPID=你的小程序AppID
WECHAT_SECRET=你的小程序Secret

# ============ 微信支付 ============
WECHAT_PAY_MCH_ID=商户号
WECHAT_PAY_API_V3_KEY=APIv3密钥
WECHAT_PAY_SERIAL_NO=商户证书序列号
WECHAT_PAY_PRIVATE_KEY_PATH=/run/secrets/wechat_pay/apiclient_key.pem
WECHAT_PAY_PUBLIC_KEY_PATH=/run/secrets/wechat_pay/wx_public_key.pem
WECHAT_PAY_PUBLIC_KEY_ID=微信支付公钥ID
WECHAT_PAY_NOTIFY_URL=https://api.你的域名.com/api/v1/payments/notify

# ============ Cloudflare Tunnel ============
# 当前 compose 方案不读取 TUNNEL_TOKEN。
# 隧道配置来自：
# 1. tunnel/config.yml
# 2. tunnel/certs/*.json
# 如需迁移新机器，请复制上述文件或重新执行 cloudflared 登录与隧道凭据配置。
