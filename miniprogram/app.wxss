/**
 * ═══════════════════════════════════════════════════════════════
 * SDM 小程序 - 极简奢华设计系统
 * ═══════════════════════════════════════════════════════════════
 * 设计理念：呼吸 · 精致 · 永恒
 * ═══════════════════════════════════════════════════════════════
 */

page {
  /* ─────────────────────────────────────────────────────────────
   * 色彩系统 - 极简奢华
   * ───────────────────────────────────────────────────────────── */

  /* 主色调 - 深灰而非纯黑，更柔和 */
  --primary: #1A1A1A;
  --primary-dark: #0A0A0A;
  --primary-light: rgba(26, 26, 26, 0.04);
  --primary-glow: rgba(26, 26, 26, 0.06);

  /* 强调色 - 优雅金色 */
  --accent: #C9A961;
  --accent-light: rgba(201, 169, 97, 0.08);
  --accent-dark: #A68B4E;

  /* 背景色 - 温暖的灰白 */
  --background: #FAFAF8;
  --background-subtle: #F5F5F3;
  --background-card: #FFFFFF;
  --background-elevated: #FFFFFF;
  --background-warm: #FEFDFB;

  /* 文字色 - 柔和层次 */
  --text-primary: #1A1A1A;
  --text-secondary: #6B6B6B;
  --text-tertiary: #A0A0A0;
  --text-muted: #D4D4D4;

  /* 状态色 - 优雅克制 */
  --status-not-started: #9B9B9B;
  --status-not-started-bg: rgba(155, 155, 155, 0.06);
  --status-ongoing: #5B8C7D;
  --status-ongoing-bg: rgba(91, 140, 125, 0.06);
  --status-ended: #9B9B9B;
  --status-ended-bg: rgba(155, 155, 155, 0.06);

  /* 语义色 */
  --success: #5B8C7D;
  --success-bg: rgba(91, 140, 125, 0.06);
  --error: #C85A54;
  --error-bg: rgba(200, 90, 84, 0.06);
  --warning: #C9A961;
  --warning-bg: rgba(201, 169, 97, 0.06);
  --info: #6B8CAF;
  --info-bg: rgba(107, 140, 175, 0.06);

  /* 边框与分割 */
  --border: rgba(26, 26, 26, 0.06);
  --border-light: rgba(26, 26, 26, 0.03);
  --divider: rgba(26, 26, 26, 0.04);

  /* ─────────────────────────────────────────────────────────────
   * 阴影系统 - 柔和精致
   * ───────────────────────────────────────────────────────────── */
  --shadow-xs: 0 1px 3px rgba(26, 26, 26, 0.02);
  --shadow-sm: 0 2px 12px rgba(26, 26, 26, 0.03);
  --shadow-md: 0 8px 24px rgba(26, 26, 26, 0.04);
  --shadow-lg: 0 16px 40px rgba(26, 26, 26, 0.06);
  --shadow-elevated: 0 24px 64px rgba(26, 26, 26, 0.08);

  /* ─────────────────────────────────────────────────────────────
   * 间距系统 - 呼吸节奏
   * ───────────────────────────────────────────────────────────── */
  --space-xs: 8rpx;
  --space-sm: 16rpx;
  --space-md: 24rpx;
  --space-lg: 40rpx;
  --space-xl: 64rpx;
  --space-2xl: 96rpx;
  --space-3xl: 160rpx;

  /* ─────────────────────────────────────────────────────────────
   * 圆角系统 - 柔和边角
   * ───────────────────────────────────────────────────────────── */
  --radius-xs: 4rpx;
  --radius-sm: 8rpx;
  --radius-md: 12rpx;
  --radius-lg: 20rpx;
  --radius-xl: 28rpx;
  --radius-full: 9999rpx;

  /* ─────────────────────────────────────────────────────────────
   * 字体系统 - 优雅精致
   * ───────────────────────────────────────────────────────────── */
  --font-display: "PingFang SC", -apple-system, "SF Pro Display", sans-serif;
  --font-body: "PingFang SC", -apple-system, "SF Pro Text", sans-serif;

  font-family: var(--font-body);
  background-color: var(--background);
  font-size: 28rpx;
  color: var(--text-primary);
  line-height: 1.6;
  letter-spacing: 0.02em;
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
}

/* ─────────────────────────────────────────────────────────────
 * 容器布局
 * ───────────────────────────────────────────────────────────── */
.container {
  padding: 0 var(--space-lg);
}

/* ─────────────────────────────────────────────────────────────
 * 卡片组件 - 柔和精致
 * ───────────────────────────────────────────────────────────── */
.card {
  background: var(--background-card);
  border-radius: var(--radius-xl);
  padding: var(--space-xl);
  margin-bottom: var(--space-lg);
  box-shadow: var(--shadow-sm);
  border: 1px solid var(--border-light);
  transition: all 0.5s cubic-bezier(0.23, 1, 0.32, 1);
}

.card:active {
  transform: translateY(2rpx);
  box-shadow: var(--shadow-xs);
}

/* ─────────────────────────────────────────────────────────────
 * 按钮系统 - 优雅触感
 * ───────────────────────────────────────────────────────────── */
.btn-primary {
  background: linear-gradient(135deg, var(--primary) 0%, var(--primary-dark) 100%);
  color: #FFFFFF;
  border-radius: var(--radius-lg);
  font-weight: 500;
  border: none;
  padding: 36rpx var(--space-2xl);
  font-size: 32rpx;
  letter-spacing: 0.04em;
  transition: all 0.5s cubic-bezier(0.23, 1, 0.32, 1);
  box-shadow: 0 8rpx 24rpx rgba(26, 26, 26, 0.12);
  position: relative;
  overflow: hidden;
}

.btn-primary::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(135deg, rgba(201, 169, 97, 0.1) 0%, transparent 100%);
  opacity: 0;
  transition: opacity 0.5s ease;
}

.btn-primary:active {
  transform: translateY(2rpx);
  box-shadow: 0 4rpx 12rpx rgba(26, 26, 26, 0.08);
}

.btn-primary:active::before {
  opacity: 1;
}

.btn-primary[disabled] {
  opacity: 0.4;
  transform: none;
}

.btn-secondary {
  background: transparent;
  color: var(--text-primary);
  border-radius: var(--radius-lg);
  border: 1px solid var(--border);
  padding: 32rpx var(--space-xl);
  font-size: 30rpx;
  font-weight: 500;
  letter-spacing: 0.04em;
  transition: all 0.5s cubic-bezier(0.23, 1, 0.32, 1);
}

.btn-secondary:active {
  background: var(--background-subtle);
  border-color: var(--text-secondary);
  transform: translateY(2rpx);
}

.btn-text {
  background: none;
  color: var(--text-secondary);
  border: none;
  padding: var(--space-sm) var(--space-md);
  font-size: 28rpx;
  font-weight: 400;
  letter-spacing: 0.02em;
  transition: all 0.3s ease;
}

.btn-text::after {
  border: none;
}

.btn-text:active {
  color: var(--text-primary);
}

/* ─────────────────────────────────────────────────────────────
 * 标签组件 - 精致小巧
 * ───────────────────────────────────────────────────────────── */
.tag {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 10rpx 20rpx;
  border-radius: var(--radius-sm);
  font-size: 22rpx;
  font-weight: 500;
  letter-spacing: 0.04em;
}

.tag-not-started {
  background: var(--status-not-started-bg);
  color: var(--status-not-started);
}

.tag-ongoing {
  background: var(--status-ongoing-bg);
  color: var(--status-ongoing);
}

.tag-ended {
  background: var(--status-ended-bg);
  color: var(--status-ended);
}

/* ─────────────────────────────────────────────────────────────
 * 输入框组件 - 简洁优雅
 * ───────────────────────────────────────────────────────────── */
.input {
  width: 100%;
  height: 96rpx;
  padding: 0 var(--space-md);
  font-size: 28rpx;
  background: var(--background-warm);
  border: 1px solid var(--border);
  border-radius: var(--radius-md);
  box-sizing: border-box;
  color: var(--text-primary);
  transition: all 0.3s ease;
  letter-spacing: 0.02em;
}

.input:focus {
  border-color: var(--accent);
  background: var(--background-card);
  box-shadow: 0 0 0 3px var(--accent-light);
}

.input::placeholder {
  color: var(--text-muted);
}

/* ─────────────────────────────────────────────────────────────
 * 分割线
 * ───────────────────────────────────────────────────────────── */
.divider {
  height: 1px;
  background: var(--divider);
  margin: var(--space-md) 0;
}

/* ─────────────────────────────────────────────────────────────
 * 加载动画 - 优雅旋转
 * ───────────────────────────────────────────────────────────── */
@keyframes spin {
  to { transform: rotate(360deg); }
}

@keyframes fadeIn {
  from { opacity: 0; transform: translateY(8rpx); }
  to { opacity: 1; transform: translateY(0); }
}

@keyframes slideUp {
  from { opacity: 0; transform: translateY(24rpx); }
  to { opacity: 1; transform: translateY(0); }
}

@keyframes pulse {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.6; }
}

.loading {
  width: 48rpx;
  height: 48rpx;
  border: 2rpx solid var(--border);
  border-top-color: var(--primary);
  border-radius: 50%;
  animation: spin 0.8s cubic-bezier(0.4, 0, 0.2, 1) infinite;
}

/* ─────────────────────────────────────────────────────────────
 * 安全区域
 * ───────────────────────────────────────────────────────────── */
.safe-area-bottom {
  padding-bottom: env(safe-area-inset-bottom);
}

/* ─────────────────────────────────────────────────────────────
 * 动画辅助类
 * ───────────────────────────────────────────────────────────── */
.fade-in {
  animation: fadeIn 0.4s ease forwards;
}

.slide-up {
  animation: slideUp 0.5s cubic-bezier(0.4, 0, 0.2, 1) forwards;
}

.delay-1 { animation-delay: 0.1s; }
.delay-2 { animation-delay: 0.2s; }
.delay-3 { animation-delay: 0.3s; }
.delay-4 { animation-delay: 0.4s; }
