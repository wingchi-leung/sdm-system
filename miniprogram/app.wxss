page {
  /* 主色调 - 蓝色 */
  --primary: #355CC2;
  --primary-dark: #2A4A9E;
  --primary-light: rgba(53, 92, 194, 0.1);

  /* 背景色 */
  --background: #FAFAF8;
  --background-card: #FFFFFF;
  --background-input: #F5F4F2;

  /* 文字色 */
  --text-primary: #1A1A1A;
  --text-secondary: #6B6B6B;
  --text-tertiary: #9B9B9B;

  /* 状态色 */
  --status-not-started: #9B9B9B;
  --status-not-started-bg: rgba(155, 155, 155, 0.1);
  --status-ongoing: #27AE60;
  --status-ongoing-bg: rgba(39, 174, 96, 0.1);
  --status-ended: #355CC2;
  --status-ended-bg: rgba(53, 92, 194, 0.1);

  /* 语义色 */
  --error: #E74C3C;
  --error-bg: rgba(231, 76, 60, 0.1);
  --warning: #F39C12;
  --warning-bg: rgba(243, 156, 18, 0.1);

  /* 边框 */
  --border: rgba(0, 0, 0, 0.08);
  --divider: rgba(0, 0, 0, 0.06);

  /* 阴影 */
  --shadow: 0 2px 8px rgba(0, 0, 0, 0.06);

  /* 间距 */
  --space-sm: 16rpx;
  --space-md: 24rpx;
  --space-lg: 32rpx;
  --space-xl: 48rpx;

  /* 字体 */
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', sans-serif;
  background-color: var(--background);
  font-size: 28rpx;
  color: var(--text-primary);
  line-height: 1.5;
}

/* 容器 */
.container {
  padding: 0 var(--space-lg);
}

/* 卡片 */
.card {
  background: var(--background-card);
  border-radius: 12rpx;
  padding: var(--space-lg);
  margin-bottom: var(--space-md);
  box-shadow: var(--shadow);
  border: 1px solid var(--border);
}

/* 按钮 */
.btn-primary {
  background: var(--primary);
  color: #FFFFFF;
  border-radius: 8rpx;
  font-weight: 600;
  border: none;
  padding: 24rpx var(--space-lg);
  font-size: 30rpx;
}

.btn-primary:active {
  opacity: 0.8;
}

.btn-secondary {
  background: transparent;
  color: var(--text-primary);
  border-radius: 8rpx;
  border: 1px solid var(--border);
  padding: 22rpx var(--space-md);
  font-size: 28rpx;
}

.btn-text {
  background: none;
  color: var(--primary);
  border: none;
  padding: 12rpx 20rpx;
  font-size: 28rpx;
}

.btn-text::after {
  border: none;
}

/* 标签 */
.tag {
  display: inline-block;
  padding: 6rpx 12rpx;
  border-radius: 4rpx;
  font-size: 22rpx;
  font-weight: 500;
}

.tag-not-started {
  background: var(--status-not-started-bg);
  color: var(--status-not-started);
}

.tag-ongoing {
  background: var(--status-ongoing-bg);
  color: var(--status-ongoing);
}

.tag-ended {
  background: var(--status-ended-bg);
  color: var(--status-ended);
}

/* 输入框 */
.input {
  width: 100%;
  height: 88rpx;
  padding: 0 var(--space-md);
  font-size: 28rpx;
  background: var(--background-input);
  border: 1px solid var(--border);
  border-radius: 8rpx;
  box-sizing: border-box;
  color: var(--text-primary);
}

.input:focus {
  border-color: var(--primary);
}

/* 分割线 */
.divider {
  height: 1px;
  background: var(--divider);
  margin: var(--space-md) 0;
}

/* 加载 */
@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading {
  width: 48rpx;
  height: 48rpx;
  border: 3rpx solid var(--border);
  border-top-color: var(--primary);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}
