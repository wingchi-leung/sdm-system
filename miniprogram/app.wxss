/**
 * ═══════════════════════════════════════════════════════════════
 * SDM 小程序 - Bold Minimal 设计系统
 * ═══════════════════════════════════════════════════════════════
 * 设计理念：极致简约 · 大胆强调 · 戏剧性元素
 * 强调色：电光绿 - 充满活力，高级且独特
 * ═══════════════════════════════════════════════════════════════
 */

page {
  /* ─────────────────────────────────────────────────────────────
   * 色彩系统 - 极简黑白 + 电光绿强调
   * ───────────────────────────────────────────────────────────── */

  /* 强调色 - 电光绿，充满活力 */
  --accent: #00C853;
  --accent-dark: #00A844;
  --accent-light: rgba(0, 200, 83, 0.12);
  --accent-glow: rgba(0, 200, 83, 0.3);

  /* 辅助强调色 */
  --accent-secondary: #FF5722;

  /* 背景色 - 纯净白 */
  --bg-primary: #FFFFFF;
  --bg-secondary: #F8F9FA;
  --bg-tertiary: #F1F3F5;
  --bg-card: #FFFFFF;

  /* 文字色 - 黑白层次 */
  --text-primary: #0A0A0A;
  --text-secondary: #4A4A4A;
  --text-tertiary: #8A8A8A;
  --text-muted: #CACACA;

  /* 状态色 - 柔和但有辨识度 */
  --status-pending: #8A8A8A;
  --status-pending-bg: rgba(138, 138, 138, 0.1);
  --status-active: #00C853;
  --status-active-bg: rgba(0, 200, 83, 0.1);
  --status-ended: #0A0A0A;
  --status-ended-bg: rgba(10, 10, 10, 0.06);

  /* 语义色 */
  --success: #00C853;
  --success-bg: rgba(0, 200, 83, 0.1);
  --error: #E53935;
  --error-bg: rgba(229, 57, 53, 0.08);
  --warning: #FF9800;
  --warning-bg: rgba(255, 152, 0, 0.1);

  /* 边框 */
  --border: rgba(10, 10, 10, 0.08);
  --border-strong: rgba(10, 10, 10, 0.15);

  /* ─────────────────────────────────────────────────────────────
   * 阴影系统 - 大胆但精致
   * ───────────────────────────────────────────────────────────── */
  --shadow-sm: 0 2px 8px rgba(0, 0, 0, 0.04);
  --shadow-md: 0 4px 20px rgba(0, 0, 0, 0.08);
  --shadow-lg: 0 8px 40px rgba(0, 0, 0, 0.12);
  --shadow-accent: 0 4px 20px rgba(0, 200, 83, 0.25);
  --shadow-bold: 0 12px 48px rgba(0, 0, 0, 0.15);

  /* ─────────────────────────────────────────────────────────────
   * 间距系统
   * ───────────────────────────────────────────────────────────── */
  --space-xs: 8rpx;
  --space-sm: 16rpx;
  --space-md: 24rpx;
  --space-lg: 32rpx;
  --space-xl: 48rpx;
  --space-2xl: 64rpx;
  --space-3xl: 96rpx;

  /* ─────────────────────────────────────────────────────────────
   * 圆角系统
   * ───────────────────────────────────────────────────────────── */
  --radius-sm: 4rpx;
  --radius-md: 8rpx;
  --radius-lg: 16rpx;
  --radius-xl: 24rpx;
  --radius-2xl: 32rpx;
  --radius-full: 9999rpx;

  /* ─────────────────────────────────────────────────────────────
   * 字体系统
   * ───────────────────────────────────────────────────────────── */
  --font-display: "SF Pro Display", -apple-system, "PingFang SC", sans-serif;
  --font-body: "SF Pro Text", -apple-system, "PingFang SC", sans-serif;
  --font-mono: "SF Mono", "Menlo", monospace;

  font-family: var(--font-body);
  background-color: var(--bg-secondary);
  font-size: 28rpx;
  color: var(--text-primary);
  line-height: 1.6;
  letter-spacing: 0.01em;
  -webkit-font-smoothing: antialiased;
}

/* ─────────────────────────────────────────────────────────────
 * 页面容器
 * ───────────────────────────────────────────────────────────── */
.container {
  padding: 0 var(--space-lg);
}

/* ─────────────────────────────────────────────────────────────
 * 卡片组件
 * ───────────────────────────────────────────────────────────── */
.card {
  background: var(--bg-card);
  border-radius: var(--radius-xl);
  padding: var(--space-xl);
  margin-bottom: var(--space-md);
  box-shadow: var(--shadow-md);
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}

.card:active {
  transform: translateY(2rpx);
  box-shadow: var(--shadow-sm);
}

/* ─────────────────────────────────────────────────────────────
 * 主按钮 - 大胆设计
 * ───────────────────────────────────────────────────────────── */
.btn-primary {
  background: var(--accent);
  color: #FFFFFF;
  border-radius: var(--radius-full);
  font-weight: 600;
  border: none;
  padding: 32rpx var(--space-2xl);
  font-size: 30rpx;
  letter-spacing: 0.02em;
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  box-shadow: var(--shadow-accent);
}

.btn-primary:active {
  transform: scale(0.97);
  box-shadow: var(--shadow-sm);
}

.btn-primary[disabled] {
  opacity: 0.5;
  transform: none;
}

/* 次要按钮 */
.btn-secondary {
  background: var(--bg-primary);
  color: var(--text-primary);
  border-radius: var(--radius-full);
  border: 2rpx solid var(--border-strong);
  padding: 28rpx var(--space-xl);
  font-size: 28rpx;
  font-weight: 500;
  letter-spacing: 0.02em;
  transition: all 0.3s ease;
}

.btn-secondary:active {
  background: var(--bg-tertiary);
}

/* 文字按钮 */
.btn-text {
  background: none;
  color: var(--accent);
  border: none;
  padding: var(--space-sm) var(--space-md);
  font-size: 28rpx;
  font-weight: 600;
  letter-spacing: 0.02em;
  transition: all 0.2s ease;
}

.btn-text::after {
  border: none;
}

.btn-text:active {
  opacity: 0.7;
}

/* ─────────────────────────────────────────────────────────────
 * 标签组件
 * ───────────────────────────────────────────────────────────── */
.tag {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 8rpx 16rpx;
  border-radius: var(--radius-sm);
  font-size: 22rpx;
  font-weight: 600;
  letter-spacing: 0.04em;
  text-transform: uppercase;
}

.tag-pending {
  background: var(--status-pending-bg);
  color: var(--status-pending);
}

.tag-active {
  background: var(--status-active-bg);
  color: var(--status-active);
}

.tag-ended {
  background: var(--status-ended-bg);
  color: var(--status-ended);
}

/* ─────────────────────────────────────────────────────────────
 * 输入框组件
 * ───────────────────────────────────────────────────────────── */
.input {
  width: 100%;
  height: 100rpx;
  padding: 0 var(--space-lg);
  font-size: 30rpx;
  background: var(--bg-primary);
  border: 2rpx solid var(--border);
  border-radius: var(--radius-lg);
  box-sizing: border-box;
  color: var(--text-primary);
  transition: all 0.25s ease;
  letter-spacing: 0.01em;
}

.input:focus {
  border-color: var(--accent);
  box-shadow: 0 0 0 6rpx var(--accent-light);
}

.input::placeholder {
  color: var(--text-muted);
}

/* ─────────────────────────────────────────────────────────────
 * 分割线
 * ───────────────────────────────────────────────────────────── */
.divider {
  height: 1px;
  background: var(--border);
  margin: var(--space-md) 0;
}

/* ─────────────────────────────────────────────────────────────
 * 动画系统
 * ───────────────────────────────────────────────────────────── */
@keyframes spin {
  to { transform: rotate(360deg); }
}

@keyframes fadeIn {
  from { opacity: 0; transform: translateY(16rpx); }
  to { opacity: 1; transform: translateY(0); }
}

@keyframes slideUp {
  from { opacity: 0; transform: translateY(32rpx); }
  to { opacity: 1; transform: translateY(0); }
}

@keyframes scaleIn {
  from { opacity: 0; transform: scale(0.9); }
  to { opacity: 1; transform: scale(1); }
}

@keyframes pulse {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.6; }
}

/* 加载动画 */
.loading {
  width: 48rpx;
  height: 48rpx;
  border: 3rpx solid var(--border);
  border-top-color: var(--accent);
  border-radius: 50%;
  animation: spin 0.7s linear infinite;
}

/* 动画辅助类 */
.fade-in {
  animation: fadeIn 0.4s ease forwards;
}

.slide-up {
  animation: slideUp 0.5s cubic-bezier(0.4, 0, 0.2, 1) forwards;
}

.scale-in {
  animation: scaleIn 0.4s ease forwards;
}

.delay-1 { animation-delay: 0.05s; }
.delay-2 { animation-delay: 0.1s; }
.delay-3 { animation-delay: 0.15s; }
.delay-4 { animation-delay: 0.2s; }
.delay-5 { animation-delay: 0.25s; }

/* ─────────────────────────────────────────────────────────────
 * 装饰元素
 * ───────────────────────────────────────────────────────────── */
.dot {
  display: inline-block;
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  background: var(--accent);
}

.dot-large {
  width: 12rpx;
  height: 12rpx;
}

.accent-bar {
  width: 6rpx;
  height: 100%;
  background: var(--accent);
  border-radius: 3rpx;
}

.accent-line {
  height: 4rpx;
  background: var(--accent);
  border-radius: 2rpx;
}