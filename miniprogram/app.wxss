/**
 * ═══════════════════════════════════════════════════════════════
 * SDM 小程序 - 极简奢华设计系统
 * ═══════════════════════════════════════════════════════════════
 * 设计理念：呼吸 · 精致 · 永恒
 * ═══════════════════════════════════════════════════════════════
 */

page {
  /* ─────────────────────────────────────────────────────────────
   * 色彩系统 - 极简奢华
   * ───────────────────────────────────────────────────────────── */

  /* 主色调 - 深灰而非纯黑，更柔和 */
  --primary: #2F4F46;
  --primary-dark: #2F4F46;
  --primary-light: rgba(47, 79, 70, 0.08);
  --primary-glow: rgba(47, 79, 70, 0.08);

  /* 强调色 - 优雅金色 */
  --accent: #2F4F46;
  --accent-light: rgba(47, 79, 70, 0.08);
  --accent-dark: #2F4F46;

  /* 背景色 - 温暖的灰白 */
  --background: #FFFFFF;
  --background-subtle: #F7F7F5;
  --background-card: #FFFFFF;
  --background-elevated: #FFFFFF;
  --background-warm: #FAFAF8;

  /* 文字色 - 柔和层次 */
  --text-primary: #111111;
  --text-secondary: #666666;
  --text-tertiary: #999999;
  --text-muted: #BBBBBB;

  /* 状态色 - 优雅克制 */
  --status-not-started: #9B9B9B;
  --status-not-started-bg: rgba(155, 155, 155, 0.06);
  --status-ongoing: #2F4F46;
  --status-ongoing-bg: rgba(47, 79, 70, 0.08);
  --status-ended: #9B9B9B;
  --status-ended-bg: rgba(155, 155, 155, 0.06);

  /* 语义色 */
  --success: #2F4F46;
  --success-bg: rgba(47, 79, 70, 0.08);
  --error: #B24137;
  --error-bg: rgba(178, 65, 55, 0.08);
  --warning: #8A7451;
  --warning-bg: rgba(138, 116, 81, 0.08);
  --info: #6B8CAF;
  --info-bg: rgba(107, 140, 175, 0.06);

  /* 边框与分割 */
  --border: #E5E7EB;
  --border-light: #F0F1F0;
  --divider: #EEF0EE;

  /* ─────────────────────────────────────────────────────────────
   * 阴影系统 - 柔和精致
   * ───────────────────────────────────────────────────────────── */
  --shadow-xs: 0 1px 3px rgba(26, 26, 26, 0.02);
  --shadow-sm: 0 2px 12px rgba(26, 26, 26, 0.03);
  --shadow-md: 0 8px 24px rgba(26, 26, 26, 0.04);
  --shadow-lg: 0 16px 40px rgba(26, 26, 26, 0.06);
  --shadow-elevated: 0 24px 64px rgba(26, 26, 26, 0.08);

  /* ─────────────────────────────────────────────────────────────
   * 间距系统 - 呼吸节奏
   * ───────────────────────────────────────────────────────────── */
  --space-xs: 8rpx;
  --space-sm: 16rpx;
  --space-md: 24rpx;
  --space-lg: 40rpx;
  --space-xl: 64rpx;
  --space-2xl: 96rpx;
  --space-3xl: 160rpx;

  /* ─────────────────────────────────────────────────────────────
   * 圆角系统 - 柔和边角
   * ───────────────────────────────────────────────────────────── */
  --radius-xs: 4rpx;
  --radius-sm: 8rpx;
  --radius-md: 16rpx;
  --radius-lg: 16rpx;
  --radius-xl: 24rpx;
  --radius-full: 9999rpx;

  /* ─────────────────────────────────────────────────────────────
   * 字体系统 - 优雅精致
   * ───────────────────────────────────────────────────────────── */
  --font-display: "PingFang SC", -apple-system, BlinkMacSystemFont, sans-serif;
  --font-body: "PingFang SC", -apple-system, BlinkMacSystemFont, sans-serif;
  --ink: #111111;
  --green: #2F4F46;
  --text-soft: #999999;
  --paper: #F7F7F5;
  --line: #E5E7EB;

  font-family: var(--font-body);
  background-color: var(--background);
  font-size: 28rpx;
  color: var(--text-primary);
  line-height: 40rpx;
  letter-spacing: 0.4rpx;
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
}

/* ─────────────────────────────────────────────────────────────
 * 容器布局
 * ───────────────────────────────────────────────────────────── */
.container {
  padding: 0 var(--space-lg);
}

/* ─────────────────────────────────────────────────────────────
 * 卡片组件 - 柔和精致
 * ───────────────────────────────────────────────────────────── */
.card {
  background: var(--background-card);
  border-radius: var(--radius-xl);
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: none;
  border: none;
  transition: all 0.5s cubic-bezier(0.23, 1, 0.32, 1);
}

.card:active {
  transform: translateY(2rpx);
  box-shadow: none;
}

/* ─────────────────────────────────────────────────────────────
 * 按钮系统 - 优雅触感
 * ───────────────────────────────────────────────────────────── */
.btn-primary {
  height: 88rpx;
  background: var(--primary);
  color: #FFFFFF;
  border-radius: 16rpx;
  font-weight: 500;
  border: none;
  padding: 0 32rpx;
  font-size: 28rpx;
  letter-spacing: 0.4rpx;
  transition: all 0.5s cubic-bezier(0.23, 1, 0.32, 1);
  box-shadow: none;
  position: relative;
  overflow: hidden;
}

.btn-primary::before {
  content: none;
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: transparent;
  opacity: 0;
  transition: opacity 0.5s ease;
}

.btn-primary:active {
  transform: translateY(2rpx);
  box-shadow: none;
}

.btn-primary:active::before {
  opacity: 1;
}

.btn-primary[disabled] {
  opacity: 0.4;
  transform: none;
}

.btn-secondary {
  background: transparent;
  color: var(--text-primary);
  border-radius: 16rpx;
  border: 1px solid var(--border);
  padding: 32rpx var(--space-xl);
  font-size: 28rpx;
  font-weight: 500;
  letter-spacing: 0.4rpx;
  transition: all 0.5s cubic-bezier(0.23, 1, 0.32, 1);
}

.btn-secondary:active {
  background: var(--background-subtle);
  border-color: var(--text-secondary);
  transform: translateY(2rpx);
}

.btn-text {
  background: none;
  color: var(--text-secondary);
  border: none;
  padding: var(--space-sm) var(--space-md);
  font-size: 28rpx;
  font-weight: 400;
  letter-spacing: 0.02em;
  transition: all 0.3s ease;
}

.btn-text::after {
  border: none;
}

.btn-text:active {
  color: var(--text-primary);
}

/* ─────────────────────────────────────────────────────────────
 * 标签组件 - 精致小巧
 * ───────────────────────────────────────────────────────────── */
.tag {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 6rpx 12rpx;
  border-radius: 12rpx;
  font-size: 22rpx;
  font-weight: 500;
  letter-spacing: 0.4rpx;
}

.tag-not-started {
  background: var(--status-not-started-bg);
  color: var(--status-not-started);
}

.tag-ongoing {
  background: var(--status-ongoing-bg);
  color: var(--status-ongoing);
}

.tag-ended {
  background: var(--status-ended-bg);
  color: var(--status-ended);
}

/* ─────────────────────────────────────────────────────────────
 * 输入框组件 - 简洁优雅
 * ───────────────────────────────────────────────────────────── */
.input {
  width: 100%;
  height: 88rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  background: var(--background-warm);
  border: 1px solid var(--border);
  border-radius: 16rpx;
  box-sizing: border-box;
  color: var(--text-primary);
  transition: all 0.3s ease;
  letter-spacing: 0.4rpx;
}

.input:focus {
  border-color: var(--accent);
  background: var(--background-card);
  box-shadow: none;
}

.input::placeholder {
  color: var(--text-muted);
}

/* ─────────────────────────────────────────────────────────────
 * 分割线
 * ───────────────────────────────────────────────────────────── */
.divider {
  height: 1px;
  background: var(--divider);
  margin: var(--space-md) 0;
}

/* ─────────────────────────────────────────────────────────────
 * 加载动画 - 优雅旋转
 * ───────────────────────────────────────────────────────────── */
@keyframes spin {
  to { transform: rotate(360deg); }
}

@keyframes fadeIn {
  from { opacity: 0; transform: translateY(8rpx); }
  to { opacity: 1; transform: translateY(0); }
}

@keyframes slideUp {
  from { opacity: 0; transform: translateY(24rpx); }
  to { opacity: 1; transform: translateY(0); }
}

@keyframes pulse {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.6; }
}

.loading {
  width: 48rpx;
  height: 48rpx;
  border: 2rpx solid var(--border);
  border-top-color: var(--primary);
  border-radius: 50%;
  animation: spin 0.8s cubic-bezier(0.4, 0, 0.2, 1) infinite;
}

/* ─────────────────────────────────────────────────────────────
 * 安全区域
 * ───────────────────────────────────────────────────────────── */
.safe-area-bottom {
  padding-bottom: env(safe-area-inset-bottom);
}

/* ─────────────────────────────────────────────────────────────
 * 动画辅助类
 * ───────────────────────────────────────────────────────────── */
.fade-in {
  animation: fadeIn 0.4s ease forwards;
}

.slide-up {
  animation: slideUp 0.5s cubic-bezier(0.4, 0, 0.2, 1) forwards;
}

.delay-1 { animation-delay: 0.1s; }
.delay-2 { animation-delay: 0.2s; }
.delay-3 { animation-delay: 0.3s; }
.delay-4 { animation-delay: 0.4s; }

/* ─────────────────────────────────────────────────────────────
 * Product UI baseline
 * 不改结构：统一产品级字体、字重、按钮和视觉噪音
 * ───────────────────────────────────────────────────────────── */
text,
input,
textarea,
button {
  font-family: "PingFang SC", -apple-system, BlinkMacSystemFont, sans-serif;
  letter-spacing: 0.4rpx !important;
}

button {
  min-height: 88rpx;
  border-radius: 16rpx;
  font-weight: 500;
  box-shadow: none !important;
}

view,
button,
input,
textarea {
  box-shadow: none !important;
}
