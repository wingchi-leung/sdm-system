/**
 * ═══════════════════════════════════════════════════════════════
 * SDM 小程序 - 高级简约设计系统
 * ═══════════════════════════════════════════════════════════════
 * 灵感来源：Jil Sander × Aesop
 * 设计理念：纯粹 · 精致 · 克制
 * ═══════════════════════════════════════════════════════════════
 */

page {
  /* ─────────────────────────────────────────────────────────────
   * 色彩系统 - 纯粹克制
   * ───────────────────────────────────────────────────────────── */

  /* 品牌色 - 深邃墨绿，自然高级 */
  --primary: #2C5545;
  --primary-dark: #1E3D2F;
  --primary-light: rgba(44, 85, 69, 0.08);
  --primary-glow: rgba(44, 85, 69, 0.15);

  /* 强调色 - 暖金点缀 */
  --accent: #B8956B;
  --accent-light: rgba(184, 149, 107, 0.1);

  /* 背景色 - 纯净留白 */
  --background: #FFFFFF;
  --background-subtle: #FAFAFA;
  --background-card: #FFFFFF;
  --background-elevated: #FEFEFE;
  --background-input: #F7F7F7;

  /* 文字色 - 层次分明 */
  --text-primary: #1A1A1A;
  --text-secondary: #5C5C5C;
  --text-tertiary: #8C8C8C;
  --text-muted: #C2C2C2;

  /* 状态色 - 低饱和度 */
  --status-not-started: #7A7A7A;
  --status-not-started-bg: rgba(122, 122, 122, 0.08);
  --status-ongoing: #4A7C6B;
  --status-ongoing-bg: rgba(74, 124, 107, 0.08);
  --status-ended: #5A6B7A;
  --status-ended-bg: rgba(90, 107, 122, 0.08);

  /* 语义色 */
  --success: #4A7C6B;
  --success-bg: rgba(74, 124, 107, 0.08);
  --error: #A65D5D;
  --error-bg: rgba(166, 93, 93, 0.08);
  --warning: #A68B5D;
  --warning-bg: rgba(166, 139, 93, 0.08);
  --info: #5A6B7A;
  --info-bg: rgba(90, 107, 122, 0.08);

  /* 边框与分割 */
  --border: rgba(0, 0, 0, 0.06);
  --border-light: rgba(0, 0, 0, 0.04);
  --divider: rgba(0, 0, 0, 0.04);

  /* ─────────────────────────────────────────────────────────────
   * 阴影系统 - 轻盈透气
   * ───────────────────────────────────────────────────────────── */
  --shadow-xs: 0 1px 2px rgba(0, 0, 0, 0.02);
  --shadow-sm: 0 2px 8px rgba(0, 0, 0, 0.03);
  --shadow-md: 0 4px 16px rgba(0, 0, 0, 0.04);
  --shadow-lg: 0 8px 32px rgba(0, 0, 0, 0.05);
  --shadow-elevated: 0 12px 48px rgba(0, 0, 0, 0.06);

  /* ─────────────────────────────────────────────────────────────
   * 间距系统 - 严谨节奏
   * ───────────────────────────────────────────────────────────── */
  --space-xs: 8rpx;
  --space-sm: 16rpx;
  --space-md: 24rpx;
  --space-lg: 32rpx;
  --space-xl: 48rpx;
  --space-2xl: 64rpx;
  --space-3xl: 96rpx;

  /* ─────────────────────────────────────────────────────────────
   * 圆角系统 - 柔和边角
   * ───────────────────────────────────────────────────────────── */
  --radius-xs: 2rpx;
  --radius-sm: 4rpx;
  --radius-md: 8rpx;
  --radius-lg: 12rpx;
  --radius-xl: 16rpx;
  --radius-full: 9999rpx;

  /* ─────────────────────────────────────────────────────────────
   * 字体系统 - 现代优雅
   * ───────────────────────────────────────────────────────────── */
  --font-display: "Noto Serif SC", "Songti SC", "PingFang SC", serif;
  --font-body: "PingFang SC", "Noto Sans SC", -apple-system, sans-serif;

  font-family: var(--font-body);
  background-color: var(--background);
  font-size: 28rpx;
  color: var(--text-primary);
  line-height: 1.6;
  letter-spacing: 0.03em;
  -webkit-font-smoothing: antialiased;
}

/* ─────────────────────────────────────────────────────────────
 * 容器布局
 * ───────────────────────────────────────────────────────────── */
.container {
  padding: 0 var(--space-lg);
}

/* ─────────────────────────────────────────────────────────────
 * 卡片组件 - 柔和精致
 * ───────────────────────────────────────────────────────────── */
.card {
  background: var(--background-card);
  border-radius: var(--radius-lg);
  padding: var(--space-lg);
  margin-bottom: var(--space-md);
  box-shadow: var(--shadow-sm);
  border: 1px solid var(--border-light);
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}

.card:active {
  transform: scale(0.995);
  box-shadow: var(--shadow-xs);
}

/* ─────────────────────────────────────────────────────────────
 * 按钮系统 - 优雅触感
 * ───────────────────────────────────────────────────────────── */
.btn-primary {
  background: var(--primary);
  color: #FFFFFF;
  border-radius: var(--radius-md);
  font-weight: 500;
  border: none;
  padding: 28rpx var(--space-xl);
  font-size: 30rpx;
  letter-spacing: 0.04em;
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  box-shadow: var(--shadow-sm);
}

.btn-primary:active {
  opacity: 0.85;
  transform: scale(0.98);
  box-shadow: var(--shadow-xs);
}

.btn-primary[disabled] {
  opacity: 0.5;
  transform: none;
}

.btn-secondary {
  background: transparent;
  color: var(--text-primary);
  border-radius: var(--radius-md);
  border: 1px solid var(--border);
  padding: 26rpx var(--space-lg);
  font-size: 28rpx;
  font-weight: 500;
  letter-spacing: 0.02em;
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}

.btn-secondary:active {
  background: var(--background-warm);
  border-color: var(--text-tertiary);
}

.btn-text {
  background: none;
  color: var(--primary);
  border: none;
  padding: var(--space-sm) var(--space-md);
  font-size: 28rpx;
  font-weight: 500;
  letter-spacing: 0.02em;
  transition: all 0.2s ease;
}

.btn-text::after {
  border: none;
}

.btn-text:active {
  opacity: 0.7;
}

/* ─────────────────────────────────────────────────────────────
 * 标签组件 - 精致小巧
 * ───────────────────────────────────────────────────────────── */
.tag {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 8rpx 16rpx;
  border-radius: var(--radius-xs);
  font-size: 22rpx;
  font-weight: 500;
  letter-spacing: 0.02em;
}

.tag-not-started {
  background: var(--status-not-started-bg);
  color: var(--status-not-started);
}

.tag-ongoing {
  background: var(--status-ongoing-bg);
  color: var(--status-ongoing);
}

.tag-ended {
  background: var(--status-ended-bg);
  color: var(--status-ended);
}

/* ─────────────────────────────────────────────────────────────
 * 输入框组件 - 简洁优雅
 * ───────────────────────────────────────────────────────────── */
.input {
  width: 100%;
  height: 96rpx;
  padding: 0 var(--space-md);
  font-size: 28rpx;
  background: var(--background-input);
  border: 1px solid var(--border);
  border-radius: var(--radius-md);
  box-sizing: border-box;
  color: var(--text-primary);
  transition: all 0.25s ease;
  letter-spacing: 0.02em;
}

.input:focus {
  border-color: var(--primary);
  background: var(--background-card);
  box-shadow: 0 0 0 3px var(--primary-light);
}

.input::placeholder {
  color: var(--text-muted);
}

/* ─────────────────────────────────────────────────────────────
 * 分割线
 * ───────────────────────────────────────────────────────────── */
.divider {
  height: 1px;
  background: var(--divider);
  margin: var(--space-md) 0;
}

/* ─────────────────────────────────────────────────────────────
 * 加载动画 - 优雅旋转
 * ───────────────────────────────────────────────────────────── */
@keyframes spin {
  to { transform: rotate(360deg); }
}

@keyframes fadeIn {
  from { opacity: 0; transform: translateY(8rpx); }
  to { opacity: 1; transform: translateY(0); }
}

@keyframes slideUp {
  from { opacity: 0; transform: translateY(24rpx); }
  to { opacity: 1; transform: translateY(0); }
}

@keyframes pulse {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.6; }
}

.loading {
  width: 48rpx;
  height: 48rpx;
  border: 2rpx solid var(--border);
  border-top-color: var(--primary);
  border-radius: 50%;
  animation: spin 0.8s cubic-bezier(0.4, 0, 0.2, 1) infinite;
}

/* ─────────────────────────────────────────────────────────────
 * 安全区域
 * ───────────────────────────────────────────────────────────── */
.safe-area-bottom {
  padding-bottom: env(safe-area-inset-bottom);
}

/* ─────────────────────────────────────────────────────────────
 * 动画辅助类
 * ───────────────────────────────────────────────────────────── */
.fade-in {
  animation: fadeIn 0.4s ease forwards;
}

.slide-up {
  animation: slideUp 0.5s cubic-bezier(0.4, 0, 0.2, 1) forwards;
}

.delay-1 { animation-delay: 0.1s; }
.delay-2 { animation-delay: 0.2s; }
.delay-3 { animation-delay: 0.3s; }
.delay-4 { animation-delay: 0.4s; }
