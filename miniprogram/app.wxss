/**
 * ═══════════════════════════════════════════════════════════════
 * SDM 小程序 - 奢华简约设计系统
 * ═══════════════════════════════════════════════════════════════
 * 灵感来源：Apple × Hermès
 * 设计理念：极简 · 奢华 · 永恒
 * ═══════════════════════════════════════════════════════════════
 */

page {
  /* ─────────────────────────────────────────────────────────────
   * 色彩系统 - 奢华克制
   * ───────────────────────────────────────────────────────────── */

  /* 品牌色 - 深邃黑，极致纯粹 */
  --primary: #000000;
  --primary-dark: #000000;
  --primary-light: rgba(0, 0, 0, 0.03);
  --primary-glow: rgba(0, 0, 0, 0.05);

  /* 强调色 - 优雅橙调（Hermès 橙） */
  --accent: #FF6B35;
  --accent-light: rgba(255, 107, 53, 0.06);

  /* 背景色 - 纯净留白 */
  --background: #FAFAFA;
  --background-subtle: #F5F5F5;
  --background-card: #FFFFFF;
  --background-elevated: #FFFFFF;
  --background-input: #FFFFFF;

  /* 文字色 - 精致层次 */
  --text-primary: #000000;
  --text-secondary: #666666;
  --text-tertiary: #999999;
  --text-muted: #CCCCCC;

  /* 状态色 - 极简优雅 */
  --status-not-started: #8E8E93;
  --status-not-started-bg: rgba(142, 142, 147, 0.06);
  --status-ongoing: #34C759;
  --status-ongoing-bg: rgba(52, 199, 89, 0.06);
  --status-ended: #8E8E93;
  --status-ended-bg: rgba(142, 142, 147, 0.06);

  /* 语义色 */
  --success: #34C759;
  --success-bg: rgba(52, 199, 89, 0.06);
  --error: #FF3B30;
  --error-bg: rgba(255, 59, 48, 0.06);
  --warning: #FF9500;
  --warning-bg: rgba(255, 149, 0, 0.06);
  --info: #007AFF;
  --info-bg: rgba(0, 122, 255, 0.06);

  /* 边框与分割 */
  --border: rgba(0, 0, 0, 0.08);
  --border-light: rgba(0, 0, 0, 0.05);
  --divider: rgba(0, 0, 0, 0.06);

  /* ─────────────────────────────────────────────────────────────
   * 阴影系统 - 轻盈精致
   * ───────────────────────────────────────────────────────────── */
  --shadow-xs: 0 1px 2px rgba(0, 0, 0, 0.03);
  --shadow-sm: 0 2px 8px rgba(0, 0, 0, 0.04);
  --shadow-md: 0 4px 16px rgba(0, 0, 0, 0.06);
  --shadow-lg: 0 8px 32px rgba(0, 0, 0, 0.08);
  --shadow-elevated: 0 16px 48px rgba(0, 0, 0, 0.1);

  /* ─────────────────────────────────────────────────────────────
   * 间距系统 - 严谨节奏
   * ───────────────────────────────────────────────────────────── */
  --space-xs: 8rpx;
  --space-sm: 12rpx;
  --space-md: 20rpx;
  --space-lg: 32rpx;
  --space-xl: 48rpx;
  --space-2xl: 72rpx;
  --space-3xl: 120rpx;

  /* ─────────────────────────────────────────────────────────────
   * 圆角系统 - 柔和边角
   * ───────────────────────────────────────────────────────────── */
  --radius-xs: 2rpx;
  --radius-sm: 4rpx;
  --radius-md: 8rpx;
  --radius-lg: 12rpx;
  --radius-xl: 16rpx;
  --radius-full: 9999rpx;

  /* ─────────────────────────────────────────────────────────────
   * 字体系统 - 极致优雅
   * ───────────────────────────────────────────────────────────── */
  --font-display: -apple-system, "SF Pro Display", "PingFang SC", "Helvetica Neue", sans-serif;
  --font-body: -apple-system, "SF Pro Text", "PingFang SC", "Helvetica Neue", sans-serif;

  font-family: var(--font-body);
  background-color: var(--background);
  font-size: 28rpx;
  color: var(--text-primary);
  line-height: 1.5;
  letter-spacing: -0.01em;
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
}

/* ─────────────────────────────────────────────────────────────
 * 容器布局
 * ───────────────────────────────────────────────────────────── */
.container {
  padding: 0 var(--space-lg);
}

/* ─────────────────────────────────────────────────────────────
 * 卡片组件 - 奢华精致
 * ───────────────────────────────────────────────────────────── */
.card {
  background: var(--background-card);
  border-radius: var(--radius-xl);
  padding: var(--space-xl);
  margin-bottom: var(--space-lg);
  box-shadow: var(--shadow-sm);
  border: 0.5px solid var(--border-light);
  transition: all 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94);
}

.card:active {
  transform: scale(0.98);
  box-shadow: var(--shadow-xs);
}

/* ─────────────────────────────────────────────────────────────
 * 按钮系统 - 极致触感
 * ───────────────────────────────────────────────────────────── */
.btn-primary {
  background: var(--primary);
  color: #FFFFFF;
  border-radius: 980rpx;
  font-weight: 500;
  border: none;
  padding: 32rpx var(--space-2xl);
  font-size: 32rpx;
  letter-spacing: -0.01em;
  transition: all 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.12);
}

.btn-primary:active {
  opacity: 0.88;
  transform: scale(0.97);
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
}

.btn-primary[disabled] {
  opacity: 0.4;
  transform: none;
}

.btn-secondary {
  background: transparent;
  color: var(--text-primary);
  border-radius: 980rpx;
  border: 1.5px solid var(--border);
  padding: 30rpx var(--space-xl);
  font-size: 30rpx;
  font-weight: 500;
  letter-spacing: -0.01em;
  transition: all 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94);
}

.btn-secondary:active {
  background: var(--background-subtle);
  border-color: var(--text-secondary);
  transform: scale(0.97);
}

.btn-text {
  background: none;
  color: var(--primary);
  border: none;
  padding: var(--space-sm) var(--space-md);
  font-size: 28rpx;
  font-weight: 500;
  letter-spacing: 0.02em;
  transition: all 0.2s ease;
}

.btn-text::after {
  border: none;
}

.btn-text:active {
  opacity: 0.7;
}

/* ─────────────────────────────────────────────────────────────
 * 标签组件 - 精致小巧
 * ───────────────────────────────────────────────────────────── */
.tag {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 8rpx 16rpx;
  border-radius: var(--radius-xs);
  font-size: 22rpx;
  font-weight: 500;
  letter-spacing: 0.02em;
}

.tag-not-started {
  background: var(--status-not-started-bg);
  color: var(--status-not-started);
}

.tag-ongoing {
  background: var(--status-ongoing-bg);
  color: var(--status-ongoing);
}

.tag-ended {
  background: var(--status-ended-bg);
  color: var(--status-ended);
}

/* ─────────────────────────────────────────────────────────────
 * 输入框组件 - 简洁优雅
 * ───────────────────────────────────────────────────────────── */
.input {
  width: 100%;
  height: 96rpx;
  padding: 0 var(--space-md);
  font-size: 28rpx;
  background: var(--background-input);
  border: 1px solid var(--border);
  border-radius: var(--radius-md);
  box-sizing: border-box;
  color: var(--text-primary);
  transition: all 0.25s ease;
  letter-spacing: 0.02em;
}

.input:focus {
  border-color: var(--primary);
  background: var(--background-card);
  box-shadow: 0 0 0 3px var(--primary-light);
}

.input::placeholder {
  color: var(--text-muted);
}

/* ─────────────────────────────────────────────────────────────
 * 分割线
 * ───────────────────────────────────────────────────────────── */
.divider {
  height: 1px;
  background: var(--divider);
  margin: var(--space-md) 0;
}

/* ─────────────────────────────────────────────────────────────
 * 加载动画 - 优雅旋转
 * ───────────────────────────────────────────────────────────── */
@keyframes spin {
  to { transform: rotate(360deg); }
}

@keyframes fadeIn {
  from { opacity: 0; transform: translateY(8rpx); }
  to { opacity: 1; transform: translateY(0); }
}

@keyframes slideUp {
  from { opacity: 0; transform: translateY(24rpx); }
  to { opacity: 1; transform: translateY(0); }
}

@keyframes pulse {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.6; }
}

.loading {
  width: 48rpx;
  height: 48rpx;
  border: 2rpx solid var(--border);
  border-top-color: var(--primary);
  border-radius: 50%;
  animation: spin 0.8s cubic-bezier(0.4, 0, 0.2, 1) infinite;
}

/* ─────────────────────────────────────────────────────────────
 * 安全区域
 * ───────────────────────────────────────────────────────────── */
.safe-area-bottom {
  padding-bottom: env(safe-area-inset-bottom);
}

/* ─────────────────────────────────────────────────────────────
 * 动画辅助类
 * ───────────────────────────────────────────────────────────── */
.fade-in {
  animation: fadeIn 0.4s ease forwards;
}

.slide-up {
  animation: slideUp 0.5s cubic-bezier(0.4, 0, 0.2, 1) forwards;
}

.delay-1 { animation-delay: 0.1s; }
.delay-2 { animation-delay: 0.2s; }
.delay-3 { animation-delay: 0.3s; }
.delay-4 { animation-delay: 0.4s; }
