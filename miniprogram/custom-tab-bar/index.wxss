.tab-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 100rpx;
  background: #FFFFFF;
  display: flex;
  border-top: 1px solid rgba(0, 0, 0, 0.06);
  padding-bottom: env(safe-area-inset-bottom);
  z-index: 9999;
}

.tab-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 4rpx;
  transition: all 0.2s ease;
}

.tab-item:active {
  background: rgba(0, 0, 0, 0.02);
}

.tab-icon {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.icon-text {
  font-size: 40rpx;
  color: #8C8C8C;
  font-weight: 300;
  transition: color 0.2s ease;
}

.tab-item.active .icon-text {
  color: #2C5545;
  font-weight: 400;
}

.tab-label {
  font-size: 22rpx;
  color: #8C8C8C;
  letter-spacing: 0.04em;
  transition: color 0.2s ease;
}

.tab-item.active .tab-label {
  color: #2C5545;
  font-weight: 500;
}