.tab-bar {
  position: fixed;
  right: 0;
  bottom: 0;
  left: 0;
  z-index: 9999;
  height: 96rpx;
  padding-bottom: env(safe-area-inset-bottom);
  background: rgba(255, 255, 255, 0.96);
  display: flex;
}

.tab-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.tab-item:active {
  opacity: 0.72;
}

.tab-icon {
  width: 64rpx;
  height: 64rpx;
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
}

.tab-item:last-child .tab-icon::before {
  content: '';
  position: absolute;
  left: 16rpx;
  top: 7rpx;
  width: 12rpx;
  height: 12rpx;
  border: 2rpx solid currentColor;
  border-radius: 50%;
}

.tab-item:last-child .tab-icon::after {
  content: '';
  position: absolute;
  left: 10rpx;
  bottom: 7rpx;
  width: 24rpx;
  height: 13rpx;
  border: 2rpx solid currentColor;
  border-radius: 24rpx 24rpx 0 0;
  border-bottom: 0;
}

.icon-text {
  display: none;
}

.tab-logo {
  width: 60rpx;
  height: 60rpx;
  opacity: 1;
}

.tab-icon {
  color: #6B7280;
}

.tab-item.active .tab-icon {
  color: #0F1A17;
}

.tab-item:first-child.active .tab-icon::after {
  content: '';
  position: absolute;
  left: 50%;
  bottom: -8rpx;
  width: 24rpx;
  height: 3rpx;
  border-radius: 999rpx;
  background: #0F1A17;
  transform: translateX(-50%);
}

/* Product UI refinement：无文字导航，仅保留克制图形状态 */
.tab-bar {
  height: 88rpx;
  background: #FFFFFF;
}

.tab-icon {
  width: 56rpx;
  height: 56rpx;
}

.tab-logo {
  width: 80rpx;
  height: 80rpx;
}
