.tab-bar {
  position: fixed;
  right: 0;
  bottom: 0;
  left: 0;
  z-index: 9999;
  height: 112rpx;
  padding-bottom: env(safe-area-inset-bottom);
  background: rgba(255, 255, 255, 0.94);
  display: flex;
  align-items: center;
  box-shadow: 0 -8rpx 30rpx rgba(15, 26, 23, 0.06);
}

.tab-item {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
}

.tab-item:active {
  opacity: 0.72;
}

.tab-bubble {
  min-width: 96rpx;
  height: 72rpx;
  padding: 0 22rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.22s ease;
}

.tab-icon {
  width: 48rpx;
  height: 48rpx;
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  opacity: 0.72;
  transform: scale(0.96);
  transition: all 0.22s ease;
}

.tab-logo {
  width: 60rpx;
  height: 60rpx;
  opacity: 1;
}

.tab-personnel {
  width: 52rpx;
  height: 52rpx;
  opacity: 0.84;
}

.tab-item.active .tab-bubble {
  background: rgba(255, 255, 255, 0.48);
  border: 1rpx solid rgba(255, 255, 255, 0.72);
  box-shadow:
    0 12rpx 32rpx rgba(15, 26, 23, 0.10),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.9);
  backdrop-filter: blur(18rpx);
  -webkit-backdrop-filter: blur(18rpx);
}

.tab-item.active .tab-icon {
  opacity: 1;
  transform: scale(1);
}

.tab-logo {
  width: 74rpx;
  height: 74rpx;
}

.tab-item.active .tab-personnel {
  opacity: 1;
}
