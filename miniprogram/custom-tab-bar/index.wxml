<view class="tab-bar">
  <view
    class="tab-item {{selected === 0 ? 'active' : ''}}"
    data-index="0"
    bindtap="switchTab"
  >
    <view class="tab-bubble">
      <view class="tab-icon">
      <image class="tab-logo" src="/assets/icons/mainlogo-door.png" mode="aspectFit" />
      </view>
    </view>
  </view>
  <view
    class="tab-item {{selected === 1 ? 'active' : ''}}"
    data-index="1"
    bindtap="switchTab"
  >
    <view class="tab-bubble">
      <view class="tab-icon">
        <image class="tab-personnel" src="/assets/icons/tab-personnel.png" mode="aspectFit" />
      </view>
    </view>
  </view>
</view>
