/**
 * 报名人员列表 - 高级简约风格
 */

.page {
  min-height: 100vh;
  padding: var(--space-xl) var(--space-lg);
  background: var(--background);
}

/* ─────────────────────────────────────────────────────────────
 * 统计头部
 * ───────────────────────────────────────────────────────────── */
.header {
  display: flex;
  align-items: baseline;
  gap: var(--space-sm);
  padding-bottom: var(--space-lg);
  border-bottom: 1px solid var(--divider);
  margin-bottom: var(--space-lg);
}

.total-label {
  font-size: 22rpx;
  color: var(--text-muted);
  letter-spacing: 0.1em;
  text-transform: uppercase;
}

.total-count {
  font-family: var(--font-display);
  font-size: 44rpx;
  font-weight: 500;
  color: var(--text-primary);
  letter-spacing: 0.02em;
}

/* ─────────────────────────────────────────────────────────────
 * 状态页面
 * ───────────────────────────────────────────────────────────── */
.state-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 50vh;
}

.state-title {
  font-family: var(--font-display);
  font-size: 32rpx;
  font-weight: 500;
  color: var(--text-primary);
  letter-spacing: 0.04em;
}

/* ─────────────────────────────────────────────────────────────
 * 人员列表
 * ───────────────────────────────────────────────────────────── */
.list {
  display: flex;
  flex-direction: column;
}

.participant-item {
  padding: var(--space-lg) 0;
  border-bottom: 1px solid var(--divider);
}

.participant-item:last-of-type {
  border-bottom: none;
}

.participant-header {
  display: flex;
  align-items: center;
  gap: var(--space-md);
  margin-bottom: var(--space-sm);
}

.participant-index {
  width: 40rpx;
  font-size: 22rpx;
  color: var(--text-muted);
  letter-spacing: 0.04em;
}

.participant-name {
  font-size: 28rpx;
  font-weight: 500;
  color: var(--text-primary);
  letter-spacing: 0.04em;
}

.participant-info {
  display: flex;
  align-items: baseline;
  padding-left: 56rpx;
  margin-bottom: var(--space-xs);
}

.participant-info .info-label {
  width: 100rpx;
  font-size: 22rpx;
  color: var(--text-muted);
  letter-spacing: 0.08em;
  text-transform: uppercase;
}

.participant-info .info-value {
  font-size: 24rpx;
  color: var(--text-secondary);
  letter-spacing: 0.02em;
}

/* ─────────────────────────────────────────────────────────────
 * 分页
 * ───────────────────────────────────────────────────────────── */
.pagination {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: var(--space-lg);
  margin-top: var(--space-xl);
  padding-top: var(--space-lg);
  border-top: 1px solid var(--divider);
}

.page-btn {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  color: var(--text-primary);
  border: 1px solid var(--border);
  transition: all 0.2s ease;
}

.page-btn:active {
  background: var(--background-subtle);
}

.page-btn.disabled {
  opacity: 0.3;
  pointer-events: none;
}

.page-info {
  font-size: 24rpx;
  color: var(--text-tertiary);
  letter-spacing: 0.04em;
}

/* 视觉降噪：人员列表页去掉硬分割线 */
.header,
.table-header,
.table-row,
.pagination {
  border-bottom: none;
  border-top: none;
}

.page-btn {
  border: none;
  background: #F8F8F6;
}

/* Product UI refinement：数据页规格统一 */
.page {
  padding: 24rpx 32rpx;
}

.header-title {
  font-size: 44rpx;
  line-height: 56rpx;
  font-weight: 500;
  letter-spacing: 0.4rpx;
}

.header-subtitle,
.table-cell,
.empty-text,
.page-info {
  color: #999999;
  font-size: 24rpx;
  line-height: 34rpx;
  font-weight: 400;
  letter-spacing: 0.4rpx;
}

.page-btn {
  border-radius: 16rpx;
}
