.page {
  min-height: 100vh;
  padding: 24rpx 32rpx;
  background: #ffffff;
  box-sizing: border-box;
  color: #111111;
  font-family: var(--font-body);
}

.header {
  display: flex;
  align-items: baseline;
  gap: 12rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid var(--divider);
  margin-bottom: 16rpx;
}

.total-label {
  font-size: 22rpx;
  color: #999999;
  letter-spacing: 0.08em;
}

.total-count {
  font-size: 44rpx;
  font-weight: 500;
  color: #111111;
  letter-spacing: 0.02em;
}

.state-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 50vh;
}

.state-title {
  font-size: 32rpx;
  font-weight: 500;
  color: #111111;
  letter-spacing: 0.04em;
}

.list {
  display: flex;
  flex-direction: column;
}

.participant-item {
  padding: 22rpx 0;
  border-bottom: 1rpx solid var(--divider);
}

.participant-item:last-of-type {
  border-bottom: none;
}

.participant-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 8rpx;
}

.participant-index {
  width: 40rpx;
  font-size: 22rpx;
  color: #999999;
}

.participant-name {
  font-size: 28rpx;
  font-weight: 500;
  color: #111111;
}

.participant-info {
  display: flex;
  align-items: baseline;
  padding-left: 52rpx;
  margin-bottom: 4rpx;
}

.participant-info .info-label {
  width: 100rpx;
  font-size: 22rpx;
  color: #999999;
}

.participant-info .info-value {
  font-size: 24rpx;
  color: #666666;
}

.participant-info .refund-status.is-pending {
  color: #b26a00;
}

.participant-info .refund-status.is-processing {
  color: #1b7a5a;
}

.participant-info .refund-status.is-success {
  color: #0f8b3d;
}

.participant-info .refund-status.is-failed {
  color: #c43d3d;
}

.participant-info .refund-status.is-closed {
  color: #999999;
}

.participant-actions {
  display: flex;
  justify-content: flex-end;
  padding: 12rpx 0 0 52rpx;
}

.refund-btn {
  margin: 0;
  padding: 0 28rpx;
  height: 64rpx;
  line-height: 64rpx;
  border-radius: 18rpx;
  background: #111111;
  color: #ffffff;
  font-size: 24rpx;
}

.refund-btn[disabled] {
  opacity: 0.6;
}

.pagination {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 20rpx;
  margin-top: 24rpx;
  padding-top: 24rpx;
  border-top: 1rpx solid var(--divider);
}

.page-btn {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  color: #111111;
  border: 1rpx solid var(--border-light);
  border-radius: 16rpx;
  background: #ffffff;
}

.page-btn:active {
  background: #f7f7f5;
}

.page-btn.disabled {
  opacity: 0.3;
  pointer-events: none;
}

.page-info {
  font-size: 24rpx;
  color: #999999;
  letter-spacing: 0.04em;
}
