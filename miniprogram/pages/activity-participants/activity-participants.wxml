<view class="page">
  <page-header title="报名人员"></page-header>
  <!-- 统计 -->
  <view class="header">
    <text class="total-label">报名人数</text>
    <text class="total-count">{{total}}</text>
  </view>

  <!-- 加载状态 -->
  <view wx:if="{{loading}}" class="state-wrap">
    <view class="loading"></view>
  </view>

  <!-- 空状态 -->
  <view wx:elif="{{participants.length === 0}}" class="state-wrap empty">
    <text class="state-title">暂无报名人员</text>
  </view>

  <!-- 人员列表 -->
  <view wx:else class="list">
    <view wx:for="{{participants}}" wx:key="id" class="participant-item">
      <view class="participant-header">
        <text class="participant-index">{{currentPage * pageSize + index + 1}}</text>
        <text class="participant-name">{{item.participant_name}}</text>
      </view>
      <view class="participant-info">
        <text class="info-label">电话</text>
        <text class="info-value">{{item.phone || '-'}}</text>
      </view>
      <view class="participant-info">
        <text class="info-label">报名时间</text>
        <text class="info-value">{{item.create_time}}</text>
      </view>
      <view class="participant-info" wx:if="{{item.payment_order_no}}">
        <text class="info-label">订单号</text>
        <text class="info-value">{{item.payment_order_no}}</text>
      </view>
      <view class="participant-info" wx:if="{{item.payment_status === 2}}">
        <text class="info-label">退款状态</text>
        <text class="info-value refund-status {{item.refund_status_class}}">{{item.refund_status_text}}</text>
      </view>
      <view class="participant-info" wx:if="{{item.refund_reason_text}}">
        <text class="info-label">退款原因</text>
        <text class="info-value">{{item.refund_reason_text}}</text>
      </view>
      <view class="participant-actions">
        <button
          wx:if="{{item.can_refund}}"
          class="refund-btn"
          data-id="{{item.id}}"
          loading="{{refundingParticipantId === item.id}}"
          disabled="{{refundingParticipantId === item.id}}"
          bindtap="onRefund"
        >
          {{item.refund_action_text}}
        </button>
      </view>
    </view>

    <!-- 分页 -->
    <view class="pagination">
      <view class="page-btn {{currentPage === 0 ? 'disabled' : ''}}" bindtap="onPrevPage">
        <text class="page-btn-arrow ui-chevron ui-chevron--md">‹</text>
      </view>
      <text class="page-info">{{currentPage + 1}} / {{totalPages}}</text>
      <view class="page-btn {{currentPage >= totalPages - 1 ? 'disabled' : ''}}" bindtap="onNextPage">
        <text class="page-btn-arrow ui-chevron ui-chevron--md">›</text>
      </view>
    </view>
  </view>
</view>
