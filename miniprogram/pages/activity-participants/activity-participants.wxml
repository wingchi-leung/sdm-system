<view class="page">
  <!-- 统计 -->
  <view class="header">
    <text class="total-label">报名人数</text>
    <text class="total-count">{{total}}</text>
  </view>

  <!-- 加载状态 -->
  <view wx:if="{{loading}}" class="state-wrap">
    <view class="loading"></view>
  </view>

  <!-- 空状态 -->
  <view wx:elif="{{participants.length === 0}}" class="state-wrap empty">
    <text class="state-title">暂无报名人员</text>
  </view>

  <!-- 人员列表 -->
  <view wx:else class="list">
    <view wx:for="{{participants}}" wx:key="id" class="participant-item">
      <view class="participant-header">
        <text class="participant-index">{{currentPage * pageSize + index + 1}}</text>
        <text class="participant-name">{{item.participant_name}}</text>
      </view>
      <view class="participant-info">
        <text class="info-label">电话</text>
        <text class="info-value">{{item.phone || '-'}}</text>
      </view>
      <view class="participant-info" wx:if="{{item.identity_number}}">
        <text class="info-label">证件</text>
        <text class="info-value">{{item.identity_number}}</text>
      </view>
      <view class="participant-info">
        <text class="info-label">报名时间</text>
        <text class="info-value">{{item.create_time}}</text>
      </view>
    </view>

    <!-- 分页 -->
    <view class="pagination">
      <view class="page-btn {{currentPage === 0 ? 'disabled' : ''}}" bindtap="onPrevPage">←</view>
      <text class="page-info">{{currentPage + 1}} / {{totalPages}}</text>
      <view class="page-btn {{currentPage >= totalPages - 1 ? 'disabled' : ''}}" bindtap="onNextPage">→</view>
    </view>
  </view>
</view>