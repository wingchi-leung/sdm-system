.page {
  min-height: 100vh;
  background: linear-gradient(180deg, #f6fafc 0%, #ffffff 100%);
}

.form {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  padding: 24rpx;
}

.field {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.field-label {
  font-size: 24rpx;
  color: rgba(15, 26, 23, 0.58);
  font-weight: 600;
}

.input,
.textarea,
.picker {
  width: 100%;
  box-sizing: border-box;
  border-radius: 24rpx;
  border: 1rpx solid rgba(15, 26, 23, 0.08);
  background: #ffffff;
  padding: 22rpx 24rpx;
  font-size: 28rpx;
  color: #0f1a17;
}

.input-placeholder,
.textarea-placeholder {
  color: rgba(15, 26, 23, 0.34);
}

.picker {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.picker-value {
  font-size: 28rpx;
  color: #0f1a17;
}

.picker-arrow {
  color: rgba(15, 26, 23, 0.34);
}

.datetime-row {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
}

.cover-preview-wrap {
  border-radius: 24rpx;
  overflow: hidden;
  border: 1rpx solid rgba(15, 26, 23, 0.08);
}

.cover-preview {
  width: 100%;
  height: 320rpx;
}

.cover-actions {
  display: flex;
  align-items: center;
}

.cover-btn {
  padding: 16rpx 22rpx;
  border-radius: 999rpx;
  background: rgba(47, 111, 232, 0.08);
}

.cover-btn__text {
  font-size: 24rpx;
  font-weight: 600;
  color: #2f6fe8;
}

.textarea {
  min-height: 220rpx;
}

.footer {
  padding-top: 12rpx;
}

.submit-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 24rpx;
  border-radius: 999rpx;
  background: #2f6fe8;
}

.submit-btn--loading {
  opacity: 0.7;
}

.submit-btn__text {
  font-size: 28rpx;
  color: #ffffff;
  font-weight: 700;
}
