.page {
  min-height: 100vh;
  box-sizing: border-box;
  background:
    radial-gradient(circle at top left, rgba(42, 77, 135, 0.08) 0, rgba(42, 77, 135, 0.02) 24%, transparent 48%),
    linear-gradient(180deg, #ffffff 0%, #fbfcfe 100%);
  color: #111827;
  font-family: "PingFang SC", -apple-system, BlinkMacSystemFont, "Helvetica Neue", sans-serif;
}

.content {
  padding: 0 40rpx calc(44rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

.nav-btn {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #111827;
}

.nav-btn-right {
  justify-content: flex-end;
}

.nav-icon {
  font-size: 44rpx;
  line-height: 1;
  font-weight: 300;
}

.nav-icon.more {
  font-size: 30rpx;
  letter-spacing: 4rpx;
}

.hero-card {
  margin-top: 34rpx;
  padding: 28rpx;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.9);
  border: 1rpx solid rgba(17, 17, 17, 0.06);
  box-shadow: 0 18rpx 44rpx rgba(15, 23, 42, 0.04);
  display: flex;
  align-items: center;
  gap: 24rpx;
  box-sizing: border-box;
}

.avatar-shell {
  width: 104rpx;
  height: 104rpx;
  flex-shrink: 0;
  border-radius: 50%;
  background: linear-gradient(180deg, #111111 0%, #3a3a3a 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}

.avatar-text {
  color: #ffffff;
  font-size: 40rpx;
  line-height: 1;
  font-weight: 500;
}

.hero-copy {
  flex: 1;
  min-width: 0;
}

.hero-title-row {
  display: flex;
  align-items: center;
  gap: 14rpx;
  flex-wrap: wrap;
}

.hero-name {
  color: #111111;
  font-size: 32rpx;
  line-height: 1.28;
  font-weight: 600;
  word-break: break-word;
}

.status-pill {
  min-width: 72rpx;
  height: 34rpx;
  padding: 0 12rpx;
  border-radius: 999rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  font-size: 18rpx;
  line-height: 1;
  font-weight: 500;
}

.status-pill.is-normal {
  background: rgba(17, 17, 17, 0.06);
  color: #4b5563;
}

.status-pill.is-blocked {
  background: rgba(178, 65, 55, 0.08);
  color: #b24137;
}

.hero-subtitle {
  display: block;
  margin-top: 12rpx;
  color: #8f9199;
  font-size: 22rpx;
  line-height: 1.45;
  word-break: break-word;
}

.summary-grid {
  margin-top: 24rpx;
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 14rpx;
}

.summary-item {
  min-height: 98rpx;
  padding: 18rpx 20rpx;
  border-radius: 22rpx;
  background: rgba(255, 255, 255, 0.92);
  border: 1rpx solid rgba(17, 17, 17, 0.06);
  box-sizing: border-box;
}

.summary-label {
  display: block;
  color: #8f9199;
  font-size: 20rpx;
  line-height: 1.35;
}

.summary-value {
  display: block;
  margin-top: 10rpx;
  color: #111111;
  font-size: 24rpx;
  line-height: 1.4;
  word-break: break-word;
}

.section {
  margin-top: 28rpx;
}

.section-title {
  display: block;
  margin-bottom: 14rpx;
  color: #667085;
  font-size: 20rpx;
  line-height: 1.45;
  font-weight: 500;
  letter-spacing: 0.16em;
}

.info-card {
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.94);
  border: 1rpx solid rgba(17, 17, 17, 0.06);
  box-shadow: 0 16rpx 36rpx rgba(15, 23, 42, 0.03);
  overflow: hidden;
}

.info-row {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
  padding: 22rpx 24rpx;
  border-bottom: 1rpx solid rgba(17, 17, 17, 0.05);
  box-sizing: border-box;
}

.info-row:last-child {
  border-bottom: none;
}

.info-label {
  flex-shrink: 0;
  color: #8f9199;
  font-size: 22rpx;
  line-height: 1.45;
}

.info-value {
  flex: 1;
  min-width: 0;
  color: #111111;
  font-size: 22rpx;
  line-height: 1.6;
  text-align: right;
  word-break: break-word;
}

.info-value.is-warning {
  color: #b24137;
}

.action-section {
  padding-top: 30rpx;
}

.primary-btn {
  height: 88rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  font-size: 24rpx;
  font-weight: 500;
  letter-spacing: 0.04em;
}

.primary-btn.ghost {
  border: 1rpx solid rgba(17, 17, 17, 0.18);
  color: #111111;
  background: #ffffff;
}

.primary-btn.danger {
  border: 1rpx solid rgba(178, 65, 55, 0.22);
  color: #b24137;
  background: rgba(178, 65, 55, 0.04);
}

.state-wrap {
  min-height: 56vh;
  padding: 120rpx 56rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  text-align: center;
}

.state-wrap.error .state-icon {
  width: 72rpx;
  height: 72rpx;
  margin-bottom: 26rpx;
  background: rgba(42, 77, 135, 0.08);
  border-radius: 50%;
  color: #2a4d87;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 34rpx;
}

.state-title {
  color: #111111;
  font-size: 28rpx;
  font-weight: 500;
  letter-spacing: 0.04em;
}

.state-text {
  margin-top: 14rpx;
  color: #8f97ab;
  font-size: 20rpx;
  line-height: 1.7;
}

.loading {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(17, 17, 17, 0.12);
  border-top-color: #111111;
  animation: spin 0.9s linear infinite;
}

@keyframes spin {
  from {
    transform: rotate(0deg);
  }

  to {
    transform: rotate(360deg);
  }
}
