.page {
  min-height: 100vh;
  box-sizing: border-box;
  background: #ffffff;
  color: #111111;
  font-family: "PingFang SC", -apple-system, BlinkMacSystemFont, "Helvetica Neue", sans-serif;
}

.content {
  padding: 0 32rpx calc(48rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

.nav-btn {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #111827;
}

.nav-btn-right {
  justify-content: flex-end;
}

.nav-icon {
  font-size: 44rpx;
  line-height: 1;
  font-weight: 300;
}

.nav-icon.more {
  font-size: 30rpx;
  letter-spacing: 4rpx;
}

.hero-card {
  margin-top: 32rpx;
  padding: 24rpx;
  border-radius: 24rpx;
  background: #ffffff;
  border: 1rpx solid var(--border-light);
  box-shadow: none;
  display: flex;
  align-items: center;
  gap: 20rpx;
  box-sizing: border-box;
}

.avatar-shell {
  width: 96rpx;
  height: 96rpx;
  flex-shrink: 0;
  border-radius: 50%;
  background: #111111;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  overflow: hidden;
  box-shadow: inset 0 0 0 1rpx rgba(255, 255, 255, 0.12);
}

.avatar-image {
  width: 100%;
  height: 100%;
  display: block;
  border-radius: 50%;
}

.avatar-text {
  color: #ffffff;
  font-size: 36rpx;
  line-height: 1;
  font-weight: 500;
}

.hero-copy {
  flex: 1;
  min-width: 0;
}

.hero-title-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex-wrap: wrap;
}

.hero-name {
  color: #111111;
  font-size: 32rpx;
  line-height: 1.35;
  font-weight: 500;
  word-break: break-word;
}

.status-pill {
  min-width: 72rpx;
  height: 34rpx;
  padding: 0 12rpx;
  border-radius: 12rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  font-size: 20rpx;
  line-height: 1;
  font-weight: 500;
}

.status-pill.is-normal {
  background: #f4f4f2;
  color: #6b7280;
}

.status-pill.is-blocked {
  background: rgba(178, 65, 55, 0.08);
  color: #b24137;
}

.hero-subtitle {
  display: block;
  margin-top: 10rpx;
  color: #6b7280;
  font-size: 24rpx;
  line-height: 1.6;
  word-break: break-word;
}

.summary-grid {
  margin-top: 20rpx;
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
}

.summary-item {
  min-height: 96rpx;
  padding: 18rpx 18rpx 16rpx;
  border-radius: 18rpx;
  background: #ffffff;
  border: 1rpx solid var(--border-light);
  box-sizing: border-box;
}

.summary-label {
  display: block;
  color: #8f97ab;
  font-size: 20rpx;
  line-height: 1.45;
}

.summary-value {
  display: block;
  margin-top: 10rpx;
  color: #111111;
  font-size: 24rpx;
  line-height: 1.5;
  word-break: break-word;
}

.section {
  margin-top: 32rpx;
}

.section-title {
  display: block;
  margin-bottom: 16rpx;
  color: #667085;
  font-size: 22rpx;
  line-height: 1.45;
  font-weight: 500;
  letter-spacing: 0.12em;
}

.info-card {
  border-radius: 20rpx;
  background: #ffffff;
  border: 1rpx solid var(--border-light);
  box-shadow: none;
  overflow: hidden;
}

.info-row {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
  padding: 20rpx 22rpx;
  border-bottom: 1rpx solid var(--divider);
  box-sizing: border-box;
}

.info-row:last-child {
  border-bottom: none;
}

.info-label {
  flex-shrink: 0;
  color: #8f9199;
  font-size: 22rpx;
  line-height: 1.5;
}

.info-value {
  flex: 1;
  min-width: 0;
  color: #111111;
  font-size: 22rpx;
  line-height: 1.65;
  text-align: right;
  word-break: break-word;
}

.info-value.is-warning {
  color: #b24137;
}

.action-section {
  padding-top: 32rpx;
}

.primary-btn {
  height: 88rpx;
  width: 100%;
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  font-size: 26rpx;
  font-weight: 500;
  letter-spacing: 0.04em;
  background: #ffffff;
}

.primary-btn.ghost {
  border: 1rpx solid rgba(17, 17, 17, 0.16);
  color: #111111;
  background: #ffffff;
}

.primary-btn.danger {
  border: 1rpx solid rgba(178, 65, 55, 0.22);
  color: #b24137;
  background: rgba(178, 65, 55, 0.04);
}

.state-wrap {
  min-height: 56vh;
  padding: 120rpx 56rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  text-align: center;
}

.state-wrap.error .state-icon {
  width: 72rpx;
  height: 72rpx;
  margin-bottom: 26rpx;
  background: rgba(42, 77, 135, 0.08);
  border-radius: 50%;
  color: #2a4d87;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 34rpx;
}

.state-title {
  color: #111111;
  font-size: 28rpx;
  font-weight: 500;
  letter-spacing: 0.04em;
}

.state-text {
  margin-top: 14rpx;
  color: #8f97ab;
  font-size: 20rpx;
  line-height: 1.7;
}

.loading {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(17, 17, 17, 0.12);
  border-top-color: #111111;
  animation: spin 0.9s linear infinite;
}

@keyframes spin {
  from {
    transform: rotate(0deg);
  }

  to {
    transform: rotate(360deg);
  }
}
