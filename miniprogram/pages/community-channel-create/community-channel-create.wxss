.page {
  min-height: 100vh;
  padding: 0 32rpx calc(180rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
  background:
    radial-gradient(circle at top, rgba(255, 255, 255, 0.98) 0%, rgba(255, 255, 255, 1) 46%, #fafbff 100%);
  color: #101828;
}

.page-body {
  min-height: 100vh;
}

.hero {
  margin-top: 72rpx;
}

.state-wrap {
  min-height: 64vh;
  padding: 96rpx 0 120rpx;
  text-align: center;
}

.state-text {
  color: #667085;
  font-size: 26rpx;
  line-height: 1.6;
}

.hero-title {
  display: block;
  color: #16233d;
  font-size: 42rpx;
  line-height: 1.15;
  font-weight: 500;
  letter-spacing: 0.04em;
}

.hero-accent {
  width: 68rpx;
  height: 6rpx;
  margin-top: 22rpx;
  border-radius: 999rpx;
  background: #2f6fe8;
}

.form-shell {
  display: flex;
  flex-direction: column;
  gap: 44rpx;
  margin-top: 46rpx;
}

.field {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.field-head {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.field-head--split {
  justify-content: space-between;
  gap: 24rpx;
}

.field-title-wrap {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.field-label {
  color: #18253d;
  font-size: 28rpx;
  line-height: 1.3;
  font-weight: 500;
}

.field-required {
  color: #f04438;
  font-size: 22rpx;
  line-height: 1;
}

.avatar-card {
  width: 100%;
  height: 320rpx;
  flex-shrink: 0;
  overflow: hidden;
  border-radius: 26rpx;
  border: 2rpx solid #e4e7ec;
  background: linear-gradient(180deg, #ffffff 0%, #fafbff 100%);
  position: relative;
}

.avatar-placeholder,
.avatar-loading {
  width: 100%;
  height: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.avatar-plus {
  color: #2f6fe8;
  font-size: 72rpx;
  line-height: 1;
  font-weight: 300;
}

.avatar-preview {
  width: 100%;
  height: 100%;
}

.avatar-badge {
  position: absolute;
  right: 18rpx;
  bottom: 18rpx;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(15, 23, 42, 0.76);
  color: #ffffff;
  font-size: 18rpx;
  line-height: 1.2;
}

.loading-spin {
  width: 42rpx;
  height: 42rpx;
  border: 4rpx solid #d0d5dd;
  border-top-color: #2f6fe8;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

.avatar-loading-text {
  margin-top: 12rpx;
  color: #667085;
  font-size: 20rpx;
  line-height: 1.5;
}

@keyframes spin {
  to {
    transform: rotate(360deg);
  }
}

.field-tip {
  display: block;
  margin-top: -2rpx;
  color: #667085;
  font-size: 24rpx;
  line-height: 1.6;
}

.input-shell {
  display: flex;
  align-items: center;
  min-height: 82rpx;
  padding: 0 24rpx;
  border: 2rpx solid #e4e7ec;
  border-radius: 22rpx;
  background: #ffffff;
}

.line-input {
  flex: 1;
  min-width: 0;
  height: 82rpx;
  color: #101828;
  font-size: 28rpx;
  line-height: 82rpx;
}

.line-input-error {
  color: #d92d20;
}

.input-placeholder {
  color: #98a2b3;
}

.field-count {
  flex-shrink: 0;
  color: #98a2b3;
  font-size: 24rpx;
  line-height: 1.4;
}

.field-error {
  color: #d92d20;
  font-size: 22rpx;
  line-height: 1.6;
}

.description-box {
  border: 2rpx solid #e4e7ec;
  border-radius: 26rpx;
  background: #ffffff;
  overflow: hidden;
}

.description-input {
  width: 100%;
  min-height: 276rpx;
  padding: 26rpx 24rpx;
  box-sizing: border-box;
  color: #101828;
  font-size: 28rpx;
  line-height: 1.76;
}

.footer-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 18rpx;
  padding: 20rpx 32rpx calc(26rpx + env(safe-area-inset-bottom));
  background: linear-gradient(180deg, rgba(255, 255, 255, 0) 0%, #ffffff 34%, #ffffff 100%);
  box-sizing: border-box;
}

.publish-btn {
  min-width: 132rpx;
  height: 64rpx;
  margin: 0;
  padding: 0 24rpx;
  border: 0;
  border-radius: 999rpx;
  background: #59a1ff;
  color: #ffffff;
  font-size: 24rpx;
  line-height: 1;
  font-weight: 600;
  box-shadow: none;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  text-align: center;
  flex: 0 0 auto;
  min-height: 0;
}

.publish-btn::after {
  border: 0;
}

.publish-btn--active {
  opacity: 0.88;
}

.publish-btn--disabled {
  opacity: 0.45;
}

.publish-btn__text {
  color: #ffffff;
  font-size: 24rpx;
  line-height: 1;
  font-weight: 600;
  letter-spacing: 0.04em;
}
