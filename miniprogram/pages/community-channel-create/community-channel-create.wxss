.page {
  min-height: 100vh;
  background: var(--background);
}

.page-body {
  padding: var(--space-md);
  display: flex;
  flex-direction: column;
  gap: var(--space-sm);
}

/* ── 头像区 ── */
.avatar-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: var(--space-xs);
  padding: var(--space-sm) 0;
}

.avatar-label {
  font-size: 28rpx;
  color: var(--text-primary);
  font-weight: 500;
  align-self: flex-start;
}

.avatar-picker {
  width: 160rpx;
  height: 160rpx;
  border-radius: var(--radius-full);
  overflow: hidden;
  position: relative;
  background: var(--background);
  border: 2rpx dashed var(--border);
}

.avatar-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 6rpx;
}

.avatar-plus {
  font-size: 52rpx;
  color: var(--text-tertiary);
  line-height: 1;
}

.avatar-hint {
  font-size: 20rpx;
  color: var(--text-tertiary);
}

.avatar-preview {
  width: 100%;
  height: 100%;
}

.avatar-badge {
  position: absolute;
  bottom: 0;
  right: 0;
  background: rgba(17, 17, 17, 0.55);
  color: #fff;
  font-size: 20rpx;
  padding: 4rpx 10rpx;
  border-radius: var(--radius-md) 0 0 0;
}

.avatar-loading {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--background);
}

.loading-spin {
  width: 40rpx;
  height: 40rpx;
  border: 4rpx solid var(--border);
  border-top-color: var(--ink);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.avatar-tip {
  font-size: 22rpx;
  color: var(--text-tertiary);
  text-align: center;
}

/* ── 表单字段 ── */
.field-group {
  display: flex;
  flex-direction: column;
}

.field {
  padding: var(--space-sm) 0;
  position: relative;
}

.field-label {
  font-size: 26rpx;
  color: var(--text-secondary);
  margin-bottom: 10rpx;
  display: flex;
  align-items: center;
  gap: 4rpx;
}

.field-required {
  color: var(--error);
  font-size: 26rpx;
}

.field-input {
  width: 100%;
  font-size: 30rpx;
  color: var(--text-primary);
  padding: 14rpx 0;
  border-bottom: 1rpx solid var(--form-border);
  background: transparent;
  box-sizing: border-box;
}

.field-input--error {
  border-bottom-color: var(--error);
}

.field-error {
  font-size: 22rpx;
  color: var(--error);
  margin-top: 6rpx;
}

.field-textarea {
  width: 100%;
  font-size: 30rpx;
  color: var(--text-primary);
  min-height: 120rpx;
  padding: 14rpx 0;
  background: transparent;
  box-sizing: border-box;
}

.field-count {
  font-size: 22rpx;
  color: var(--text-tertiary);
  text-align: right;
  margin-top: 4rpx;
}

.field-divider {
  height: 1rpx;
  background: var(--form-border);
}

/* ── 提交按钮 ── */
.btn-wrap {
  padding: var(--space-md) 0 var(--space-xl);
}

.btn-primary {
  width: 100%;
  height: 96rpx;
  background: var(--ink);
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 500;
  border-radius: var(--radius-full);
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
}

.btn-disabled {
  opacity: 0.5;
}
