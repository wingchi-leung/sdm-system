.page {
  min-height: 100vh;
  padding: 28rpx 36rpx 220rpx;
  box-sizing: border-box;
  background: #ffffff;
}

.hero {
  margin-bottom: 42rpx;
}

.state-wrap {
  padding: 80rpx 0 120rpx;
  text-align: center;
}

.state-text {
  color: #667085;
  font-size: 26rpx;
  line-height: 1.6;
}

.hero-caption {
  display: block;
  color: #667085;
  font-size: 22rpx;
  line-height: 1.5;
  font-weight: 500;
}

.hero-title {
  display: block;
  margin-top: 14rpx;
  color: #101828;
  font-size: 42rpx;
  line-height: 1.14;
  font-weight: 500;
  letter-spacing: 0.02em;
}

.hero-accent {
  width: 66rpx;
  height: 6rpx;
  margin-top: 28rpx;
  border-radius: 999rpx;
  background: #2f6fe8;
}

.form-shell {
  display: flex;
  flex-direction: column;
  gap: 40rpx;
}

.field {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.field-head {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.field-label {
  color: #101828;
  font-size: 28rpx;
  line-height: 1.3;
  font-weight: 500;
}

.field-required {
  color: #f04438;
  font-size: 22rpx;
  line-height: 1;
}

.field-optional {
  color: #98a2b3;
  font-size: 22rpx;
  line-height: 1.4;
}

.avatar-row {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.avatar-picker {
  width: 176rpx;
  height: 176rpx;
  flex-shrink: 0;
  overflow: hidden;
  border-radius: 28rpx;
  border: 2rpx solid #e4e7ec;
  background: linear-gradient(180deg, #f8fafc 0%, #eef2f6 100%);
  position: relative;
}

.avatar-placeholder,
.avatar-loading {
  width: 100%;
  height: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.avatar-plus {
  color: #98a2b3;
  font-size: 42rpx;
  line-height: 1;
  font-weight: 300;
}

.avatar-preview {
  width: 100%;
  height: 100%;
}

.avatar-badge {
  position: absolute;
  right: 12rpx;
  bottom: 12rpx;
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  background: rgba(15, 23, 42, 0.76);
  color: #ffffff;
  font-size: 18rpx;
  line-height: 1.2;
}

.loading-spin {
  width: 44rpx;
  height: 44rpx;
  border: 4rpx solid #d0d5dd;
  border-top-color: #101828;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

.avatar-loading-text {
  margin-top: 12rpx;
  color: #667085;
  font-size: 20rpx;
  line-height: 1.5;
}

@keyframes spin {
  to {
    transform: rotate(360deg);
  }
}

.avatar-copy {
  flex: 1;
  min-width: 0;
}

.avatar-title {
  display: block;
  color: #101828;
  font-size: 26rpx;
  line-height: 1.5;
  font-weight: 500;
}

.avatar-tip {
  display: block;
  margin-top: 10rpx;
  color: #667085;
  font-size: 22rpx;
  line-height: 1.75;
}

.line-input-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding-bottom: 16rpx;
  border-bottom: 2rpx solid #eaecf0;
}

.line-input {
  flex: 1;
  min-width: 0;
  height: 84rpx;
  color: #101828;
  font-size: 28rpx;
  line-height: 84rpx;
}

.line-input-error {
  color: #d92d20;
}

.input-placeholder {
  color: #98a2b3;
}

.field-count {
  flex-shrink: 0;
  color: #98a2b3;
  font-size: 22rpx;
  line-height: 1.4;
}

.field-error {
  color: #d92d20;
  font-size: 22rpx;
  line-height: 1.6;
}

.description-box {
  border: 2rpx solid #e4e7ec;
  border-radius: 24rpx;
  background: #ffffff;
  overflow: hidden;
}

.description-input {
  width: 100%;
  min-height: 220rpx;
  padding: 26rpx 24rpx 12rpx;
  box-sizing: border-box;
  color: #101828;
  font-size: 28rpx;
  line-height: 1.8;
}

.description-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  padding: 0 24rpx 22rpx;
}

.description-tip {
  flex: 1;
  min-width: 0;
  color: #98a2b3;
  font-size: 22rpx;
  line-height: 1.6;
}

.footer-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  justify-content: flex-end;
  padding: 24rpx 32rpx calc(24rpx + env(safe-area-inset-bottom));
  background: linear-gradient(180deg, rgba(255, 255, 255, 0) 0%, #ffffff 28%, #ffffff 100%);
}

.submit-btn {
  min-width: 240rpx;
  height: 88rpx;
  margin: 0;
  padding: 0 40rpx;
  border: 0;
  border-radius: 20rpx;
  background: #0f172a;
  color: #ffffff;
  font-size: 28rpx;
  line-height: 88rpx;
  font-weight: 500;
  box-shadow: 0 16rpx 40rpx rgba(15, 23, 42, 0.16);
}

.submit-btn::after {
  border: 0;
}

.submit-btn[disabled] {
  opacity: 0.56;
}
