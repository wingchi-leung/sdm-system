.page {
  min-height: 100vh;
  padding: 24rpx 32rpx;
  box-sizing: border-box;
  background: #ffffff;
  color: #111111;
  font-family: var(--font-body);
}

.card {
  margin-bottom: 24rpx;
  padding-bottom: 24rpx;
  border-bottom: 1rpx solid var(--divider);
}

.title {
  display: block;
  font-size: 32rpx;
  line-height: 44rpx;
  color: #111111;
}

.desc {
  display: block;
  margin-top: 10rpx;
  color: #999999;
  font-size: 24rpx;
  line-height: 34rpx;
}

.list {
  border-top: 1rpx solid var(--divider);
}

.item {
  padding: 22rpx 0;
  border-bottom: 1rpx solid var(--divider);
}

.item:last-child {
  border-bottom: none;
}

.item-title {
  display: block;
  font-size: 30rpx;
  line-height: 42rpx;
  color: #111111;
}

.item-desc {
  display: block;
  margin-top: 6rpx;
  color: #999999;
  font-size: 24rpx;
  line-height: 34rpx;
}
