.page {
  min-height: 100vh;
  padding: 24rpx;
  box-sizing: border-box;
  background: var(--background);
}

.card {
  background: #fff;
  border: 1px solid var(--border-light);
  border-radius: 20rpx;
  padding: 26rpx;
  margin-bottom: 24rpx;
}

.title {
  display: block;
  font-size: 32rpx;
  color: var(--text-primary);
}

.desc {
  display: block;
  margin-top: 10rpx;
  color: var(--text-secondary);
  font-size: 24rpx;
  line-height: 34rpx;
}

.list {
  background: #fff;
  border: 1px solid var(--border-light);
  border-radius: 20rpx;
  overflow: hidden;
}

.item {
  padding: 24rpx;
}

.item + .item {
  border-top: 1px solid var(--border-light);
}

.item-title {
  display: block;
  font-size: 30rpx;
  color: var(--text-primary);
}

.item-desc {
  display: block;
  margin-top: 6rpx;
  color: var(--text-tertiary);
  font-size: 24rpx;
}

