<view class="page">
  <view class="hero">
    <view class="hero-top">
      <view class="hero-copy">
        <text class="hero-title">Explore</text>
        <text class="hero-title">Together.</text>
        <text class="hero-subtitle">一起探索更大的世界</text>
      </view>
      <view class="hero-side">
        <view class="header-avatar" wx:if="{{isUser}}" bindtap="goMine">
          <image wx:if="{{headerAvatarUrl}}" class="header-avatar-image" src="{{headerAvatarUrl}}" mode="aspectFill" />
          <text wx:else class="header-avatar-text">{{headerAvatarText}}</text>
        </view>
        <view class="header-action" wx:if="{{isAdmin && canCreateActivity}}">
          <button class="btn-publish" bindtap="goCreateActivity">
            <text class="publish-icon">+</text>
          </button>
        </view>
      </view>
    </view>

    <scroll-view wx:if="{{dateTabs.length}}" class="date-strip" scroll-x enable-flex show-scrollbar="{{false}}">
      <view class="date-strip-inner">
        <view
          class="date-item {{selectedDateKey === item.key ? 'date-item-active' : ''}}"
          wx:for="{{dateTabs}}"
          wx:key="key"
          data-date-key="{{item.key}}"
          bindtap="onSelectDate"
        >
          <text class="date-number">{{item.dateLabel}}</text>
          <text class="date-week">{{item.weekdayLabel}}</text>
          <text class="date-marker">{{item.markerLabel || '\u00A0'}}</text>
          <view class="date-dot"></view>
        </view>
      </view>
    </scroll-view>
  </view>

  <view wx:if="{{loading}}" class="state-wrap">
    <view class="loading"></view>
    <text class="state-text">加载中...</text>
  </view>

  <view wx:elif="{{error}}" class="state-wrap error">
    <view class="state-icon">!</view>
    <text class="state-title">加载失败</text>
    <text class="state-text">{{error}}</text>
    <button class="btn-retry" bindtap="onRefresh">重试</button>
  </view>

  <!-- 空状态 -->
  <view wx:elif="{{activities.length === 0}}" class="state-wrap empty">
    <image class="empty-image" src="/assets/icons/noactivity.png" mode="aspectFit" />
    <text class="state-title">暂无活动</text>
    <text class="state-text">精彩活动即将上线，敬请期待</text>
    <button class="btn-text" bindtap="onRefresh">刷新</button>
  </view>

  <view wx:else class="list-shell">
    <view class="section-header">
      <text class="section-title">{{selectedDateKey ? (visibleActivities.length ? '即将开始' : '这个日期还没有活动') : '全部活动'}}</text>
      <text class="section-link" bindtap="onShowAllActivities">查看全部 →</text>
    </view>

    <view wx:if="{{visibleActivities.length === 0}}" class="day-empty">
      <text class="day-empty-title">先留一点空白</text>
      <text class="day-empty-text">换个日期看看，或稍后刷新获取新活动。</text>
    </view>

    <view
      wx:else
      class="activity-item"
      wx:for="{{visibleActivities}}"
      wx:key="id"
      data-activity="{{item}}"
      bindtap="goDetail"
    >
      <view class="poster-wrap">
        <image
          wx:if="{{item.poster_url}}"
          class="poster-img"
          src="{{item.poster_url}}"
          mode="aspectFill"
          lazy-load
        />
        <view wx:else class="no-poster">
          <text class="no-poster-mark">SDM</text>
        </view>
      </view>

      <view class="item-content">
        <text class="item-code">{{item.card_code}}</text>
        <text class="item-name">{{item.activity_name}}</text>
        <text class="item-summary">{{item.summary_text}}</text>
        <view class="item-info">
          <view class="info-row">
            <text class="info-text info-text-strong">{{item.date_label}} ({{item.weekday_label}})</text>
            <text class="info-text">{{item.time_range_display}}</text>
          </view>
          <view class="info-row">
            <text class="meta-icon">⌖</text>
            <text class="info-text">{{item.location_display}}</text>
          </view>
          <view class="info-row">
            <text class="meta-icon">◌</text>
            <text class="info-text">{{item.participant_display}}</text>
          </view>
        </view>
        <view class="status-row">
          <text class="status-chip status-chip-{{item.status}}">{{item.status_text}}</text>
          <text wx:if="{{item.has_registered}}" class="status-chip status-chip-registered">{{item.registration_status_text}}</text>
        </view>
      </view>
    </view>
  </view>

  <view class="footer-space"></view>
</view>
