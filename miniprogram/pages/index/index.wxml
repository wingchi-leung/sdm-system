<view class="page">
  <!-- 顶部标题区域 -->
  <view class="header">
    <view class="header-content">
      <image class="brand-logo" src="/assets/icons/mainlogo-door.png" mode="aspectFit" />
      <text class="header-title">活动</text>
      <text class="header-subtitle">探索增长新路径，预见未来新机会</text>
    </view>
    <view class="header-action" wx:if="{{isAdmin && canCreateActivity}}">
      <button class="btn-publish" bindtap="goCreateActivity">
        <text class="publish-icon">+</text>
      </button>
    </view>
  </view>

  <!-- 加载状态 -->
  <view wx:if="{{loading}}" class="state-wrap">
    <view class="loading"></view>
    <text class="state-text">加载中...</text>
  </view>

  <!-- 错误状态 -->
  <view wx:elif="{{error}}" class="state-wrap error">
    <view class="state-icon">!</view>
    <text class="state-title">加载失败</text>
    <text class="state-text">{{error}}</text>
    <button class="btn-retry" bindtap="onRefresh">重试</button>
  </view>

  <!-- 空状态 -->
  <view wx:elif="{{activities.length === 0}}" class="state-wrap empty">
    <image class="empty-image" src="/assets/icons/noactivity.png" mode="aspectFit" />
    <text class="state-title">暂无活动</text>
    <text class="state-text">精彩活动即将上线，敬请期待</text>
    <button class="btn-text" bindtap="onRefresh">刷新</button>
  </view>

  <!-- 活动列表 - 卡片样式 -->
  <view wx:else class="list">
    <view
      class="activity-item"
      wx:for="{{activities}}"
      wx:key="id"
      data-activity="{{item}}"
      bindtap="goDetail"
    >
      <!-- 海报区域 -->
      <view class="poster-wrap">
        <image
          wx:if="{{item.poster_url}}"
          class="poster-img"
          src="{{item.poster_url}}"
          mode="aspectFill"
          lazy-load
        />
        <view wx:else class="no-poster">暂无海报</view>
        <!-- 状态标签 -->
        <view class="status-tag {{item.status === 1 ? 'status-1' : (item.status === 2 ? 'status-2' : 'status-3')}}">
          {{item.status_text}}
        </view>
      </view>

      <!-- 内容区 -->
      <view class="item-content">
        <text class="item-name">{{item.activity_name}}</text>
        <view class="item-info">
          <view class="info-row">
            <text class="info-dot"></text>
            <text class="info-text">{{item.start_time_display}}</text>
          </view>
          <text class="info-text" wx:if="{{item.location}}">{{item.location}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 底部留白 -->
  <view class="footer-space"></view>
</view>
