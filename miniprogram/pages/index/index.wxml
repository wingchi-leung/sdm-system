<view class="page">
  <view class="hero">
    <view class="hero-top">
      <view class="hero-action" bindtap="goCommunityNotifications" aria-label="站内信">
        <image class="hero-bell" src="/assets/icons/bell.png" mode="aspectFit" aria-hidden="true" />
        <view wx:if="{{communityUnreadCount > 0}}" class="hero-action-badge">
          <text class="hero-action-badge-text">{{communityUnreadCount > 99 ? '99+' : communityUnreadCount}}</text>
        </view>
      </view>
    </view>

    <view class="hero-copy">
      <text class="hero-title">参悟真理</text>
    </view>

    <view class="hero-rule"></view>

    <text class="hero-date">{{todayDateShort}} {{weekdayLabelEn}}</text>
  </view>

  <view wx:if="{{loading}}" class="state-wrap">
    <view class="loading"></view>
    <text class="state-text">加载中...</text>
  </view>

  <view wx:elif="{{error}}" class="state-wrap error">
    <view class="state-icon">!</view>
    <text class="state-title">加载失败</text>
    <text class="state-text">{{error}}</text>
    <button class="btn-retry" bindtap="onRefresh">重试</button>
  </view>

  <view wx:elif="{{visibleActivities.length === 0}}" class="state-wrap empty">
    <image class="empty-image" src="/assets/icons/noactivity.png" mode="aspectFit" />
    <text class="state-title">暂无活动</text>
    <button class="btn-text" bindtap="onRefresh">刷新</button>
  </view>

  <view wx:else class="list-shell">
    <view class="activity-groups">
      <view wx:for="{{dateGroups}}" wx:key="key" class="activity-group">
        <view class="activity-group-header">
          <text class="activity-group-date">{{item.date_label}}</text>
          <text wx:if="{{item.weekday_label}}" class="activity-group-weekday">{{item.weekday_label}}</text>
        </view>
        <view class="activity-list">
          <view
            class="activity-card"
            wx:for="{{item.activities}}"
            wx:for-item="activity"
            wx:key="id"
            data-activity="{{activity}}"
            bindtap="goDetail"
          >
            <view class="activity-cover">
              <image
                wx:if="{{activity.poster_url}}"
                class="activity-cover-image"
                src="{{activity.poster_url}}"
                mode="aspectFill"
                lazy-load
              />
              <view wx:else class="activity-cover-placeholder">
                <text class="activity-cover-placeholder-text">SDM</text>
              </view>
            </view>

            <view class="activity-content">
              <view class="activity-head">
                <text class="activity-title-text">{{activity.activity_name}}</text>
                <text class="activity-arrow">→</text>
              </view>

              <text wx:if="{{activity.summary_text}}" class="activity-summary">{{activity.summary_text}}</text>
              <text wx:else class="activity-summary muted">探索更多活动细节</text>

              <view class="activity-meta">
                <text wx:if="{{activity.date_label}}" class="activity-meta-text">{{activity.date_label}}</text>
                <text wx:if="{{activity.weekday_label}}" class="activity-meta-text">{{activity.weekday_label}}</text>
                <text wx:if="{{activity.time_range_display}}" class="activity-meta-text">{{activity.time_range_display}}</text>
                <text class="activity-meta-text">{{activity.location_display}}</text>
              </view>
            </view>
          </view>
        </view>
      </view>
    </view>
  </view>

  <view class="footer-space"></view>
</view>
