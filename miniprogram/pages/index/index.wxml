<view class="page">
  <view class="nav-actions" wx:if="{{isAdmin && canCreateActivity}}">
    <button class="btn-text" bindtap="goCreateActivity">发布活动</button>
  </view>

  <view wx:if="{{loading}}" class="loading-wrap">
    <view class="loading"></view>
    <text class="loading-tip">加载中…</text>
  </view>

  <view wx:elif="{{error}}" class="error-wrap">
    <text class="error-title">加载失败</text>
    <text class="error-msg">{{error}}</text>
    <button class="btn-primary retry-btn" bindtap="onRefresh">重试</button>
  </view>

  <view wx:elif="{{activities.length === 0}}" class="empty-wrap">
    <text class="empty-title">暂无可报名活动</text>
    <text class="empty-tip">下拉刷新试试</text>
    <button class="btn-text" bindtap="onRefresh">刷新</button>
  </view>

  <view wx:else class="list">
    <view
      class="activity-item"
      wx:for="{{activities}}"
      wx:key="id"
      data-activity="{{item}}"
      bindtap="goDetail"
    >
      <view class="activity-icon">
        <text class="icon-date">{{date_day || '--'}}</text>
        <text class="icon-month">{{date_month || '未知'}}</text>
      </view>
      <view class="activity-body">
        <text class="activity-name">{{item.activity_name}}</text>
        <text class="activity-time" wx:if="{{item.start_time_display}}">{{item.start_time_display}}</text>
        <view class="tag {{item.status === 1 ? 'tag-not-started' : (item.status === 2 ? 'tag-ongoing' : 'tag-ended')}}">
          {{item.status_text}}
        </view>
      </view>
      <text class="arrow">›</text>
    </view>
  </view>
</view>
