.page {
  min-height: 100vh;
  background:
    radial-gradient(circle at top right, rgba(29, 52, 79, 0.05) 0%, transparent 28%),
    linear-gradient(180deg, #FFFDFC 0%, #FFFFFF 32%);
  box-sizing: border-box;
}

.hero {
  padding: 36rpx 24rpx 0;
}

.hero-top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
}

.hero-copy {
  flex: 1;
  min-width: 0;
}

.hero-title {
  display: block;
  color: #1D344F;
  font-family: "Times New Roman", "Noto Serif SC", serif;
  font-size: 76rpx;
  line-height: 0.96;
  font-weight: 400;
}

.hero-title + .hero-title {
  margin-top: 12rpx;
}

.hero-subtitle {
  display: block;
  margin-top: 26rpx;
  color: rgba(29, 52, 79, 0.82);
  font-size: 28rpx;
  line-height: 40rpx;
  letter-spacing: 0.8rpx !important;
}

.hero-side {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
}

.hero-side .header-action {
  margin-top: 16rpx;
}

.header-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  overflow: hidden;
  background: rgba(29, 52, 79, 0.08);
  border: 1rpx solid rgba(29, 52, 79, 0.08);
  display: flex;
  align-items: center;
  justify-content: center;
}

.header-avatar-image {
  width: 100%;
  height: 100%;
}

.header-avatar-text {
  color: #1D344F;
  font-size: 28rpx;
  font-weight: 600;
  line-height: 1;
}

.btn-publish {
  width: 72rpx !important;
  height: 72rpx !important;
  min-height: 72rpx;
  padding: 0 !important;
  margin: 0;
  border: 0;
  border-radius: 50%;
  background: #1D344F;
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn-publish::after {
  border: 0;
}

.publish-icon {
  color: #FFFFFF;
  font-size: 40rpx;
  font-weight: 300;
  line-height: 1;
}

.date-strip {
  margin-top: 42rpx;
  white-space: nowrap;
}

.date-strip-inner {
  display: inline-flex;
  align-items: flex-start;
  padding-right: 24rpx;
}

.date-item {
  position: relative;
  width: 116rpx;
  margin-right: 8rpx;
  padding: 0 6rpx 26rpx;
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  box-sizing: border-box;
}

.date-number {
  color: rgba(29, 52, 79, 0.42);
  font-size: 30rpx;
  line-height: 38rpx;
  font-weight: 500;
}

.date-week,
.date-marker {
  margin-top: 10rpx;
  color: rgba(29, 52, 79, 0.36);
  font-size: 18rpx;
  line-height: 24rpx;
  letter-spacing: 1.4rpx !important;
}

.date-marker {
  min-height: 24rpx;
}

.date-dot {
  position: absolute;
  left: 50%;
  bottom: 0;
  width: 10rpx;
  height: 10rpx;
  margin-left: -5rpx;
  border-radius: 50%;
  background: transparent;
}

.date-item-active .date-number,
.date-item-active .date-week,
.date-item-active .date-marker {
  color: #1D344F;
}

.date-item-active .date-number {
  font-weight: 700;
}

.date-item-active .date-dot {
  background: #1D344F;
}

.state-wrap {
  min-height: 56vh;
  padding: 110rpx 56rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.state-wrap.error .state-icon {
  width: 72rpx;
  height: 72rpx;
  margin-bottom: 28rpx;
  background: rgba(178, 65, 55, 0.06);
  border-radius: 50%;
  color: var(--error);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 34rpx;
}

.state-title {
  margin-top: 10rpx;
  font-size: 32rpx;
  font-weight: 500;
  color: #1D344F;
}

.state-text {
  margin-top: 14rpx;
  font-size: 24rpx;
  line-height: 34rpx;
  color: rgba(29, 52, 79, 0.54);
  text-align: center;
}

.empty-image {
  width: 220rpx;
  height: 260rpx;
  margin-bottom: 20rpx;
}

.btn-retry,
.btn-text {
  margin-top: 34rpx;
  padding: 18rpx 52rpx;
  border: 0;
  border-radius: 999rpx;
  background: rgba(29, 52, 79, 0.08);
  color: #1D344F;
  font-size: 26rpx;
}

.btn-retry::after,
.btn-text::after {
  border: 0;
}

.list-shell {
  padding: 32rpx 24rpx 0;
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.section-title {
  color: #1D344F;
  font-size: 30rpx;
  line-height: 38rpx;
  font-weight: 600;
}

.section-link {
  color: rgba(29, 52, 79, 0.58);
  font-size: 22rpx;
  line-height: 30rpx;
}

.day-empty {
  padding: 60rpx 28rpx;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.86);
  border: 1rpx solid rgba(29, 52, 79, 0.08);
}

.day-empty-title {
  display: block;
  color: #1D344F;
  font-size: 30rpx;
  line-height: 40rpx;
  font-weight: 500;
}

.day-empty-text {
  display: block;
  margin-top: 12rpx;
  color: rgba(29, 52, 79, 0.54);
  font-size: 24rpx;
  line-height: 34rpx;
}

.activity-item {
  display: flex;
  align-items: stretch;
  margin-bottom: 24rpx;
  border-radius: 28rpx;
  overflow: hidden;
  background: rgba(255, 255, 255, 0.9);
  border: 1rpx solid rgba(29, 52, 79, 0.08);
}

.poster-wrap {
  position: relative;
  width: 246rpx;
  min-width: 246rpx;
  height: 276rpx;
  overflow: hidden;
  background:
    linear-gradient(180deg, rgba(29, 52, 79, 0.08) 0%, rgba(29, 52, 79, 0.18) 100%);
}

.poster-img {
  width: 100%;
  height: 100%;
}

.no-poster {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: flex-end;
  justify-content: flex-start;
  padding: 20rpx;
  box-sizing: border-box;
  background:
    linear-gradient(180deg, rgba(232, 238, 245, 0.92) 0%, rgba(182, 198, 218, 0.96) 100%);
}

.no-poster-mark {
  color: rgba(29, 52, 79, 0.75);
  font-size: 22rpx;
  letter-spacing: 2rpx !important;
}

.item-content {
  flex: 1;
  min-width: 0;
  padding: 26rpx 24rpx 22rpx;
  display: flex;
  flex-direction: column;
}

.item-code {
  color: rgba(29, 52, 79, 0.46);
  font-size: 18rpx;
  line-height: 24rpx;
  letter-spacing: 1.6rpx !important;
}

.item-name {
  display: block;
  margin-top: 18rpx;
  color: #1D344F;
  font-size: 38rpx;
  line-height: 50rpx;
  font-weight: 500;
}

.item-summary {
  display: block;
  margin-top: 14rpx;
  min-height: 68rpx;
  color: rgba(29, 52, 79, 0.56);
  font-size: 24rpx;
  line-height: 34rpx;
}

.item-info {
  margin-top: auto;
}

.info-row {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  margin-top: 8rpx;
}

.info-row:first-child {
  margin-top: 0;
}

.meta-icon {
  margin-right: 10rpx;
  color: rgba(29, 52, 79, 0.46);
  font-size: 20rpx;
  line-height: 28rpx;
}

.info-text {
  margin-right: 16rpx;
  color: rgba(29, 52, 79, 0.54);
  font-size: 22rpx;
  line-height: 32rpx;
}

.info-text-strong {
  color: rgba(29, 52, 79, 0.8);
}

.status-row {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  margin-top: 18rpx;
}

.status-chip {
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  font-size: 20rpx;
  line-height: 28rpx;
  margin-right: 10rpx;
  margin-bottom: 10rpx;
}

.status-chip-1 {
  background: rgba(29, 52, 79, 0.08);
  color: rgba(29, 52, 79, 0.76);
}

.status-chip-2 {
  background: #1D344F;
  color: #FFFFFF;
}

.status-chip-3 {
  background: rgba(29, 52, 79, 0.12);
  color: rgba(29, 52, 79, 0.46);
}

.status-chip-registered {
  background: rgba(57, 122, 81, 0.12);
  color: #397A51;
}

.footer-space {
  height: 112rpx;
}
