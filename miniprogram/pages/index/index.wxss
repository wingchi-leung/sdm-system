.page {
  min-height: 100vh;
  background: #ffffff;
  box-sizing: border-box;
}

.hero {
  padding: 28rpx 30rpx 14rpx;
}

.hero-top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
}

.hero-copy {
  flex: 1;
  min-width: 0;
  display: flex;
  align-items: baseline;
  gap: 14rpx;
}

.hero-title {
  display: inline-block;
  color: #161616;
  font-family: "PingFang SC", -apple-system, BlinkMacSystemFont, sans-serif;
  font-size: 48rpx;
  line-height: 1.1;
  font-weight: 500;
}

.hero-subtitle {
  color: #666666;
  font-family: "Songti SC", "STSong", "SimSun", serif;
  font-size: 24rpx;
  line-height: 1.3;
  font-weight: 500;
}

.hero-side {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
}

.hero-side .header-action {
  margin-top: 12rpx;
}

.header-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  overflow: hidden;
  background: #e9e9e9;
  display: flex;
  align-items: center;
  justify-content: center;
}

.header-avatar-image {
  width: 100%;
  height: 100%;
}

.header-avatar-text {
  color: #666666;
  font-size: 28rpx;
  font-weight: 600;
  line-height: 1;
}

.btn-publish {
  width: 72rpx !important;
  height: 72rpx !important;
  min-height: 72rpx;
  padding: 0 !important;
  margin: 0;
  border: 0;
  border-radius: 50%;
  background: #222222;
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn-publish::after {
  border: 0;
}

.publish-icon {
  color: #FFFFFF;
  font-size: 40rpx;
  font-weight: 300;
  line-height: 1;
}

.state-wrap {
  min-height: 56vh;
  padding: 110rpx 56rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.state-wrap.error .state-icon {
  width: 72rpx;
  height: 72rpx;
  margin-bottom: 28rpx;
  background: rgba(178, 65, 55, 0.06);
  border-radius: 50%;
  color: var(--error);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 34rpx;
}

.state-title {
  margin-top: 10rpx;
  font-size: 32rpx;
  font-weight: 500;
  color: #222222;
}

.state-text {
  margin-top: 14rpx;
  font-size: 24rpx;
  line-height: 34rpx;
  color: #8e8e8e;
  text-align: center;
}

.empty-image {
  width: 220rpx;
  height: 260rpx;
  margin-bottom: 20rpx;
}

.btn-retry,
.btn-text {
  margin-top: 34rpx;
  padding: 18rpx 52rpx;
  border: 0;
  border-radius: 999rpx;
  background: #ececec;
  color: #444444;
  font-size: 26rpx;
}

.btn-retry::after,
.btn-text::after {
  border: 0;
}

.list-shell {
  margin-top: 10rpx;
  padding: 0 30rpx;
  background: transparent;
}

.section-header {
  margin-bottom: 10rpx;
  padding: 10rpx 0 6rpx;
}

.section-title {
  color: #2e2e2e;
  font-family: "Source Han Sans SC", "Noto Sans SC", "PingFang SC", sans-serif;
  font-size: 28rpx;
  line-height: 1.2;
  font-weight: 400;
}

.day-empty {
  padding: 56rpx 18rpx;
  background: #ffffff;
}

.day-empty-title {
  display: block;
  color: #222222;
  font-size: 30rpx;
  line-height: 40rpx;
  font-weight: 500;
}

.day-empty-text {
  display: block;
  margin-top: 12rpx;
  color: #8c8c8c;
  font-size: 24rpx;
  line-height: 34rpx;
}

.activity-item {
  display: flex;
  align-items: flex-start;
  padding: 20rpx 0 10rpx;
  position: relative;
}

.activity-item::after {
  content: "";
  position: absolute;
  left: 30%;
  bottom: 0;
  width: 50%;
  height: 0.8rpx;
  background: #f1f1f1;
}

.poster-wrap {
  position: relative;
  width: 184rpx;
  min-width: 184rpx;
  height: 184rpx;
  border-radius: 12rpx;
  overflow: hidden;
  background: #eeeeee;
}

.poster-img {
  width: 100%;
  height: 100%;
}

.no-poster {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
  box-sizing: border-box;
  background: #efefef;
}

.no-poster-mark {
  color: #a4a4a4;
  font-size: 26rpx;
  letter-spacing: 2rpx !important;
}

.item-content {
  flex: 1;
  min-width: 0;
  padding: 8rpx 0 0 22rpx;
  display: flex;
  flex-direction: column;
}

.item-name {
  display: block;
  margin-top: 0;
  color: #141414;
  font-family: "PingFang SC", -apple-system, BlinkMacSystemFont, sans-serif;
  font-size: 34rpx;
  line-height: 1.35;
  font-weight: 500;
  max-height: 104rpx;
  overflow: hidden;
}

.item-info {
  margin-top: 20rpx;
}

.info-row {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  margin-top: 18rpx;
}

.info-row:first-child {
  margin-top: 0;
}

.meta-icon {
  margin-right: 8rpx;
  color: #a5a5a5;
  font-size: 20rpx;
  line-height: 1.4;
}

.info-text {
  margin-right: 12rpx;
  color: #666666;
  font-family: "Songti SC", "STSong", "SimSun", serif;
  font-size: 28rpx;
  line-height: 1.4;
  font-weight: 400;
}

.info-text-strong {
  color: #3c3c3c;
}

.footer-space {
  height: 112rpx;
}
