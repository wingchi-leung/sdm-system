.page {
  min-height: 100vh;
  background: #ffffff;
  box-sizing: border-box;
  font-family: "PingFang SC", "SF Pro Text", -apple-system, BlinkMacSystemFont, "Helvetica Neue", sans-serif;
}

.hero {
  padding: 52rpx 40rpx 28rpx;
}

.hero-top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
}

.hero-copy {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  gap: 14rpx;
}

.hero-title {
  color: #161616;
  font-family: "PingFang SC", "SF Pro Display", -apple-system, BlinkMacSystemFont, sans-serif;
  font-size: 52rpx;
  line-height: 1.12;
  font-weight: 500;
  letter-spacing: -0.015em;
}

.hero-subtitle {
  display: flex;
  align-items: baseline;
  color: #a3a3a3;
  font-size: 24rpx;
  line-height: 1.6;
  font-weight: 400;
}

.hero-subtitle-cn {
  color: #8f8f8f;
  font-family: "PingFang SC", "SF Pro Text", -apple-system, BlinkMacSystemFont, sans-serif;
}

.hero-subtitle-gap {
  margin-left: 30rpx;
  color: #8f8f8f;
  font-family: "PingFang SC", "SF Pro Text", -apple-system, BlinkMacSystemFont, sans-serif;
}

.hero-side {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
}

.hero-side .header-action {
  margin-top: 12rpx;
}

.header-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  overflow: hidden;
  background: #efefef;
  display: flex;
  align-items: center;
  justify-content: center;
}

.header-avatar-image {
  width: 100%;
  height: 100%;
}

.header-avatar-text {
  color: #777777;
  font-size: 28rpx;
  font-weight: 600;
  line-height: 1;
}

.btn-publish {
  width: 72rpx !important;
  height: 72rpx !important;
  min-height: 72rpx;
  padding: 0 !important;
  margin: 0;
  border: 0;
  border-radius: 50%;
  background: #1b1b1b;
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn-publish::after {
  border: 0;
}

.publish-icon {
  color: #ffffff;
  font-size: 40rpx;
  font-weight: 400;
  line-height: 1;
}

.state-wrap {
  min-height: 56vh;
  padding: 120rpx 56rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.state-wrap.error .state-icon {
  width: 72rpx;
  height: 72rpx;
  margin-bottom: 28rpx;
  background: rgba(178, 65, 55, 0.05);
  border-radius: 50%;
  color: var(--error);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 34rpx;
}

.state-title {
  margin-top: 10rpx;
  font-size: 32rpx;
  line-height: 1.4;
  font-weight: 500;
  color: #222222;
}

.state-text {
  margin-top: 16rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: #9a9a9a;
  text-align: center;
}

.empty-image {
  width: 220rpx;
  height: 260rpx;
  margin-bottom: 20rpx;
}

.btn-retry,
.btn-text {
  margin-top: 34rpx;
  padding: 18rpx 52rpx;
  border: 0;
  border-radius: 999rpx;
  background: #f1f1f1;
  color: #5c5c5c;
  font-size: 26rpx;
  font-weight: 500;
}

.btn-retry::after,
.btn-text::after {
  border: 0;
}

.list-shell {
  margin-top: 18rpx;
  padding: 0 40rpx;
  background: transparent;
}

.section-header {
  margin-bottom: 26rpx;
  padding: 6rpx 0 14rpx;
}

.section-title {
  color: #737373;
  font-family: "SF Pro Text", "PingFang SC", -apple-system, BlinkMacSystemFont, sans-serif;
  font-size: 26rpx;
  line-height: 1.6;
  font-weight: 400;
  letter-spacing: 0.01em;
}

.day-empty {
  padding: 64rpx 18rpx;
  background: #ffffff;
}

.day-empty-title {
  display: block;
  color: #222222;
  font-size: 30rpx;
  line-height: 1.45;
  font-weight: 500;
}

.day-empty-text {
  display: block;
  margin-top: 12rpx;
  color: #969696;
  font-size: 24rpx;
  line-height: 1.7;
}

.activity-item {
  display: flex;
  align-items: flex-start;
  padding: 36rpx 0 42rpx;
}

.poster-wrap {
  position: relative;
  width: 184rpx;
  min-width: 184rpx;
  height: 184rpx;
  border-radius: 12rpx;
  overflow: hidden;
  background: #eeeeee;
}

.poster-img {
  width: 100%;
  height: 100%;
}

.no-poster {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  background: #efefef;
}

.no-poster-mark {
  color: #ababab;
  font-size: 24rpx;
  font-family: "SF Pro Display", "PingFang SC", -apple-system, BlinkMacSystemFont, sans-serif;
  font-weight: 400;
  letter-spacing: 0.14em !important;
}

.item-content {
  flex: 1;
  min-width: 0;
  padding: 0 0 0 30rpx;
  display: flex;
  flex-direction: column;
}

.item-name {
  display: block;
  margin-top: 0;
  color: #1c1c1c;
  font-size: 34rpx;
  line-height: 1.48;
  font-weight: 500;
  max-height: 104rpx;
  overflow: hidden;
}

.item-name-cn {
  color: #1c1c1c;
  font-family: "PingFang SC", "SF Pro Display", -apple-system, BlinkMacSystemFont, sans-serif;
  font-size: 34rpx;
  line-height: 1.48;
  font-weight: 500;
}

.item-name-sep {
  color: #8f8f8f;
}

.item-name-en {
  color: #a1a1a1;
  font-family: "SF Pro Text", "PingFang SC", -apple-system, BlinkMacSystemFont, sans-serif;
  font-size: 33rpx;
  line-height: 1.48;
  font-weight: 400;
}

.item-info {
  margin-top: 24rpx;
}

.info-row {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  margin-top: 20rpx;
}

.info-row:first-child {
  margin-top: 0;
}

.meta-icon {
  width: 20rpx;
  height: 20rpx;
  margin-right: 12rpx;
  flex-shrink: 0;
  opacity: 0.72;
}

.meta-icon-image {
  display: block;
}

.info-text {
  margin-right: 16rpx;
  color: #989898;
  font-family: "SF Pro Text", "PingFang SC", -apple-system, BlinkMacSystemFont, sans-serif;
  font-size: 24rpx;
  line-height: 1.68;
  font-weight: 400;
  letter-spacing: 0.01em;
}

.item-divider {
  margin-top: 36rpx;
  margin-left: 0;
  width: 100%;
  height: 1rpx;
  transform: scaleY(0.6);
  transform-origin: center bottom;
  background: #e9e9e9;
}

.footer-space {
  height: 118rpx;
}
