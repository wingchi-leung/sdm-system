.page {
  min-height: 100vh;
  padding: 24rpx 32rpx 48rpx;
  background: var(--background);
}

.nav-actions {
  margin-bottom: 16rpx;
  text-align: right;
}

.btn-text {
  display: inline-block;
  padding: 16rpx 24rpx;
  font-size: 28rpx;
  color: var(--primary);
  background: none;
  border: none;
}

.btn-text::after {
  border: none;
}

.loading-wrap, .error-wrap, .empty-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 32rpx;
}

.loading {
  width: 64rpx;
  height: 64rpx;
  border: 4rpx solid var(--primary-light);
  border-top-color: var(--primary);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-tip {
  margin-top: 24rpx;
  font-size: 28rpx;
  color: var(--text-secondary);
}

.error-title, .empty-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.error-msg, .empty-tip {
  margin-top: 16rpx;
  font-size: 26rpx;
  color: var(--text-secondary);
  text-align: center;
}

.retry-btn {
  margin-top: 40rpx;
  padding: 24rpx 48rpx;
  font-size: 30rpx;
}

.empty-wrap .btn-text {
  margin-top: 32rpx;
}

.activity-item {
  display: flex;
  align-items: center;
  padding: 32rpx;
  margin-bottom: 24rpx;
  background: var(--surface);
  border-radius: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.04);
}

.activity-icon {
  width: 96rpx;
  height: 96rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin-right: 28rpx;
}

.icon-text {
  font-size: 26rpx;
  color: inherit;
}

.activity-body {
  flex: 1;
  min-width: 0;
}

.activity-name {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 16rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.activity-time {
  display: block;
  font-size: 26rpx;
  color: var(--text-secondary);
  margin-bottom: 16rpx;
}

.activity-body .tag {
  display: inline-block;
}

.arrow {
  font-size: 40rpx;
  color: var(--text-tertiary);
  margin-left: 16rpx;
}
