/**
 * 首页 - 极简奢华风格
 */

.page {
  min-height: 100vh;
  padding: var(--space-2xl) var(--space-lg);
  background: var(--background);
  box-sizing: border-box;
}

/* ─────────────────────────────────────────────────────────────
 * 顶部标题区域
 * ───────────────────────────────────────────────────────────── */
.header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: var(--space-2xl);
  padding: 0 var(--space-xs);
}

.header-content {
  display: flex;
  flex-direction: column;
  gap: var(--space-xs);
}

.header-title {
  font-family: var(--font-display);
  font-size: 72rpx;
  font-weight: 300;
  color: var(--text-primary);
  letter-spacing: 0.08em;
  line-height: 1;
}

.header-subtitle {
  font-size: 24rpx;
  color: var(--text-tertiary);
  letter-spacing: 0.12em;
  font-weight: 400;
  margin-top: var(--space-sm);
}

.header-action {
  flex-shrink: 0;
}

.btn-publish {
  width: 88rpx !important;
  height: 88rpx !important;
  min-height: 88rpx;
  padding: 0 !important;
  margin: 0;
  background: linear-gradient(135deg, var(--accent) 0%, var(--accent-dark) 100%);
  border-radius: var(--radius-md);
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(201, 169, 97, 0.25);
  transition: all 0.5s cubic-bezier(0.23, 1, 0.32, 1);
}

.btn-publish::after {
  border: none;
  display: none;
}

.btn-publish:active {
  transform: translateY(2rpx);
  box-shadow: 0 4rpx 12rpx rgba(201, 169, 97, 0.2);
}

.publish-icon {
  font-size: 48rpx;
  color: #FFFFFF;
  font-weight: 200;
  line-height: 1;
}

/* ─────────────────────────────────────────────────────────────
 * 状态页面
 * ───────────────────────────────────────────────────────────── */
.state-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 32rpx;
  min-height: 60vh;
}

.loading {
  width: 44rpx;
  height: 44rpx;
  border: 2rpx solid var(--border);
  border-top-color: var(--primary);
  border-radius: 50%;
  animation: spin 0.8s cubic-bezier(0.4, 0, 0.2, 1) infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.state-wrap.error .state-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: #fff2f0;
  color: #ff4d4f;
  font-size: 36rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 24rpx;
}

.state-title {
  font-size: 32rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 8rpx;
}

.state-text {
  font-size: 26rpx;
  color: #999;
  text-align: center;
  margin-top: 8rpx;
}

.btn-retry {
  margin-top: 32rpx;
  padding: 20rpx 56rpx;
  background: #2C5545;
  color: #FFFFFF;
  font-size: 26rpx;
  font-weight: 500;
  border-radius: 8rpx;
  border: none;
}

.btn-retry::after {
  border: none;
}

.btn-text {
  margin-top: 24rpx;
  padding: 16rpx 40rpx;
  background: transparent;
  color: #2C5545;
  font-size: 26rpx;
  border: none;
}

.btn-text::after {
  border: none;
}

/* ─────────────────────────────────────────────────────────────
 * 空状态插画
 * ───────────────────────────────────────────────────────────── */
.empty-illustration {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 24rpx;
}

.empty-circle {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: #eee;
  margin-bottom: 16rpx;
}

.empty-line {
  width: 140rpx;
  height: 4rpx;
  background: #ddd;
  margin-bottom: 12rpx;
}

.empty-line.short {
  width: 100rpx;
}

/* ─────────────────────────────────────────────────────────────
 * 活动卡片 - 精致大图样式
 * ───────────────────────────────────────────────────────────── */
.list {
  display: flex;
  flex-direction: column;
  gap: var(--space-xl);
}

.activity-item {
  background: var(--background-card);
  border-radius: var(--radius-xl);
  overflow: hidden;
  box-shadow: var(--shadow-md);
  border: 1px solid var(--border-light);
  transition: all 0.5s cubic-bezier(0.23, 1, 0.32, 1);
}

.activity-item:active {
  transform: translateY(4rpx);
  box-shadow: var(--shadow-sm);
}

/* 海报区域 */
.poster-wrap {
  width: 100%;
  height: 480rpx;
  background: linear-gradient(135deg, var(--background-subtle) 0%, var(--background-warm) 100%);
  position: relative;
  overflow: hidden;
}

.poster-img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform 0.6s cubic-bezier(0.23, 1, 0.32, 1);
}

.activity-item:active .poster-img {
  transform: scale(1.02);
}

.no-poster {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--text-muted);
  font-size: 26rpx;
  letter-spacing: 0.08em;
}

/* 状态标签 - 浮动在海报上 */
.status-tag {
  position: absolute;
  top: var(--space-md);
  right: var(--space-md);
  font-size: 20rpx;
  font-weight: 500;
  padding: 12rpx 24rpx;
  border-radius: var(--radius-sm);
  backdrop-filter: blur(40rpx);
  letter-spacing: 0.08em;
  text-transform: uppercase;
}

.status-tag.status-1 {
  color: var(--info);
  background: rgba(255, 255, 255, 0.95);
  box-shadow: 0 4rpx 12rpx rgba(107, 140, 175, 0.15);
}

.status-tag.status-2 {
  color: var(--success);
  background: rgba(255, 255, 255, 0.95);
  box-shadow: 0 4rpx 12rpx rgba(91, 140, 125, 0.15);
}

.status-tag.status-3 {
  color: var(--text-tertiary);
  background: rgba(255, 255, 255, 0.95);
  box-shadow: 0 4rpx 12rpx rgba(155, 155, 155, 0.15);
}

/* 内容区 */
.item-content {
  padding: var(--space-lg) var(--space-xl);
}

.item-name {
  font-size: 38rpx;
  font-weight: 500;
  color: var(--text-primary);
  line-height: 1.4;
  margin-bottom: var(--space-md);
  letter-spacing: 0.02em;
}

.item-info {
  display: flex;
  flex-direction: column;
  gap: var(--space-xs);
}

.info-text {
  font-size: 24rpx;
  color: var(--text-secondary);
  letter-spacing: 0.04em;
}

/* ─────────────────────────────────────────────────────────────
 * 底部留白
 * ───────────────────────────────────────────────────────────── */
.footer-space {
  height: 48rpx;
}