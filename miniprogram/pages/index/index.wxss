/**
 * 首页 - 活动列表
 * 设计风格：Bold Minimal
 * 核心亮点：超大号日期 + 左侧彩色指示条
 */

.page {
  min-height: 100vh;
  padding: var(--space-xl) var(--space-lg);
  background: var(--bg-secondary);
}

/* ─────────────────────────────────────────────────────────────
 * 顶部标题区域
 * ───────────────────────────────────────────────────────────── */
.header {
  margin-bottom: var(--space-2xl);
  padding-bottom: var(--space-lg);
}

.header-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: var(--space-sm);
}

.header-left {
  display: flex;
  align-items: center;
  gap: var(--space-sm);
}

.header-title {
  font-family: var(--font-display);
  font-size: 64rpx;
  font-weight: 700;
  color: var(--text-primary);
  letter-spacing: -0.03em;
  line-height: 1;
}

.header-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: var(--accent);
  animation: pulse 2s ease-in-out infinite;
}

.header-subtitle {
  font-size: 26rpx;
  color: var(--text-tertiary);
  letter-spacing: 0.01em;
}

/* 发布按钮 */
.btn-publish {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: var(--accent);
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: var(--shadow-accent);
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}

.btn-publish::after {
  border: none;
}

.btn-publish:active {
  transform: scale(0.92);
  box-shadow: var(--shadow-sm);
}

.publish-icon {
  font-size: 40rpx;
  color: #FFFFFF;
  font-weight: 300;
  line-height: 1;
}

/* ─────────────────────────────────────────────────────────────
 * 状态展示
 * ───────────────────────────────────────────────────────────── */
.state-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 60vh;
}

.state-text {
  font-size: 26rpx;
  color: var(--text-tertiary);
  margin-top: var(--space-md);
}

.state-title {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--text-primary);
  margin-top: var(--space-lg);
  letter-spacing: -0.01em;
}

.state-desc {
  font-size: 26rpx;
  color: var(--text-tertiary);
  margin-top: var(--space-sm);
}

/* 错误状态 */
.error-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: var(--error-bg);
  display: flex;
  align-items: center;
  justify-content: center;
}

.error-icon text {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--error);
}

.btn-retry {
  margin-top: var(--space-xl);
  padding: 20rpx 48rpx;
  background: var(--accent);
  color: #FFFFFF;
  font-size: 28rpx;
  font-weight: 600;
  border-radius: var(--radius-full);
  border: none;
  box-shadow: var(--shadow-accent);
}

.btn-retry::after {
  border: none;
}

/* 空状态图形 */
.empty-graphic {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: var(--space-sm);
}

.empty-circle {
  width: 80rpx;
  height: 80rpx;
  border: 4rpx solid var(--border-strong);
  border-radius: 50%;
}

.empty-line {
  width: 120rpx;
  height: 4rpx;
  background: var(--border-strong);
  border-radius: 2rpx;
}

/* ─────────────────────────────────────────────────────────────
 * 活动卡片 - 大胆设计
 * ───────────────────────────────────────────────────────────── */
.activity-list {
  display: flex;
  flex-direction: column;
  gap: var(--space-md);
}

.activity-card {
  position: relative;
  display: flex;
  align-items: center;
  background: var(--bg-card);
  border-radius: var(--radius-xl);
  padding: var(--space-lg);
  padding-left: var(--space-xl);
  box-shadow: var(--shadow-md);
  overflow: hidden;
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  opacity: 0;
}

.activity-card:active {
  transform: translateY(4rpx);
  box-shadow: var(--shadow-sm);
}

/* 左侧状态指示条 */
.card-indicator {
  position: absolute;
  left: 0;
  top: 24rpx;
  bottom: 24rpx;
  width: 6rpx;
  border-radius: 0 3rpx 3rpx 0;
  transition: all 0.3s ease;
}

.card-indicator.pending {
  background: var(--status-pending);
}

.card-indicator.active {
  background: var(--accent);
}

.card-indicator.ended {
  background: var(--text-primary);
}

/* 日期区块 - 戏剧性设计 */
.date-block {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-width: 100rpx;
  margin-right: var(--space-lg);
  padding-right: var(--space-lg);
  border-right: 2rpx solid var(--border);
}

.date-day {
  font-family: var(--font-display);
  font-size: 56rpx;
  font-weight: 800;
  color: var(--text-primary);
  letter-spacing: -0.04em;
  line-height: 1;
}

.date-month {
  font-size: 22rpx;
  font-weight: 600;
  color: var(--text-tertiary);
  letter-spacing: 0.08em;
  text-transform: uppercase;
  margin-top: 4rpx;
}

/* 卡片内容 */
.card-content {
  flex: 1;
  min-width: 0;
}

.card-header {
  display: flex;
  align-items: center;
  gap: var(--space-sm);
  margin-bottom: var(--space-xs);
}

.card-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
  letter-spacing: -0.01em;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  flex: 1;
}

/* 状态点 */
.status-dot {
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  flex-shrink: 0;
}

.status-dot.pending {
  background: var(--status-pending);
}

.status-dot.active {
  background: var(--accent);
  box-shadow: 0 0 8rpx var(--accent-glow);
}

.status-dot.ended {
  background: var(--text-primary);
}

.card-time {
  display: block;
  font-size: 24rpx;
  color: var(--text-tertiary);
  letter-spacing: 0.01em;
  margin-bottom: var(--space-xs);
}

/* 状态文字 */
.status-text {
  display: inline-block;
  font-size: 22rpx;
  font-weight: 600;
  letter-spacing: 0.04em;
  padding: 6rpx 14rpx;
  border-radius: var(--radius-sm);
}

.status-text.pending {
  background: var(--status-pending-bg);
  color: var(--status-pending);
}

.status-text.active {
  background: var(--status-active-bg);
  color: var(--status-active);
}

.status-text.ended {
  background: var(--status-ended-bg);
  color: var(--status-ended);
}

/* 箭头 */
.card-arrow {
  flex-shrink: 0;
  margin-left: var(--space-md);
  opacity: 0.3;
  transition: all 0.3s ease;
}

.card-arrow text {
  font-size: 28rpx;
  font-weight: 300;
  color: var(--text-primary);
}

.activity-card:active .card-arrow {
  opacity: 0.6;
  transform: translateX(8rpx);
}

/* ─────────────────────────────────────────────────────────────
 * 底部装饰
 * ───────────────────────────────────────────────────────────── */
.footer-deco {
  display: flex;
  justify-content: center;
  padding: var(--space-2xl) 0;
}

.deco-line {
  width: 48rpx;
  height: 6rpx;
  background: var(--border-strong);
  border-radius: 3rpx;
}