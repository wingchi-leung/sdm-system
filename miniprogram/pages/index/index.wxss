/**
 * 首页 - 活动列表 - 单列大卡片样式
 */

.page {
  min-height: 100vh;
  padding: 24rpx;
  padding-top: 32rpx;
  background: #f5f5f5;
  box-sizing: border-box;
}

/* ─────────────────────────────────────────────────────────────
 * 顶部标题区域
 * ───────────────────────────────────────────────────────────── */
.header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 24rpx;
  padding: 0 4rpx;
}

.header-content {
  display: flex;
  flex-direction: column;
}

.header-title {
  font-size: 44rpx;
  font-weight: 600;
  color: #333;
  letter-spacing: 0.04em;
  line-height: 1.2;
}

.header-subtitle {
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
  letter-spacing: 0.08em;
}

.header-action {
  flex-shrink: 0;
}

.btn-publish {
  width: 64rpx !important;
  height: 64rpx !important;
  min-height: 64rpx;
  padding: 0 !important;
  margin: 0;
  line-height: 64rpx;
  background: #2C5545;
  border-radius: 12rpx;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn-publish::after {
  border: none;
  display: none;
}

.btn-publish:active {
  opacity: 0.8;
}

.publish-icon {
  font-size: 40rpx;
  color: #FFFFFF;
  font-weight: 300;
  line-height: 1;
}

/* ─────────────────────────────────────────────────────────────
 * 状态页面
 * ───────────────────────────────────────────────────────────── */
.state-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 24rpx;
  min-height: 60vh;
}

.loading {
  width: 40rpx;
  height: 40rpx;
  border: 3rpx solid #ddd;
  border-top-color: #2C5545;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.state-wrap.error .state-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: #fff2f0;
  color: #ff4d4f;
  font-size: 36rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 24rpx;
}

.state-title {
  font-size: 32rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 8rpx;
}

.state-text {
  font-size: 26rpx;
  color: #999;
  text-align: center;
  margin-top: 8rpx;
}

.btn-retry {
  margin-top: 32rpx;
  padding: 20rpx 56rpx;
  background: #2C5545;
  color: #FFFFFF;
  font-size: 26rpx;
  font-weight: 500;
  border-radius: 8rpx;
  border: none;
}

.btn-retry::after {
  border: none;
}

.btn-text {
  margin-top: 24rpx;
  padding: 16rpx 40rpx;
  background: transparent;
  color: #2C5545;
  font-size: 26rpx;
  border: none;
}

.btn-text::after {
  border: none;
}

/* ─────────────────────────────────────────────────────────────
 * 空状态插画
 * ───────────────────────────────────────────────────────────── */
.empty-illustration {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 24rpx;
}

.empty-circle {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: #eee;
  margin-bottom: 16rpx;
}

.empty-line {
  width: 140rpx;
  height: 4rpx;
  background: #ddd;
  margin-bottom: 12rpx;
}

.empty-line.short {
  width: 100rpx;
}

/* ─────────────────────────────────────────────────────────────
 * 活动卡片 - 海报大图样式
 * ───────────────────────────────────────────────────────────── */
.list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.activity-item {
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
}

.activity-item:active {
  opacity: 0.9;
}

/* 海报区域 */
.poster-wrap {
  width: 100%;
  height: 400rpx;
  background: #f0f0f0;
  position: relative;
}

.poster-img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.no-poster {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #bbb;
  font-size: 28rpx;
}

/* 状态标签 - 浮动在海报上 */
.status-tag {
  position: absolute;
  top: 16rpx;
  right: 16rpx;
  font-size: 24rpx;
  font-weight: 500;
  padding: 8rpx 16rpx;
  border-radius: 8rpx;
}

.status-tag.status-1 {
  color: #1890ff;
  background: #e6f7ff;
}

.status-tag.status-2 {
  color: #52c41a;
  background: #f6ffed;
}

.status-tag.status-3 {
  color: #8c8c8c;
  background: #f5f5f5;
}

/* 内容区 */
.item-content {
  padding: 20rpx 24rpx;
}

.item-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  line-height: 1.4;
  margin-bottom: 12rpx;
}

.item-info {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.info-text {
  font-size: 26rpx;
  color: #666;
}

/* ─────────────────────────────────────────────────────────────
 * 底部留白
 * ───────────────────────────────────────────────────────────── */
.footer-space {
  height: 48rpx;
}