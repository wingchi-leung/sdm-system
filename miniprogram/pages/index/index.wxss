/**
 * 首页 - 奢华简约风格
 */

.page {
  min-height: 100vh;
  padding: 48rpx 32rpx;
  background: var(--background);
  box-sizing: border-box;
}

/* ─────────────────────────────────────────────────────────────
 * 顶部标题区域
 * ───────────────────────────────────────────────────────────── */
.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 48rpx;
  padding: 0 8rpx;
}

.header-content {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.header-title {
  font-family: var(--font-display);
  font-size: 56rpx;
  font-weight: 600;
  color: var(--text-primary);
  letter-spacing: -0.02em;
  line-height: 1.1;
}

.header-subtitle {
  font-size: 26rpx;
  color: var(--text-tertiary);
  letter-spacing: 0.02em;
  font-weight: 400;
}

.header-action {
  flex-shrink: 0;
}

.btn-publish {
  width: 72rpx !important;
  height: 72rpx !important;
  min-height: 72rpx;
  padding: 0 !important;
  margin: 0;
  background: var(--primary);
  border-radius: 50%;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.15);
  transition: all 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94);
}

.btn-publish::after {
  border: none;
  display: none;
}

.btn-publish:active {
  transform: scale(0.92);
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.publish-icon {
  font-size: 44rpx;
  color: #FFFFFF;
  font-weight: 300;
  line-height: 1;
}

/* ─────────────────────────────────────────────────────────────
 * 状态页面
 * ───────────────────────────────────────────────────────────── */
.state-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 32rpx;
  min-height: 60vh;
}

.loading {
  width: 44rpx;
  height: 44rpx;
  border: 2rpx solid var(--border);
  border-top-color: var(--primary);
  border-radius: 50%;
  animation: spin 0.8s cubic-bezier(0.4, 0, 0.2, 1) infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.state-wrap.error .state-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: #fff2f0;
  color: #ff4d4f;
  font-size: 36rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 24rpx;
}

.state-title {
  font-size: 32rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 8rpx;
}

.state-text {
  font-size: 26rpx;
  color: #999;
  text-align: center;
  margin-top: 8rpx;
}

.btn-retry {
  margin-top: 32rpx;
  padding: 20rpx 56rpx;
  background: #2C5545;
  color: #FFFFFF;
  font-size: 26rpx;
  font-weight: 500;
  border-radius: 8rpx;
  border: none;
}

.btn-retry::after {
  border: none;
}

.btn-text {
  margin-top: 24rpx;
  padding: 16rpx 40rpx;
  background: transparent;
  color: #2C5545;
  font-size: 26rpx;
  border: none;
}

.btn-text::after {
  border: none;
}

/* ─────────────────────────────────────────────────────────────
 * 空状态插画
 * ───────────────────────────────────────────────────────────── */
.empty-illustration {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 24rpx;
}

.empty-circle {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: #eee;
  margin-bottom: 16rpx;
}

.empty-line {
  width: 140rpx;
  height: 4rpx;
  background: #ddd;
  margin-bottom: 12rpx;
}

.empty-line.short {
  width: 100rpx;
}

/* ─────────────────────────────────────────────────────────────
 * 活动卡片 - 奢华大图样式
 * ───────────────────────────────────────────────────────────── */
.list {
  display: flex;
  flex-direction: column;
  gap: 32rpx;
}

.activity-item {
  background: var(--background-card);
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 16rpx rgba(0, 0, 0, 0.06);
  border: 0.5px solid var(--border-light);
  transition: all 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94);
}

.activity-item:active {
  transform: scale(0.98);
  box-shadow: 0 1rpx 8rpx rgba(0, 0, 0, 0.04);
}

/* 海报区域 */
.poster-wrap {
  width: 100%;
  height: 420rpx;
  background: var(--background-subtle);
  position: relative;
  overflow: hidden;
}

.poster-img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.no-poster {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--text-muted);
  font-size: 28rpx;
  letter-spacing: 0.02em;
}

/* 状态标签 - 浮动在海报上 */
.status-tag {
  position: absolute;
  top: 20rpx;
  right: 20rpx;
  font-size: 22rpx;
  font-weight: 500;
  padding: 10rpx 20rpx;
  border-radius: 980rpx;
  backdrop-filter: blur(20rpx);
  letter-spacing: 0.02em;
}

.status-tag.status-1 {
  color: var(--info);
  background: rgba(255, 255, 255, 0.92);
}

.status-tag.status-2 {
  color: var(--success);
  background: rgba(255, 255, 255, 0.92);
}

.status-tag.status-3 {
  color: var(--text-tertiary);
  background: rgba(255, 255, 255, 0.92);
}

/* 内容区 */
.item-content {
  padding: 28rpx 32rpx 32rpx;
}

.item-name {
  font-size: 36rpx;
  font-weight: 600;
  color: var(--text-primary);
  line-height: 1.3;
  margin-bottom: 16rpx;
  letter-spacing: -0.01em;
}

.item-info {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.info-text {
  font-size: 26rpx;
  color: var(--text-secondary);
  letter-spacing: 0;
}

/* ─────────────────────────────────────────────────────────────
 * 底部留白
 * ───────────────────────────────────────────────────────────── */
.footer-space {
  height: 48rpx;
}