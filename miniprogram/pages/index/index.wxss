.page {
  min-height: 100vh;
  background: #ffffff;
  box-sizing: border-box;
  font-family: "PingFang SC", "SF Pro Text", -apple-system, BlinkMacSystemFont, sans-serif;
}

.hero {
  padding: 14rpx 40rpx 18rpx;
}

.hero-top {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  min-height: 52rpx;
}

.hero-action {
  position: relative;
  width: 76rpx;
  height: 76rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.hero-bell {
  width: 50rpx;
  height: 40rpx;
  display: block;
}

.hero-action-badge {
  position: absolute;
  top: 2rpx;
  right: 4rpx;
  min-width: 30rpx;
  height: 30rpx;
  padding: 0 7rpx;
  border-radius: 999rpx;
  background: #111111;
  display: flex;
  align-items: center;
  justify-content: center;
}

.hero-action-badge-text {
  color: #ffffff;
  font-size: 18rpx;
  line-height: 1;
  font-weight: 500;
}

.hero-copy {
  margin-top: 24rpx;
  display: flex;
  flex-direction: column;
  align-items: flex-start;
}

.hero-title {
  color: #111111;
  font-family: "Songti SC", "STSong", "Times New Roman", serif;
  font-size: 78rpx;
  line-height: 1.18;
  font-weight: 500;
  letter-spacing: 0.02em;
}

.hero-subtitle {
  margin-top: 18rpx;
  color: #8d8d8d;
  font-family: "Times New Roman", Georgia, serif;
  font-size: 26rpx;
  line-height: 1.5;
  letter-spacing: 0.04em;
}

.hero-rule {
  width: 70rpx;
  height: 4rpx;
  margin-top: 20rpx;
  background: #355cc7;
  border-radius: 999rpx;
}

.hero-date {
  display: block;
  margin-top: 22rpx;
  color: #111111;
  font-family: "Times New Roman", "PingFang SC", serif;
  font-size: 30rpx;
  line-height: 1.4;
  letter-spacing: 0.03em;
}

.state-wrap {
  min-height: 48vh;
  padding: 120rpx 56rpx 120rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.state-wrap.error .state-icon {
  width: 72rpx;
  height: 72rpx;
  margin-bottom: 28rpx;
  background: rgba(178, 65, 55, 0.06);
  border-radius: 50%;
  color: var(--error);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 34rpx;
}

.state-title {
  margin-top: 10rpx;
  font-size: 32rpx;
  line-height: 1.4;
  font-weight: 500;
  color: #222222;
}

.state-text {
  margin-top: 16rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: #9a9a9a;
  text-align: center;
}

.empty-image {
  width: 220rpx;
  height: 260rpx;
  margin-bottom: 20rpx;
}

.btn-retry,
.btn-text {
  margin-top: 34rpx;
  padding: 18rpx 52rpx;
  border: 0;
  border-radius: 999rpx;
  background: #f1f1f1;
  color: #5c5c5c;
  font-size: 26rpx;
  font-weight: 500;
}

.btn-retry::after,
.btn-text::after {
  border: 0;
}

.list-shell {
  padding: 0 40rpx;
}

.section-header {
  padding: 6rpx 0 14rpx;
}

.section-title {
  color: #111111;
  font-family: "PingFang SC", "Times New Roman", serif;
  font-size: 32rpx;
  line-height: 1.4;
  font-weight: 500;
  letter-spacing: 0.02em;
}

.activity-list {
  border-top: 1rpx solid #ededed;
}

.activity-card {
  display: flex;
  align-items: flex-start;
  padding: 34rpx 0 36rpx;
  border-bottom: 1rpx solid #ededed;
}

.activity-card:active {
  opacity: 0.74;
}

.activity-cover {
  width: 288rpx;
  height: 288rpx;
  min-width: 288rpx;
  border-radius: 18rpx;
  overflow: hidden;
  background: #f2f2f2;
}

.activity-cover-image {
  width: 100%;
  height: 100%;
  display: block;
}

.activity-cover-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(180deg, #f5f5f5 0%, #ececec 100%);
}

.activity-cover-placeholder-text {
  color: #b0b0b0;
  font-family: "Times New Roman", serif;
  font-size: 30rpx;
  letter-spacing: 0.16em;
}

.activity-content {
  flex: 1;
  min-width: 0;
  padding-left: 32rpx;
  display: flex;
  flex-direction: column;
  padding-top: 8rpx;
}

.activity-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
}

.activity-title-text {
  flex: 1;
  color: #111111;
  font-family: "PingFang SC", "Songti SC", serif;
  font-size: 38rpx;
  line-height: 1.28;
  font-weight: 500;
  letter-spacing: 0.01em;
}

.activity-arrow {
  flex-shrink: 0;
  color: #111111;
  font-size: 52rpx;
  line-height: 1;
  font-weight: 300;
  margin-top: -4rpx;
}

.activity-summary {
  display: block;
  margin-top: 16rpx;
  color: #5b5b5b;
  font-size: 24rpx;
  line-height: 1.65;
  letter-spacing: 0.02em;
}

.activity-summary.muted {
  color: #8e8e8e;
}

.activity-meta {
  margin-top: 28rpx;
  display: flex;
  flex-wrap: wrap;
  align-items: center;
}

.activity-meta-text {
  margin-right: 20rpx;
  color: #6d6d6d;
  font-size: 24rpx;
  line-height: 1.55;
  letter-spacing: 0.02em;
}

.footer-space {
  height: 132rpx;
}
