/**
 * 活动列表页
 */

.page {
  min-height: 100vh;
  padding: var(--space-lg);
  background: var(--background);
}

/* 导航 */
.nav-actions {
  margin-bottom: var(--space-md);
  text-align: right;
}

/* 状态展示 */
.loading-wrap,
.error-wrap,
.empty-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: var(--space-xl) var(--space-lg);
  min-height: 50vh;
}

.loading-tip {
  margin-top: var(--space-md);
  font-size: 28rpx;
  color: var(--text-secondary);
}

.error-title,
.empty-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: var(--space-sm);
}

.error-msg,
.empty-tip {
  font-size: 28rpx;
  color: var(--text-secondary);
  text-align: center;
  margin-top: var(--space-sm);
}

.retry-btn {
  margin-top: var(--space-lg);
}

/* 活动卡片 - 简洁设计 */
.activity-item {
  display: flex;
  align-items: center;
  padding: var(--space-lg);
  margin-bottom: var(--space-md);
  background: var(--background-card);
  border-radius: 12rpx;
  box-shadow: var(--shadow);
  border: 1px solid var(--border);
}

.activity-item:active {
  background: var(--background-input);
}

/* 日期方块 */
.activity-icon {
  width: 88rpx;
  height: 88rpx;
  border-radius: 8rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: var(--background-input);
  margin-right: var(--space-md);
  flex-shrink: 0;
}

.icon-date {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--primary);
  line-height: 1;
}

.icon-month {
  font-size: 20rpx;
  color: var(--text-tertiary);
  margin-top: 4rpx;
}

/* 活动信息 */
.activity-body {
  flex: 1;
  min-width: 0;
}

.activity-name {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.activity-time {
  font-size: 24rpx;
  color: var(--text-secondary);
  margin-bottom: 8rpx;
}

.activity-body .tag {
  font-size: 22rpx;
  padding: 4rpx 10rpx;
}

/* 箭头 */
.arrow {
  font-size: 32rpx;
  color: var(--text-tertiary);
  margin-left: var(--space-sm);
}
