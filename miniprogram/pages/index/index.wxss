/**
 * 首页 - 清爽现代风格
 */

.page {
  min-height: 100vh;
  padding: var(--space-xl) 0;
  background: #FFFFFF;
  box-sizing: border-box;
}

/* ─────────────────────────────────────────────────────────────
 * 顶部标题区域
 * ───────────────────────────────────────────────────────────── */
.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: var(--space-xl);
  padding: 0 var(--space-lg);
}

.header-content {
  display: flex;
  flex-direction: column;
  gap: var(--space-xs);
}

.header-title {
  font-family: var(--font-display);
  font-size: 56rpx;
  font-weight: 600;
  color: #000000;
  letter-spacing: 0;
  line-height: 1;
}

.header-subtitle {
  font-size: 28rpx;
  color: #999999;
  letter-spacing: 0;
  font-weight: 400;
  margin-top: 8rpx;
}

.header-action {
  flex-shrink: 0;
}

.btn-publish {
  width: 80rpx !important;
  height: 80rpx !important;
  min-height: 80rpx;
  padding: 0 !important;
  margin: 0;
  background: #000000;
  border-radius: 50%;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.2s ease;
}

.btn-publish::after {
  border: none;
  display: none;
}

.btn-publish:active {
  opacity: 0.8;
  transform: scale(0.95);
}

.publish-icon {
  font-size: 40rpx;
  color: #FFFFFF;
  font-weight: 300;
  line-height: 1;
}

/* ─────────────────────────────────────────────────────────────
 * 状态页面
 * ───────────────────────────────────────────────────────────── */
.state-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 32rpx;
  min-height: 60vh;
}

.loading {
  width: 40rpx;
  height: 40rpx;
  border: 2rpx solid #F0F0F0;
  border-top-color: #000000;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.state-title {
  font-size: 32rpx;
  font-weight: 500;
  color: #000000;
  margin-bottom: 8rpx;
}

.state-text {
  font-size: 26rpx;
  color: #999999;
  text-align: center;
  margin-top: 8rpx;
}

.btn-retry {
  margin-top: 32rpx;
  padding: 20rpx 56rpx;
  background: #000000;
  color: #FFFFFF;
  font-size: 28rpx;
  font-weight: 500;
  border-radius: 48rpx;
  border: none;
}

.btn-retry::after {
  border: none;
}

.btn-text {
  margin-top: 24rpx;
  padding: 16rpx 40rpx;
  background: transparent;
  color: #666666;
  font-size: 28rpx;
  border: none;
}

.btn-text::after {
  border: none;
}

/* ─────────────────────────────────────────────────────────────
 * 底部留白
 * ───────────────────────────────────────────────────────────── */
.footer-space {
  height: 48rpx;
}

.state-wrap.error .state-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: #fff2f0;
  color: #ff4d4f;
  font-size: 36rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 24rpx;
}

.state-title {
  font-size: 32rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 8rpx;
}

.state-text {
  font-size: 26rpx;
  color: #999;
  text-align: center;
  margin-top: 8rpx;
}

.btn-retry {
  margin-top: 32rpx;
  padding: 20rpx 56rpx;
  background: #2C5545;
  color: #FFFFFF;
  font-size: 26rpx;
  font-weight: 500;
  border-radius: 8rpx;
  border: none;
}

.btn-retry::after {
  border: none;
}

.btn-text {
  margin-top: 24rpx;
  padding: 16rpx 40rpx;
  background: transparent;
  color: #2C5545;
  font-size: 26rpx;
  border: none;
}

.btn-text::after {
  border: none;
}

/* ─────────────────────────────────────────────────────────────
 * 空状态插画
 * ───────────────────────────────────────────────────────────── */
.empty-illustration {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 24rpx;
}

.empty-circle {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: #eee;
  margin-bottom: 16rpx;
}

.empty-line {
  width: 140rpx;
  height: 4rpx;
  background: #ddd;
  margin-bottom: 12rpx;
}

.empty-line.short {
  width: 100rpx;
}

/* ─────────────────────────────────────────────────────────────
 * 活动卡片 - 横向布局
 * ───────────────────────────────────────────────────────────── */
.list {
  display: flex;
  flex-direction: column;
}

.activity-item {
  display: flex;
  gap: 24rpx;
  padding: var(--space-lg);
  background: #FFFFFF;
  border-bottom: 1px solid #F0F0F0;
  transition: background 0.2s ease;
}

.activity-item:active {
  background: #FAFAFA;
}

/* 海报区域 - 左侧小方块 */
.poster-wrap {
  width: 220rpx;
  height: 220rpx;
  flex-shrink: 0;
  background: #F5F5F5;
  border-radius: 12rpx;
  overflow: hidden;
  position: relative;
}

.poster-img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.no-poster {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #CCCCCC;
  font-size: 24rpx;
}

/* 状态标签 - 右上角小标签 */
.status-tag {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  font-size: 20rpx;
  font-weight: 500;
  padding: 6rpx 12rpx;
  border-radius: 6rpx;
  background: rgba(255, 255, 255, 0.95);
  color: #666666;
}

.status-tag.status-1 {
  color: #1890FF;
}

.status-tag.status-2 {
  color: #52C41A;
}

.status-tag.status-3 {
  color: #999999;
}

/* 内容区 - 右侧 */
.item-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  padding: 8rpx 0;
}

.item-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #000000;
  line-height: 1.4;
  margin-bottom: 12rpx;
  letter-spacing: 0;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.item-info {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.info-text {
  font-size: 26rpx;
  color: #999999;
  letter-spacing: 0;
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.info-text::before {
  content: '🕐';
  font-size: 24rpx;
}

/* ─────────────────────────────────────────────────────────────
 * 底部留白
 * ───────────────────────────────────────────────────────────── */
.footer-space {
  height: 48rpx;
}