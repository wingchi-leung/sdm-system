/**
 * 首页 - 活动列表
 * 设计风格：高级简约
 */

.page {
  min-height: 100vh;
  padding: 0 var(--space-lg);
  padding-top: var(--space-xl);
  background: var(--background);
}

/* ─────────────────────────────────────────────────────────────
 * 顶部标题区域
 * ───────────────────────────────────────────────────────────── */
.header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: var(--space-2xl);
  padding: 0 var(--space-xs);
}

.header-content {
  display: flex;
  flex-direction: column;
}

.header-title {
  font-family: var(--font-display);
  font-size: 56rpx;
  font-weight: 600;
  color: var(--text-primary);
  letter-spacing: -0.02em;
  line-height: 1.2;
}

.header-subtitle {
  font-size: 26rpx;
  color: var(--text-tertiary);
  margin-top: var(--space-xs);
  letter-spacing: 0.02em;
}

.header-action {
  flex-shrink: 0;
}

.btn-publish {
  display: flex;
  align-items: center;
  gap: var(--space-xs);
  padding: 16rpx 24rpx;
  background: var(--primary);
  border-radius: var(--radius-full);
  border: none;
  box-shadow: var(--shadow-sm);
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}

.btn-publish::after {
  border: none;
}

.btn-publish:active {
  transform: scale(0.95);
  box-shadow: var(--shadow-xs);
}

.publish-icon {
  font-size: 32rpx;
  color: #FFFFFF;
  font-weight: 300;
  line-height: 1;
}

.publish-text {
  font-size: 26rpx;
  color: #FFFFFF;
  font-weight: 500;
  letter-spacing: 0.04em;
}

/* ─────────────────────────────────────────────────────────────
 * 状态页面
 * ───────────────────────────────────────────────────────────── */
.state-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: var(--space-3xl) var(--space-lg);
  min-height: 60vh;
}

.state-wrap.error .state-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: var(--error-bg);
  color: var(--error);
  font-size: 40rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: var(--space-lg);
}

.state-title {
  font-size: 34rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: var(--space-sm);
  letter-spacing: 0.02em;
}

.state-text {
  font-size: 26rpx;
  color: var(--text-tertiary);
  text-align: center;
  margin-top: var(--space-sm);
}

.btn-retry {
  margin-top: var(--space-xl);
  padding: 20rpx 48rpx;
  background: var(--primary);
  color: #FFFFFF;
  font-size: 28rpx;
  font-weight: 500;
  border-radius: var(--radius-full);
  border: none;
  box-shadow: var(--shadow-sm);
  transition: all 0.3s ease;
}

.btn-retry::after {
  border: none;
}

.btn-retry:active {
  transform: scale(0.98);
}

/* ─────────────────────────────────────────────────────────────
 * 空状态插画
 * ───────────────────────────────────────────────────────────── */
.empty-illustration {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: var(--space-xl);
}

.empty-circle {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  background: var(--background-warm);
  border: 2px solid var(--border);
  margin-bottom: var(--space-md);
}

.empty-line {
  width: 160rpx;
  height: 8rpx;
  background: var(--border);
  border-radius: var(--radius-full);
  margin-bottom: var(--space-sm);
}

.empty-line.short {
  width: 120rpx;
}

/* ─────────────────────────────────────────────────────────────
 * 活动卡片 - 精致简约
 * ───────────────────────────────────────────────────────────── */
.list {
  display: flex;
  flex-direction: column;
  gap: var(--space-md);
}

.activity-item {
  display: flex;
  align-items: center;
  padding: var(--space-lg);
  background: var(--background-card);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-sm);
  border: 1px solid var(--border-light);
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  opacity: 0;
}

.activity-item:active {
  transform: scale(0.99);
  box-shadow: var(--shadow-xs);
  background: var(--background-warm);
}

/* 日期模块 */
.date-block {
  width: 80rpx;
  height: 80rpx;
  border-radius: var(--radius-md);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: var(--primary-light);
  margin-right: var(--space-lg);
  flex-shrink: 0;
}

.date-day {
  font-family: var(--font-display);
  font-size: 32rpx;
  font-weight: 600;
  color: var(--primary);
  line-height: 1;
  letter-spacing: -0.02em;
}

.date-month {
  font-size: 20rpx;
  color: var(--primary);
  opacity: 0.8;
  margin-top: 2rpx;
  letter-spacing: 0.02em;
}

/* 活动内容 */
.activity-content {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: var(--space-xs);
}

.activity-header {
  display: flex;
  align-items: center;
  gap: var(--space-sm);
}

.activity-name {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  letter-spacing: 0.02em;
  flex: 1;
}

.activity-content .tag {
  flex-shrink: 0;
  font-size: 20rpx;
  padding: 6rpx 12rpx;
}

.activity-time {
  font-size: 24rpx;
  color: var(--text-tertiary);
  letter-spacing: 0.02em;
}

/* 箭头指示 */
.arrow-indicator {
  flex-shrink: 0;
  margin-left: var(--space-md);
  opacity: 0.3;
  transition: all 0.3s ease;
}

.activity-item:active .arrow-indicator {
  opacity: 0.6;
  transform: translateX(4rpx);
}

.arrow-icon {
  font-size: 28rpx;
  color: var(--text-secondary);
  font-weight: 300;
}

/* ─────────────────────────────────────────────────────────────
 * 底部留白
 * ───────────────────────────────────────────────────────────── */
.footer-space {
  height: var(--space-3xl);
}