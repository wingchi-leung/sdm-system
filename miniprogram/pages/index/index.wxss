.page {
  min-height: 100vh;
  background: radial-gradient(circle at 50% 0%, #FEFEFE 0%, #FEFEFE 38%, #FEFEFE 100%);
  box-sizing: border-box;
  font-family: "LorchinSansP0", "PingFang SC", "SF Pro Text", -apple-system, BlinkMacSystemFont, sans-serif;
}

.hero {
  position: relative;
  min-height: 22vh;
  padding: 12rpx 34rpx 28rpx;
  overflow: hidden;
}

.hero::before {
  content: "";
  position: absolute;
  inset: 0;
  background:
    radial-gradient(circle at 18% 84%, rgba(254, 254, 254, 0.8) 0%, rgba(254, 254, 254, 0) 34%),
    radial-gradient(circle at 82% 18%, rgba(254, 254, 254, 0.72) 0%, rgba(254, 254, 254, 0) 28%);
  pointer-events: none;
}

.hero-top {
  position: relative;
  z-index: 1;
  display: flex;
  align-items: center;
  justify-content: flex-end;
  min-height: 72rpx;
  padding: 4rpx 0 0;
}

.hero-bell-wrap {
  position: relative;
  right: 0;
  top: 0;
  z-index: 1;
  width: 52rpx;
  height: 52rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.hero-bell {
  width: 34rpx;
  height: 34rpx;
  display: block;
  opacity: 0.85;
}

.hero-bell-badge {
  position: absolute;
  top: -4rpx;
  right: -4rpx;
  min-width: 28rpx;
  height: 28rpx;
  padding: 0 6rpx;
  border-radius: 999rpx;
  background: #111111;
  display: flex;
  align-items: center;
  justify-content: center;
}

.hero-bell-badge-text {
  color: #FEFEFE;
  font-size: 16rpx;
  line-height: 1;
  font-weight: 500;
}

.hero-mark {
  position: relative;
  z-index: 1;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
  margin-top: 28rpx;
  padding: 0 8rpx;
}

.hero-mark-left {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  align-items: flex-start;
}

.hero-mark-cn {
  color: #111111;
  font-family: "Songti SC", "STSong", "Times New Roman", serif;
  font-size: 126rpx;
  line-height: 0.9;
  font-weight: 500;
  letter-spacing: 0.02em;
}

.hero-mark-en {
  margin-top: 10rpx;
  color: #9b9b9b;
  font-family: "LorchinSansP0", "PingFang SC", -apple-system, BlinkMacSystemFont, sans-serif;
  font-size: 24rpx;
  line-height: 1.45;
  letter-spacing: 0.08em;
  
}

.hero-divider {
  width: 2rpx;
  align-self: stretch;
  margin-left: 10rpx;
  background: rgba(17, 17, 17, 0.2);
}

.hero-mark-right {
  width: 190rpx;
  padding-left: 12rpx;
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  justify-content: center;
}

.hero-mark-vertical {
  color: #111111;
  font-family: "Songti SC", "STSong", "Times New Roman", serif;
  font-size: 126rpx;
  line-height: 0.9;
  font-weight: 500;
  letter-spacing: 0.02em;
}

.state-wrap {
  position: absolute;
  inset: 0;
  z-index: 3;
  background: rgba(254, 254, 254, 0.92);
  min-height: 48vh;
  padding: 120rpx 56rpx 120rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.state-wrap.error .state-icon {
  width: 72rpx;
  height: 72rpx;
  margin-bottom: 28rpx;
  background: rgba(178, 65, 55, 0.06);
  border-radius: 50%;
  color: var(--error);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 34rpx;
}

.state-title {
  margin-top: 10rpx;
  font-size: 32rpx;
  line-height: 1.4;
  font-weight: 500;
  color: #222222;
}

.state-text {
  margin-top: 16rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: #9a9a9a;
  text-align: center;
}

.empty-image {
  width: 220rpx;
  height: 260rpx;
  margin-bottom: 20rpx;
}

.btn-retry,
.btn-text {
  margin-top: 34rpx;
  padding: 18rpx 52rpx;
  border: 0;
  border-radius: 999rpx;
  background: #f1f1f1;
  color: #5c5c5c;
  font-size: 26rpx;
  font-weight: 500;
}

.btn-retry::after,
.btn-text::after {
  border: 0;
}

.list-shell {
  margin-top: -18rpx;
  padding: 0 40rpx 0;
}

.activity-groups {
  padding-top: 4rpx;
}

.activity-list {
  border-top: 1rpx solid #ededed;
}

.activity-group {
  margin-top: 12rpx;
}

.activity-group:first-child {
  margin-top: 0;
}

.activity-group-header {
  position: sticky;
  top: 0;
  z-index: 2;
  display: flex;
  align-items: baseline;
  gap: 12rpx;
  padding: 16rpx 0 18rpx;
  background: linear-gradient(180deg, rgba(254, 254, 254, 0.98) 72%, rgba(254, 254, 254, 0.88) 100%);
  backdrop-filter: blur(12rpx);
}

.activity-group-date {
  color: #111111;
  font-family: "LorchinSansP0", "PingFang SC", -apple-system, BlinkMacSystemFont, sans-serif;
  font-size: 32rpx;
  line-height: 1.3;
  font-weight: 600;
  letter-spacing: 0.02em;
}

.activity-group-weekday {
  color: #8b8b8b;
  font-size: 22rpx;
  line-height: 1.4;
  letter-spacing: 0.04em;
}

.activity-card {
  display: flex;
  align-items: flex-start;
  padding: 34rpx 0 36rpx;
  border-bottom: 1rpx solid #ededed;
}

.activity-card:active {
  opacity: 0.74;
}

.activity-cover {
  width: 288rpx;
  height: 288rpx;
  min-width: 288rpx;
  border-radius: 18rpx;
  overflow: hidden;
  background: #f2f2f2;
}

.activity-cover-image {
  width: 100%;
  height: 100%;
  display: block;
}

.activity-cover-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(180deg, #f5f5f5 0%, #ececec 100%);
}

.activity-cover-placeholder-text {
  color: #b0b0b0;
  font-family: "LorchinSansP0", "PingFang SC", -apple-system, BlinkMacSystemFont, sans-serif;
  font-size: 30rpx;
  letter-spacing: 0.16em;
}

.activity-content {
  flex: 1;
  min-width: 0;
  padding-left: 32rpx;
  display: flex;
  flex-direction: column;
  padding-top: 8rpx;
}

.activity-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
}

.activity-title-text {
  flex: 1;
  color: #111111;
  font-family: "LorchinSansP0", "PingFang SC", -apple-system, BlinkMacSystemFont, sans-serif;
  font-size: 38rpx;
  line-height: 1.28;
  font-weight: 500;
  letter-spacing: 0.01em;
}

.activity-arrow {
  flex-shrink: 0;
  color: #111111;
  font-size: 52rpx;
  line-height: 1;
  font-weight: 300;
  margin-top: -4rpx;
}

.activity-summary {
  display: block;
  margin-top: 16rpx;
  color: #5b5b5b;
  font-size: 24rpx;
  line-height: 1.65;
  letter-spacing: 0.02em;
}

.activity-summary.muted {
  color: #8e8e8e;
}

.activity-meta {
  margin-top: 28rpx;
  display: flex;
  flex-wrap: wrap;
  align-items: center;
}

.activity-meta-text {
  margin-right: 20rpx;
  color: #6d6d6d;
  font-size: 24rpx;
  line-height: 1.55;
  letter-spacing: 0.02em;
}

.footer-space {
  height: 88rpx;
}
