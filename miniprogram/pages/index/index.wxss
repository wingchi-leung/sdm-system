.page {
  min-height: 100vh;
  padding: 28rpx 0 0;
  background: #FFFFFF;
  box-sizing: border-box;
}

.header {
  padding: 2rpx 36rpx 34rpx;
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
}

.header-content {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
}



.header-title {
  font-family: var(--font-display);
  font-size: 44rpx;
  line-height: 56rpx;
  font-weight: 500;
  color: var(--ink);
  letter-spacing: 0.02em;
}

.header-subtitle {
  margin-top: 18rpx;
  font-size: 24rpx;
  color: var(--text-soft);
  letter-spacing: 0.04em;
}

.header-action {
  padding-top: 112rpx;
}

.btn-publish {
  width: 72rpx !important;
  height: 72rpx !important;
  min-height: 72rpx;
  padding: 0 !important;
  margin: 0;
  border: 0;
  border-radius: 50%;
  background: #FFFFFF;
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn-publish::after {
  border: 0;
}

.btn-publish:active {
  background: var(--paper);
}

.publish-icon {
  color: var(--green);
  font-size: 42rpx;
  font-weight: 300;
  line-height: 1;
}

.state-wrap {
  min-height: 60vh;
  padding: 110rpx 56rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.state-wrap.error .state-icon {
  width: 72rpx;
  height: 72rpx;
  margin-bottom: 28rpx;
  background: rgba(178, 65, 55, 0.06);
  border-radius: 50%;
  color: var(--error);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 34rpx;
}

.state-title {
  margin-top: 10rpx;
  font-size: 32rpx;
  font-weight: 400;
  color: var(--ink);
  letter-spacing: 0.04em;
}

.state-text {
  margin-top: 14rpx;
  font-size: 24rpx;
  color: var(--text-soft);
  text-align: center;
  letter-spacing: 0.04em;
}

.empty-image {
  width: 220rpx;
  height: 260rpx;
  margin-bottom: 20rpx;
}

.btn-retry,
.btn-text {
  margin-top: 34rpx;
  padding: 18rpx 52rpx;
  border: 0;
  border-radius: 0;
  background: #FFFFFF;
  color: var(--green);
  font-size: 26rpx;
  letter-spacing: 0.08em;
}

.btn-retry::after,
.btn-text::after {
  border: 0;
}

.list {
  padding: 0 48rpx;
}

.activity-item {
  margin-bottom: 36rpx;
  border-radius: 8rpx;
  overflow: hidden;
  background: #FFFFFF;
  box-shadow: none;
}

.activity-item:active {
  transform: translateY(2rpx);
}

.poster-wrap {
  width: 100%;
  height: 256rpx;
  position: relative;
  overflow: hidden;
  background: #F6F6F6;
}

.poster-img {
  width: 100%;
  height: 100%;
}

.no-poster {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #B7BBB8;
  font-size: 24rpx;
  letter-spacing: 0.12em;
}

.status-tag {
  position: absolute;
  left: 0;
  top: 0;
  min-width: 96rpx;
  height: 52rpx;
  padding: 0 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(15, 26, 23, 0.92);
  color: #FFFFFF;
  font-size: 22rpx;
  letter-spacing: 0.08em;
}

.status-tag.status-1 {
  background: rgba(107, 114, 128, 0.88);
}

.status-tag.status-2 {
  background: rgba(28, 47, 38, 0.94);
}

.status-tag.status-3 {
  background: rgba(15, 26, 23, 0.32);
}

.item-content {
  position: relative;
  min-height: 132rpx;
  padding: 28rpx 96rpx 30rpx 34rpx;
  background: #FFFFFF;
}

.item-content::after {
  content: '→';
  position: absolute;
  right: 32rpx;
  bottom: 32rpx;
  color: var(--green);
  font-size: 34rpx;
  font-weight: 300;
}

.item-name {
  display: block;
  font-size: 32rpx;
  line-height: 1.35;
  font-weight: 400;
  color: var(--ink);
  letter-spacing: 0.02em;
}

.item-info {
  margin-top: 18rpx;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.info-row {
  display: flex;
  align-items: center;
}

.info-dot {
  width: 8rpx;
  height: 8rpx;
  margin-right: 12rpx;
  border-radius: 50%;
  background: var(--green);
}

.info-text {
  font-size: 23rpx;
  color: var(--text-soft);
  letter-spacing: 0.04em;
}

.footer-space {
  height: 160rpx;
}

/* Product UI refinement：不改结构，仅收敛视觉规格 */
.page {
  padding-top: 0;
  background: #FFFFFF;
}

.header {
  padding: 0 32rpx 24rpx;
}

.brand-logo {
  width: 350rpx;
  height: 116rpx;
  margin-left: -130rpx;
  margin-bottom: 0rpx;
  object-fit: contain;
}

.header-title {
  font-size: 44rpx;
  line-height: 56rpx;
  font-weight: 500;
  letter-spacing: 0.4rpx;
}

.header-subtitle,
.state-text,
.info-text {
  font-size: 24rpx;
  line-height: 34rpx;
  color: #999999;
  font-weight: 400;
  letter-spacing: 0.4rpx;
}

.header-action {
  padding-top: 124rpx;
}

.list {
  padding: 0 32rpx;
}

.activity-item {
  margin-bottom: 24rpx;
  border-radius: 24rpx;
  box-shadow: none;
}

.poster-wrap {
  height: 240rpx;
  background: #F6F6F6;
}

.status-tag {
  min-width: auto;
  height: 40rpx;
  padding: 0 12rpx;
  background: #2F4F46;
  font-size: 22rpx;
  line-height: 32rpx;
  letter-spacing: 0.4rpx;
}

.item-content {
  min-height: auto;
  padding: 24rpx 64rpx 24rpx 24rpx;
}

.item-name {
  font-size: 32rpx;
  line-height: 44rpx;
  font-weight: 500;
  letter-spacing: 0.4rpx;
}

.item-content::after {
  right: 24rpx;
  bottom: 24rpx;
}

.footer-space {
  height: 112rpx;
}
