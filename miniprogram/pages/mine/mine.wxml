<!-- 普通用户 -->
<view class="page user" wx:if="{{view === 'user'}}">
  <view wx:if="{{loading}}" class="loading-wrap">
    <view class="loading"></view>
  </view>
  <view wx:else class="content">
    <view class="card profile-card">
      <view class="avatar-wrap">
        <view class="avatar">{{userName ? userName[0] : '用'}}</view>
      </view>
      <view class="profile-info">
        <text class="name">{{userName || '用户'}}</text>
      </view>
    </view>
    <view class="card section">
      <view class="menu-item" bindtap="logout">
        <text class="menu-title secondary">退出登录</text>
        <text class="arrow">›</text>
      </view>
    </view>
  </view>
</view>

<!-- 管理员 -->
<view class="page admin" wx:elif="{{view === 'admin'}}">
  <view class="content">
    <view class="card profile-card">
      <view class="avatar-wrap admin">
        <view class="avatar">管</view>
      </view>
      <view class="profile-info">
        <text class="name">{{adminProfile.levelText || '管理员'}}</text>
        <text class="subtitle" wx:if="{{adminProfile && adminProfile.typeNamesText}}">已授权类型：{{adminProfile.typeNamesText}}</text>
      </view>
    </view>
<view class="card section">
      <view class="menu-item {{!(adminProfile && adminProfile.canCreateActivity) ? 'menu-item-disabled' : ''}}" bindtap="goCreateActivity">
        <text class="menu-title">发布活动</text>
        <text class="menu-subtitle">{{adminProfile && adminProfile.canCreateActivity ? '创建新的活动' : '暂无可发布类型'}}</text>
        <text class="arrow">›</text>
      </view>
      <view class="menu-item" bindtap="goActivityManage">
        <text class="menu-title">活动管理</text>
        <text class="menu-subtitle">编辑、删除活动</text>
        <text class="arrow">›</text>
      </view>
      <!-- 超级管理员专属入口 -->
      <view wx:if="{{adminProfile && adminProfile.isSuper}}" class="menu-item" bindtap="goUserList">
        <text class="menu-title">用户管理</text>
        <text class="menu-subtitle">查看平台所有用户</text>
        <text class="arrow">›</text>
      </view>

    </view>
    <view class="card section">
      <view class="menu-item" bindtap="logout">
        <text class="menu-title secondary">退出登录</text>
        <text class="arrow">›</text>
      </view>
    </view>
  </view>
</view>
