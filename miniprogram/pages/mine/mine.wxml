<view class="page" wx:if="{{view === 'user' || view === 'admin'}}">
  <view wx:if="{{loading}}" class="state-wrap">
    <view class="loading"></view>
  </view>

  <view wx:else class="content">
    <view class="hero-space">
    </view>

    <view class="profile-row" bindtap="goAvatarPicker">
      <view class="avatar-wrap">
        <image wx:if="{{avatarDisplayUrl}}" class="avatar-image" src="{{avatarDisplayUrl}}" mode="aspectFill" />
        <text wx:else class="avatar-fallback">{{userName ? userName[0] : (view === 'admin' ? '管' : '用')}}</text>
      </view>

      <view class="profile-copy">
        <text class="profile-name">{{userName || (view === 'admin' ? '管理员' : '探索者')}}</text>
        <text class="profile-role">{{view === 'admin' ? (adminProfile.levelText || '活动管理员') : 'Welcome back'}}</text>
        <view class="profile-underline"></view>
      </view>
      <text class="row-arrow ui-chevron ui-chevron--md ui-chevron--right"></text>
    </view>

    <view class="stats-row" wx:if="{{view === 'user'}}">
      <view class="stat-item" wx:for="{{summaryCards}}" wx:key="label">
        <text class="stat-value">{{item.value}}</text>
        <text class="stat-label">{{item.label}}</text>
      </view>
    </view>

    <view class="service-section">
      <text class="group-title">我的服务</text>

      <view class="service-list">
        <view class="service-item" bindtap="goMyActivities">
          <view class="service-icon">
            <image class="service-icon-image" src="/assets/icons/enroll.png" mode="aspectFit" />
          </view>
          <view class="service-copy">
            <text class="service-title">报名活动</text>
            <text class="service-desc">查看已报名和候补中的活动</text>
          </view>
          <text class="row-arrow row-arrow-dark ui-chevron ui-chevron--md ui-chevron--right"></text>
        </view>

        <view class="service-item" bindtap="goMyOrders">
          <view class="service-icon">
            <image class="service-icon-image" src="/assets/icons/order.png" mode="aspectFit" />
          </view>
          <view class="service-copy">
            <text class="service-title">我的订单</text>
            <text class="service-desc">查看订单与状态</text>
          </view>
          <text class="row-arrow row-arrow-dark ui-chevron ui-chevron--md ui-chevron--right"></text>
        </view>

        <view class="service-item" bindtap="goSettings">
          <view class="service-icon">
            <image class="service-icon-image" src="/assets/icons/setting.png" mode="aspectFit" />
          </view>
          <view class="service-copy">
            <text class="service-title">设置</text>
            <text class="service-desc">修改个人信息、注销账号</text>
          </view>
          <text class="row-arrow row-arrow-dark ui-chevron ui-chevron--md ui-chevron--right"></text>
        </view>

        <view class="service-item" bindtap="goAgreementNotes">
          <view class="service-icon">
            <image class="service-icon-image" src="/assets/icons/agree.png" mode="aspectFit" />
          </view>
          <view class="service-copy">
            <text class="service-title">协议和说明</text>
            <text class="service-desc">查看隐私政策与平台说明</text>
          </view>
          <text class="row-arrow row-arrow-dark ui-chevron ui-chevron--md ui-chevron--right"></text>
        </view>
      </view>
    </view>

    <view class="service-section" wx:if="{{view === 'admin'}}">
      <text class="group-title">管理功能</text>

      <view class="service-list">
        <view class="service-item {{!(adminProfile && adminProfile.canCreateActivity) ? 'is-disabled' : ''}}" bindtap="goCreateActivity">
          <view class="service-icon">
            <image class="service-icon-image" src="/assets/icons/lanuch.png" mode="aspectFit" />
          </view>
          <view class="service-copy">
            <text class="service-title">发布活动</text>
            <text class="service-desc">{{adminProfile && adminProfile.canCreateActivity ? '创建新的活动' : '暂无可发布类型'}}</text>
          </view>
          <text class="row-arrow row-arrow-dark ui-chevron ui-chevron--md ui-chevron--right"></text>
        </view>

        <view class="service-item" bindtap="goActivityManage">
          <view class="service-icon">
            <image class="service-icon-image" src="/assets/icons/manage.png" mode="aspectFit" />
          </view>
          <view class="service-copy">
            <text class="service-title">活动管理</text>
            <text class="service-desc">编辑、删除活动</text>
          </view>
          <text class="row-arrow row-arrow-dark ui-chevron ui-chevron--md ui-chevron--right"></text>
        </view>

        <view class="service-item" wx:if="{{adminProfile && adminProfile.canViewUsers}}" bindtap="goUserList">
          <view class="service-icon">
            <image class="service-icon-image" src="/assets/icons/users.png" mode="aspectFit" />
          </view>
          <view class="service-copy">
            <text class="service-title">用户管理</text>
            <text class="service-desc">查看平台所有用户</text>
          </view>
          <text class="row-arrow row-arrow-dark ui-chevron ui-chevron--md ui-chevron--right"></text>
        </view>

        <view class="service-item" bindtap="goCommunityModeration">
          <view class="service-icon">
            <image class="service-icon-image" src="/assets/icons/audit.png" mode="aspectFit" />
          </view>
          <view class="service-copy">
            <text class="service-title">内容审核</text>
            <text class="service-desc">审核普通用户待处理的社区内容</text>
          </view>
          <text class="row-arrow row-arrow-dark ui-chevron ui-chevron--md ui-chevron--right"></text>
        </view>
      </view>
    </view>

    <view class="logout-row" bindtap="logout">
      <text class="logout-text">退出登录</text>
      <text class="logout-arrow ui-chevron ui-chevron--md ui-chevron--right"></text>
    </view>
  </view>
</view>
