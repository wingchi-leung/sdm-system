/**
 * 我的页面 - 高级简约风格
 */

.page {
  min-height: 100vh;
  padding: var(--space-xl) var(--space-lg);
  background: var(--background);
}

.content {
  animation: fadeIn 0.4s ease;
}

/* ─────────────────────────────────────────────────────────────
 * 加载状态
 * ───────────────────────────────────────────────────────────── */
.state-wrap {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 60vh;
}

/* ─────────────────────────────────────────────────────────────
 * 用户信息卡片
 * ───────────────────────────────────────────────────────────── */
.profile-section {
  display: flex;
  align-items: center;
  padding: var(--space-xl) 0;
  margin-bottom: var(--space-2xl);
  border-bottom: 1px solid var(--divider);
}

.profile-section.admin {
  flex-wrap: wrap;
  border-bottom: none;
}

.avatar {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: var(--space-lg);
  flex-shrink: 0;
  position: relative;
}

.avatar::before {
  content: '';
  position: absolute;
  left: 0;
  top: 0;
  width: 2px;
  height: 100%;
  background: var(--text-primary);
}

.avatar.admin-avatar::before {
  background: var(--primary);
}

.avatar-text {
  font-family: var(--font-display);
  font-size: 32rpx;
  font-weight: 500;
  color: var(--text-primary);
  letter-spacing: 0.04em;
}

.admin-avatar .avatar-text {
  color: var(--primary);
}

.profile-info {
  flex: 1;
  min-width: 0;
}

.profile-name {
  display: block;
  font-family: var(--font-display);
  font-size: 32rpx;
  font-weight: 500;
  color: var(--text-primary);
  letter-spacing: 0.06em;
  margin-bottom: var(--space-xs);
}

.profile-role {
  display: block;
  font-size: 22rpx;
  color: var(--text-tertiary);
  letter-spacing: 0.08em;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  text-transform: uppercase;
}

.admin-badge {
  margin-top: var(--space-lg);
  padding: var(--space-sm) 0;
  width: 100%;
  border-top: 1px solid var(--divider);
  text-align: center;
}

.admin-badge text {
  font-size: 20rpx;
  color: var(--primary);
  font-weight: 500;
  letter-spacing: 0.12em;
  text-transform: uppercase;
}

/* ─────────────────────────────────────────────────────────────
 * 菜单区域
 * ───────────────────────────────────────────────────────────── */
.menu-section {
  margin-bottom: var(--space-xl);
}

.section-title {
  font-size: 20rpx;
  font-weight: 500;
  color: var(--text-muted);
  letter-spacing: 0.16em;
  text-transform: uppercase;
  margin-bottom: var(--space-md);
  padding-left: var(--space-xs);
}

.menu-card {
  border-top: 1px solid var(--divider);
}

.menu-item {
  display: flex;
  align-items: center;
  padding: var(--space-lg) 0;
  border-bottom: 1px solid var(--divider);
  transition: all 0.2s ease;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-item:active {
  background: var(--background-subtle);
  margin: 0 calc(-1 * var(--space-lg));
  padding-left: var(--space-lg);
  padding-right: var(--space-lg);
}

.menu-item.disabled {
  opacity: 0.4;
  pointer-events: none;
}

.menu-item.logout .menu-text {
  color: var(--text-tertiary);
}

/* 菜单图标 */
.menu-icon {
  width: 32rpx;
  height: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: var(--space-md);
  flex-shrink: 0;
}

.icon-symbol {
  font-size: 20rpx;
  color: var(--text-primary);
  font-weight: 300;
}

/* 菜单内容 */
.menu-content {
  flex: 1;
  min-width: 0;
}

.menu-text {
  display: block;
  font-size: 28rpx;
  font-weight: 500;
  color: var(--text-primary);
  letter-spacing: 0.04em;
}

.menu-hint {
  display: block;
  font-size: 22rpx;
  color: var(--text-tertiary);
  margin-top: 4rpx;
  letter-spacing: 0.02em;
}

/* 箭头 */
.menu-arrow {
  font-size: 20rpx;
  color: var(--text-muted);
  font-weight: 300;
  margin-left: var(--space-sm);
  transition: transform 0.2s ease;
}

.menu-item:active .menu-arrow {
  transform: translateX(4rpx);
}