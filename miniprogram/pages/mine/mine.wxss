.page {
  min-height: 100vh;
  padding: 84rpx 56rpx 150rpx;
  background: #FFFFFF;
  box-sizing: border-box;
}

.content {
  animation: fadeIn 0.35s ease;
}

.state-wrap {
  min-height: 60vh;
  display: flex;
  align-items: center;
  justify-content: center;
}

.profile-section {
  display: flex;
  align-items: center;
  padding-bottom: 48rpx;
  margin-bottom: 38rpx;
}

.profile-section.admin {
  flex-wrap: wrap;
}

.avatar {
  width: 112rpx;
  height: 112rpx;
  margin-right: 28rpx;
  background: #F8F8F6;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--green);
}

.avatar::before {
  content: '';
  width: 30rpx;
  height: 56rpx;
  border-left: 14rpx solid currentColor;
  border-top: 2rpx solid currentColor;
  border-bottom: 2rpx solid currentColor;
  transform: skewY(-12deg);
}

.avatar-text {
  display: none;
}

.profile-info {
  flex: 1;
  min-width: 0;
}

.profile-name {
  display: block;
  color: var(--ink);
  font-size: 36rpx;
  line-height: 1.3;
  font-weight: 400;
  letter-spacing: 0.04em;
}

.profile-role {
  display: block;
  margin-top: 8rpx;
  color: var(--text-soft);
  font-size: 23rpx;
  letter-spacing: 0.05em;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.admin-badge {
  width: 100%;
  margin-top: 26rpx;
  padding-top: 8rpx;
}

.admin-badge text {
  color: var(--green);
  font-size: 22rpx;
  letter-spacing: 0.1em;
}

.menu-section {
  margin-bottom: 42rpx;
}

.section-title {
  margin-bottom: 18rpx;
  color: var(--text-soft);
  font-size: 22rpx;
  letter-spacing: 0.08em;
}

.menu-card {
  background: transparent;
}

.menu-item {
  min-height: 96rpx;
  padding: 22rpx 0;
  display: flex;
  align-items: center;
  box-sizing: border-box;
}

.menu-item:active {
  opacity: 0.72;
}

.menu-item.disabled {
  opacity: 0.38;
  pointer-events: none;
}

.menu-icon {
  width: 34rpx;
  height: 34rpx;
  margin-right: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--green);
}

.icon-symbol {
  color: currentColor;
  font-size: 25rpx;
  font-weight: 300;
}

.menu-content {
  flex: 1;
  min-width: 0;
}

.menu-text {
  display: block;
  color: var(--ink);
  font-size: 28rpx;
  letter-spacing: 0.04em;
}

.menu-hint {
  display: block;
  margin-top: 6rpx;
  color: var(--text-soft);
  font-size: 22rpx;
  letter-spacing: 0.02em;
}

.menu-item.logout .menu-text {
  color: var(--text-soft);
}

.menu-arrow {
  margin-left: 20rpx;
  color: var(--green);
  font-size: 28rpx;
  font-weight: 300;
}

/* Product UI refinement：不改结构，仅收敛视觉规格 */
.page {
  padding: 48rpx 32rpx 112rpx;
}

.profile-section {
  padding-bottom: 24rpx;
  margin-bottom: 24rpx;
}

.avatar {
  width: 88rpx;
  height: 88rpx;
  margin-right: 16rpx;
}

.profile-name {
  font-size: 44rpx;
  line-height: 56rpx;
  font-weight: 500;
  letter-spacing: 0.4rpx;
}

.profile-role,
.admin-badge text,
.section-title,
.menu-hint {
  color: #999999;
  font-size: 24rpx;
  line-height: 34rpx;
  font-weight: 400;
  letter-spacing: 0.4rpx;
}

.menu-section {
  margin-bottom: 24rpx;
}

.menu-item {
  min-height: 64rpx;
  padding: 12rpx 0;
}

.menu-text {
  font-size: 28rpx;
  line-height: 40rpx;
  font-weight: 400;
  letter-spacing: 0.4rpx;
}
