.page {
  min-height: 100vh;
  background: #ffffff;
  /* 系统导航栏模式下，页面内容从导航栏下方开始，padding-top 只需预留想要的留白 */
  padding: 24rpx 32rpx calc(120rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
  color: #111111;
  font-family: "PingFang SC", -apple-system, BlinkMacSystemFont, "Helvetica Neue", sans-serif;
}

.content {
  position: relative;
  animation: fadeIn 0.18s ease;
}

.hero-space {
  position: relative;
  height: 24rpx;
}

.state-wrap {
  min-height: 60vh;
  display: flex;
  align-items: center;
  justify-content: center;
}

.profile-row {
  display: flex;
  align-items: center;
  padding: 0 0 20rpx;
  margin-top: 4rpx;
  border-bottom: 1rpx solid var(--divider);
}

.avatar-wrap {
  width: 148rpx;
  height: 148rpx;
  border-radius: 50%;
  overflow: hidden;
  background: #f7f7f5;
  flex-shrink: 0;
}

.avatar-image {
  width: 100%;
  height: 100%;
}

.avatar-fallback {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #999999;
  font-size: 48rpx;
  font-weight: 500;
}

.profile-copy {
  flex: 1;
  min-width: 0;
  padding-left: 20rpx;
}

.profile-name {
  display: block;
  color: #111111;
  font-size: 40rpx;
  line-height: 1.2;
  font-weight: 500;
}

.profile-role {
  display: block;
  margin-top: 8rpx;
  color: #999999;
  font-size: 24rpx;
  line-height: 1.3;
}

.profile-underline {
  width: 48rpx;
  height: 3rpx;
  margin-top: 12rpx;
  background: #111111;
  border-radius: 999rpx;
}

.row-arrow {
  color: #111111;
  font-size: 46rpx;
  line-height: 1;
  margin-left: 8rpx;
  font-weight: 300;
}

.row-arrow-dark {
  color: #111111;
}

.stats-row {
  display: flex;
  align-items: stretch;
  justify-content: space-between;
  margin-top: 24rpx;
  padding: 0;
}

.stat-item {
  flex: 1;
  min-width: 0;
  text-align: center;
  position: relative;
}

.stat-item + .stat-item::before {
  content: '';
  position: absolute;
  left: 0;
  top: 16rpx;
  bottom: 16rpx;
  width: 1rpx;
  background: var(--divider);
}

.stat-value {
  display: block;
  color: #111111;
  font-size: 44rpx;
  line-height: 1;
  font-weight: 500;
}

.stat-label {
  display: block;
  margin-top: 10rpx;
  color: #999999;
  font-size: 23rpx;
  line-height: 1.25;
}

.service-section {
  margin-top: 32rpx;
}

.group-title {
  display: block;
  color: #999999;
  font-size: 24rpx;
  line-height: 1.3;
  margin-bottom: 8rpx;
}

.service-list {
  display: flex;
  flex-direction: column;
}

.service-item {
  min-height: 100rpx;
  padding: 18rpx 0;
  display: flex;
  align-items: center;
  border-bottom: 1rpx solid var(--divider);
}

.service-item:last-child {
  border-bottom: none;
}

.service-item.is-disabled {
  opacity: 0.4;
}

.service-icon {
  width: 54rpx;
  height: 54rpx;
  margin-right: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.service-icon-text {
  font-size: 28rpx;
  line-height: 1;
  color: #111111;
}

.service-icon-text-blue {
  color: #111111;
}

.service-icon-image {
  width: 34rpx;
  height: 34rpx;
}

.service-copy {
  flex: 1;
  min-width: 0;
}

.service-title {
  display: block;
  color: #111111;
  font-size: 30rpx;
  line-height: 1.25;
  font-weight: 500;
}

.service-desc {
  display: block;
  margin-top: 8rpx;
  color: #999999;
  font-size: 23rpx;
  line-height: 1.35;
}

.logout-row {
  margin-top: 32rpx;
  display: inline-flex;
  align-items: center;
  padding: 4rpx 2rpx;
}

.logout-text {
  color: #b24137;
  font-size: 31rpx;
  line-height: 1.3;
  font-weight: 500;
}

.logout-arrow {
  margin-left: 16rpx;
  color: #b24137;
  font-size: 38rpx;
  line-height: 1;
}

.loading {
  width: 52rpx;
  height: 52rpx;
  border-radius: 50%;
  border: 6rpx solid rgba(17, 17, 17, 0.12);
  border-top-color: #111111;
  animation: spin 0.9s linear infinite;
}

@keyframes spin {
  from {
    transform: rotate(0deg);
  }

  to {
    transform: rotate(360deg);
  }
}

@keyframes fadeIn {
  from {
    opacity: 0;
    transform: translateY(8rpx);
  }

  to {
    opacity: 1;
    transform: translateY(0);
  }
}
