/**
 * 我的页面 - 高级简约风格
 */

.page {
  min-height: 100vh;
  padding: var(--space-xl) var(--space-lg);
  background: var(--background);
}

.content {
  animation: fadeIn 0.4s ease;
}

/* ─────────────────────────────────────────────────────────────
 * 加载状态
 * ───────────────────────────────────────────────────────────── */
.state-wrap {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 60vh;
}

/* ─────────────────────────────────────────────────────────────
 * 用户信息卡片
 * ───────────────────────────────────────────────────────────── */
.profile-section {
  display: flex;
  align-items: center;
  padding: var(--space-xl);
  margin-bottom: var(--space-2xl);
  background: var(--background-card);
  border-radius: var(--radius-xl);
  box-shadow: var(--shadow-sm);
  border: 1px solid var(--border-light);
}

.profile-section.admin {
  flex-wrap: wrap;
}

.avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: var(--primary-light);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: var(--space-lg);
  flex-shrink: 0;
}

.avatar.admin-avatar {
  background: var(--primary);
}

.avatar-text {
  font-family: var(--font-display);
  font-size: 40rpx;
  font-weight: 600;
  color: var(--primary);
  letter-spacing: -0.02em;
}

.admin-avatar .avatar-text {
  color: #FFFFFF;
}

.profile-info {
  flex: 1;
  min-width: 0;
}

.profile-name {
  display: block;
  font-family: var(--font-display);
  font-size: 36rpx;
  font-weight: 600;
  color: var(--text-primary);
  letter-spacing: -0.01em;
  margin-bottom: var(--space-xs);
}

.profile-role {
  display: block;
  font-size: 26rpx;
  color: var(--text-tertiary);
  letter-spacing: 0.02em;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.admin-badge {
  margin-top: var(--space-md);
  padding: 8rpx 20rpx;
  background: var(--primary-light);
  border-radius: var(--radius-full);
  width: 100%;
  text-align: center;
}

.admin-badge text {
  font-size: 22rpx;
  color: var(--primary);
  font-weight: 500;
  letter-spacing: 0.04em;
}

/* ─────────────────────────────────────────────────────────────
 * 菜单区域
 * ───────────────────────────────────────────────────────────── */
.menu-section {
  margin-bottom: var(--space-xl);
}

.section-title {
  font-size: 24rpx;
  font-weight: 500;
  color: var(--text-tertiary);
  letter-spacing: 0.04em;
  text-transform: uppercase;
  margin-bottom: var(--space-md);
  padding-left: var(--space-xs);
}

.menu-card {
  background: var(--background-card);
  border-radius: var(--radius-lg);
  overflow: hidden;
  box-shadow: var(--shadow-xs);
  border: 1px solid var(--border-light);
}

.menu-item {
  display: flex;
  align-items: center;
  padding: var(--space-lg);
  border-bottom: 1px solid var(--border-light);
  transition: all 0.2s ease;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-item:active {
  background: var(--background-warm);
}

.menu-item.disabled {
  opacity: 0.5;
  pointer-events: none;
}

.menu-item.logout .menu-text {
  color: var(--text-tertiary);
}

/* 菜单图标 */
.menu-icon {
  width: 48rpx;
  height: 48rpx;
  border-radius: var(--radius-md);
  background: var(--primary-light);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: var(--space-md);
  flex-shrink: 0;
}

.icon-symbol {
  font-size: 28rpx;
  color: var(--primary);
  font-weight: 300;
}

/* 菜单内容 */
.menu-content {
  flex: 1;
  min-width: 0;
}

.menu-text {
  display: block;
  font-size: 30rpx;
  font-weight: 500;
  color: var(--text-primary);
  letter-spacing: 0.02em;
}

.menu-hint {
  display: block;
  font-size: 24rpx;
  color: var(--text-tertiary);
  margin-top: 4rpx;
  letter-spacing: 0.02em;
}

/* 箭头 */
.menu-arrow {
  font-size: 28rpx;
  color: var(--text-muted);
  font-weight: 300;
  margin-left: var(--space-sm);
  transition: transform 0.2s ease;
}

.menu-item:active .menu-arrow {
  transform: translateX(4rpx);
}