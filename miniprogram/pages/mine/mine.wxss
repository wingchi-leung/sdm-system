/**
 * 我的页面 - Bold Minimal
 * 设计亮点：大头像卡片 + 几何图标菜单
 */

.page {
  min-height: 100vh;
  padding: var(--space-xl) var(--space-lg);
  background: var(--bg-secondary);
}

.content {
  animation: fadeIn 0.4s ease;
}

/* ─────────────────────────────────────────────────────────────
 * 加载状态
 * ───────────────────────────────────────────────────────────── */
.state-wrap {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 60vh;
}

/* ─────────────────────────────────────────────────────────────
 * 用户信息卡片 - 戏剧性设计
 * ───────────────────────────────────────────────────────────── */
.profile-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: var(--space-2xl);
  margin-bottom: var(--space-2xl);
  background: var(--bg-card);
  border-radius: var(--radius-2xl);
  box-shadow: var(--shadow-md);
}

.avatar-large {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: var(--bg-tertiary);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: var(--space-lg);
  border: 4rpx solid var(--border);
}

.avatar-large.admin-avatar {
  background: var(--text-primary);
  border-color: var(--accent);
}

.avatar-text {
  font-family: var(--font-display);
  font-size: 48rpx;
  font-weight: 700;
  color: var(--text-secondary);
  letter-spacing: -0.02em;
}

.admin-avatar .avatar-text {
  color: #FFFFFF;
}

.profile-info {
  text-align: center;
}

.profile-name {
  display: block;
  font-family: var(--font-display);
  font-size: 40rpx;
  font-weight: 700;
  color: var(--text-primary);
  letter-spacing: -0.02em;
  margin-bottom: var(--space-sm);
}

.profile-badge {
  display: inline-block;
  padding: 8rpx 20rpx;
  background: var(--bg-tertiary);
  border-radius: var(--radius-full);
}

.profile-badge text {
  font-size: 22rpx;
  font-weight: 600;
  color: var(--text-tertiary);
  letter-spacing: 0.04em;
}

.profile-badge.admin-badge text {
  color: var(--accent);
}

.super-badge {
  margin-top: var(--space-md);
  padding: 10rpx 24rpx;
  background: var(--accent);
  border-radius: var(--radius-full);
}

.super-badge text {
  font-size: 22rpx;
  font-weight: 700;
  color: #FFFFFF;
  letter-spacing: 0.08em;
}

/* ─────────────────────────────────────────────────────────────
 * 菜单区域
 * ───────────────────────────────────────────────────────────── */
.menu-section {
  margin-bottom: var(--space-xl);
}

.section-label {
  display: block;
  font-size: 22rpx;
  font-weight: 700;
  color: var(--text-tertiary);
  letter-spacing: 0.08em;
  text-transform: uppercase;
  margin-bottom: var(--space-md);
  padding-left: var(--space-xs);
}

.menu-list {
  background: var(--bg-card);
  border-radius: var(--radius-xl);
  overflow: hidden;
  box-shadow: var(--shadow-sm);
}

.menu-item {
  display: flex;
  align-items: center;
  padding: var(--space-lg);
  border-bottom: 1rpx solid var(--border);
  transition: all 0.2s ease;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-item:active {
  background: var(--bg-tertiary);
}

.menu-item.disabled {
  opacity: 0.4;
  pointer-events: none;
}

/* 几何图标 */
.menu-icon {
  width: 48rpx;
  height: 48rpx;
  border-radius: var(--radius-md);
  background: var(--bg-tertiary);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: var(--space-lg);
  flex-shrink: 0;
}

.menu-icon text {
  font-size: 28rpx;
  color: var(--text-primary);
  font-weight: 300;
}

/* 菜单内容 */
.menu-content {
  flex: 1;
  min-width: 0;
}

.menu-title {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
  letter-spacing: 0.01em;
}

.menu-desc {
  display: block;
  font-size: 24rpx;
  color: var(--text-tertiary);
  margin-top: 4rpx;
}

/* 箭头 */
.menu-arrow {
  font-size: 28rpx;
  color: var(--text-muted);
  font-weight: 300;
  margin-left: var(--space-sm);
  transition: transform 0.2s ease;
}

.menu-item:active .menu-arrow {
  transform: translateX(8rpx);
}

/* ─────────────────────────────────────────────────────────────
 * 退出按钮
 * ───────────────────────────────────────────────────────────── */
.btn-logout {
  width: 100%;
  height: 100rpx;
  background: var(--bg-card);
  border-radius: var(--radius-xl);
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: var(--shadow-sm);
  transition: all 0.2s ease;
}

.btn-logout::after {
  border: none;
}

.btn-logout:active {
  background: var(--bg-tertiary);
}

.logout-text {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-tertiary);
  letter-spacing: 0.02em;
}