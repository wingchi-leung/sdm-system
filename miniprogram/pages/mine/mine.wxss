.page {
  min-height: 100vh;
  background: #ffffff;
  padding: 34rpx 54rpx 150rpx;
  box-sizing: border-box;
}

.content {
  animation: fadeIn 0.25s ease;
}

.state-wrap {
  min-height: 60vh;
  display: flex;
  align-items: center;
  justify-content: center;
}

.page-title {
  text-align: center;
  color: #111111;
  font-family: "Source Han Sans SC", "Noto Sans SC", "PingFang SC", sans-serif;
  font-size: 31rpx;
  line-height: 1.2;
  font-weight: 500;
  margin-top: 18rpx;
}

.profile-row {
  margin-top: 52rpx;
  padding: 0;
  display: flex;
  align-items: center;
}

.avatar-wrap {
  width: 92rpx;
  height: 92rpx;
  border-radius: 50%;
  overflow: hidden;
  background: #f4f4f4;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.avatar-image {
  width: 100%;
  height: 100%;
}

.avatar-fallback {
  color: #777777;
  font-size: 32rpx;
  font-family: "Source Han Sans SC", "Noto Sans SC", "PingFang SC", sans-serif;
}

.profile-copy {
  flex: 1;
  min-width: 0;
  padding-left: 20rpx;
}

.profile-name {
  display: block;
  color: #111111;
  font-family: "Source Han Sans SC", "Noto Sans SC", "PingFang SC", sans-serif;
  font-size: 37rpx;
  line-height: 1.2;
  font-weight: 500;
}

.profile-role,
.profile-meta {
  display: block;
  margin-top: 8rpx;
  color: #8e8e93;
  font-family: "Source Han Sans SC", "Noto Sans SC", "PingFang SC", sans-serif;
  font-size: 24rpx;
  line-height: 1.35;
  font-weight: 400;
}

.row-arrow {
  color: #8e8e93;
  font-size: 38rpx;
  line-height: 1;
  margin-left: 12rpx;
  font-weight: 300;
}

.group {
  margin-top: 52rpx;
}

.group-title {
  display: block;
  color: #8e8e93;
  font-family: "Source Han Sans SC", "Noto Sans SC", "PingFang SC", sans-serif;
  font-size: 26rpx;
  line-height: 1.35;
  margin-bottom: 16rpx;
}

.item {
  min-height: 96rpx;
  padding: 20rpx 0;
  display: flex;
  align-items: center;
  border-bottom: 1rpx solid #ebebed;
}

.item.disabled {
  opacity: 0.38;
}

.item-icon {
  width: 44rpx;
  margin-right: 14rpx;
  color: #666666;
  font-size: 38rpx;
  line-height: 1;
  text-align: center;
  font-weight: 300;
}

.item-icon-image {
  width: 36rpx;
  height: 36rpx;
  margin-right: 18rpx;
  flex-shrink: 0;
}

.item-copy {
  flex: 1;
  min-width: 0;
}

.item-title {
  display: block;
  color: #111111;
  font-family: "Source Han Sans SC", "Noto Sans SC", "PingFang SC", sans-serif;
  font-size: 31rpx;
  line-height: 1.3;
  font-weight: 500;
}

.item-desc {
  display: block;
  margin-top: 6rpx;
  color: #8e8e93;
  font-family: "Source Han Sans SC", "Noto Sans SC", "PingFang SC", sans-serif;
  font-size: 22rpx;
  line-height: 1.4;
  font-weight: 400;
}

.logout-row {
  margin-top: 46rpx;
  display: inline-flex;
  align-items: center;
}

.logout-text {
  color: #d93025;
  font-family: "Source Han Sans SC", "Noto Sans SC", "PingFang SC", sans-serif;
  font-size: 31rpx;
  line-height: 1.3;
}

.logout-arrow {
  margin-left: 18rpx;
  color: #d93025;
  font-size: 36rpx;
  line-height: 1;
}
