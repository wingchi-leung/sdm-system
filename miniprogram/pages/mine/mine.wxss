/**
 * 我的页面
 */

.page {
  min-height: 100vh;
  padding: var(--space-lg);
  background: var(--background);
}

/* 登录引导 */
.center-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: var(--space-xl) var(--space-lg);
  min-height: 50vh;
}

.guest-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: var(--space-sm);
}

.guest-subtitle {
  font-size: 28rpx;
  color: var(--text-secondary);
  text-align: center;
  margin-bottom: var(--space-xl);
}

.login-btn {
  padding: 24rpx var(--space-xl);
}

/* 个人信息卡片 */
.profile-card {
  display: flex;
  align-items: center;
  padding: var(--space-lg);
  margin-bottom: var(--space-lg);
  background: var(--background-card);
  border-radius: 12rpx;
  box-shadow: var(--shadow);
  border: 1px solid var(--border);
}

.avatar-wrap {
  width: 96rpx;
  height: 96rpx;
  border-radius: 48rpx;
  background: var(--background-input);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: var(--space-md);
}

.avatar {
  font-size: 32rpx;
  color: var(--primary);
  font-weight: 600;
}

.profile-info {
  flex: 1;
}

.profile-info .name {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 4rpx;
}

.profile-info .subtitle {
  font-size: 26rpx;
  color: var(--text-secondary);
}

/* 信息列表 */
.section {
  margin-bottom: var(--space-lg);
}

.info-row {
  display: flex;
  align-items: center;
  padding: var(--space-md) var(--space-lg);
  background: var(--background-card);
  border-bottom: 1px solid var(--border);
}

.info-row:first-child {
  border-radius: 12rpx 12rpx 0 0;
}

.info-row:last-child {
  border-bottom: none;
  border-radius: 0 0 12rpx 12rpx;
}

.info-row:only-child {
  border-radius: 12rpx;
}

.info-row:active {
  background: var(--background-input);
}

.info-label {
  width: 140rpx;
  font-size: 28rpx;
  color: var(--text-secondary);
}

.info-value {
  flex: 1;
  font-size: 28rpx;
  color: var(--text-primary);
}

/* 菜单列表 */
.menu-list {
  background: var(--background-card);
  border-radius: 12rpx;
  overflow: hidden;
  box-shadow: var(--shadow);
  border: 1px solid var(--border);
}

.menu-item {
  display: flex;
  align-items: center;
  padding: var(--space-md) var(--space-lg);
  border-bottom: 1px solid var(--border);
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-item:active {
  background: var(--background-input);
}

.menu-item-disabled {
  opacity: 0.5;
}

.menu-title {
  flex: 1;
  font-size: 28rpx;
  color: var(--text-primary);
}

.menu-title.secondary {
  color: var(--text-secondary);
}

.arrow {
  font-size: 28rpx;
  color: var(--text-tertiary);
}

/* 退出按钮 */
.logout-btn {
  width: 100%;
  margin-top: var(--space-lg);
  padding: 24rpx;
  font-size: 28rpx;
  background: transparent;
  color: var(--error);
  border: 1px solid rgba(231, 76, 60, 0.3);
  border-radius: 8rpx;
}
