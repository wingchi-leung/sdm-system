.page {
  min-height: 100vh;
  padding: 84rpx 56rpx 150rpx;
  background: #FFFFFF;
  box-sizing: border-box;
}

.content {
  animation: fadeIn 0.35s ease;
}

.state-wrap {
  min-height: 60vh;
  display: flex;
  align-items: center;
  justify-content: center;
}

.profile-section {
  display: flex;
  flex-direction: column;
  align-items: stretch;
  padding-bottom: 48rpx;
  margin-bottom: 38rpx;
}

.profile-section.admin {
  flex-direction: row;
  flex-wrap: wrap;
  align-items: center;
}

.profile-card {
  display: flex;
  align-items: center;
  padding: 24rpx;
  background: #FFFFFF;
  border: 1rpx solid #ECECEC;
  border-radius: 24rpx;
}

.avatar {
  width: 112rpx;
  height: 112rpx;
  margin-right: 28rpx;
  background: #FFFFFF;
  border: 1rpx solid #ECECEC;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--green);
  overflow: hidden;
}

.avatar-clickable:active {
  opacity: 0.84;
}

.avatar-image {
  width: 100%;
  height: 100%;
}

.avatar-fallback {
  color: var(--green);
  font-size: 34rpx;
  font-weight: 500;
}

.profile-info {
  flex: 1;
  min-width: 0;
}

.profile-summary {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16rpx;
  margin-top: 16rpx;
}

.summary-item {
  padding: 22rpx 24rpx;
  background: #F7FAF8;
  border: 1rpx solid #E8EEEA;
  border-radius: 20rpx;
}

.summary-value {
  display: block;
  color: var(--ink);
  font-size: 34rpx;
  line-height: 46rpx;
  font-weight: 500;
}

.summary-label {
  display: block;
  margin-top: 6rpx;
  color: #999999;
  font-size: 22rpx;
  line-height: 32rpx;
}

.profile-name {
  display: block;
  color: var(--ink);
  font-size: 36rpx;
  line-height: 1.3;
  font-weight: 400;
  letter-spacing: 0.04em;
}

.profile-role {
  display: block;
  margin-top: 8rpx;
  color: var(--text-soft);
  font-size: 23rpx;
  letter-spacing: 0.05em;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.profile-link {
  display: block;
  margin-top: 10rpx;
  color: var(--green);
  font-size: 22rpx;
  line-height: 32rpx;
}

.admin-badge {
  width: 100%;
  margin-top: 26rpx;
  padding-top: 8rpx;
}

.admin-badge text {
  color: var(--green);
  font-size: 22rpx;
  letter-spacing: 0.1em;
}

.menu-section {
  margin-bottom: 42rpx;
}

.section-title {
  margin-bottom: 18rpx;
  color: var(--text-soft);
  font-size: 22rpx;
  letter-spacing: 0.08em;
}

.menu-card {
  background: #FFFFFF;
  border: 1rpx solid #ECECEC;
  border-radius: 24rpx;
  overflow: hidden;
}

.menu-item {
  min-height: 96rpx;
  padding: 24rpx;
  display: flex;
  align-items: center;
  box-sizing: border-box;
}

.menu-item + .menu-item {
  border-top: 1rpx solid #F1F1F1;
}

.menu-item:active {
  opacity: 0.72;
}

.menu-item.disabled {
  opacity: 0.38;
  pointer-events: none;
}

.menu-icon {
  width: 34rpx;
  height: 34rpx;
  margin-right: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--green);
}

.icon-symbol {
  color: currentColor;
  font-size: 25rpx;
  font-weight: 300;
}

.menu-content {
  flex: 1;
  min-width: 0;
}

.menu-text {
  display: block;
  color: var(--ink);
  font-size: 28rpx;
  letter-spacing: 0.04em;
}

.menu-hint {
  display: block;
  margin-top: 6rpx;
  color: var(--text-soft);
  font-size: 22rpx;
  letter-spacing: 0.02em;
}

.menu-item.logout .menu-text {
  color: #B42318;
}

.menu-item.logout .menu-arrow {
  color: #B42318;
}

.menu-arrow {
  margin-left: 20rpx;
  color: var(--green);
  font-size: 28rpx;
  font-weight: 300;
}

/* Product UI refinement：不改结构，仅收敛视觉规格 */
.page {
  padding: 48rpx 32rpx 112rpx;
}

.profile-section {
  padding-bottom: 24rpx;
  margin-bottom: 24rpx;
}

.avatar {
  width: 88rpx;
  height: 88rpx;
  margin-right: 16rpx;
}

.profile-name {
  font-size: 44rpx;
  line-height: 56rpx;
  font-weight: 500;
  letter-spacing: 0.4rpx;
}

.profile-role,
.admin-badge text,
.section-title,
.menu-hint {
  color: #999999;
  font-size: 24rpx;
  line-height: 34rpx;
  font-weight: 400;
  letter-spacing: 0.4rpx;
}

.menu-section {
  margin-bottom: 24rpx;
}

.menu-item {
  min-height: 64rpx;
  padding: 20rpx 24rpx;
}

.menu-text {
  font-size: 28rpx;
  line-height: 40rpx;
  font-weight: 400;
  letter-spacing: 0.4rpx;
}
