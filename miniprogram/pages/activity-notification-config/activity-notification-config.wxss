.page {
  min-height: 100vh;
  background: #ffffff;
  color: #111111;
  font-family: var(--font-body);
  overflow-x: hidden;
}

.content {
  box-sizing: border-box;
}

.content-inner {
  padding: 32rpx 32rpx 280rpx;
  box-sizing: border-box;
}

.hero {
  margin-top: 28rpx;
  margin-bottom: 56rpx;
}

.hero-title {
  display: block;
  color: #111111;
  font-size: 42rpx;
  line-height: 1.3;
  font-weight: 500;
  letter-spacing: 0.04em;
}

.hero-text {
  display: block;
  margin-top: 18rpx;
  color: #666666;
  font-size: 24rpx;
  line-height: 1.7;
}

.field {
  margin-bottom: 56rpx;
}

.switch-row {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
  padding: 4rpx 0;
}

.switch-copy {
  flex: 1;
  min-width: 0;
}

.switch-label,
.field-label {
  display: block;
  color: #111111;
  font-size: 28rpx;
  line-height: 1.4;
  font-weight: 500;
}

.field-label {
  margin-bottom: 16rpx;
}

.input {
  width: 100%;
  font-size: 28rpx;
  color: #111111;
  background: transparent;
  border: none;
  box-sizing: border-box;
}

.input-line {
  height: 84rpx;
  padding: 0 0 12rpx;
  border-bottom: 1rpx solid var(--divider);
  border-radius: 0;
}

.input-placeholder {
  color: #b8b8b8;
}

.textarea-card {
  border: 1rpx solid var(--border-light);
  border-radius: 18rpx;
  background: #ffffff;
}

.textarea-input {
  width: 100%;
  min-height: 320rpx;
  padding: 22rpx;
  box-sizing: border-box;
  color: #111111;
  font-size: 26rpx;
  line-height: 1.75;
}

.field-hint {
  display: block;
  margin-top: 14rpx;
  color: #999999;
  font-size: 22rpx;
  line-height: 1.5;
}

.error-box {
  padding: 18rpx 20rpx;
  border-radius: 18rpx;
  background: rgba(178, 65, 55, 0.08);
}

.error-text {
  color: #b24137;
  font-size: 24rpx;
  line-height: 1.6;
}

.page-spacer {
  height: 48rpx;
}

.footer-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  justify-content: center;
  padding: 20rpx 32rpx calc(30rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
  background: linear-gradient(180deg, rgba(255, 255, 255, 0), rgba(255, 255, 255, 0.92) 32%, #ffffff 100%);
  border-top: 1rpx solid var(--divider);
}

.footer-btn {
  flex: 1;
  height: 86rpx;
  margin: 0;
  padding: 0 28rpx;
  border-radius: 999rpx;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  box-shadow: 0 12rpx 28rpx rgba(15, 23, 42, 0.04);
}

.footer-btn::after {
  border: none;
}

.footer-btn-primary {
  background: #ffffff;
  border: 1rpx solid rgba(17, 17, 17, 0.12);
  color: #111111;
}

.footer-btn[disabled] {
  opacity: 0.5;
}

.footer-btn-text {
  color: #111111;
  font-size: 28rpx;
  font-weight: 500;
  line-height: 1.35;
  letter-spacing: 0.06em;
}

.footer-btn-arrow {
  color: #111111;
  font-size: 28rpx;
  line-height: 1;
  font-weight: 300;
  margin-top: -2rpx;
}

.loading-state {
  padding: 160rpx 32rpx;
  text-align: center;
}

.loading-text {
  color: #888888;
  font-size: 24rpx;
}
