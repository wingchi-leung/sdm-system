.page {
  min-height: 100vh;
  padding: 32rpx;
  background: #FFFFFF;
  box-sizing: border-box;
}

.hero {
  margin-bottom: 24rpx;
  padding: 28rpx;
  background: #F7FAF8;
  border: 1rpx solid #E8EEEA;
  border-radius: 24rpx;
}

.hero-title {
  display: block;
  color: var(--ink);
  font-size: 36rpx;
  line-height: 48rpx;
  font-weight: 500;
}

.hero-text {
  display: block;
  margin-top: 8rpx;
  color: #999999;
  font-size: 24rpx;
  line-height: 34rpx;
}

.state-wrap {
  min-height: 62vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  text-align: center;
}

.state-title {
  color: var(--ink);
  font-size: 30rpx;
  line-height: 42rpx;
  font-weight: 500;
}

.state-text {
  margin-top: 12rpx;
  color: #999999;
  font-size: 24rpx;
  line-height: 34rpx;
}

.list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.order-card {
  padding: 24rpx;
  background: #FFFFFF;
  border: 1rpx solid #ECECEC;
  border-radius: 24rpx;
}

.order-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.order-title {
  flex: 1;
  color: var(--ink);
  font-size: 30rpx;
  line-height: 42rpx;
  font-weight: 500;
}

.order-status {
  flex-shrink: 0;
  padding: 8rpx 14rpx;
  color: var(--green);
  font-size: 22rpx;
  line-height: 1;
  background: #F4F8F6;
  border-radius: 999rpx;
}

.order-status.is-pending {
  color: #9A6700;
  background: #FFF7E6;
}

.order-status.is-failed,
.order-status.is-closed {
  color: #B42318;
  background: #FEF3F2;
}

.order-amount {
  display: block;
  margin-top: 18rpx;
  color: var(--ink);
  font-size: 34rpx;
  line-height: 46rpx;
  font-weight: 500;
}

.order-meta {
  display: block;
  margin-top: 10rpx;
  color: #999999;
  font-size: 24rpx;
  line-height: 34rpx;
  word-break: break-all;
}
