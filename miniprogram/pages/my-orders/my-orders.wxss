.page {
  min-height: 100vh;
  padding: 24rpx 32rpx 120rpx;
  background: #ffffff;
  box-sizing: border-box;
  color: #111111;
  font-family: "PingFang SC", -apple-system, BlinkMacSystemFont, "Helvetica Neue", sans-serif;
}

.hero {
  margin-bottom: 24rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid var(--divider);
}

.hero-title {
  display: block;
  color: #111111;
  font-size: 44rpx;
  line-height: 56rpx;
  font-weight: 500;
}

.hero-text {
  display: block;
  margin-top: 8rpx;
  color: #999999;
  font-size: 24rpx;
  line-height: 34rpx;
}

.state-wrap {
  min-height: 62vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  text-align: center;
}

.state-title {
  color: #111111;
  font-size: 30rpx;
  line-height: 42rpx;
  font-weight: 500;
}

.state-text {
  margin-top: 12rpx;
  color: #999999;
  font-size: 24rpx;
  line-height: 34rpx;
}

.list {
  display: flex;
  flex-direction: column;
}

.order-card {
  padding: 0 0 20rpx;
  margin-bottom: 20rpx;
  border-bottom: 1rpx solid var(--divider);
}

.order-card:last-child {
  margin-bottom: 0;
  border-bottom: none;
}

.order-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.order-title {
  flex: 1;
  color: #111111;
  font-size: 32rpx;
  line-height: 44rpx;
  font-weight: 500;
}

.order-status {
  flex-shrink: 0;
  padding: 6rpx 12rpx;
  color: #111111;
  font-size: 22rpx;
  line-height: 32rpx;
  background: rgba(17, 17, 17, 0.05);
  border-radius: 999rpx;
}

.order-status.is-pending,
.order-status.is-failed,
.order-status.is-closed {
  background: rgba(17, 17, 17, 0.05);
}

.order-amount {
  display: block;
  margin-top: 16rpx;
  color: #111111;
  font-size: 34rpx;
  line-height: 46rpx;
  font-weight: 500;
}

.order-meta {
  display: block;
  margin-top: 10rpx;
  color: #999999;
  font-size: 24rpx;
  line-height: 34rpx;
  word-break: break-all;
}
