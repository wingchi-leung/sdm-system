<view class="page">
  <page-header title="我的订单"></page-header>
  <view class="hero" wx:if="{{!loading && !error}}">
    <text class="hero-title">我的订单</text>
    <text class="hero-text">{{orders.length ? summaryText : '这里只展示你的支付记录'}}</text>
  </view>

  <view wx:if="{{loading}}" class="state-wrap">
    <view class="loading"></view>
    <text class="state-text">加载中…</text>
  </view>

  <view wx:elif="{{error}}" class="state-wrap">
    <text class="state-title">加载失败</text>
    <text class="state-text">{{error}}</text>
  </view>

  <view wx:elif="{{orders.length}}" class="list">
    <view class="order-card" wx:for="{{orders}}" wx:key="order_no">
      <view class="order-head">
        <text class="order-title">{{item.activity_name}}</text>
        <text class="order-status {{item.status_class}}">{{item.status_text}}</text>
      </view>
      <text class="order-amount">{{item.amount_display}}</text>
      <text class="order-meta">订单号：{{item.order_no}}</text>
      <text class="order-meta" wx:if="{{item.time_display}}">更新时间：{{item.time_display}}</text>
    </view>
  </view>

  <view wx:else class="state-wrap">
    <text class="state-title">暂无订单</text>
    <text class="state-text">这里仅展示支付记录</text>
  </view>
</view>
