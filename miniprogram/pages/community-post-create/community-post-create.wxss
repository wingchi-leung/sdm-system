.page {
  min-height: 100vh;
  box-sizing: border-box;
  background: #ffffff;
  color: #101828;
}

.header-actions {
  display: flex;
  align-items: center;
  gap: 18rpx;
}

.header-action {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 66rpx;
  height: 66rpx;
  border-radius: 999rpx;
  box-sizing: border-box;
}

.header-action--active {
  background: rgba(16, 24, 40, 0.06);
}

.header-plus-icon {
  color: #111111;
  font-size: 58rpx;
  line-height: 1;
  font-weight: 300;
  margin-top: -6rpx;
}

.header-bell {
  width: 44rpx;
  height: 44rpx;
  flex-shrink: 0;
}

.composer-shell {
  display: flex;
  flex-direction: column;
  gap: 34rpx;
  padding: 12rpx 36rpx 220rpx;
  box-sizing: border-box;
}

.channel-name {
  color: #98a2b3;
  font-size: 24rpx;
  line-height: 1.6;
}

.field {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.field-head {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.field-label {
  color: #101828;
  font-size: 38rpx;
  line-height: 1.25;
  font-weight: 500;
}

.field-required {
  color: #f04438;
  font-size: 30rpx;
  line-height: 1;
}

.title-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding-bottom: 20rpx;
  border-bottom: 2rpx solid #eaecf0;
}

.title-input {
  flex: 1;
  min-width: 0;
  height: 84rpx;
  color: #101828;
  font-size: 34rpx;
  line-height: 84rpx;
}

.input-placeholder {
  color: #98a2b3;
}

.field-counter {
  flex-shrink: 0;
  color: #98a2b3;
  font-size: 26rpx;
  line-height: 1.4;
}

.editor-panel {
  overflow: hidden;
  border: 2rpx solid #e4e7ec;
  border-radius: 24rpx;
  background: #ffffff;
}

.toolbar-scroll {
  width: 100%;
  white-space: nowrap;
  border-bottom: 2rpx solid #eaecf0;
  background: #fcfcfd;
}

.toolbar {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 18rpx 22rpx;
  width: max-content;
  box-sizing: border-box;
}

.tool-btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 64rpx;
  height: 60rpx;
  padding: 0 18rpx;
  border-radius: 14rpx;
  background: #ffffff;
  color: #344054;
  font-size: 26rpx;
  line-height: 1;
  box-shadow: inset 0 0 0 2rpx #eaecf0;
  white-space: nowrap;
  box-sizing: border-box;
}

.tool-btn-text {
  min-width: 108rpx;
  padding: 0 16rpx 0 18rpx;
}

.tool-caret {
  margin-left: 8rpx;
  color: #667085;
  font-size: 18rpx;
}

.tool-btn-italic {
  font-style: italic;
}

.tool-btn-underline {
  text-decoration: underline;
}

.tool-btn-strike {
  text-decoration: line-through;
}

.tool-btn-quote {
  font-size: 22rpx;
}

.tool-btn-image {
  font-size: 24rpx;
}

.tool-btn-clear {
  min-width: 96rpx;
}

.tool-divider {
  width: 2rpx;
  height: 28rpx;
  background: #d0d5dd;
  border-radius: 999rpx;
}

.rich-editor {
  min-height: 560rpx;
  padding: 28rpx 24rpx;
  color: #101828;
  font-size: 30rpx;
  line-height: 1.8;
  box-sizing: border-box;
}

.editor-actions {
  display: flex;
  gap: 16rpx;
  padding: 0 24rpx 20rpx;
}

.editor-action-btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  height: 72rpx;
  padding: 0 24rpx;
  border-radius: 18rpx;
  border: 2rpx solid #d0d5dd;
  background: #ffffff;
  color: #344054;
  box-sizing: border-box;
}

.editor-action-btn-primary {
  border-color: #0f172a;
  background: #0f172a;
  color: #ffffff;
}

.editor-action-icon {
  font-size: 28rpx;
  line-height: 1;
  font-weight: 500;
}

.editor-action-text {
  font-size: 26rpx;
  line-height: 1;
  font-weight: 500;
}

.editor-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  padding: 18rpx 24rpx 24rpx;
}

.editor-tip {
  flex: 1;
  min-width: 0;
  color: #98a2b3;
  font-size: 24rpx;
  line-height: 1.6;
}

.error-box {
  padding: 22rpx 24rpx;
  border-radius: 18rpx;
  background: #fef3f2;
}

.error-text {
  color: #d92d20;
  font-size: 24rpx;
  line-height: 1.7;
}

.footer-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  justify-content: flex-end;
  padding: 24rpx 32rpx calc(24rpx + env(safe-area-inset-bottom));
  background: linear-gradient(180deg, rgba(255, 255, 255, 0) 0%, #ffffff 28%, #ffffff 100%);
}

.submit-btn {
  min-width: 220rpx;
  height: 88rpx;
  margin: 0;
  padding: 0 40rpx;
  border: 0;
  border-radius: 20rpx;
  background: #0f172a;
  color: #ffffff;
  font-size: 30rpx;
  line-height: 88rpx;
  font-weight: 500;
  box-shadow: 0 16rpx 40rpx rgba(15, 23, 42, 0.16);
}

.submit-btn::after {
  border: 0;
}

.submit-btn[disabled] {
  opacity: 0.56;
}
