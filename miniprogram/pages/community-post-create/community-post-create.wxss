.page {
  min-height: 100vh;
  box-sizing: border-box;
  background: #ffffff;
  color: #101828;
}

.composer-shell {
  display: flex;
  flex-direction: column;
  gap: 30rpx;
  padding: 12rpx 36rpx 48rpx;
  box-sizing: border-box;
}

.page-toolbar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.channel-name {
  flex: 1;
  min-width: 0;
  color: #98a2b3;
  font-size: 22rpx;
  line-height: 1.5;
}

.field {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.field-head {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.field-label {
  color: #101828;
  font-size: 28rpx;
  line-height: 1.3;
  font-weight: 500;
}

.field-required {
  color: #f04438;
  font-size: 22rpx;
  line-height: 1;
}

.title-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding-bottom: 18rpx;
  border-bottom: 2rpx solid #eceff3;
}

.title-input {
  flex: 1;
  min-width: 0;
  height: 74rpx;
  color: #101828;
  font-size: 28rpx;
  line-height: 74rpx;
}

.input-placeholder {
  color: #98a2b3;
}

.field-counter {
  flex-shrink: 0;
  color: #98a2b3;
  font-size: 22rpx;
  line-height: 1.4;
}

.editor-panel {
  overflow: hidden;
  border: 2rpx solid #e6eaf0;
  border-radius: 22rpx;
  background: #ffffff;
}

.toolbar-scroll {
  width: 100%;
  white-space: nowrap;
  border-bottom: 2rpx solid #eceff3;
  background: #ffffff;
}

.toolbar {
  display: flex;
  align-items: center;
  gap: 10rpx;
  padding: 16rpx 18rpx;
  width: max-content;
  box-sizing: border-box;
}

.tool-btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 48rpx;
  height: 50rpx;
  padding: 0 12rpx;
  border-radius: 12rpx;
  background: transparent;
  color: #344054;
  font-size: 22rpx;
  line-height: 1;
  white-space: nowrap;
  box-sizing: border-box;
}

.tool-btn:active {
  background: rgba(16, 24, 40, 0.06);
}

.tool-btn-text {
  min-width: 96rpx;
  padding: 0 14rpx 0 16rpx;
}

.tool-btn-icon {
  min-width: 52rpx;
  padding: 0 9rpx;
}

.tool-caret {
  margin-left: 8rpx;
  color: #667085;
  font-size: 14rpx;
}

.tool-text-icon {
  color: #344054;
  font-size: 22rpx;
  line-height: 1;
  font-weight: 600;
}

.tool-btn-italic .tool-text-icon {
  font-style: italic;
}

.tool-divider {
  width: 2rpx;
  height: 24rpx;
  background: #d0d5dd;
  border-radius: 999rpx;
}

.tool-icon {
  position: relative;
  width: 28rpx;
  height: 28rpx;
}

.tool-icon-align {
  display: flex;
  flex-direction: column;
  justify-content: center;
  gap: 5rpx;
}

.tool-icon-align__line {
  width: 18rpx;
  height: 2rpx;
  border-radius: 999rpx;
  background: #344054;
}

.tool-icon-align__line--wide {
  width: 28rpx;
}

.tool-icon-bullet {
  display: flex;
  align-items: center;
  justify-content: center;
}

.tool-icon-bullet__rows {
  display: flex;
  flex-direction: column;
  justify-content: center;
  gap: 3rpx;
  width: 100%;
}

.tool-icon-bullet__row {
  display: flex;
  align-items: center;
  gap: 5rpx;
}

.tool-icon-bullet__dot {
  width: 6rpx;
  height: 6rpx;
  border-radius: 999rpx;
  background: #344054;
  flex-shrink: 0;
}

.tool-icon-bullet__line {
  width: 15rpx;
  height: 2rpx;
  border-radius: 999rpx;
  background: #344054;
}

.tool-icon-ordered {
  display: flex;
  align-items: center;
  gap: 5rpx;
  width: 100%;
}

.tool-icon-ordered__num {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  justify-content: center;
  gap: 0;
  width: 10rpx;
  flex-shrink: 0;
}

.tool-icon-ordered__num-text {
  color: #344054;
  font-size: 10rpx;
  line-height: 1;
  font-weight: 600;
  transform: scale(0.92);
  transform-origin: left center;
}

.tool-icon-ordered__lines {
  display: flex;
  flex-direction: column;
  justify-content: center;
  gap: 4rpx;
  flex: 1;
}

.tool-icon-ordered__line {
  width: 15rpx;
  height: 2rpx;
  border-radius: 999rpx;
  background: #344054;
}

.tool-icon-image {
  display: flex;
  align-items: center;
  justify-content: center;
}

.tool-icon-image__frame {
  position: absolute;
  inset: 2rpx;
  border: 2rpx solid #344054;
  border-radius: 4rpx;
}

.tool-icon-image__sun {
  position: absolute;
  right: 6rpx;
  top: 5rpx;
  width: 4rpx;
  height: 4rpx;
  border-radius: 999rpx;
  background: #344054;
}

.tool-icon-image__mountain {
  position: absolute;
  left: 6rpx;
  bottom: 5rpx;
  width: 0;
  height: 0;
  border-left: 7rpx solid transparent;
  border-right: 7rpx solid transparent;
  border-bottom: 8rpx solid #344054;
  opacity: 0.9;
}

.tool-icon-more {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 4rpx;
}

.tool-icon-more__dot {
  width: 5rpx;
  height: 5rpx;
  border-radius: 999rpx;
  background: #344054;
}

.rich-editor {
  min-height: 540rpx;
  padding: 24rpx 22rpx;
  color: #101828;
  font-size: 28rpx;
  line-height: 1.75;
  box-sizing: border-box;
}

.editor--community-thumb-image {
  border-radius: 20rpx;
  margin: 18rpx 0;
  box-shadow: 0 10rpx 28rpx rgba(15, 23, 42, 0.10);
}

.editor-actions {
  display: flex;
  gap: 16rpx;
  padding: 0 22rpx 14rpx;
}

.editor-action-btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  height: 70rpx;
  padding: 0 24rpx;
  border-radius: 16rpx;
  border: 2rpx solid #d0d5dd;
  background: #ffffff;
  color: #344054;
  box-sizing: border-box;
}

.editor-action-btn-primary {
  border-color: #0f172a;
  background: #0f172a;
  color: #ffffff;
}

.editor-action-icon {
  font-size: 24rpx;
  line-height: 1;
  font-weight: 500;
}

.editor-action-text {
  font-size: 22rpx;
  line-height: 1;
  font-weight: 500;
}

.editor-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  padding: 10rpx 22rpx 22rpx;
}

.editor-tip {
  flex: 1;
  min-width: 0;
  color: #98a2b3;
  font-size: 20rpx;
  line-height: 1.6;
}

.error-box {
  padding: 22rpx 24rpx;
  border-radius: 18rpx;
  background: #fef3f2;
}

.error-text {
  color: #d92d20;
  font-size: 22rpx;
  line-height: 1.7;
}

.submit-btn {
  min-width: 0;
  height: 44rpx;
  margin: 0;
  padding: 0 8rpx;
  border: 0;
  border-radius: 0;
  background: transparent;
  color: #0f172a;
  font-size: 24rpx;
  line-height: 44rpx;
  font-weight: 600;
}

.submit-btn-top {
  flex-shrink: 0;
}

.submit-btn::after {
  border: 0;
}

.submit-btn[disabled] {
  opacity: 0.4;
}
