.page {
  min-height: 100vh;
  padding: 24rpx 32rpx 40rpx;
  background: var(--background);
}

.field {
  margin-bottom: 24rpx;
}

.field-label,
.upload-hint {
  display: block;
  color: #999999;
  font-size: 24rpx;
  line-height: 34rpx;
  font-weight: 400;
  letter-spacing: 0.4rpx;
}

.field-label {
  margin-bottom: 12rpx;
}

.input,
.static-box,
.textarea {
  width: 100%;
  box-sizing: border-box;
  border-radius: 16rpx;
  background: #F8F8F6;
  color: var(--text-primary);
  font-size: 28rpx;
  line-height: 40rpx;
  letter-spacing: 0.4rpx;
}

.input,
.static-box {
  height: 88rpx;
  padding: 24rpx;
}

.static-text {
  color: var(--text-primary);
}

.textarea {
  min-height: 320rpx;
  padding: 24rpx;
}

.input-placeholder {
  color: var(--text-muted);
}

.poster-section {
  margin-top: 12rpx;
}

.poster-upload {
  width: 100%;
  height: 300rpx;
  border: 2rpx dashed var(--border);
  border-radius: 20rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: var(--background-subtle);
}

.upload-icon {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: var(--border);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 44rpx;
  color: var(--text-tertiary);
  margin-bottom: 12rpx;
}

.upload-text {
  font-size: 28rpx;
  color: var(--text-secondary);
}

.poster-preview {
  position: relative;
  width: 100%;
  height: 300rpx;
  border-radius: 20rpx;
  overflow: hidden;
}

.poster-image {
  width: 100%;
  height: 100%;
}

.poster-remove {
  position: absolute;
  top: 16rpx;
  right: 16rpx;
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: rgba(0, 0, 0, 0.56);
  display: flex;
  align-items: center;
  justify-content: center;
}

.remove-icon {
  color: #FFFFFF;
  font-size: 32rpx;
}

.error-box {
  margin: 16rpx 0 24rpx;
  padding: 20rpx 24rpx;
  background: var(--error-bg);
  border-left: 2px solid var(--error);
}

.error-text {
  color: var(--error);
  font-size: 24rpx;
  line-height: 1.6;
}

.btn-submit {
  width: 100%;
  height: 88rpx;
  margin-top: 24rpx;
  border: 0;
  border-radius: 16rpx;
  background: #2F4F46;
}

.btn-submit::after {
  border: 0;
}

.btn-submit[disabled] {
  opacity: 0.6;
}

.btn-text {
  color: #FFFFFF;
  font-size: 28rpx;
  font-weight: 500;
  letter-spacing: 0.4rpx;
}
