<view class="page">
  <view class="form">
    <!-- 频道信息 -->
    <view class="field">
      <text class="field-label">所属频道</text>
      <view class="static-box">
        <text class="static-text">{{channelName || '当前频道'}}</text>
      </view>
    </view>

    <!-- 标题 -->
    <view class="field">
      <text class="field-label">标题</text>
      <input
        class="input"
        placeholder="请输入动态标题"
        placeholder-class="input-placeholder"
        value="{{title}}"
        maxlength="60"
        bindinput="onTitleInput"
      />
    </view>

    <!-- 富文本编辑器(微信原生 <editor> 单编辑器,支持图文混排) -->
    <view class="field">
      <view class="field-label-row">
        <text class="field-label">正文</text>
        <text class="field-tip">支持加粗/斜体/列表/插入图片</text>
      </view>
      <view class="editor-wrap">
        <editor
          id="richEditor"
          class="rich-editor"
          placeholder="说点什么…"
          show-img-toolbar="{{true}}"
          show-img-resize="{{true}}"
          bindinput="onEditorInput"
          bindready="onEditorReady"
          bindblur="onEditorBlur"
        />
      </view>
    </view>

    <!-- 错误提示 -->
    <view wx:if="{{error}}" class="error-box">
      <text class="error-text">{{error}}</text>
    </view>

    <!-- 提交 -->
    <button class="btn-submit" disabled="{{submitting}}" bindtap="onSubmit">
      <text class="btn-text">{{submitting ? '发布中…' : '发布动态'}}</text>
    </button>
  </view>
</view>
