<view class="page">
  <page-header title="发布动态" statusBarHeight="{{statusBarHeight}}" bindback="onBackTap">
    <view slot="actions" class="header-actions">
      <view class="header-action header-action-plus" bindtap="onAddTap" hover-class="header-action--active">
        <text class="header-plus-icon">+</text>
      </view>
      <image class="header-bell" src="/assets/icons/bell.png" mode="aspectFit" bindtap="onBellTap" />
    </view>
  </page-header>

  <view class="composer-shell">
    <text wx:if="{{channelName}}" class="channel-name">{{channelName}}</text>

    <view class="field field-title">
      <view class="field-head">
        <text class="field-label">标题</text>
        <text class="field-required">*</text>
      </view>
      <view class="title-row">
        <input
          class="title-input"
          placeholder="输入动态标题"
          placeholder-class="input-placeholder"
          value="{{title}}"
          maxlength="50"
          bindinput="onTitleInput"
        />
        <text class="field-counter">{{titleLength}}/50</text>
      </view>
    </view>

    <view class="field field-editor">
      <view class="field-head">
        <text class="field-label">正文</text>
        <text class="field-required">*</text>
      </view>

      <view class="editor-panel">
        <scroll-view class="toolbar-scroll" scroll-x="{{true}}" enable-flex="{{true}}" show-scrollbar="{{false}}">
          <view class="toolbar">
            <view class="tool-btn tool-btn-text" data-action="paragraph" bindtap="onToolbarAction">
              <text>正文</text>
              <text class="tool-caret">⌄</text>
            </view>
            <view class="tool-btn tool-btn-strong" data-action="bold" bindtap="onToolbarAction">B</view>
            <view class="tool-btn tool-btn-italic" data-action="italic" bindtap="onToolbarAction">I</view>
            <view class="tool-btn tool-btn-underline" data-action="underline" bindtap="onToolbarAction">U</view>
            <view class="tool-btn tool-btn-strike" data-action="strike" bindtap="onToolbarAction">S</view>
            <view class="tool-divider"></view>
            <view class="tool-btn tool-btn-align" data-action="align-left" bindtap="onToolbarAction">≡</view>
            <view class="tool-btn" data-action="list-bullet" bindtap="onToolbarAction">•</view>
            <view class="tool-btn" data-action="list-ordered" bindtap="onToolbarAction">1.</view>
            <view class="tool-btn tool-btn-quote" data-action="blockquote" bindtap="onToolbarAction">“ ”</view>
            <view class="tool-btn tool-btn-image" data-action="insert-image" bindtap="onToolbarAction">图片</view>
            <view class="tool-btn tool-btn-clear" data-action="clear" bindtap="onToolbarAction">清空</view>
          </view>
        </scroll-view>

        <editor
          id="richEditor"
          class="rich-editor"
          placeholder="输入正文内容"
          show-img-toolbar="{{false}}"
          show-img-resize="{{true}}"
          bindready="onEditorReady"
          bindinput="onEditorInput"
          bindblur="onEditorBlur"
        />

        <view class="editor-actions">
          <view class="editor-action-btn editor-action-btn-primary" bindtap="onInsertImage">
            <text class="editor-action-icon">＋</text>
            <text class="editor-action-text">插入图片</text>
          </view>
          <view class="editor-action-btn" data-action="clear" bindtap="onToolbarAction">
            <text class="editor-action-text">清空正文</text>
          </view>
        </view>

        <view class="editor-footer">
          <text class="editor-tip">支持图文混排，最多插入 9 张图片</text>
          <text class="field-counter">{{contentLength}} 字</text>
        </view>
      </view>
    </view>

    <view wx:if="{{error}}" class="error-box">
      <text class="error-text">{{error}}</text>
    </view>
  </view>

  <view class="footer-bar">
    <button class="submit-btn" disabled="{{submitting}}" bindtap="onSubmit">
      {{submitting ? '发布中…' : '发布'}}
    </button>
  </view>
</view>
