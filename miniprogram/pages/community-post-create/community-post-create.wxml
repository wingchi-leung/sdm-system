<view class="page">
  <view class="form">
    <view class="field">
      <text class="field-label">所属活动</text>
      <view class="static-box">
        <text class="static-text">{{activityName || activity.activity_name || '当前活动'}}</text>
      </view>
    </view>

    <view class="field">
      <text class="field-label">标题</text>
      <input
        class="input"
        placeholder="请输入动态标题"
        placeholder-class="input-placeholder"
        value="{{title}}"
        bindinput="onTitleInput"
      />
    </view>

    <view class="field">
      <text class="field-label">正文</text>
      <textarea
        class="textarea"
        placeholder="请输入动态内容"
        placeholder-class="input-placeholder"
        value="{{content}}"
        bindinput="onContentInput"
        maxlength="10000"
      />
    </view>

    <view class="field">
      <text class="field-label">封面图</text>
      <view class="poster-section">
        <view wx:if="{{coverLocalPath}}" class="poster-preview">
          <image class="poster-image" src="{{coverLocalPath}}" mode="aspectFill" />
          <view class="poster-remove" bindtap="onRemoveCover">
            <text class="remove-icon">×</text>
          </view>
        </view>
        <view wx:else class="poster-upload" bindtap="onChooseCover">
          <view class="upload-icon">+</view>
          <text class="upload-text">选择封面图</text>
          <text class="upload-hint">支持 PNG、JPG，最大 5MB</text>
        </view>
      </view>
    </view>

    <view wx:if="{{error}}" class="error-box">
      <text class="error-text">{{error}}</text>
    </view>

    <button class="btn-submit" disabled="{{submitting}}" bindtap="onSubmit">
      <text class="btn-text">{{submitting ? '发布中…' : '发布动态'}}</text>
    </button>
  </view>
</view>
