.page {
  min-height: 100vh;
  background: #f7f6f2;
}

.nav-btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}

.nav-btn-more {
  min-width: 72rpx;
  height: 72rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  background: rgba(116, 128, 243, 0.04);
}

.nav-btn-more:active {
  background: rgba(17, 17, 17, 0.08);
}

.nav-icon.more {
  color: #111111;
  font-size: 20rpx;
  line-height: 1;
  letter-spacing: 0.06em;
  font-weight: 700;
}

.shell {
  min-height: 100vh;
  padding: 18rpx 48rpx calc(48rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
  background: radial-gradient(circle at top, #ffffff 0%, #ffffff 45%, #ffffff 100%);
}

.shell-more-row {
  display: flex;
  justify-content: flex-end;
  align-items: center;
  padding-top: 6rpx;
}

.content {
  padding-top: 24rpx;
  padding-bottom: 32rpx;
}

.hero {
  margin-top: 8rpx;
}

.hero-title {
  display: block;
  color: #111111;
  font-size: 42rpx;
  line-height: 1.05;
  letter-spacing: 0.02em;
  font-weight: 500;
}

.hero-subtitle {
  display: block;
  margin-top: 22rpx;
  color: #7c7c7c;
  font-size: 24rpx;
  line-height: 1.35;
}

.channel-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 24rpx;
  margin-top: 104rpx;
}

.channel-actions {
  display: flex;
  align-items: center;
  gap: 16rpx;
  flex-shrink: 0;
}

.action-stack {
  display: flex;
  gap: 10rpx;
}

.channel-copy {
  min-width: 0;
  margin-top: 10px;
}

.channel-name {
  display: block;
  color: #111111;
  font-size: 34rpx;
  line-height: 1.2;
  letter-spacing: 0.01em;
  font-weight: 500;
}

.channel-meta {
  display: block;
  margin-top: 16rpx;
  color: #8d8d8d;
  font-size: 24rpx;
  line-height: 1;
}

.member-list {
  margin-top: 50rpx;
}

.member-row {
  display: flex;
  align-items: center;
  gap: 24rpx;
  padding: 18rpx 0 22rpx;
}

.member-avatar {
  position: relative;
  width: 124rpx;
  height: 124rpx;
  flex-shrink: 0;
  overflow: hidden;
  border-radius: 50%;
}

.member-avatar-image {
  width: 100%;
  height: 100%;
  display: block;
}

.member-avatar-text {
  position: absolute;
  left: 50%;
  top: 50%;
  color: rgba(255, 255, 255, 0.98);
  font-size: 28rpx;
  line-height: 1;
  transform: translate(-50%, -50%);
}

.member-main {
  flex: 1;
  min-width: 0;
}

.member-title-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  flex-wrap: wrap;
}

.member-name {
  color: #111111;
  font-size: 32rpx;
  line-height: 1.15;
  letter-spacing: 0.01em;
  font-weight: 500;
}

.member-badge {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: #f4f2ef;
  color: #555555;
  font-size: 24rpx;
  line-height: 1;
  box-shadow: inset 0 2rpx 0 rgba(255, 255, 255, 0.9);
}

.member-meta {
  display: block;
  margin-top: 18rpx;
  color: #8a8a8a;
  font-size: 24rpx;
  line-height: 1.2;
}

.member-state {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  margin-top: 14rpx;
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  line-height: 1;
}

.member-state--muted {
  color: #666666;
  background: #f3f2f0;
}
 
.state-wrap {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  padding-top: 40rpx;
}

.state-wrap--loading {
  gap: 18rpx;
}

.state-wrap--error {
  gap: 18rpx;
}

.loading-card {
  border-radius: 999rpx;
  background: rgba(17, 17, 17, 0.06);
  animation: pulse 1.2s ease-in-out infinite;
}

.loading-card--headline {
  width: 68%;
  height: 96rpx;
}

.loading-card--sub {
  width: 56%;
  height: 34rpx;
}

.loading-card--line {
  width: 100%;
  height: 1rpx;
  margin-top: 36rpx;
  border-radius: 0;
}

.state-title {
  color: #111111;
  font-size: 34rpx;
  line-height: 1.4;
  font-weight: 500;
}

.state-text {
  color: #777777;
  font-size: 24rpx;
  line-height: 1.7;
}

.state-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 10rpx;
}

.state-btn {
  height: 70rpx;
  padding: 0 24rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  border-radius: 20rpx;
  background: #111111;
  color: #ffffff;
  font-size: 26rpx;
  line-height: 1;
}

.state-btn--ghost {
  background: #f0efec;
  color: #111111;
}

.empty-box {
  min-height: 40vh;
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  justify-content: center;
  padding-top: 88rpx;
}

.empty-title {
  color: #111111;
  font-size: 32rpx;
  line-height: 1.35;
  font-weight: 500;
}

.empty-text {
  margin-top: 12rpx;
  color: #7a7a7a;
  font-size: 24rpx;
  line-height: 1.7;
}

@keyframes pulse {
  0%, 100% {
    opacity: 0.75;
  }

  50% {
    opacity: 0.42;
  }
}
