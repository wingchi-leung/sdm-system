<view class="page">
  <page-header title="社区管理" statusBarHeight="{{statusBarHeight}}"></page-header>
  <view class="shell">
    <view wx:if="{{showPageMenu}}" class="shell-more-row">
      <view class="nav-btn nav-btn-more" bindtap="onPageMoreTap" aria-label="更多">
        <text class="nav-icon more">···</text>
      </view>
    </view>

    <view wx:if="{{loading}}" class="state-wrap state-wrap--loading">
      <view class="loading-card loading-card--headline"></view>
      <view class="loading-card loading-card--sub"></view>
      <view class="loading-card loading-card--line"></view>
    </view>

    <view wx:elif="{{error}}" class="state-wrap state-wrap--error">
      <text class="state-title">暂时无法查看成员</text>
      <text class="state-text">{{error}}</text>
      <view class="state-actions">
        <view class="state-btn state-btn--ghost" bindtap="loadMembers">
          <text>重试</text>
        </view>
        <view class="state-btn" bindtap="onInviteMembers">
          <text>邀请成员</text>
        </view>
      </view>
    </view>

    <view wx:else class="content">
   
      <view class="channel-copy">
        <text class="channel-name">{{channelName}}</text>
        <text class="channel-meta">{{channelMemberCount}} 位成员</text>
      </view>
 
      <view wx:if="{{members.length === 0}}" class="empty-box">
        <text class="empty-title">暂无成员</text>
        <text class="empty-text">邀请成员后，这里会显示社区的人员列表。</text>
      </view>

      <view wx:else class="member-list">
        <view wx:for="{{members}}" wx:key="id" class="member-row">
          <view class="member-avatar" >
            <image wx:if="{{item.avatarDisplayUrl}}" class="member-avatar-image" src="{{item.avatarDisplayUrl}}" mode="aspectFill" />
            <text wx:else class="member-avatar-text">{{item.avatarText}}</text>
          </view>

          <view class="member-main">
            <view class="member-title-row">
              <text class="member-name">{{item.user_name}}</text>
              <text class="member-badge">{{item.role_label === '管理员' ? '创建者' : item.role_label}}</text>
            </view>

            <text class="member-meta">{{item.joined_display}}</text>

            <view wx:if="{{item.status_label !== '正常'}}" class="member-state member-state--muted">
              <text>{{item.status_label}}</text>
            </view>
          </view>

       
        </view>
      </view>
    </view>
  </view>
</view>
