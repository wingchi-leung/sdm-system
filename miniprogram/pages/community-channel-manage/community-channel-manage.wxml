<view class="page">
  <view class="hero">
    <text class="hero-caption">CHANNEL MANAGEMENT</text>
    <text class="hero-title">{{channelName || '频道管理'}}</text>
    <text class="hero-subtitle">查看成员、邀请新成员，并对异常成员做管理操作。</text>
    <view class="hero-meta">
      <text class="meta-pill">{{channelMemberCount}} 人</text>
      <text class="meta-pill">{{channelRole === 'admin' ? '管理员权限' : '成员视图'}}</text>
    </view>
    <view class="hero-actions">
      <view wx:if="{{showInviteButton}}" class="primary-btn" bindtap="onInviteMembers">
        <text>{{inviting ? '邀请中…' : '邀请成员'}}</text>
      </view>
      <view wx:if="{{showDeleteButton}}" class="danger-btn" bindtap="onDeleteChannel">
        <text>{{deleting ? '删除中…' : '删除频道'}}</text>
      </view>
      <view class="secondary-btn" bindtap="loadMembers">
        <text>刷新</text>
      </view>
    </view>
  </view>

  <view wx:if="{{loading}}" class="state-wrap">
    <text class="state-text">加载中…</text>
  </view>

  <view wx:elif="{{error}}" class="state-wrap">
    <text class="state-title">暂时无法查看成员</text>
    <text class="state-text">{{error}}</text>
  </view>

  <view wx:elif="{{members.length === 0}}" class="empty-box">
    <text class="empty-title">暂无成员</text>
    <text class="empty-text">邀请成员后，这里会显示频道的人员列表。</text>
  </view>

  <view wx:else class="member-list">
    <view wx:for="{{members}}" wx:key="id" class="member-card">
      <view class="member-main">
        <view class="member-avatar">
          <text class="member-avatar-text">{{item.user_name ? item.user_name.slice(0, 1) : '人'}}</text>
        </view>
        <view class="member-copy">
          <view class="member-title-row">
            <text class="member-name">{{item.user_name}}</text>
            <text class="badge role-badge">{{item.role_label}}</text>
          </view>
          <text class="member-meta">用户 ID {{item.user_id}}</text>
          <text wx:if="{{item.joined_display}}" class="member-meta">加入时间 {{item.joined_display}}</text>
        </view>
      </view>

      <view class="member-footer">
        <text class="badge status-badge {{item.status_class}}">{{item.status_label}}</text>
        <view wx:if="{{item.can_action}}" class="member-actions">
          <text wx:if="{{item.can_kick}}" class="action-link" data-member="{{item}}" bindtap="onKickMember">踢出</text>
          <text wx:if="{{item.can_ban}}" class="action-link" data-member="{{item}}" bindtap="onBanMember">禁言</text>
          <text wx:if="{{item.can_unban}}" class="action-link" data-member="{{item}}" bindtap="onUnbanMember">解禁</text>
        </view>
      </view>
    </view>
  </view>
</view>
