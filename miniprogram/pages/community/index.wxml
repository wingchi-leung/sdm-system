<view class="page">
  <view class="hero">
    <image class="hero-bg" src="/assets/communtiy_banner.png" mode="aspectFill" />
    <view class="hero-mask"></view>

    <view class="hero-actions">
      <view class="icon-btn" bindtap="onOpenNotifications" aria-label="社区通知">
        <image class="icon-bell-image" src="/assets/icons/bell.png" mode="aspectFit" />
        <view wx:if="{{unreadCount > 0}}" class="icon-badge" aria-hidden="true"></view>
      </view>
      <view class="icon-btn icon-btn-add" bindtap="onCreateChannel" aria-label="创建社区">
        <text class="icon-plus">＋</text>
      </view>
    </view>

    <view class="hero-copy">
      <image
        class="hero-title-image"
        src="/assets/text/renzhi-shiye-community.png"
        mode="aspectFit"
        aria-hidden="true"
      />
      <view class="hero-subtitle">
        <text class="hero-subtitle-line">Expand your</text>
        <text class="hero-subtitle-line">perspective.</text>
      </view>
    </view>
  </view>

  <view class="page-body">
    <view wx:if="{{loading}}" class="state-wrap">
      <text class="state-text">加载中…</text>
    </view>

    <view wx:elif="{{error}}" class="state-wrap">
      <text class="state-title">暂时无法查看社区</text>
      <text class="state-text">{{error}}</text>
    </view>

    <view wx:elif="{{channels.length === 0}}" class="state-wrap state-wrap-empty">
      <text class="state-title">还没有加入任何社区</text>
    </view>

    <view wx:else class="channel-section">
      <view class="section-head">
        <text class="section-title">我的社区</text>
      </view>

      <view class="channel-list">
        <view wx:for="{{channels}}" wx:key="id" class="channel-item" data-channel="{{item}}" bindtap="onOpenChannel">
          <view class="channel-thumb {{item.cover_theme}}">
            <image wx:if="{{item.cover_url}}" class="channel-thumb-image" src="{{item.cover_url}}" mode="aspectFill" />
            <view wx:else class="channel-thumb-placeholder">
              <view class="thumb-circle thumb-circle-large"></view>
              <view class="thumb-circle thumb-circle-small"></view>
              <text class="channel-thumb-text">{{item.short_name}}</text>
            </view>
          </view>

          <view class="channel-main">
            <text class="channel-name">{{item.name}}</text>
            <text wx:if="{{item.description}}" class="channel-desc">{{item.description}}</text>
            <view class="channel-actions">
            </view>
          </view>

          <text class="channel-arrow ui-chevron ui-chevron--md">›</text>
        </view>
      </view>
    </view>
  </view>
</view>
