<view class="page">
  <view class="topbar">
    <text class="topbar-title">社区</text>
    <view class="topbar-tools">
      <view class="icon-btn" bindtap="onOpenNotifications">
        <image class="icon-bell-image" src="/assets/icons/bell.png" mode="aspectFit" />
        <view wx:if="{{unreadCount > 0}}" class="icon-badge">{{unreadCount > 99 ? '99+' : unreadCount}}</view>
      </view>
      <view class="icon-btn" bindtap="onCreateChannel">
        <text class="icon-plus">＋</text>
      </view>
    </view>
  </view>

  <view class="hero">
    <text class="hero-title">我的社区</text>
    <view class="hero-accent"></view>
  </view>

  <view wx:if="{{loading}}" class="state-wrap">
    <text class="state-text">加载中…</text>
  </view>

  <view wx:elif="{{error}}" class="state-wrap">
    <text class="state-title">暂时无法查看社区</text>
    <text class="state-text">{{error}}</text>
  </view>

  <view wx:elif="{{channels.length === 0}}" class="state-wrap">
    <text class="state-title">还没有加入任何社区</text>
    <text class="state-text">创建社区或接受邀请后，会在这里显示。</text>
  </view>

  <view wx:else class="channel-list">
    <view wx:for="{{channels}}" wx:key="id" class="channel-item" data-channel="{{item}}" bindtap="onOpenChannel">
      <view class="channel-cover {{item.cover_theme}}">
        <image wx:if="{{item.cover_url}}" class="channel-cover-image" src="{{item.cover_url}}" mode="aspectFill" />
        <view wx:else class="channel-cover-placeholder">
          <view class="cover-ghost-line cover-ghost-line-top"></view>
          <view class="cover-ghost-line cover-ghost-line-mid"></view>
          <text class="channel-cover-text">{{item.short_name}}</text>
        </view>
      </view>

      <view class="channel-main">
        <view class="channel-main-top">
          <text class="channel-name">{{item.name}}</text>
        </view>
        <text wx:if="{{item.description}}" class="channel-desc">{{item.description}}</text>
        <view class="channel-meta">
          <text class="meta-pill">{{item.member_count}} 人</text>
          <text class="meta-pill">{{item.role_label}}</text>
        </view>
      </view>

      <text class="channel-arrow">›</text>
    </view>
  </view>
</view>
