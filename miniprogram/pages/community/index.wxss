.page {
  min-height: 100vh;
  box-sizing: border-box;
  padding: calc(env(safe-area-inset-top) + 20rpx) 28rpx calc(132rpx + env(safe-area-inset-bottom));
  background:
    radial-gradient(circle at 0% 0%, rgba(245, 241, 235, 0.9) 0%, rgba(255, 255, 255, 0) 38%),
    linear-gradient(180deg, #fdfcf9 0%, #ffffff 58%, #faf9f6 100%);
}

.hero {
  position: relative;
  min-height: 500rpx;
  overflow: hidden;
  border-radius: 34rpx;
  background: #ffffff;
  box-shadow: 0 18rpx 50rpx rgba(17, 24, 39, 0.06);
}

.hero-bg {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  opacity: 0.88;
}

.hero-mask {
  position: absolute;
  inset: 0;
  background:
    linear-gradient(180deg, rgba(255, 255, 255, 0.84) 0%, rgba(255, 255, 255, 0.68) 44%, rgba(255, 255, 255, 0.94) 100%),
    radial-gradient(circle at 72% 28%, rgba(255, 255, 255, 0.42) 0%, rgba(255, 255, 255, 0) 24%);
}

.hero-actions {
  position: absolute;
  top: 28rpx;
  right: 26rpx;
  z-index: 2;
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.icon-btn {
  position: relative;
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.74);
  box-shadow: 0 8rpx 22rpx rgba(17, 24, 39, 0.08);
  backdrop-filter: blur(8px);
}

.icon-btn-add {
  width: 68rpx;
  height: 68rpx;
}

.icon-bell-image {
  width: 34rpx;
  height: 34rpx;
  display: block;
}

.icon-plus {
  color: #101828;
  font-size: 44rpx;
  line-height: 1;
  font-weight: 300;
}

.icon-badge {
  position: absolute;
  top: -4rpx;
  right: -2rpx;
  min-width: 30rpx;
  height: 30rpx;
  padding: 0 8rpx;
  border-radius: 999rpx;
  background: #111111;
  color: #ffffff;
  font-size: 18rpx;
  line-height: 30rpx;
  text-align: center;
}

.hero-copy {
  position: absolute;
  left: 28rpx;
  right: 28rpx;
  bottom: 42rpx;
  z-index: 2;
}

.hero-title {
  display: block;
  color: #111111;
  font-size: 58rpx;
  line-height: 1.05;
  font-weight: 300;
  letter-spacing: 0.06em;
  font-family: "Songti SC", "STSong", "Times New Roman", serif;
}

.hero-subtitle {
  display: flex;
  flex-direction: column;
  margin-top: 20rpx;
  color: #868686;
  font-size: 30rpx;
  line-height: 1.45;
  font-weight: 300;
  letter-spacing: 0.03em;
}

.hero-subtitle-line {
  display: block;
}

.state-wrap {
  min-height: 38vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 44rpx 0 18rpx;
  text-align: center;
}

.state-wrap-empty {
  min-height: 26vh;
}

.state-title {
  color: #111111;
  font-size: 34rpx;
  line-height: 1.35;
  font-weight: 500;
}

.state-text {
  margin-top: 14rpx;
  color: #868686;
  font-size: 24rpx;
  line-height: 1.7;
}

.channel-section {
  margin-top: 40rpx;
}

.section-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 6rpx;
}

.section-title {
  color: #111111;
  font-size: 34rpx;
  line-height: 1.35;
  font-weight: 600;
  letter-spacing: 0.02em;
}

.channel-list {
  margin-top: 10rpx;
}

.channel-item {
  display: flex;
  align-items: center;
  gap: 24rpx;
  padding: 28rpx 4rpx;
  border-bottom: 1rpx solid rgba(17, 17, 17, 0.08);
}

.channel-thumb {
  position: relative;
  width: 112rpx;
  height: 112rpx;
  flex-shrink: 0;
  overflow: hidden;
  border-radius: 24rpx;
  background: #f0ede8;
  box-shadow: inset 0 0 0 1rpx rgba(17, 17, 17, 0.08);
}

.channel-thumb-image {
  width: 100%;
  height: 100%;
}

.channel-thumb-placeholder {
  position: relative;
  width: 100%;
  height: 100%;
  overflow: hidden;
  background:
    radial-gradient(circle at 24% 26%, rgba(255, 255, 255, 0.98) 0%, rgba(255, 255, 255, 0) 24%),
    radial-gradient(circle at 78% 76%, rgba(255, 255, 255, 0.2) 0%, rgba(255, 255, 255, 0) 18%),
    linear-gradient(135deg, #151515 0%, #4a4a4a 100%);
}

.thumb-circle {
  position: absolute;
  border-radius: 999rpx;
  border: 3rpx solid rgba(255, 255, 255, 0.5);
}

.thumb-circle-large {
  left: -6rpx;
  top: -6rpx;
  width: 66rpx;
  height: 66rpx;
  background: rgba(0, 0, 0, 0.88);
}

.thumb-circle-small {
  right: 6rpx;
  bottom: 8rpx;
  width: 42rpx;
  height: 42rpx;
  background: rgba(255, 255, 255, 0.82);
}

.channel-thumb-text {
  position: absolute;
  left: 50%;
  bottom: 12rpx;
  z-index: 1;
  transform: translateX(-50%);
  color: rgba(255, 255, 255, 0.9);
  font-size: 24rpx;
  line-height: 1;
  font-weight: 500;
  letter-spacing: 0.12em;
}

.theme-ocean,
.theme-mist,
.theme-sand,
.theme-forest {
  background: #f1efe9;
}

.channel-main {
  flex: 1;
  min-width: 0;
}

.channel-name {
  display: block;
  color: #111111;
  font-size: 32rpx;
  line-height: 1.35;
  font-weight: 500;
  letter-spacing: 0.02em;
}

.channel-desc {
  display: block;
  margin-top: 10rpx;
  color: #6f6f6f;
  font-size: 24rpx;
  line-height: 1.55;
}

.channel-arrow {
  flex-shrink: 0;
  color: #111111;
  font-size: 38rpx;
  line-height: 1;
  font-weight: 300;
  opacity: 0.8;
  padding-left: 4rpx;
}
