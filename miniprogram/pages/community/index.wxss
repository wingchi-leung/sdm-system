.page {
  min-height: 100vh;
  box-sizing: border-box;
  padding-bottom: calc(132rpx + env(safe-area-inset-bottom));
  background: #ffffff;
}

.hero {
  position: relative;
  width: 100%;
  height: 440rpx;
  overflow: hidden;
  background:
    radial-gradient(circle at 52% 58%, rgba(255, 255, 255, 0.80) 0%, rgba(255, 255, 255, 0.90) 46%, rgba(248, 246, 242, 0.96) 100%),
    #ffffff;
}

.hero-bg {
  position: absolute;
  left: 0;
  top: 0;
  width: 100%;
  height: 100%;
  opacity: 1;
  display: block;
}

.hero-mask {
  position: absolute;
  inset: 0;
  background:
    linear-gradient(180deg, rgba(255, 255, 255, 0.22) 0%, rgba(255, 255, 255, 0.14) 46%, rgba(255, 255, 255, 0.18) 100%),
    radial-gradient(circle at 30% 22%, rgba(255, 248, 240, 0.10) 0%, rgba(255, 248, 240, 0) 30%);
}

.hero-actions {
  position: absolute;
  top: 28rpx;
  right: 26rpx;
  z-index: 2;
  display: flex;
  align-items: center;
  gap: 18rpx;
}

.icon-btn {
  position: relative;
  width: 44rpx;
  height: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: transparent;
}

.icon-btn-add {
  width: 44rpx;
  height: 44rpx;
}

.icon-bell-image {
  width: 30rpx;
  height: 30rpx;
  display: block;
}

.icon-plus {
  color: #111111;
  font-size: 48rpx;
  line-height: 1;
  font-weight: 300;
}

.icon-badge {
  position: absolute;
  top: 2rpx;
  right: 2rpx;
  width: 14rpx;
  height: 14rpx;
  border-radius: 999rpx;
  background: #e64646;
  border: 2rpx solid #ffffff;
  box-shadow: 0 0 0 1rpx rgba(230, 70, 70, 0.12);
}

.hero-copy {
  position: absolute;
  left: 42rpx;
  top: 88rpx;
  z-index: 2;
}

.hero-title-image {
  display: block;
  width: 420rpx;
  height: 178rpx;
  max-width: 100%;
}

.hero-subtitle {
  display: flex;
  flex-direction: column;
  margin-top:-30rpx;
  margin-left: 2rpx;
  color: #7a7a7a;
  font-family: "Songti SC", "STSong", "Times New Roman", serif;
  font-size: 28rpx;
  line-height: 1.55;
  font-weight: 200;
  letter-spacing: 0.02em;
  width: 210rpx;
}

.hero-subtitle-line {
  display: block;
}

.page-body {
  padding: 0 28rpx;
}

.channel-section {
  margin-top: 28rpx;
}

.state-wrap {
  min-height: 38vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 44rpx 0 18rpx;
  text-align: center;
}

.state-wrap-empty {
  min-height: 26vh;
}

.state-title {
  color: #111111;
  font-size: 34rpx;
  line-height: 1.35;
  font-weight: 500;
}

.state-text {
  margin-top: 14rpx;
  color: #868686;
  font-size: 24rpx;
  line-height: 1.7;
}

.section-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 6rpx;
}

.section-title {
  color: #111111;
  font-size: 34rpx;
  line-height: 1.35;
  font-weight: 600;
  letter-spacing: 0.02em;
}

.channel-list {
  margin-top: 10rpx;
}

.channel-item {
  display: flex;
  align-items: center;
  gap: 24rpx;
  padding: 28rpx 4rpx;
  border-bottom: 1rpx solid rgba(17, 17, 17, 0.08);
}

.channel-thumb {
  position: relative;
  width: 112rpx;
  height: 112rpx;
  flex-shrink: 0;
  overflow: hidden;
  border-radius: 24rpx;
  background: #ffffff;
  box-shadow: inset 0 0 0 1rpx rgba(17, 17, 17, 0.08);
}

.channel-thumb-image {
  width: 100%;
  height: 100%;
}

.channel-thumb-placeholder {
  position: relative;
  width: 100%;
  height: 100%;
  overflow: hidden;
  background:
    radial-gradient(circle at 24% 26%, rgba(255, 255, 255, 0.98) 0%, rgba(255, 255, 255, 0) 24%),
    radial-gradient(circle at 78% 76%, rgba(255, 255, 255, 0.2) 0%, rgba(255, 255, 255, 0) 18%),
    linear-gradient(135deg, #151515 0%, #4a4a4a 100%);
}

.thumb-circle {
  position: absolute;
  border-radius: 999rpx;
  border: 3rpx solid rgba(255, 255, 255, 0.5);
}

.thumb-circle-large {
  left: -6rpx;
  top: -6rpx;
  width: 66rpx;
  height: 66rpx;
  background: rgba(0, 0, 0, 0.88);
}

.thumb-circle-small {
  right: 6rpx;
  bottom: 8rpx;
  width: 42rpx;
  height: 42rpx;
  background: rgba(255, 255, 255, 0.82);
}

.channel-thumb-text {
  position: absolute;
  left: 50%;
  bottom: 12rpx;
  z-index: 1;
  transform: translateX(-50%);
  color: rgba(255, 255, 255, 0.9);
  font-size: 24rpx;
  line-height: 1;
  font-weight: 500;
  letter-spacing: 0.12em;
}

.theme-ocean,
.theme-mist,
.theme-sand,
.theme-forest {
  background: #ffffff;
}

.channel-main {
  flex: 1;
  min-width: 0;
}

.channel-name {
  display: block;
  color: #111111;
  font-size: 32rpx;
  line-height: 1.35;
  font-weight: 500;
  letter-spacing: 0.02em;
}

.channel-desc {
  display: block;
  margin-top: 10rpx;
  color: #6f6f6f;
  font-size: 24rpx;
  line-height: 1.55;
}

.channel-actions {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-top: 14rpx;
}

.channel-action-chip {
  min-height: 44rpx;
  padding: 0 16rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  border-radius: 999rpx;
  background: rgba(47, 111, 232, 0.10);
}

.channel-action-chip--ghost {
  background: rgba(17, 17, 17, 0.05);
}

.channel-action-chip__text {
  font-size: 22rpx;
  line-height: 1;
  color: #2f6fe8;
  font-weight: 600;
}

.channel-action-chip--ghost .channel-action-chip__text {
  color: #111111;
}

.channel-manage {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 46rpx;
  padding: 0 16rpx;
  border-radius: 999rpx;
  border: 1rpx solid rgba(17, 17, 17, 0.12);
  background: rgba(255, 255, 255, 0.96);
  color: #111111;
  font-size: 22rpx;
  line-height: 1;
}

.channel-arrow {
  flex-shrink: 0;
  color: #111111;
  font-size: 38rpx;
  line-height: 1;
  font-weight: 300;
  opacity: 0.8;
  padding-left: 4rpx;
}
