.page {
  min-height: 100vh;
  padding: calc(env(safe-area-inset-top) + 88rpx) 32rpx calc(148rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
  background: #ffffff;
}

.topbar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  min-height: 100rpx;
  padding: 42rpx 0 8rpx;
}

.topbar-title {
  color: #475467;
  font-size: 24rpx;
  line-height: 34rpx;
  font-weight: 400;
  letter-spacing: 0.4rpx;
}

.topbar-tools {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding-top: 24rpx;
}

.icon-btn {
  position: relative;
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.icon-plus {
  color: #101828;
  line-height: 1;
}

.icon-bell-image {
  width: 40rpx;
  height: 40rpx;
  display: block;
}

.icon-plus {
  font-size: 48rpx;
  line-height: 1;
  font-weight: 400;
  opacity: 0.96;
}

.icon-badge {
  position: absolute;
  top: 0;
  right: -2rpx;
  min-width: 30rpx;
  height: 30rpx;
  padding: 0 8rpx;
  border-radius: 999rpx;
  background: #2f6fe8;
  color: #ffffff;
  font-size: 18rpx;
  line-height: 30rpx;
  text-align: center;
}

.hero {
  margin: 40rpx 0 24rpx;
}

.hero-title {
  display: block;
  color: #101828;
  font-size: 40rpx;
  line-height: 1.2;
  font-weight: 600;
  letter-spacing: 0.02em;
}

.hero-accent {
  width: 56rpx;
  height: 5rpx;
  margin-top: 18rpx;
  border-radius: 999rpx;
  background: #2f6fe8;
}

.state-wrap {
  min-height: 52vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  text-align: center;
}

.state-title {
  color: #101828;
  font-size: 36rpx;
  line-height: 1.35;
  font-weight: 500;
}

.state-text {
  margin-top: 12rpx;
  color: #667085;
  font-size: 24rpx;
  line-height: 1.7;
}

.channel-list {
  display: flex;
  flex-direction: column;
}

.channel-item {
  display: flex;
  align-items: center;
  gap: 28rpx;
  padding: 30rpx 0;
  border-bottom: 2rpx solid #f2f4f7;
}

.channel-cover {
  width: 200rpx;
  height: 200rpx;
  flex-shrink: 0;
  overflow: hidden;
  border-radius: 18rpx;
  border: 2rpx solid #eef2f6;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #ffffff;
  box-shadow: inset 0 0 0 1rpx rgba(255, 255, 255, 0.8);
}

.channel-cover-image {
  width: 100%;
  height: 100%;
}

.channel-cover-placeholder {
  position: relative;
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.cover-ghost-line {
  position: absolute;
  left: 26rpx;
  right: 26rpx;
  height: 2rpx;
  background: linear-gradient(90deg, rgba(226, 232, 240, 0) 0%, #edf2f7 24%, #edf2f7 76%, rgba(226, 232, 240, 0) 100%);
}

.cover-ghost-line-top {
  top: 56rpx;
}

.cover-ghost-line-mid {
  bottom: 56rpx;
}

.channel-cover-text {
  position: relative;
  z-index: 1;
  color: #d7dde7;
  font-size: 30rpx;
  line-height: 1;
  font-weight: 400;
  letter-spacing: 0.08em;
}

.theme-ocean {
  background: #ffffff;
}

.theme-mist {
  background: #ffffff;
}

.theme-sand {
  background: #ffffff;
}

.theme-forest {
  background: #ffffff;
}

.channel-main {
  flex: 1;
  min-width: 0;
  padding-top: 2rpx;
}

.channel-main-top {
  display: flex;
  align-items: flex-start;
}

.channel-name {
  display: block;
  color: #101828;
  font-size: 34rpx;
  line-height: 44rpx;
  font-weight: 500;
  letter-spacing: 0.4rpx;
}

.channel-desc {
  display: block;
  margin-top: 12rpx;
  color: #475467;
  font-size: 24rpx;
  line-height: 34rpx;
  letter-spacing: 0.4rpx;
}

.channel-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 16rpx;
}

.meta-pill {
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  background: #f7f9fc;
  color: #2f6fe8;
  font-size: 20rpx;
  line-height: 30rpx;
  font-weight: 400;
  letter-spacing: 0.4rpx;
}

.channel-arrow {
  flex-shrink: 0;
  color: #101828;
  font-size: 48rpx;
  line-height: 1;
  font-weight: 300;
  opacity: 0.72;
}
