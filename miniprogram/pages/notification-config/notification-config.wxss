.page {
  min-height: 100vh;
  background:
    radial-gradient(circle at top right, rgba(216, 240, 233, 0.85), transparent 26%),
    linear-gradient(180deg, #f8fbf9 0%, #ffffff 28%, #ffffff 100%);
  color: #111111;
  font-family: var(--font-body);
  overflow-x: hidden;
}

.content {
  box-sizing: border-box;
}

.content-inner {
  padding: 32rpx 32rpx 64rpx;
  box-sizing: border-box;
}

.hero {
  margin-top: 24rpx;
  margin-bottom: 36rpx;
}

.hero-title {
  display: block;
  color: #111111;
  font-size: 42rpx;
  line-height: 1.3;
  font-weight: 600;
  letter-spacing: 0.03em;
}

.hero-text {
  display: block;
  margin-top: 16rpx;
  color: #666666;
  font-size: 24rpx;
  line-height: 1.7;
}

.scene-card {
  margin-bottom: 28rpx;
  padding: 28rpx;
  border: 1rpx solid rgba(17, 17, 17, 0.08);
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.92);
  box-shadow: 0 16rpx 36rpx rgba(15, 23, 42, 0.05);
  backdrop-filter: blur(16px);
}

.scene-card__header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.scene-card__title-wrap {
  min-width: 0;
}

.scene-card__title {
  display: block;
  color: #111111;
  font-size: 32rpx;
  line-height: 1.4;
  font-weight: 600;
}

.scene-card__scene {
  display: block;
  margin-top: 8rpx;
  color: #8a8a8a;
  font-size: 22rpx;
  line-height: 1.4;
}

.scene-card__desc {
  display: block;
  margin-bottom: 28rpx;
  color: #666666;
  font-size: 24rpx;
  line-height: 1.65;
}

.field {
  margin-bottom: 28rpx;
}

.field-label {
  display: block;
  margin-bottom: 12rpx;
  color: #111111;
  font-size: 26rpx;
  line-height: 1.4;
  font-weight: 500;
}

.input {
  width: 100%;
  font-size: 26rpx;
  color: #111111;
  background: transparent;
  border: none;
  box-sizing: border-box;
}

.input-line {
  height: 82rpx;
  padding: 0 0 12rpx;
  border-bottom: 1rpx solid rgba(17, 17, 17, 0.12);
  border-radius: 0;
}

.input-placeholder {
  color: #b8b8b8;
}

.textarea-card {
  border: 1rpx solid rgba(17, 17, 17, 0.08);
  border-radius: 18rpx;
  background: #ffffff;
}

.textarea-input {
  width: 100%;
  min-height: 260rpx;
  padding: 22rpx;
  box-sizing: border-box;
  color: #111111;
  font-size: 24rpx;
  line-height: 1.75;
}

.textarea-input--short {
  min-height: 160rpx;
}

.field-hint {
  display: block;
  margin-top: 12rpx;
  color: #888888;
  font-size: 22rpx;
  line-height: 1.5;
}

.scene-card__button {
  width: 100%;
  height: 84rpx;
  margin: 8rpx 0 0;
  padding: 0 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 999rpx;
  background: #111111;
  color: #ffffff;
  box-sizing: border-box;
}

.scene-card__button::after {
  border: none;
}

.scene-card__button[disabled] {
  opacity: 0.5;
}

.scene-card__button-text {
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 500;
  line-height: 1.3;
}

.error-box {
  margin-bottom: 28rpx;
  padding: 18rpx 20rpx;
  border-radius: 18rpx;
  background: rgba(178, 65, 55, 0.08);
}

.error-text {
  color: #b24137;
  font-size: 24rpx;
  line-height: 1.6;
}

.page-spacer {
  height: 48rpx;
}

.loading-state {
  padding: 160rpx 32rpx;
  text-align: center;
}

.loading-text {
  color: #888888;
  font-size: 24rpx;
}
