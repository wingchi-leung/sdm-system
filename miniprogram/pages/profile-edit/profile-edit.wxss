.page {
  min-height: 100vh;
  padding: 24rpx 32rpx calc(32rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
  background: #ffffff;
  color: #111111;
  font-family: var(--font-body);
}

.state-wrap {
  min-height: 78vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.state-text {
  margin-top: 10rpx;
  color: #999999;
  font-size: 24rpx;
}

.content {
  padding-bottom: 8rpx;
}

.avatar-panel {
  display: flex;
  justify-content: center;
  padding: 48rpx 0 56rpx;
}

.avatar-shell {
  width: 208rpx;
  height: 208rpx;
  border-radius: 50%;
  overflow: hidden;
  background: #f3f3f3;
}

.avatar-image {
  width: 100%;
  height: 100%;
  display: block;
  border-radius: 50%;
  overflow: hidden;
  background: #f3f3f3;
}

.form-card {
  background: #ffffff;
}

.field {
  min-height: 96rpx;
  display: flex;
  align-items: center;
}

.field-title {
  width: 140rpx;
  flex-shrink: 0;
  color: #111111;
  font-size: 28rpx;
  line-height: 1.3;
}

.field-value {
  flex: 1;
  min-width: 0;
  color: #111111;
  font-size: 28rpx;
  text-align: right;
}

.field-arrow {
  flex-shrink: 0;
  color: #b5b5b5;
  font-size: 38rpx;
  line-height: 1;
  margin-left: 8rpx;
}

.mask {
  position: fixed;
  inset: 0;
  z-index: 2000;
  background: rgba(17, 17, 17, 0.45);
  display: flex;
  align-items: flex-end;
}

.sheet {
  width: 100%;
  padding: 12rpx 20rpx calc(20rpx + env(safe-area-inset-bottom));
  border-radius: 28rpx 28rpx 0 0;
  background: #ffffff;
  box-sizing: border-box;
}

.sheet-action,
.sheet-cancel {
  width: 100%;
  padding: 30rpx 16rpx;
  border: none;
  background: transparent;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #111111;
  font-size: 32rpx;
  line-height: 1.2;
  font-weight: 500;
  border-radius: 0;
}

.sheet-action::after,
.sheet-cancel::after {
  border: none;
}

.sheet-cancel {
  margin-top: 8rpx;
  border-radius: 20rpx;
  background: #f7f7f7;
}
