<view class="page">
  <page-header title="个人资料"></page-header>

  <view wx:if="{{loading}}" class="state-wrap">
    <view class="loading"></view>
    <text class="state-text">加载中…</text>
  </view>

  <view wx:else class="content">
    <view class="avatar-panel">
      <view class="avatar-shell" bindtap="showAvatarMenu">
        <image class="avatar-image" src="{{avatarDisplayUrl || avatarUrl}}" mode="aspectFill" />
      </view>
    </view>

    <view class="form-card">
      <view class="field">
        <text class="field-title">昵称</text>
        <text class="field-value">{{form.name || '未设置'}}</text>
        <text class="field-arrow ui-chevron ui-chevron--md">›</text>
      </view>
    </view>
  </view>

  <view wx:if="{{avatarMenuVisible}}" class="mask" bindtap="hideAvatarMenu">
    <view class="sheet" catchtap="noop">
      <button class="sheet-action sheet-action-primary" open-type="chooseAvatar" bindchooseavatar="onChooseWechatAvatar" bindtap="onWechatAvatarTap">
        微信头像
      </button>
      <button class="sheet-action" bindtap="chooseAvatarFromAlbum">
        从相册选择
      </button>
      <button class="sheet-action" bindtap="chooseAvatarFromCamera">
        拍照
      </button>
      <button class="sheet-cancel" bindtap="hideAvatarMenu">
        取消
      </button>
    </view>
  </view>
</view>
