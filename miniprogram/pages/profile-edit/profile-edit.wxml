<view class="page">
  <view class="form-card">
    <view class="field">
      <text class="field-label">姓名</text>
      <input class="input" value="{{form.name}}" bindinput="onNameInput" placeholder="请输入姓名" placeholder-class="input-placeholder" />
    </view>

    <view class="field">
      <text class="field-label">性别</text>
      <picker mode="selector" range="{{sexOptions}}" range-key="label" value="{{sexIndex}}" bindchange="onSexChange">
        <view class="picker-row">
          <text>{{sexOptions[sexIndex].label}}</text>
          <text class="row-arrow">›</text>
        </view>
      </picker>
    </view>

    <view class="field">
      <text class="field-label">年龄</text>
      <input class="input" type="number" value="{{form.age}}" bindinput="onAgeInput" placeholder="请输入年龄" placeholder-class="input-placeholder" />
    </view>

    <view class="field">
      <text class="field-label">职业</text>
      <input class="input" value="{{form.occupation}}" bindinput="onOccupationInput" placeholder="请输入职业" placeholder-class="input-placeholder" />
    </view>

    <view class="field">
      <text class="field-label">行业</text>
      <input class="input" value="{{form.industry}}" bindinput="onIndustryInput" placeholder="请输入行业" placeholder-class="input-placeholder" />
    </view>

    <view class="field">
      <text class="field-label">邮箱（选填）</text>
      <input class="input" value="{{form.email}}" bindinput="onEmailInput" placeholder="请输入邮箱" placeholder-class="input-placeholder" />
    </view>

    <view class="error-box" wx:if="{{error}}">
      <text class="error-text">{{error}}</text>
    </view>

    <button class="save-btn" bindtap="onSubmit" loading="{{submitting}}" disabled="{{submitting}}">
      <text>{{submitting ? '保存中…' : '保存修改'}}</text>
    </button>
  </view>
</view>

