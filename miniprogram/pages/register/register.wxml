<!-- 加载状态 -->
<view wx:if="{{loading}}" class="page loading-wrap">
  <view class="loading"></view>
  <text class="loading-text">加载中…</text>
</view>

<view class="page" wx:elif="{{activity}}">

  <view class="hero-card">
    <view class="hero-copy">
      <text class="hero-eyebrow-cn">活动报名</text>
      <text class="hero-activity">{{activity.activity_name}}</text>
      <text class="hero-code">参 001</text>
    </view>
    <view class="hero-poster">
      <image wx:if="{{activity.poster_url}}" class="hero-poster-image" src="{{activity.poster_url}}" mode="aspectFill" />
      <view wx:else class="hero-poster-fallback">
        <text class="hero-poster-fallback-text">SDM</text>
      </view>
    </view>
  </view>

  <view class="section-divider"></view>

  <view class="profile-summary" bindtap="toggleBasicInfo">
    <view class="profile-summary-left">
      <text class="profile-icon">◌</text>
      <text class="profile-label">个人资料</text>
    </view>
    <view class="profile-summary-right">
      <text class="profile-summary-title">基本信息</text>
      <text class="section-arrow {{basicInfoExpanded ? 'expanded' : ''}}">›</text>
    </view>
  </view>

  <view wx:if="{{basicInfoExpanded}}" class="profile-list">
    <view class="field field-readonly">
      <text class="field-label">姓名</text>
      <view class="readonly-value">{{name || '未设置'}}</view>
    </view>
    <view class="field field-readonly">
      <text class="field-label">性别</text>
      <view class="readonly-value">{{sex || '未设置'}}</view>
    </view>
    <view class="field field-readonly">
      <text class="field-label">年龄</text>
      <view class="readonly-value">{{age || '未设置'}}</view>
    </view>
    <view class="field field-readonly">
      <text class="field-label">职业</text>
      <view class="readonly-value">{{occupation || '未设置'}}</view>
    </view>
    <view class="field field-readonly">
      <text class="field-label">电话</text>
      <view class="readonly-value">{{phone || '未设置'}}</view>
    </view>
    <view class="field field-readonly">
      <text class="field-label">邮箱</text>
      <view class="readonly-value">{{email || '未设置'}}</view>
    </view>
    <view class="field field-readonly">
      <text class="field-label">行业</text>
      <view class="readonly-value">{{industry || '未设置'}}</view>
    </view>
  </view>

  <view class="section-divider"></view>

  <view class="form-card">
    <view class="section-title-row">
      <text class="section-marker"></text>
      <text class="section-kicker section-kicker-strong">报名问卷</text>
    </view>

    <view class="field">
      <text class="field-label required">为什么要参与？</text>
      <view class="control-wrap {{activeField === 'whyJoin' ? 'active' : ''}}">
        <text wx:if="{{!whyJoin}}" class="custom-placeholder">请说明您参与此次活动的原因</text>
        <textarea
          class="textarea"
          placeholder=""
          value="{{whyJoin}}"
          bindinput="onWhyJoinInput"
          bindfocus="onFieldFocus"
          bindblur="onFieldBlur"
          data-field="whyJoin"
          maxlength="500"
          auto-height
        />
      </view>
    </view>

    <view class="field">
      <text class="field-label required">您是通过什么渠道了解此活动的？</text>
      <view class="control-wrap {{activeField === 'channel' ? 'active' : ''}}">
        <text wx:if="{{!channel}}" class="custom-placeholder">如：朋友推荐、公众号、社群等</text>
        <input
          class="input"
          placeholder=""
          value="{{channel}}"
          bindinput="onChannelInput"
          bindfocus="onFieldFocus"
          bindblur="onFieldBlur"
          data-field="channel"
          maxlength="255"
        />
      </view>
    </view>

    <view class="field">
      <text class="field-label required">您对本次活动有什么学习期望？</text>
      <view class="control-wrap {{activeField === 'expectation' ? 'active' : ''}}">
        <text wx:if="{{!expectation}}" class="custom-placeholder">请描述您希望在活动中获得什么</text>
        <textarea
          class="textarea"
          placeholder=""
          value="{{expectation}}"
          bindinput="onExpectationInput"
          bindfocus="onFieldFocus"
          bindblur="onFieldBlur"
          data-field="expectation"
          maxlength="500"
          auto-height
        />
      </view>
    </view>

    <view class="field">
      <text class="field-label">用一句话描述您对本活动的了解？</text>
      <view class="control-wrap {{activeField === 'understanding' ? 'active' : ''}}">
        <text wx:if="{{!activityUnderstanding}}" class="custom-placeholder">选填</text>
        <input
          class="input"
          placeholder=""
          value="{{activityUnderstanding}}"
          bindinput="onUnderstandingInput"
          bindfocus="onFieldFocus"
          bindblur="onFieldBlur"
          data-field="understanding"
          maxlength="255"
        />
      </view>
    </view>

    <view class="field">
      <text class="field-label">您是否有任何问题想要了解？</text>
      <view class="control-wrap {{activeField === 'questions' ? 'active' : ''}}">
        <text wx:if="{{!hasQuestions}}" class="custom-placeholder">选填，如有问题请在此提出</text>
        <textarea
          class="textarea"
          placeholder=""
          value="{{hasQuestions}}"
          bindinput="onQuestionsInput"
          bindfocus="onFieldFocus"
          bindblur="onFieldBlur"
          data-field="questions"
          maxlength="500"
          auto-height
        />
      </view>
    </view>
  </view>

  <view class="section-block payment-block" wx:if="{{requirePayment}}">
    <view class="section-title-row">
      <text class="section-marker"></text>
      <text class="section-kicker section-kicker-strong">支付信息</text>
    </view>

    <view class="field fee-field">
      <text class="field-label">支付金额</text>
      <view class="fee-input-wrapper">
        <text class="fee-currency">¥</text>
        <view class="control-wrap fee-control {{activeField === 'fee' ? 'active' : ''}}">
          <input
            class="input fee-input"
            type="digit"
            placeholder="{{suggestedFeeYuan}}"
            placeholder-class="input-placeholder"
            value="{{actualFeeYuan}}"
            bindinput="onFeeInput"
            bindfocus="onFieldFocus"
            bindblur="onFeeBlur"
            data-field="fee"
          />
        </view>
      </view>
      <view class="fee-info">
        <text class="fee-hint">建议费用：¥{{suggestedFeeYuan}}，可支付更高金额</text>
      </view>
    </view>
  </view>

  <view class="error-box" wx:if="{{error}}">
    <text class="error-text">{{error}}</text>
  </view>

  <view class="bottom-bar">
    <view class="bottom-left">
      <view wx:if="{{recoverPendingPayment && paymentOrderNo}}">
        <text class="bottom-title">当前订单仍可继续支付</text>
        <text class="bottom-sub">订单号：{{paymentOrderNo}}</text>
      </view>
      <view wx:else>
        <text class="bottom-title">当前订单仍可继续支付</text>
        <text class="bottom-sub">订单号：{{paymentOrderNo || '待生成'}}</text>
      </view>
    </view>
    <button class="btn-submit {{isFull ? 'waitlist' : ''}}" disabled="{{submitting}}" bindtap="submit">
      <text class="btn-text">{{submitting ? '处理中…' : (recoverPendingPayment ? '继续支付' : (isFull ? '进入候补' : '继续支付'))}}</text>
    </button>
  </view>
</view>
