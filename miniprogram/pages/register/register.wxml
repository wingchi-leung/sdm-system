<view class="page" style="--status-bar-height: {{statusBarHeight}}px;">
  <view wx:if="{{loading}}" class="state-wrap">
    <view class="loading"></view>
    <text class="state-text">加载中…</text>
  </view>

  <view wx:elif="{{activity}}" class="shell">
    <page-header title="报名问卷" statusBarHeight="{{statusBarHeight}}" autoBack="{{false}}" bindback="goBack">
      <view slot="actions" class="nav-btn nav-btn-more" bindtap="onMoreTap">
        <text class="nav-icon">···</text>
      </view>
    </page-header>

    <view class="hero">
      <text class="hero-title">加入本次探索</text>
      <view class="hero-underline"></view>
      <text class="hero-subtitle">报名问卷</text>
      <text class="hero-activity">{{activity.activity_name}}</text>
      <text wx:if="{{recoverPendingPayment}}" class="hero-badge">当前有未完成支付</text>
    </view>

    <view class="profile-toggle" bindtap="toggleBasicInfo">
      <text class="profile-toggle-label">个人资料</text>
      <view class="profile-toggle-meta">
        <text class="profile-toggle-text">{{basicInfoExpanded ? '收起' : '展开'}}</text>
        <view class="profile-toggle-arrow ui-chevron ui-chevron--sm ui-chevron--right {{basicInfoExpanded ? 'expanded' : ''}}"></view>
      </view>
    </view>

    <view wx:if="{{basicInfoExpanded}}" class="profile-panel">
      <view class="profile-grid">
        <view class="profile-item">
          <text class="profile-name">姓名</text>
          <text class="profile-value">{{name || ''}}</text>
        </view>
        <view class="profile-item">
          <text class="profile-name">性别</text>
          <text class="profile-value">{{sex || ''}}</text>
        </view>
        <view class="profile-item">
          <text class="profile-name">年龄</text>
          <text class="profile-value">{{age || ''}}</text>
        </view>
        <view class="profile-item">
          <text class="profile-name">职业</text>
          <text class="profile-value">{{occupation || ''}}</text>
        </view>
        <view class="profile-item">
          <text class="profile-name">电话</text>
          <text class="profile-value">{{phone || ''}}</text>
        </view>
        <view class="profile-item">
          <text class="profile-name">邮箱</text>
          <text class="profile-value">{{email || ''}}</text>
        </view>
        <view class="profile-item">
          <text class="profile-name">行业</text>
          <text class="profile-value">{{industry || ''}}</text>
        </view>
      </view>
    </view>

    <view class="question-card">
      <view class="question-section-title">填写报名内容</view>

      <view class="question-item">
        <text class="question-index">01</text>
        <text class="question-label required">为什么想参与？</text>
        <view class="question-control {{activeField === 'whyJoin' ? 'active' : ''}}">
          <textarea
            class="question-input question-textarea"
            placeholder="请输入您的回答"
            placeholder-class="question-placeholder"
            value="{{whyJoin}}"
            bindinput="onWhyJoinInput"
            bindfocus="onFieldFocus"
            bindblur="onFieldBlur"
            data-field="whyJoin"
            maxlength="500"
            auto-height
          />
        </view>
      </view>

      <view class="question-item">
        <text class="question-index">02</text>
        <text class="question-label required">您是通过什么渠道了解此活动的？</text>
        <view class="question-control {{activeField === 'channel' ? 'active' : ''}}">
          <input
            class="question-input"
            placeholder="请输入您的回答"
            placeholder-class="question-placeholder"
            value="{{channel}}"
            bindinput="onChannelInput"
            bindfocus="onFieldFocus"
            bindblur="onFieldBlur"
            data-field="channel"
            maxlength="255"
          />
        </view>
      </view>

      <view class="question-item">
        <text class="question-index">03</text>
        <text class="question-label required">您对本次活动有什么学习期望？</text>
        <view class="question-control {{activeField === 'expectation' ? 'active' : ''}}">
          <textarea
            class="question-input question-textarea"
            placeholder="请输入您的回答"
            placeholder-class="question-placeholder"
            value="{{expectation}}"
            bindinput="onExpectationInput"
            bindfocus="onFieldFocus"
            bindblur="onFieldBlur"
            data-field="expectation"
            maxlength="500"
            auto-height
          />
        </view>
      </view>

      <view class="question-item">
        <text class="question-index">04</text>
        <text class="question-label">用一句话描述您对本次活动的了解？</text>
        <view class="question-control {{activeField === 'understanding' ? 'active' : ''}}">
          <input
            class="question-input"
            placeholder="请输入您的回答"
            placeholder-class="question-placeholder"
            value="{{activityUnderstanding}}"
            bindinput="onUnderstandingInput"
            bindfocus="onFieldFocus"
            bindblur="onFieldBlur"
            data-field="understanding"
            maxlength="255"
          />
        </view>
      </view>

      <view class="question-item">
        <text class="question-index">05</text>
        <text class="question-label required">您是否有任何问题想要了解？</text>
        <view class="question-control {{activeField === 'questions' ? 'active' : ''}}">
          <textarea
            class="question-input question-textarea"
            placeholder="请输入您的回答"
            placeholder-class="question-placeholder"
            value="{{hasQuestions}}"
            bindinput="onQuestionsInput"
            bindfocus="onFieldFocus"
            bindblur="onFieldBlur"
            data-field="questions"
            maxlength="500"
            auto-height
          />
        </view>
      </view>

      <view wx:if="{{requirePayment}}" class="payment-note">
        <text class="payment-note-title">支付金额</text>
        <view class="fee-row">
          <text class="fee-currency">¥</text>
          <view class="fee-control {{activeField === 'fee' ? 'active' : ''}}">
            <input
              class="fee-input"
              type="digit"
              placeholder="请输入金额"
              placeholder-class="question-placeholder"
              value="{{actualFeeYuan}}"
              bindinput="onFeeInput"
              bindfocus="onFieldFocus"
              bindblur="onFeeBlur"
              data-field="fee"
            />
          </view>
        </view>
        <text class="payment-hint">建议费用：¥{{suggestedFeeYuan}}，可支付更高金额</text>
      </view>

      <view wx:if="{{error}}" class="error-box">
        <text class="error-text">{{error}}</text>
      </view>
    </view>
  </view>

  <view wx:if="{{activity}}" class="bottom-bar">
    <button class="next-btn" disabled="{{submitting}}" bindtap="submit">
      <text class="next-btn-text">{{submitting ? '处理中…' : (recoverPendingPayment ? '继续支付' : '下一步')}}</text>
      <view class="next-btn-arrow ui-chevron ui-chevron--md ui-chevron--right"></view>
    </button>
  </view>
</view>
