<view class="page" wx:if="{{activity}}">
  <view class="title">{{activity.activity_name}}</view>

  <view class="form">
    <view class="field">
      <text class="field-label">姓名 *</text>
      <input class="input" placeholder="请输入姓名" value="{{name}}" bindinput="onNameInput" />
    </view>
    <view class="field">
      <text class="field-label">手机号 *</text>
      <input class="input" type="number" placeholder="请输入手机号" value="{{phone}}" bindinput="onPhoneInput" />
    </view>
    <view class="field">
      <text class="field-label">证件号（选填）</text>
      <input class="input" placeholder="身份证等" value="{{identityNumber}}" bindinput="onIdInput" />
    </view>

    <view class="error-box" wx:if="{{error}}">
      <text class="error-text">{{error}}</text>
    </view>

    <button
      class="btn-primary submit-btn"
      disabled="{{submitting}}"
      bindtap="submit"
    >
      {{submitting ? '提交中…' : '提交报名'}}
    </button>
  </view>
</view>
