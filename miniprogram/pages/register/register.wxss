.page {
  min-height: 100vh;
  padding: 32rpx 40rpx 64rpx;
  background: #f5f5f5;
}

.title {
  font-size: 32rpx;
  font-weight: 500;
  color: var(--text-primary);
  margin-bottom: 48rpx;
}

.form {
  background: var(--surface);
  border-radius: 24rpx;
  padding: 40rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.04);
}

.field {
  margin-bottom: 32rpx;
}

.field-label {
  display: block;
  font-size: 28rpx;
  color: var(--text-secondary);
  margin-bottom: 16rpx;
}

.input {
  width: 100%;
  height: 88rpx;
  padding: 0 24rpx;
  font-size: 30rpx;
  background: var(--background);
  border-radius: 16rpx;
  box-sizing: border-box;
}

.error-box {
  margin: 24rpx 0;
  padding: 24rpx;
  background: var(--error-bg);
  border-radius: 16rpx;
  border: 1rpx solid rgba(255,59,48,0.3);
}

.error-text {
  font-size: 28rpx;
  color: var(--error);
}

.submit-btn {
  width: 100%;
  margin-top: 48rpx;
  padding: 32rpx;
  font-size: 32rpx;
}
