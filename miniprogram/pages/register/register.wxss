.page {
  min-height: 100vh;
  padding: 24rpx 32rpx calc(140rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
  background: #ffffff;
  color: #111111;
  font-family: "PingFang SC", -apple-system, BlinkMacSystemFont, "Helvetica Neue", sans-serif;
}

.shell {
  min-height: 100vh;
  box-sizing: border-box;
}

.nav-btn {
  width: auto;
  height: auto;
  padding: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 0;
}

.nav-btn:active {
  background: transparent;
}

.nav-icon {
  color: #111111;
  font-size: 48rpx;
  line-height: 1;
  font-weight: 300;
}

.nav-btn-more .nav-icon {
  font-size: 34rpx;
  letter-spacing: 5rpx;
}

.hero {
  margin-top: 72rpx;
}

.hero-title {
  display: block;
  color: #111111;
  font-size: 54rpx;
  line-height: 1.28;
  font-weight: 500;
  letter-spacing: 0.04em;
}

.hero-underline {
  width: 56rpx;
  height: 4rpx;
  margin-top: 24rpx;
  background: #111111;
  border-radius: 999rpx;
}

.hero-subtitle {
  display: block;
  margin-top: 34rpx;
  color: #666666;
  font-size: 28rpx;
  line-height: 1.65;
  font-weight: 400;
  letter-spacing: 0.03em;
}

.hero-activity {
  display: block;
  margin-top: 10rpx;
  color: #999999;
  font-size: 24rpx;
  line-height: 1.65;
  font-weight: 400;
  letter-spacing: 0.03em;
}

.hero-badge {
  display: inline-flex;
  align-items: center;
  margin-top: 18rpx;
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  background: rgba(17, 17, 17, 0.05);
  color: #111111;
  font-size: 22rpx;
  line-height: 1;
  font-weight: 400;
}

.profile-toggle {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 60rpx;
  padding: 20rpx 0 18rpx;
  border-top: 1rpx solid var(--divider);
}

.profile-toggle-label {
  color: #111111;
  font-size: 28rpx;
  line-height: 1.5;
}

.profile-toggle-meta {
  display: flex;
  align-items: center;
}

.profile-toggle-text {
  color: #666666;
  font-size: 22rpx;
  line-height: 1;
}

.profile-toggle-arrow {
  margin-left: 10rpx;
  color: #111111;
  font-size: 32rpx;
  line-height: 1;
  transform: rotate(0deg);
  transition: transform 0.2s ease;
}

.profile-toggle-arrow.expanded {
  transform: rotate(90deg);
}

.profile-panel {
  margin-top: 12rpx;
  padding: 8rpx 0 0;
}

.profile-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
}

.profile-item {
  padding: 18rpx 18rpx 16rpx;
  border-radius: 18rpx;
  background: #ffffff;
  border: 1rpx solid var(--border-light);
}

.profile-name {
  display: block;
  color: #999999;
  font-size: 21rpx;
  line-height: 1.55;
}

.profile-value {
  display: block;
  margin-top: 8rpx;
  color: #111111;
  font-size: 26rpx;
  line-height: 1.5;
  word-break: break-word;
}

.question-card {
  margin-top: 32rpx;
}

.question-section-title {
  margin-bottom: 18rpx;
  color: #111111;
  font-size: 30rpx;
  line-height: 1.5;
}

.question-item {
  padding: 26rpx 0 28rpx;
  border-bottom: 1rpx solid var(--divider);
}

.question-item:last-child {
  border-bottom: none;
}

.question-index {
  display: block;
  color: #999999;
  font-size: 32rpx;
  line-height: 1;
}

.question-label {
  display: block;
  margin-top: 16rpx;
  color: #111111;
  font-size: 28rpx;
  line-height: 1.72;
}

.question-label.required::after {
  content: " *";
  color: #111111;
}

.question-control,
.fee-control {
  position: relative;
  margin-top: 18rpx;
  padding-bottom: 8rpx;
}

.question-control::after,
.fee-control::after {
  content: "";
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  height: 1rpx;
  background: rgba(17, 17, 17, 0.12);
}

.question-control::before,
.fee-control::before {
  content: "";
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  height: 1rpx;
  background: #111111;
  transform: scaleX(0);
  transform-origin: left center;
  transition: transform 0.2s ease;
}

.question-control.active::before,
.fee-control.active::before {
  transform: scaleX(1);
}

.question-input {
  width: 100%;
  min-height: 58rpx;
  padding: 0;
  margin: 0;
  border: 0;
  background: transparent;
  box-sizing: border-box;
  color: #111111;
  font-size: 28rpx;
  line-height: 58rpx;
}

.question-textarea {
  min-height: 72rpx;
  line-height: 1.7;
}

.question-placeholder {
  color: #bbbbbb;
}

.payment-note {
  margin-top: 28rpx;
  padding: 24rpx 0 0;
  border-top: 1rpx solid var(--divider);
}

.payment-note-title {
  display: block;
  color: #111111;
  font-size: 28rpx;
  line-height: 1.5;
}

.fee-row {
  display: flex;
  align-items: flex-end;
  gap: 14rpx;
  margin-top: 16rpx;
}

.fee-currency {
  color: #111111;
  font-size: 36rpx;
  line-height: 1;
}

.fee-control {
  flex: 1;
  margin-top: 0;
}

.fee-input {
  width: 100%;
  min-height: 58rpx;
  padding: 0;
  border: 0;
  background: transparent;
  box-sizing: border-box;
  color: #111111;
  font-size: 30rpx;
  line-height: 58rpx;
}

.payment-hint {
  display: block;
  margin-top: 14rpx;
  color: #999999;
  font-size: 22rpx;
  line-height: 1.7;
}

.error-box {
  margin-top: 20rpx;
  padding: 16rpx 18rpx;
  border-radius: 16rpx;
  background: var(--error-bg);
}

.error-text {
  color: var(--error);
  font-size: 22rpx;
  line-height: 1.7;
}

.bottom-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 20;
  display: flex;
  justify-content: flex-end;
  padding: 18rpx 32rpx calc(env(safe-area-inset-bottom) + 24rpx);
  background: linear-gradient(180deg, rgba(255, 255, 255, 0), rgba(255, 255, 255, 0.96) 28%, #ffffff 100%);
}

.next-btn {
  display: inline-flex;
  align-items: center;
  justify-content: flex-end;
  gap: 16rpx;
  width: auto;
  min-height: 0;
  padding: 0;
  margin: 0;
  border: 0;
  background: transparent;
  border-radius: 0;
}

.next-btn::after {
  border: 0;
}

.next-btn[disabled] {
  opacity: 0.45;
}

.next-btn-text {
  color: #111111;
  font-size: 30rpx;
  line-height: 1;
}

.next-btn-arrow {
  color: #111111;
  font-size: 36rpx;
  line-height: 1;
  font-weight: 300;
}

.state-wrap {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 0 48rpx;
  box-sizing: border-box;
}

.loading {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  border: 2rpx solid rgba(17, 17, 17, 0.12);
  border-top-color: #111111;
  animation: spin 0.85s linear infinite;
}

.state-text {
  margin-top: 18rpx;
  color: #999999;
  font-size: 24rpx;
  line-height: 1.6;
}

@keyframes spin {
  to {
    transform: rotate(360deg);
  }
}
