/**
 * 活动报名页 - 极简奢华风格
 */

/* ─────────────────────────────────────────────────────────────
 * 加载状态
 * ───────────────────────────────────────────────────────────── */
.loading-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 60vh;
}

.loading {
  width: 48rpx;
  height: 48rpx;
  border: 2rpx solid var(--border);
  border-top-color: var(--accent);
  border-radius: 50%;
  animation: spin 0.8s cubic-bezier(0.4, 0, 0.2, 1) infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  font-size: 24rpx;
  color: var(--text-tertiary);
  margin-top: var(--space-md);
  letter-spacing: 0.08em;
}

.page {
  min-height: 100vh;
  padding: var(--space-2xl) var(--space-lg);
  background: var(--background);
}

/* ─────────────────────────────────────────────────────────────
 * 头部
 * ───────────────────────────────────────────────────────────── */
.header {
  margin-bottom: var(--space-2xl);
  padding-bottom: var(--space-lg);
  border-bottom: 1px solid var(--divider);
}

.header-title {
  display: block;
  font-family: var(--font-display);
  font-size: 48rpx;
  font-weight: 400;
  color: var(--text-primary);
  letter-spacing: 0.06em;
  margin-bottom: var(--space-sm);
}

.header-subtitle {
  display: block;
  font-size: 24rpx;
  color: var(--text-tertiary);
  letter-spacing: 0.08em;
}

/* ─────────────────────────────────────────────────────────────
 * 报名情况
 * ───────────────────────────────────────────────────────────── */
.enrollment-info {
  background: var(--background-warm);
  border: 1px solid var(--border);
  border-radius: var(--radius-md);
  padding: var(--space-lg);
  margin-bottom: var(--space-xl);
}

.enrollment-stats {
  display: flex;
  align-items: baseline;
  gap: var(--space-sm);
  margin-bottom: var(--space-sm);
}

.enrollment-label {
  font-size: 22rpx;
  color: var(--text-tertiary);
  letter-spacing: 0.08em;
}

.enrollment-value {
  font-family: var(--font-display);
  font-size: 32rpx;
  font-weight: 400;
  color: var(--text-primary);
  letter-spacing: 0.04em;
}

.enrollment-status {
  font-size: 24rpx;
  color: var(--status-ongoing);
  letter-spacing: 0.02em;
}

.enrollment-status.full {
  color: var(--warning);
}

.waitlist-info {
  margin-top: var(--space-sm);
  font-size: 22rpx;
  color: var(--text-muted);
  letter-spacing: 0.02em;
}

/* ─────────────────────────────────────────────────────────────
 * 表单卡片
 * ───────────────────────────────────────────────────────────── */
.form-card {
  animation: fadeIn 0.4s ease;
}

/* ─────────────────────────────────────────────────────────────
 * 分区标题
 * ───────────────────────────────────────────────────────────── */
.section-title {
  font-size: 26rpx;
  font-weight: 500;
  color: var(--text-secondary);
  letter-spacing: 0.08em;
  margin-bottom: var(--space-lg);
  padding-bottom: var(--space-sm);
  border-bottom: 1px solid var(--divider);
}

.section-divider {
  height: 1px;
  background: var(--divider);
  margin: var(--space-xl) 0;
}

/* ─────────────────────────────────────────────────────────────
 * 表单字段
 * ───────────────────────────────────────────────────────────── */
.field {
  margin-bottom: var(--space-xl);
}

.field:last-child {
  margin-bottom: 0;
}

.field-label {
  display: block;
  font-size: 22rpx;
  color: var(--text-tertiary);
  margin-bottom: var(--space-sm);
  font-weight: 500;
  letter-spacing: 0.08em;
  text-transform: uppercase;
}

.field-label.required::before {
  content: '* ';
  color: var(--error);
}

.input {
  width: 100%;
  height: 96rpx;
  padding: 0 var(--space-md);
  font-size: 30rpx;
  background: var(--background-warm);
  border: 1px solid var(--border);
  border-radius: var(--radius-md);
  box-sizing: border-box;
  color: var(--text-primary);
  transition: all 0.3s ease;
  letter-spacing: 0.02em;
}

.input:focus {
  border-color: var(--accent);
  box-shadow: 0 0 0 3px var(--accent-light);
}

.textarea {
  width: 100%;
  min-height: 140rpx;
  padding: var(--space-md);
  font-size: 30rpx;
  background: var(--background-warm);
  border: 1px solid var(--border);
  border-radius: var(--radius-md);
  box-sizing: border-box;
  color: var(--text-primary);
  transition: all 0.3s ease;
  letter-spacing: 0.02em;
  line-height: 1.6;
}

.textarea:focus {
  border-color: var(--accent);
  box-shadow: 0 0 0 3px var(--accent-light);
}

.input-placeholder {
  color: var(--text-muted);
}

/* ─────────────────────────────────────────────────────────────
 * 只读字段
 * ───────────────────────────────────────────────────────────── */
.field-readonly {
  margin-bottom: var(--space-md);
}

.readonly-value {
  font-size: 28rpx;
  color: var(--text-secondary);
  letter-spacing: 0.02em;
  padding: var(--space-xs) 0;
}

/* ─────────────────────────────────────────────────────────────
 * 错误提示
 * ───────────────────────────────────────────────────────────── */
.error-box {
  margin: var(--space-lg) 0;
  padding: var(--space-md);
  background: var(--error-bg);
  border-left: 2px solid var(--error);
}

.error-text {
  font-size: 24rpx;
  color: var(--error);
  letter-spacing: 0.02em;
}

/* ─────────────────────────────────────────────────────────────
 * 提交按钮
 * ───────────────────────────────────────────────────────────── */
.btn-submit {
  width: 100%;
  height: 112rpx;
  background: linear-gradient(135deg, var(--primary) 0%, var(--primary-dark) 100%);
  border-radius: var(--radius-lg);
  border: none;
  transition: all 0.5s cubic-bezier(0.23, 1, 0.32, 1);
  margin-top: var(--space-2xl);
  box-shadow: 0 8rpx 24rpx rgba(26, 26, 26, 0.15);
  position: relative;
  overflow: hidden;
}

.btn-submit::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(135deg, rgba(201, 169, 97, 0.15) 0%, transparent 100%);
  opacity: 0;
  transition: opacity 0.5s ease;
}

.btn-submit::after {
  border: none;
}

.btn-submit:active {
  transform: translateY(2rpx);
  box-shadow: 0 4rpx 12rpx rgba(26, 26, 26, 0.1);
}

.btn-submit:active::before {
  opacity: 1;
}

.btn-submit[disabled] {
  opacity: 0.4;
}

.btn-submit.waitlist {
  background: linear-gradient(135deg, var(--warning) 0%, #a06a00 100%);
}

.btn-submit .btn-text {
  font-size: 32rpx;
  font-weight: 500;
  color: #FFFFFF;
  letter-spacing: 0.08em;
}

/* ─────────────────────────────────────────────────────────────
 * 支付金额
 * ───────────────────────────────────────────────────────────── */
.fee-field {
  margin-top: var(--space-lg);
  padding-top: var(--space-lg);
  border-top: 1px solid var(--divider);
}

.fee-info {
  margin-bottom: var(--space-sm);
}

.fee-hint {
  font-size: 24rpx;
  color: var(--text-muted);
  letter-spacing: 0.02em;
}

.fee-input-wrapper {
  display: flex;
  align-items: center;
}

.fee-currency {
  font-size: 32rpx;
  font-weight: 500;
  color: var(--text-primary);
  margin-right: var(--space-sm);
}

.fee-input {
  flex: 1;
}