.page {
  min-height: 100vh;
  padding: 28rpx 32rpx 56rpx;
  background:
    linear-gradient(180deg, #f6f8fb 0%, #ffffff 260rpx, #ffffff 100%);
}

.loading-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 60vh;
}

.loading {
  width: 48rpx;
  height: 48rpx;
  border: 2rpx solid var(--border);
  border-top-color: #17345d;
  border-radius: 50%;
  animation: spin 0.8s cubic-bezier(0.4, 0, 0.2, 1) infinite;
}

@keyframes spin {
  to {
    transform: rotate(360deg);
  }
}

.loading-text,
.section-kicker,
.btn-caption,
.hero-eyebrow-en {
  font-family: "Canela", "Editorial New", "Iowan Old Style", Georgia, serif;
  font-size: 24rpx;
  line-height: 1.3;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  color: #8b97a8;
}

.hero-card,
.section-block,
.error-box,
.recovery-box {
  background: rgba(255, 255, 255, 0.92);
  border: 1rpx solid rgba(20, 38, 61, 0.08);
  border-radius: 32rpx;
}

.hero-card {
  padding: 34rpx 28rpx;
  display: flex;
  gap: 24rpx;
  align-items: flex-start;
  margin-bottom: 28rpx;
}

.hero-copy {
  flex: 1;
  min-width: 0;
}

.hero-title,
.section-title,
.btn-text {
  font-family: "Source Han Serif SC", "Noto Serif SC", "Songti SC", serif;
  font-weight: 600;
  color: #14263d;
}

.hero-title {
  display: block;
  margin-top: 12rpx;
  font-size: 48rpx;
  line-height: 1.36;
}

.hero-subtitle {
  display: block;
  margin-top: 20rpx;
  font-family: "HarmonyOS Sans SC", "Inter", "PingFang SC", sans-serif;
  font-size: 28rpx;
  line-height: 1.9;
  color: #586880;
}

.hero-activity {
  display: block;
  margin-top: 24rpx;
  font-family: "Source Han Serif SC", "Noto Serif SC", "Songti SC", serif;
  font-size: 32rpx;
  line-height: 1.55;
  font-weight: 600;
  color: #17345d;
}

.hero-meta {
  display: block;
  margin-top: 10rpx;
  font-family: "HarmonyOS Sans SC", "Inter", "PingFang SC", sans-serif;
  font-size: 24rpx;
  line-height: 1.8;
  color: #7a8797;
}

.hero-poster {
  width: 180rpx;
  height: 180rpx;
  flex-shrink: 0;
  border-radius: 28rpx;
  overflow: hidden;
  background: linear-gradient(180deg, #f8fafc, #eef3f8);
  display: flex;
  align-items: center;
  justify-content: center;
}

.hero-poster-image {
  width: 100%;
  height: 100%;
}

.hero-poster-fallback {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 100%;
}

.hero-poster-fallback-text {
  font-family: "Canela", "Editorial New", "Iowan Old Style", Georgia, serif;
  font-size: 40rpx;
  color: #9aa6b7;
  letter-spacing: 0.12em;
}

.form-card {
  animation: fadeIn 0.4s ease;
}

.section-block {
  padding: 32rpx 28rpx;
  margin-bottom: 24rpx;
}

.section-block:last-child {
  margin-bottom: 0;
}

.section-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.section-heading {
  flex: 1;
}

.section-title {
  display: block;
  margin-top: 12rpx;
  font-size: 40rpx;
  line-height: 1.4;
}

.section-arrow {
  font-size: 28rpx;
  color: #7a8797;
  display: inline-block;
  transition: transform 0.25s ease;
  transform: rotate(0deg);
  padding-top: 10rpx;
}

.section-arrow.expanded {
  transform: rotate(180deg);
}

.profile-list {
  margin-top: 28rpx;
}

.field {
  margin-bottom: 28rpx;
}

.field:last-child {
  margin-bottom: 0;
}

.field-label,
.readonly-value,
.fee-hint,
.error-text,
.recovery-text {
  font-family: "HarmonyOS Sans SC", "Inter", "PingFang SC", sans-serif;
}

.field-label {
  display: block;
  font-size: 24rpx;
  line-height: 1.8;
  color: #617288;
  margin-bottom: 16rpx;
  letter-spacing: 0.04em;
}

.field-label.required::before {
  content: "* ";
  color: var(--error);
}

.readonly-value {
  font-size: 30rpx;
  line-height: 1.9;
  color: #20324d;
  padding: 20rpx 24rpx;
  background: #f9fbfd;
  border-radius: 24rpx;
  border: 1rpx solid rgba(20, 38, 61, 0.06);
}

.input,
.textarea {
  width: 100%;
  box-sizing: border-box;
  color: #20324d;
  font-family: "HarmonyOS Sans SC", "Inter", "PingFang SC", sans-serif;
  font-size: 28rpx;
  line-height: 1.9;
  letter-spacing: 0.02em;
  background: #fbfcfe;
  border: 1rpx solid rgba(20, 38, 61, 0.08);
  border-radius: 24rpx;
}

.input {
  height: 104rpx;
  padding: 0 24rpx;
}

.textarea {
  min-height: 168rpx;
  padding: 24rpx;
}

.input-placeholder {
  color: #a2adbb;
}

.payment-block {
  padding-bottom: 30rpx;
}

.fee-field {
  margin-top: 28rpx;
}

.fee-info {
  margin-bottom: 14rpx;
}

.fee-hint {
  font-size: 24rpx;
  line-height: 1.8;
  color: #7a8797;
}

.fee-input-wrapper {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.fee-currency {
  font-family: "Source Han Serif SC", "Noto Serif SC", "Songti SC", serif;
  font-size: 36rpx;
  color: #14263d;
}

.fee-input {
  flex: 1;
}

.error-box,
.recovery-box {
  padding: 24rpx 26rpx;
  margin-bottom: 20rpx;
}

.error-box {
  border-color: rgba(178, 65, 55, 0.12);
  background: rgba(178, 65, 55, 0.04);
}

.error-text {
  font-size: 24rpx;
  line-height: 1.8;
  color: var(--error);
}

.recovery-box {
  border-color: rgba(23, 52, 93, 0.1);
  background: rgba(23, 52, 93, 0.04);
}

.recovery-text {
  font-size: 24rpx;
  line-height: 1.8;
  color: #17345d;
}

.btn-submit {
  width: 100%;
  min-height: 112rpx;
  background: #17345d;
  border-radius: 999rpx;
  border: none;
  margin-top: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 32rpx;
}

.btn-submit::after {
  border: none;
}

.btn-submit:active {
  opacity: 0.9;
}

.btn-submit[disabled] {
  opacity: 0.45;
}

.btn-submit.waitlist {
  background: #17345d;
}

.btn-content {
  width: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
}

.btn-copy {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  text-align: center;
}

.btn-caption {
  color: rgba(255, 255, 255, 0.72);
}

.btn-text {
  font-size: 36rpx;
  line-height: 1.4;
  color: #ffffff;
}

.btn-arrow {
  font-size: 34rpx;
  color: #ffffff;
  position: absolute;
  right: 0;
  top: 50%;
  transform: translateY(-50%);
}
