/**
 * 活动报名页 - 奢华简约风格
 */

/* ─────────────────────────────────────────────────────────────
 * 加载状态
 * ───────────────────────────────────────────────────────────── */
.loading-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 60vh;
}

.loading {
  width: 44rpx;
  height: 44rpx;
  border: 2rpx solid var(--border);
  border-top-color: var(--primary);
  border-radius: 50%;
  animation: spin 0.8s cubic-bezier(0.4, 0, 0.2, 1) infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  font-size: 26rpx;
  color: var(--text-tertiary);
  margin-top: 24rpx;
  letter-spacing: 0.02em;
}

.page {
  min-height: 100vh;
  padding: 48rpx 32rpx;
  background: var(--background);
}

/* ─────────────────────────────────────────────────────────────
 * 头部
 * ───────────────────────────────────────────────────────────── */
.header {
  margin-bottom: 48rpx;
  padding-bottom: 32rpx;
  border-bottom: 0.5px solid var(--divider);
}

.header-title {
  display: block;
  font-family: var(--font-display);
  font-size: 44rpx;
  font-weight: 600;
  color: var(--text-primary);
  letter-spacing: -0.02em;
  margin-bottom: 12rpx;
}

.header-subtitle {
  display: block;
  font-size: 26rpx;
  color: var(--text-tertiary);
  letter-spacing: 0.02em;
}

/* ─────────────────────────────────────────────────────────────
 * 表单卡片
 * ───────────────────────────────────────────────────────────── */
.form-card {
  animation: fadeIn 0.4s ease;
}

/* ─────────────────────────────────────────────────────────────
 * 分区标题
 * ───────────────────────────────────────────────────────────── */
.section-title {
  font-size: 26rpx;
  font-weight: 500;
  color: var(--text-secondary);
  letter-spacing: 0.08em;
  margin-bottom: var(--space-lg);
  padding-bottom: var(--space-sm);
  border-bottom: 1px solid var(--divider);
}

.section-divider {
  height: 1px;
  background: var(--divider);
  margin: var(--space-xl) 0;
}

/* ─────────────────────────────────────────────────────────────
 * 表单字段
 * ───────────────────────────────────────────────────────────── */
.field {
  margin-bottom: 32rpx;
}

.field:last-child {
  margin-bottom: 0;
}

.field-label {
  display: block;
  font-size: 24rpx;
  color: var(--text-tertiary);
  margin-bottom: 12rpx;
  font-weight: 500;
  letter-spacing: 0.02em;
}

.field-label.required::before {
  content: '* ';
  color: var(--error);
}

.input {
  width: 100%;
  height: 96rpx;
  padding: 0 24rpx;
  font-size: 30rpx;
  background: var(--background-card);
  border: 1.5px solid var(--border);
  border-radius: 16rpx;
  box-sizing: border-box;
  color: var(--text-primary);
  transition: all 0.3s ease;
  letter-spacing: -0.01em;
}

.input:focus {
  border-color: var(--primary);
  box-shadow: 0 0 0 4rpx var(--primary-light);
}

.textarea {
  width: 100%;
  min-height: 140rpx;
  padding: 20rpx 24rpx;
  font-size: 30rpx;
  background: var(--background-card);
  border: 1.5px solid var(--border);
  border-radius: 16rpx;
  box-sizing: border-box;
  color: var(--text-primary);
  transition: all 0.3s ease;
  letter-spacing: -0.01em;
  line-height: 1.5;
}

.textarea:focus {
  border-color: var(--primary);
  box-shadow: 0 0 0 4rpx var(--primary-light);
}

.input-placeholder {
  color: var(--text-muted);
}

/* ─────────────────────────────────────────────────────────────
 * 只读字段
 * ───────────────────────────────────────────────────────────── */
.field-readonly {
  margin-bottom: var(--space-md);
}

.readonly-value {
  font-size: 28rpx;
  color: var(--text-secondary);
  letter-spacing: 0.02em;
  padding: var(--space-xs) 0;
}

/* ─────────────────────────────────────────────────────────────
 * 错误提示
 * ───────────────────────────────────────────────────────────── */
.error-box {
  margin: var(--space-lg) 0;
  padding: var(--space-md);
  background: var(--error-bg);
  border-left: 2px solid var(--error);
}

.error-text {
  font-size: 24rpx;
  color: var(--error);
  letter-spacing: 0.02em;
}

/* ─────────────────────────────────────────────────────────────
 * 提交按钮
 * ───────────────────────────────────────────────────────────── */
.btn-submit {
  width: 100%;
  height: 104rpx;
  background: var(--primary);
  border-radius: 980rpx;
  border: none;
  transition: all 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  margin-top: 64rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.12);
}

.btn-submit::after {
  border: none;
}

.btn-submit:active {
  transform: scale(0.97);
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
}

.btn-submit[disabled] {
  opacity: 0.4;
}

.btn-submit .btn-text {
  font-size: 32rpx;
  font-weight: 500;
  color: #FFFFFF;
  letter-spacing: -0.01em;
}

/* ─────────────────────────────────────────────────────────────
 * 支付金额
 * ───────────────────────────────────────────────────────────── */
.fee-field {
  margin-top: var(--space-lg);
  padding-top: var(--space-lg);
  border-top: 1px solid var(--divider);
}

.fee-info {
  margin-bottom: var(--space-sm);
}

.fee-hint {
  font-size: 24rpx;
  color: var(--text-muted);
  letter-spacing: 0.02em;
}

.fee-input-wrapper {
  display: flex;
  align-items: center;
}

.fee-currency {
  font-size: 32rpx;
  font-weight: 500;
  color: var(--text-primary);
  margin-right: var(--space-sm);
}

.fee-input {
  flex: 1;
}