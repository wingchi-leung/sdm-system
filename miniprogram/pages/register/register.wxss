.page {
  --register-blue: #2A4D87;
  --register-blue-soft: rgba(42, 77, 135, 0.08);
  --register-blue-line: rgba(42, 77, 135, 0.18);
  --register-text: #121212;
  --register-subtext: #7a7f87;
  --register-muted: #b3b7bf;
  --register-divider: #e6e8ee;
  --register-border: rgba(42, 77, 135, 0.14);

  min-height: 100vh;
  box-sizing: border-box;
  background:
    radial-gradient(circle at top right, rgba(42, 77, 135, 0.06), transparent 34%),
    radial-gradient(circle at 12% 12%, rgba(42, 77, 135, 0.03), transparent 22%),
    #ffffff;
  color: var(--register-text);
  font-family: "PingFang SC", -apple-system, BlinkMacSystemFont, "Helvetica Neue", sans-serif;
}

.shell {
  min-height: 100vh;
  box-sizing: border-box;
  padding: calc(var(--status-bar-height, 0px) + 10rpx) 44rpx 214rpx;
}

.top-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  min-height: 92rpx;
}

.nav-btn {
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 999rpx;
}

.nav-btn:active {
  background: rgba(42, 77, 135, 0.06);
}

.nav-icon {
  color: #111111;
  font-size: 60rpx;
  line-height: 1;
  font-weight: 300;
}

.nav-btn-more .nav-icon {
  font-size: 34rpx;
  letter-spacing: 5rpx;
}

.nav-spacer {
  flex: 1;
}

.hero {
  margin-top: 76rpx;
}

.hero-title {
  display: block;
  color: var(--register-blue);
  font-size: 52rpx;
  line-height: 1.34;
  font-weight: 400;
  letter-spacing: 0.12em;
}

.hero-underline {
  width: 56rpx;
  height: 4rpx;
  margin-top: 32rpx;
  background: var(--register-blue);
  border-radius: 999rpx;
}

.hero-subtitle {
  display: block;
  margin-top: 66rpx;
  color: var(--register-text);
  font-size: 33rpx;
  line-height: 1.55;
  font-weight: 400;
  letter-spacing: 0.04em;
}

.hero-activity {
  display: block;
  margin-top: 16rpx;
  color: var(--register-subtext);
  font-size: 24rpx;
  line-height: 1.65;
  font-weight: 400;
  letter-spacing: 0.04em;
}

.hero-badge {
  display: inline-flex;
  align-items: center;
  margin-top: 20rpx;
  padding: 10rpx 16rpx;
  border-radius: 999rpx;
  background: var(--register-blue-soft);
  color: var(--register-blue);
  font-size: 22rpx;
  line-height: 1;
  font-weight: 400;
  letter-spacing: 0.04em;
}

.profile-toggle {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 72rpx;
  padding: 24rpx 0 18rpx;
  border-top: 1rpx solid rgba(42, 77, 135, 0.08);
}

.profile-toggle-label {
  color: var(--register-text);
  font-size: 28rpx;
  line-height: 1.5;
  font-weight: 400;
  letter-spacing: 0.06em;
}

.profile-toggle-meta {
  display: flex;
  align-items: center;
}

.profile-toggle-text {
  color: var(--register-blue);
  font-size: 22rpx;
  line-height: 1;
  font-weight: 400;
  letter-spacing: 0.08em;
}

.profile-toggle-arrow {
  margin-left: 10rpx;
  color: var(--register-blue);
  font-size: 32rpx;
  line-height: 1;
  transform: rotate(0deg);
  transition: transform 0.2s ease;
}

.profile-toggle-arrow.expanded {
  transform: rotate(90deg);
}

.profile-panel {
  margin-top: 12rpx;
  padding: 24rpx 0 0;
}

.profile-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 22rpx 18rpx;
}

.profile-item {
  padding: 20rpx 18rpx;
  border-radius: 18rpx;
  background: rgba(255, 255, 255, 0.96);
  border: 1rpx solid rgba(42, 77, 135, 0.08);
}

.profile-name {
  display: block;
  color: var(--register-muted);
  font-size: 21rpx;
  line-height: 1.55;
  font-weight: 400;
  letter-spacing: 0.06em;
}

.profile-value {
  display: block;
  margin-top: 8rpx;
  color: var(--register-text);
  font-size: 26rpx;
  line-height: 1.5;
  font-weight: 400;
  letter-spacing: 0.04em;
  word-break: break-word;
}

.question-card {
  margin-top: 36rpx;
}

.question-section-title {
  margin-bottom: 30rpx;
  color: var(--register-text);
  font-size: 30rpx;
  line-height: 1.5;
  font-weight: 400;
  letter-spacing: 0.08em;
}

.question-item {
  padding: 32rpx 0 34rpx;
  border-bottom: 1rpx solid var(--register-divider);
}

.question-item:first-of-type {
  padding-top: 0;
}

.question-index {
  display: block;
  color: var(--register-text);
  font-size: 38rpx;
  line-height: 1;
  font-weight: 400;
  letter-spacing: 0.08em;
}

.question-label {
  display: block;
  margin-top: 20rpx;
  color: var(--register-text);
  font-size: 30rpx;
  line-height: 1.72;
  font-weight: 400;
  letter-spacing: 0.03em;
}

.question-label.required::after {
  content: " *";
  color: var(--register-blue);
  font-weight: 400;
}

.question-control,
.fee-control {
  position: relative;
  margin-top: 22rpx;
  padding-bottom: 8rpx;
}

.question-control::after,
.fee-control::after {
  content: "";
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  height: 1rpx;
  background: rgba(42, 77, 135, 0.14);
  transform: scaleY(0.5);
  transform-origin: left center;
}

.question-control::before,
.fee-control::before {
  content: "";
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  height: 1rpx;
  background: var(--register-blue);
  transform: scaleX(0) scaleY(0.5);
  transform-origin: left center;
  transition: transform 0.25s ease;
}

.question-control.active::before,
.fee-control.active::before {
  transform: scaleX(1) scaleY(0.5);
}

.question-input {
  width: 100%;
  min-height: 58rpx;
  padding: 0;
  margin: 0;
  border: 0;
  background: transparent;
  box-sizing: border-box;
  color: var(--register-text);
  font-size: 28rpx;
  line-height: 58rpx;
  font-weight: 400;
  letter-spacing: 0.02em;
  font-family: "PingFang SC", -apple-system, BlinkMacSystemFont, "Helvetica Neue", sans-serif;
}

.question-textarea {
  min-height: 72rpx;
  line-height: 1.7;
}

.question-placeholder {
  color: var(--register-muted);
  letter-spacing: 0.02em;
}

.payment-note {
  margin-top: 34rpx;
  padding: 26rpx 0 0;
}

.payment-note-title {
  display: block;
  color: var(--register-text);
  font-size: 28rpx;
  line-height: 1.5;
  font-weight: 400;
  letter-spacing: 0.06em;
}

.fee-row {
  display: flex;
  align-items: flex-end;
  gap: 14rpx;
  margin-top: 18rpx;
}

.fee-currency {
  color: var(--register-blue);
  font-size: 36rpx;
  line-height: 1;
  font-weight: 400;
}

.fee-control {
  flex: 1;
  margin-top: 0;
}

.fee-input {
  width: 100%;
  min-height: 58rpx;
  padding: 0;
  border: 0;
  background: transparent;
  box-sizing: border-box;
  color: var(--register-text);
  font-size: 30rpx;
  line-height: 58rpx;
  font-weight: 400;
  letter-spacing: 0.03em;
}

.payment-hint {
  display: block;
  margin-top: 16rpx;
  color: var(--register-muted);
  font-size: 22rpx;
  line-height: 1.7;
  font-weight: 400;
  letter-spacing: 0.04em;
}

.error-box {
  margin-top: 28rpx;
  padding: 18rpx 20rpx;
  border-radius: 16rpx;
  background: rgba(42, 77, 135, 0.04);
  border: 1rpx solid rgba(42, 77, 135, 0.12);
}

.error-text {
  color: #7b4a44;
  font-size: 22rpx;
  line-height: 1.7;
  font-weight: 400;
  letter-spacing: 0.04em;
}

.bottom-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 20;
  display: flex;
  justify-content: flex-end;
  padding: 20rpx 44rpx calc(env(safe-area-inset-bottom) + 28rpx);
  background: linear-gradient(180deg, rgba(255, 255, 255, 0), rgba(255, 255, 255, 0.96) 28%, #ffffff 100%);
}

.next-btn {
  display: inline-flex;
  align-items: center;
  justify-content: flex-end;
  gap: 20rpx;
  width: auto;
  min-height: 0;
  padding: 0;
  margin: 0;
  border: 0;
  background: transparent;
  border-radius: 0;
}

.next-btn::after {
  border: 0;
}

.next-btn[disabled] {
  opacity: 0.45;
}

.next-btn-text {
  color: var(--register-blue);
  font-size: 30rpx;
  line-height: 1;
  font-weight: 400;
  letter-spacing: 0.12em;
}

.next-btn-arrow {
  color: var(--register-blue);
  font-size: 36rpx;
  line-height: 1;
  font-weight: 300;
}

.state-wrap {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 0 48rpx;
  box-sizing: border-box;
}

.loading {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  border: 2rpx solid rgba(42, 77, 135, 0.12);
  border-top-color: var(--register-blue);
  animation: spin 0.85s linear infinite;
}

.state-text {
  margin-top: 18rpx;
  color: var(--register-muted);
  font-size: 24rpx;
  line-height: 1.6;
  font-weight: 400;
  letter-spacing: 0.08em;
}

@keyframes spin {
  to {
    transform: rotate(360deg);
  }
}
