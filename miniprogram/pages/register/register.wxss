/**
 * 活动报名页 - Linear风格设计
 */
.page {
  min-height: 100vh;
  padding: @space-lg) @space-xl) @space-2xl);
  background: var(--background);
}

.title {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: @space-2xl);
  letter-spacing: -0.5rpx;
}

.form {
  background: var(--background-card);
  border-radius: 24rpx;
  padding: @space-2xl);
  box-shadow: var(--shadow-md);
  border: 1px solid var(--border);
}

.field {
  margin-bottom: @space-2xl);
}

.field:last-child {
  margin-bottom: 0;
}

.field-label {
  display: block;
  font-size: 28rpx;
  color: var(--text-secondary);
  margin-bottom: @space-sm);
  font-weight: 500;
}

.field-label.required::after {
  content: ' *';
  color: var(--error);
}

.input {
  width: 100%;
  height: 96rpx;
  padding: 0 @space-md);
  font-size: 30rpx;
  background: var(--background-input);
  border-radius: 14rpx;
  box-sizing: border-box;
  border: 1px solid var(--border);
  color: var(--text-primary);
  transition: all 0.2s;
}

.input:focus {
  border-color: var(--primary);
  box-shadow: 0 0 0 4rpx var(--primary-light);
}

/* ====== Linear风格错误提示 ====== */
.error-box {
  margin: @space-lg) 0;
  padding: @space-lg);
  background: var(--error-bg);
  border-radius: 14rpx;
  border: 1px solid rgba(239, 68, 68, 0.2);
  display: flex;
  align-items: center;
  gap: @space-sm);
}

.error-box::before {
  content: '✕';
  font-size: 24rpx;
  width: 32rpx;
  height: 32rpx;
  background: var(--error);
  color: #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.error-text {
  font-size: 28rpx;
  color: var(--error);
  flex: 1;
}

/* ====== Linear风格提交按钮 ====== */
.submit-btn {
  width: 100%;
  margin-top: @space-2xl);
  padding: @space-lg);
  font-size: 32rpx;
  font-weight: 600;
  box-shadow: var(--shadow-glow);
}
