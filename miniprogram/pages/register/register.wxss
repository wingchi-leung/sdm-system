.page {
  min-height: 100vh;
  padding: 0 0 300rpx;
  background: #fdfdfd;
  box-sizing: border-box;
  font-family: "SF Pro Text", "SF Pro Display", "PingFang SC", -apple-system, BlinkMacSystemFont, "Helvetica Neue", sans-serif;
}

.loading-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 62vh;
}

.loading-text {
  margin-top: 20rpx;
  color: #bdbdbd;
  font-size: 24rpx;
  line-height: 1.6;
  font-weight: 400;
  letter-spacing: 0.08em;
}

.hero-card {
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
  gap: 32rpx;
  padding: 100rpx 64rpx 76rpx;
}

.hero-copy {
  flex: 1;
  min-width: 0;
  padding-bottom: 4rpx;
}

.hero-eyebrow-cn {
  display: block;
  color: #bdbdbd;
  font-size: 24rpx;
  line-height: 1.6;
  font-weight: 400;
  letter-spacing: 0.14em;
}

.hero-activity {
  display: block;
  margin-top: 22rpx;
  color: #1a1a1a;
  font-size: 56rpx;
  line-height: 1.38;
  font-weight: 400;
  letter-spacing: 0.06em;
  word-break: break-word;
}

.hero-code {
  display: none;
}

.hero-poster {
  width: 164rpx;
  height: 164rpx;
  border-radius: 14rpx;
  overflow: hidden;
  background: #f4f4f4;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.hero-poster-image {
  width: 100%;
  height: 100%;
}

.hero-poster-fallback {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 100%;
}

.hero-poster-fallback-text {
  color: #bdbdbd;
  font-size: 24rpx;
  line-height: 1;
  font-weight: 500;
  letter-spacing: 0.18em;
}

.profile-summary {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 28rpx 64rpx 0;
}

.profile-summary-left,
.profile-summary-right {
  display: flex;
  align-items: center;
}

.profile-icon {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 28rpx;
  margin-right: 16rpx;
  color: #bdbdbd;
  font-size: 24rpx;
  line-height: 1;
  font-weight: 400;
}

.profile-label {
  color: #bdbdbd;
  font-size: 24rpx;
  line-height: 1.6;
  font-weight: 400;
  letter-spacing: 0.12em;
}

.profile-summary-title {
  color: #666666;
  font-size: 28rpx;
  line-height: 1.55;
  font-weight: 400;
  letter-spacing: 0.08em;
}

.section-arrow {
  margin-left: 12rpx;
  color: #bdbdbd;
  font-size: 28rpx;
  line-height: 1;
  font-weight: 400;
  transform: rotate(0deg);
  transition: transform 0.2s ease;
}

.section-arrow.expanded {
  transform: rotate(90deg);
}

.profile-list {
  padding: 34rpx 64rpx 0;
}

.form-card,
.section-block {
  padding: 0 64rpx;
}

.form-card {
  padding-top: 108rpx;
}

.section-block {
  padding-top: 84rpx;
}

.section-title-row {
  display: flex;
  align-items: center;
  margin-bottom: 46rpx;
}

.section-marker {
  width: 3rpx;
  height: 28rpx;
  margin-right: 14rpx;
  background: rgba(26, 26, 26, 0.08);
  border-radius: 999rpx;
}

.section-kicker,
.section-kicker-strong {
  color: #666666;
  font-size: 24rpx;
  line-height: 1.6;
  font-weight: 400;
  letter-spacing: 0.14em;
}

.field {
  margin-bottom: 0;
  padding: 0 0 30rpx;
}

.field + .field {
  padding-top: 18rpx;
}

.field-readonly:last-child,
.field:last-child {
  padding-bottom: 0;
}

.field-label {
  display: block;
  margin-bottom: 8rpx;
  color: #1a1a1a;
  font-size: 28rpx;
  line-height: 1.62;
  font-weight: 400;
  letter-spacing: 0.06em;
}

.field-label.required::after {
  content: " *";
  color: rgba(214, 68, 58, 0.82);
  font-weight: 400;
}

.control-wrap,
.fee-control {
  position: relative;
  min-height: 50rpx;
  padding-bottom: 8rpx;
}

.control-wrap::after,
.fee-control::after {
  content: "";
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  height: 1rpx;
  background: rgba(26, 26, 26, 0.11);
  transform: scaleY(0.5);
  transform-origin: left center;
}

.control-wrap::before,
.fee-control::before {
  content: "";
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  height: 1rpx;
  background: rgba(26, 26, 26, 0.92);
  transform: scaleX(0) scaleY(0.5);
  transform-origin: left center;
  transition: transform 340ms cubic-bezier(0.22, 1, 0.36, 1);
}

.control-wrap.active::after,
.fee-control.active::after {
  background: rgba(26, 26, 26, 0.11);
}

.control-wrap.active::before,
.fee-control.active::before {
  transform: scaleX(1) scaleY(0.5);
}

.input,
.textarea,
.readonly-value {
  width: 100%;
  height: 50rpx;
  min-height: 50rpx;
  padding: 0;
  margin: 0;
  border: 0;
  background: transparent;
  box-sizing: border-box;
  color: #666666;
  font-size: 25rpx;
  line-height: 50rpx;
  font-weight: 400;
  letter-spacing: 0.06em;
  font-family: "SF Pro Text", "SF Pro Display", "PingFang SC", -apple-system, BlinkMacSystemFont, "Helvetica Neue", sans-serif;
}

.readonly-value {
  color: #666666;
  padding-bottom: 2rpx;
}

.textarea {
  height: auto;
  min-height: 50rpx;
  line-height: 1.68;
}

.input-placeholder,
.textarea-placeholder {
  color: #bdbdbd;
  letter-spacing: 0.06em;
}

.payment-block {
  padding-bottom: 24rpx;
}

.fee-field .field-label {
  margin-bottom: 14rpx;
}

.fee-input-wrapper {
  display: flex;
  align-items: flex-end;
  gap: 16rpx;
}

.fee-currency {
  color: #1a1a1a;
  font-size: 34rpx;
  line-height: 1;
  font-weight: 400;
  letter-spacing: 0.04em;
  transform: translateY(-2rpx);
}

.fee-control {
  flex: 1;
  min-height: 58rpx;
}

.fee-input {
  width: 100%;
  height: 58rpx;
  min-height: 58rpx;
  color: #1a1a1a;
  font-size: 34rpx;
  line-height: 58rpx;
  font-weight: 400;
  letter-spacing: 0.04em;
}

.fee-input-placeholder {
  color: #bdbdbd;
}

.fee-info {
  margin-top: 18rpx;
}

.fee-hint {
  display: block;
  color: #bdbdbd;
  font-size: 22rpx;
  line-height: 1.7;
  font-weight: 400;
  letter-spacing: 0.08em;
}

.error-box {
  padding: 28rpx 64rpx 0;
}

.error-text {
  color: #a66863;
  font-size: 22rpx;
  line-height: 1.7;
  font-weight: 400;
  letter-spacing: 0.06em;
}

.bottom-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  justify-content: flex-start;
  padding: 40rpx 64rpx calc(env(safe-area-inset-bottom) + 34rpx);
  background: #fdfdfd;
  z-index: 20;
}

.btn-submit {
  display: inline-flex;
  align-items: flex-start;
  justify-content: flex-start;
  gap: 22rpx;
  width: auto;
  min-height: 0;
  padding: 0;
  margin: 0;
  background: transparent;
  border: 0;
  border-radius: 0;
}

.btn-submit::after {
  border: 0;
}

.btn-submit[disabled] {
  opacity: 0.4;
}

.btn-entry {
  display: inline-flex;
  flex-direction: column;
  align-items: flex-start;
}

.btn-text {
  color: #1a1a1a;
  font-size: 28rpx;
  line-height: 1.55;
  font-weight: 500;
  letter-spacing: 0.08em;
}

.btn-arrow {
  color: #1a1a1a;
  font-size: 34rpx;
  line-height: 1;
  font-weight: 400;
}

.btn-line {
  width: 100%;
  height: 1rpx;
  margin-top: 12rpx;
  background: rgba(26, 26, 26, 0.55);
  transform: scaleY(0.5);
  transform-origin: left center;
}
