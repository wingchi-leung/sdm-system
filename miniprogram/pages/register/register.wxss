.page {
  min-height: 100vh;
  background: #ffffff;
  box-sizing: border-box;
  padding: 0 0 180rpx;
  font-family: "Songti SC", "STSong", "SimSun", serif;
}

.loading-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 60vh;
}

.loading-text {
  margin-top: 16rpx;
  color: #888888;
  font-size: 24rpx;
}

.hero-card {
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
  padding: 96rpx 64rpx 62rpx;
}

.hero-copy {
  flex: 1;
  min-width: 0;
}

.hero-eyebrow-cn {
  display: block;
  color: #545454;
  font-size: 30rpx;
  line-height: 1.3;
  font-weight: 400;
  font-family: "Songti SC", "STSong", "SimSun", serif;
}

.hero-activity {
  display: block;
  margin-top: 16rpx;
  color: #111111;
  font-size: 50rpx;
  line-height: 1.22;
  font-weight: 400;
  font-family: "Songti SC", "STSong", "SimSun", serif;
}

.hero-code {
  display: none;
}

.hero-poster {
  width: 164rpx;
  height: 164rpx;
  border-radius: 14rpx;
  overflow: hidden;
  background: #f7f7f7;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.hero-poster-image {
  width: 100%;
  height: 100%;
}

.hero-poster-fallback-text {
  color: #1f1f1f;
  font-size: 34rpx;
  line-height: 1;
  font-weight: 400;
  font-family: "Songti SC", "STSong", "SimSun", serif;
}

.section-divider {
  height: 1rpx;
  margin: 0 0 0 0;
  background: #f1f1f1;
}

.profile-summary {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 34rpx 64rpx;
  border-bottom: 1rpx solid #f1f1f1;
}

.profile-summary-left,
.profile-summary-right {
  display: flex;
  align-items: center;
}

.profile-icon {
  position: relative;
  display: inline-block;
  width: 30rpx;
  height: 32rpx;
  color: #9a9a9a;
  margin-right: 16rpx;
  font-size: 0;
  line-height: 0;
}

.profile-icon::before {
  content: "";
  position: absolute;
  top: 1rpx;
  left: 9rpx;
  width: 11rpx;
  height: 11rpx;
  border: 2rpx solid #9a9a9a;
  border-radius: 50%;
}

.profile-icon::after {
  content: "";
  position: absolute;
  left: 3rpx;
  bottom: 1rpx;
  width: 22rpx;
  height: 14rpx;
  border: 2rpx solid #9a9a9a;
  border-bottom: 0;
  border-radius: 18rpx 18rpx 0 0;
}

.profile-label {
  color: #111111;
  font-size: 28rpx;
  line-height: 1.3;
  font-family: "Songti SC", "STSong", "SimSun", serif;
}

.profile-summary-title {
  color: #111111;
  font-size: 28rpx;
  line-height: 1.2;
  font-family: "Songti SC", "STSong", "SimSun", serif;
}

.section-arrow {
  color: #999999;
  font-size: 32rpx;
  margin-left: 12rpx;
  line-height: 1;
  transform: rotate(0deg);
  transition: transform 0.2s ease;
}

.section-arrow.expanded {
  transform: rotate(90deg);
}

.profile-list {
  padding: 0 64rpx 12rpx;
}

.form-card,
.section-block {
  padding: 0 64rpx;
}

.form-card {
  padding-top: 42rpx;
}

.section-title-row {
  display: flex;
  align-items: center;
  margin-bottom: 34rpx;
}

.section-marker {
  width: 6rpx;
  height: 32rpx;
  background: #d8d8d8;
  border-radius: 6rpx;
  margin-right: 12rpx;
}

.section-kicker {
  color: #111111;
  font-size: 30rpx;
  line-height: 1.2;
  font-family: "Songti SC", "STSong", "SimSun", serif;
}

.section-kicker-strong {
  font-weight: 600;
}

.field {
  margin-bottom: 44rpx;
}

.field-label {
  display: block;
  color: #111111;
  font-size: 30rpx;
  line-height: 1.35;
  margin-bottom: 12rpx;
  font-family: "Songti SC", "STSong", "SimSun", serif;
}

.field-label.required::after {
  content: " *";
  color: #d72f2f;
}

.control-wrap {
  position: relative;
  padding-bottom: 18rpx;
}

.control-wrap::after {
  content: "";
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  height: 1rpx;
  background: #e9e9e9;
}

.control-wrap.active::after {
  height: 1rpx;
  background: #111111;
}

.input,
.textarea,
.readonly-value {
  width: 100%;
  color: #111111;
  font-size: 28rpx;
  line-height: 1.45;
  padding: 0;
  margin: 0;
  border: 0;
  background: transparent;
  box-sizing: border-box;
  font-family: "Songti SC", "STSong", "SimSun", serif;
}

.readonly-value {
  padding-bottom: 8rpx;
}

.textarea {
  min-height: 44rpx;
}

.input-placeholder {
  color: #a9a9a9;
  font-size: 28rpx;
  font-family: "Songti SC", "STSong", "SimSun", serif;
}

.payment-block {
  margin-top: 36rpx;
  padding-bottom: 38rpx;
}

.fee-input-wrapper {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.fee-currency {
  color: #111111;
  font-size: 44rpx;
  line-height: 1;
  font-family: "Songti SC", "STSong", "SimSun", serif;
}

.fee-input {
  font-size: 44rpx;
  line-height: 1.2;
}

.fee-control {
  flex: 1;
}

.fee-hint {
  display: block;
  margin-top: 14rpx;
  color: #909090;
  font-size: 28rpx;
  line-height: 1.4;
  font-family: "Songti SC", "STSong", "SimSun", serif;
}

.error-box {
  padding: 8rpx 64rpx 12rpx;
}

.error-text {
  color: #d93025;
  font-size: 24rpx;
  line-height: 1.4;
}

.bottom-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  align-items: center;
  gap: 32rpx;
  padding: 24rpx 64rpx calc(env(safe-area-inset-bottom) + 24rpx);
  background: #ffffff;
  border-top: 1rpx solid #ececec;
}

.bottom-left {
  flex: 1;
  min-width: 0;
  overflow: hidden;
}

.bottom-title {
  display: block;
  color: #222222;
  font-size: 28rpx;
  line-height: 1.45;
  font-family: "Songti SC", "STSong", "SimSun", serif;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.bottom-sub {
  display: block;
  margin-top: 8rpx;
  color: #9a9a9a;
  font-size: 28rpx;
  line-height: 1.35;
  font-family: "Songti SC", "STSong", "SimSun", serif;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.btn-submit {
  width: 310rpx;
  min-height: 86rpx;
  background: #070707;
  border: 0;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn-submit::after {
  border: 0;
}

.btn-submit[disabled] {
  opacity: 0.5;
}

.btn-text {
  color: #ffffff;
  font-size: 30rpx;
  line-height: 1.2;
  font-weight: 500;
  font-family: "Songti SC", "STSong", "SimSun", serif;
}
