/**
 * 用户列表 - 高级简约风格
 */

.page {
  min-height: 100vh;
  padding: var(--space-xl) var(--space-lg);
  background: var(--background);
}

/* ─────────────────────────────────────────────────────────────
 * 搜索栏
 * ───────────────────────────────────────────────────────────── */
.search-section {
  display: flex;
  align-items: center;
  gap: var(--space-md);
  padding-bottom: var(--space-lg);
  border-bottom: 1px solid var(--divider);
  margin-bottom: var(--space-lg);
}

.search-input {
  flex: 1;
  height: 72rpx;
  padding: 0 var(--space-md);
  font-size: 26rpx;
  background: transparent;
  border: none;
  border-bottom: 1px solid var(--border);
  color: var(--text-primary);
  letter-spacing: 0.04em;
}

.search-input::placeholder {
  color: var(--text-muted);
}

.search-actions {
  display: flex;
  gap: var(--space-md);
}

.search-btn,
.clear-btn {
  font-size: 24rpx;
  color: var(--text-secondary);
  letter-spacing: 0.08em;
}

.search-btn:active,
.clear-btn:active {
  color: var(--text-primary);
}

/* ─────────────────────────────────────────────────────────────
 * 统计头部
 * ───────────────────────────────────────────────────────────── */
.stats-header {
  display: flex;
  align-items: baseline;
  gap: var(--space-sm);
  margin-bottom: var(--space-lg);
}

.stats-label {
  font-size: 22rpx;
  color: var(--text-muted);
  letter-spacing: 0.1em;
  text-transform: uppercase;
}

.stats-count {
  font-family: var(--font-display);
  font-size: 32rpx;
  font-weight: 500;
  color: var(--text-primary);
  letter-spacing: 0.02em;
}

/* ─────────────────────────────────────────────────────────────
 * 状态页面
 * ───────────────────────────────────────────────────────────── */
.state-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 40vh;
}

.state-title {
  font-family: var(--font-display);
  font-size: 32rpx;
  font-weight: 500;
  color: var(--text-primary);
  letter-spacing: 0.04em;
}

/* ─────────────────────────────────────────────────────────────
 * 用户列表
 * ───────────────────────────────────────────────────────────── */
.list {
  display: flex;
  flex-direction: column;
}

.user-item {
  padding: var(--space-lg) 0;
  border-bottom: 1px solid var(--divider);
}

.user-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: var(--space-md);
}

.user-name {
  font-size: 28rpx;
  font-weight: 500;
  color: var(--text-primary);
  letter-spacing: 0.04em;
}

.user-status {
  font-size: 20rpx;
  color: var(--status-ongoing);
  letter-spacing: 0.08em;
}

.user-status.blocked {
  color: var(--error);
}

.user-info {
  display: flex;
  flex-direction: column;
  gap: var(--space-xs);
}

.info-row {
  display: flex;
  align-items: baseline;
}

.info-label {
  width: 100rpx;
  font-size: 22rpx;
  color: var(--text-muted);
  letter-spacing: 0.08em;
  text-transform: uppercase;
}

.info-value {
  font-size: 24rpx;
  color: var(--text-secondary);
  letter-spacing: 0.02em;
}

/* ─────────────────────────────────────────────────────────────
 * 加载更多
 * ───────────────────────────────────────────────────────────── */
.load-more,
.no-more {
  text-align: center;
  padding: var(--space-2xl) 0;
}

.load-more text,
.no-more text {
  font-size: 22rpx;
  color: var(--text-muted);
  letter-spacing: 0.1em;
}