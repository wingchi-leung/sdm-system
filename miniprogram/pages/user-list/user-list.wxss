.page {
  min-height: 100vh;
  box-sizing: border-box;
  background:
    radial-gradient(circle at top left, rgba(17, 17, 17, 0.02) 0, rgba(17, 17, 17, 0.01) 20%, transparent 45%),
    linear-gradient(180deg, #ffffff 0%, #fcfcfc 100%);
  color: #111111;
  font-family: "PingFang SC", -apple-system, BlinkMacSystemFont, "Helvetica Neue", sans-serif;
}

.content {
  padding: 0 40rpx calc(180rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

.nav-btn {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #111111;
}

.nav-icon {
  font-size: 46rpx;
  line-height: 1;
  font-weight: 300;
}

.top-pill {
  width: 164rpx;
  height: 66rpx;
  border: 1rpx solid rgba(17, 17, 17, 0.08);
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.94);
  display: flex;
  align-items: center;
  overflow: hidden;
  box-sizing: border-box;
}

.top-pill-left,
.top-pill-right {
  flex: 1;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.top-pill-divider {
  width: 1rpx;
  height: 30rpx;
  background: rgba(17, 17, 17, 0.08);
}

.pill-dots {
  color: #111111;
  font-size: 24rpx;
  line-height: 1;
  letter-spacing: 4rpx;
  transform: translateY(-2rpx);
}

.pill-circle {
  width: 24rpx;
  height: 24rpx;
  border: 4rpx solid #111111;
  border-radius: 50%;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: center;
}

.pill-circle-inner {
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  background: #111111;
}

.hero {
  margin-top: 46rpx;
}

.hero-label {
  display: block;
  color: #8f9199;
  font-size: 20rpx;
  line-height: 1.3;
  font-weight: 500;
  letter-spacing: 0.02em;
}

.hero-count {
  display: block;
  margin-top: 10rpx;
  color: #111111;
  font-size: 54rpx;
  line-height: 1;
  font-weight: 500;
  letter-spacing: 0.02em;
}

.search-box {
  margin-top: 34rpx;
  height: 82rpx;
  padding: 0 24rpx;
  border-radius: 22rpx;
  background: #f5f6f7;
  display: flex;
  align-items: center;
  gap: 16rpx;
  box-sizing: border-box;
}

.picker-hint {
  margin-top: 14rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.picker-hint-text {
  flex: 1;
  min-width: 0;
  color: #8f9199;
  font-size: 20rpx;
  line-height: 1.6;
}

.picker-hint-count {
  flex-shrink: 0;
  color: #111111;
  font-size: 20rpx;
  line-height: 1.6;
  font-weight: 500;
}

.search-icon {
  flex-shrink: 0;
  color: #8f9199;
  font-size: 28rpx;
  line-height: 1;
  transform: translateY(-1rpx);
}

.search-input {
  flex: 1;
  min-width: 0;
  height: 100%;
  color: #111111;
  font-size: 24rpx;
  line-height: 1;
  background: transparent;
}

.search-input::placeholder {
  color: #9da0a8;
}

.state-wrap {
  min-height: 52vh;
  padding: 120rpx 0 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  text-align: center;
}

.state-wrap.empty {
  padding-top: 96rpx;
}

.loading {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(17, 17, 17, 0.12);
  border-top-color: #111111;
  animation: spin 0.9s linear infinite;
}

.state-title {
  color: #111111;
  font-size: 28rpx;
  line-height: 1.4;
  font-weight: 500;
}

.state-text {
  margin-top: 14rpx;
  color: #8f9199;
  font-size: 20rpx;
  line-height: 1.7;
  text-align: center;
}

.list {
  margin-top: 34rpx;
  display: flex;
  flex-direction: column;
}

.user-item {
  padding: 22rpx 0;
  border-bottom: 1rpx solid rgba(17, 17, 17, 0.08);
}

.picker-item {
  padding-left: 4rpx;
}

.user-item:last-child {
  border-bottom: none;
}

.user-main {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
}

.picker-item .user-main {
  justify-content: flex-start;
}

.user-avatar {
  width: 84rpx;
  height: 84rpx;
  flex-shrink: 0;
  margin-top: 2rpx;
  border-radius: 50%;
  overflow: hidden;
  background: linear-gradient(180deg, #f7f8fa 0%, #edf0f5 100%);
  box-shadow: inset 0 0 0 1rpx rgba(17, 17, 17, 0.06);
  display: flex;
  align-items: center;
  justify-content: center;
}

.user-avatar-image {
  width: 100%;
  height: 100%;
  display: block;
}

.user-avatar-text {
  color: #111111;
  font-size: 28rpx;
  line-height: 1;
  font-weight: 500;
}

.picker-check {
  width: 34rpx;
  height: 34rpx;
  flex-shrink: 0;
  margin-top: 4rpx;
  border-radius: 50%;
  border: 2rpx solid rgba(17, 17, 17, 0.18);
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  background: #ffffff;
}

.picker-check.is-selected {
  border-color: #111111;
  background: #111111;
}

.picker-check-text {
  color: #ffffff;
  font-size: 18rpx;
  line-height: 1;
  font-weight: 600;
}

.user-left {
  flex: 1;
  min-width: 0;
}

.picker-item .user-left {
  margin-left: 10rpx;
}

.user-title-row {
  display: flex;
  align-items: center;
  gap: 14rpx;
  flex-wrap: wrap;
}

.user-name {
  color: #111111;
  font-size: 28rpx;
  line-height: 1.28;
  font-weight: 500;
  word-break: break-word;
}

.user-badge {
  min-width: 62rpx;
  height: 34rpx;
  padding: 0 12rpx;
  border-radius: 999rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  background: #f3f4f6;
  color: #8a8d95;
  font-size: 18rpx;
  line-height: 1;
  font-weight: 500;
}

.user-badge.is-blocked {
  background: rgba(178, 65, 55, 0.08);
  color: #b24137;
}

.user-meta {
  display: block;
  margin-top: 10rpx;
  color: #8f9199;
  font-size: 20rpx;
  line-height: 1.45;
  word-break: break-word;
}

.user-more {
  flex-shrink: 0;
  width: 58rpx;
  height: 58rpx;
  margin-top: -2rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #111111;
}

.user-more-text {
  font-size: 28rpx;
  line-height: 1;
  font-weight: 500;
  letter-spacing: 4rpx;
}

.bottom-action {
  position: fixed;
  left: 0;
  right: 0;
  bottom: calc(28rpx + env(safe-area-inset-bottom));
  padding: 0 40rpx;
  box-sizing: border-box;
  pointer-events: none;
}

.invite-btn {
  width: 100%;
  height: 92rpx;
  border-radius: 20rpx;
  border: 1rpx solid rgba(17, 17, 17, 0.72);
  background: #cedbf4;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 14rpx;
  box-sizing: border-box;
  pointer-events: auto;
  box-shadow: 0 8rpx 28rpx rgba(17, 17, 17, 0.04);
}

.invite-icon {
  position: relative;
  width: 32rpx;
  height: 32rpx;
  flex-shrink: 0;
}

.invite-icon-head {
  position: absolute;
  left: 6rpx;
  top: 0;
  width: 14rpx;
  height: 14rpx;
  border: 2rpx solid #111111;
  border-radius: 50%;
  box-sizing: border-box;
}

.invite-icon-body {
  position: absolute;
  left: 2rpx;
  bottom: 1rpx;
  width: 20rpx;
  height: 14rpx;
  border: 2rpx solid #111111;
  border-top: none;
  border-radius: 0 0 16rpx 16rpx;
  box-sizing: border-box;
}

.invite-icon-plus {
  position: absolute;
  right: -2rpx;
  top: 9rpx;
  color: #111111;
  font-size: 18rpx;
  line-height: 1;
  font-weight: 500;
}

.invite-text {
  color: #111111;
  font-size: 24rpx;
  line-height: 1.2;
  font-weight: 500;
}

@keyframes spin {
  from {
    transform: rotate(0deg);
  }

  to {
    transform: rotate(360deg);
  }
}
