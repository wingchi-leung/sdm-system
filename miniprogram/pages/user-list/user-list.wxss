/**
 * 用户列表 - 极简奢华风格
 */

.page {
  min-height: 100vh;
  padding: var(--space-2xl) var(--space-lg);
  background: var(--background);
}

/* ─────────────────────────────────────────────────────────────
 * 搜索栏
 * ───────────────────────────────────────────────────────────── */
.search-section {
  display: grid;
  grid-template-columns: 1fr auto;
  align-items: center;
  column-gap: var(--space-md);
  padding-bottom: var(--space-lg);
  border-bottom: 1px solid var(--divider);
  margin-bottom: var(--space-xl);
}

.search-main {
  min-width: 0;
}

.search-input {
  width: 100%;
  height: 88rpx;
  padding: 0 var(--space-md);
  font-size: 28rpx;
  background: var(--background-warm);
  border: 1px solid var(--border);
  border-radius: var(--radius-md);
  color: var(--text-primary);
  letter-spacing: 0.02em;
  transition: all 0.3s ease;
}

.search-input:focus {
  border-color: var(--accent);
  box-shadow: none;
}

.search-input::placeholder {
  color: var(--text-muted);
}

.search-actions {
  display: flex;
  gap: var(--space-sm);
  justify-self: end;
}

.search-btn,
.clear-btn {
  font-size: 26rpx;
  color: var(--text-secondary);
  letter-spacing: 0.04em;
  padding: var(--space-xs) var(--space-sm);
  transition: all 0.3s ease;
}

.search-btn:active,
.clear-btn:active {
  color: var(--accent);
}

/* ─────────────────────────────────────────────────────────────
 * 统计头部
 * ───────────────────────────────────────────────────────────── */
.toolbar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: var(--space-xl);
}

.stats-header {
  display: flex;
  align-items: baseline;
  gap: var(--space-sm);
}

.mode-switch {
  display: inline-flex;
  align-items: center;
  background: #F3F3F3;
  border-radius: 999rpx;
  padding: 4rpx;
  gap: 4rpx;
}

.mode-btn {
  min-width: 116rpx;
  height: 48rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  color: var(--text-secondary);
  font-size: 22rpx;
  font-weight: 500;
  line-height: 1;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}

.mode-btn.active {
  background: #000000;
  color: #FFFFFF;
}

.stats-label {
  font-size: 22rpx;
  color: var(--text-tertiary);
  letter-spacing: 0.08em;
  text-transform: uppercase;
}

.stats-count {
  font-family: var(--font-display);
  font-size: 40rpx;
  font-weight: 300;
  color: var(--text-primary);
  letter-spacing: 0.04em;
}

/* ─────────────────────────────────────────────────────────────
 * 状态页面
 * ───────────────────────────────────────────────────────────── */
.state-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 40vh;
}

.state-title {
  font-family: var(--font-display);
  font-size: 32rpx;
  font-weight: 500;
  color: var(--text-primary);
  letter-spacing: 0.04em;
}

/* ─────────────────────────────────────────────────────────────
 * 用户列表
 * ───────────────────────────────────────────────────────────── */
.list {
  display: flex;
  flex-direction: column;
}

.user-item {
  padding: 18rpx 0;
  border-bottom: 1px solid var(--divider);
  transition: all 0.3s ease;
}

.user-main {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
}

.user-left {
  flex: 1;
  min-width: 0;
}

.user-right {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  justify-content: space-between;
  min-height: 120rpx;
}

.user-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 10rpx;
}

.user-name {
  font-size: 32rpx;
  font-weight: 500;
  color: var(--text-primary);
  letter-spacing: 0.02em;
}

.user-status {
  font-size: 20rpx;
  color: var(--status-ongoing);
  letter-spacing: 0.08em;
  padding: 8rpx 16rpx;
  border-radius: var(--radius-sm);
  background: var(--status-ongoing-bg);
  text-transform: uppercase;
}

.user-status.blocked {
  color: var(--error);
  background: var(--error-bg);
}

.user-info {
  display: flex;
  flex-direction: column;
  gap: var(--space-sm);
}

.compact-info {
  flex-direction: row;
  align-items: center;
  gap: 10rpx;
  min-height: 34rpx;
}

.compact-text {
  color: var(--text-tertiary);
  font-size: 24rpx;
  line-height: 1.2;
}

.compact-dot {
  color: var(--text-muted);
  font-size: 20rpx;
  line-height: 1;
}

.info-row {
  display: flex;
  align-items: baseline;
}

.info-label {
  width: 120rpx;
  font-size: 22rpx;
  color: var(--text-tertiary);
  letter-spacing: 0.08em;
  text-transform: uppercase;
}

.info-value {
  font-size: 26rpx;
  color: var(--text-secondary);
  letter-spacing: 0.02em;
}

/* ─────────────────────────────────────────────────────────────
 * 操作按钮
 * ───────────────────────────────────────────────────────────── */
.user-actions {
  display: flex;
  justify-content: flex-end;
  margin-top: 12rpx;
}

.action-btn {
  font-size: 26rpx;
  padding: var(--space-sm) var(--space-lg);
  border-radius: var(--radius-md);
  letter-spacing: 0.04em;
  font-weight: 500;
  transition: all 0.3s ease;
}

.block-btn {
  color: var(--error);
  background: transparent;
  border: 1px solid var(--error);
}

.block-btn:active {
  background: var(--error-bg);
  transform: translateY(1rpx);
}

.unblock-btn {
  color: var(--success);
  background: transparent;
  border: 1px solid var(--success);
}

.unblock-btn:active {
  background: var(--success-bg);
  transform: translateY(1rpx);
}

.block-reason {
  color: var(--error);
}

/* 视觉降噪：去掉列表分割线，依靠留白分组 */
.header {
  border-bottom: none;
}

/* Product UI refinement：用户列表规格统一 */
.page {
  padding: 24rpx 32rpx;
}

.toolbar {
  margin-bottom: 18rpx;
}

.header {
  margin-bottom: 24rpx;
  padding-bottom: 0;
}

.header-title {
  font-size: 44rpx;
  line-height: 56rpx;
  font-weight: 500;
  letter-spacing: 0.4rpx;
}

.header-subtitle,
.search-placeholder,
.user-phone,
.user-meta,
.empty-text {
  color: #999999;
  font-size: 24rpx;
  line-height: 34rpx;
  font-weight: 400;
  letter-spacing: 0.4rpx;
}

.search-box,
.user-card {
  border-radius: 24rpx;
  box-shadow: none;
}

.user-name {
  font-size: 32rpx;
  line-height: 44rpx;
  font-weight: 500;
  letter-spacing: 0.4rpx;
}

.action-btn {
  min-height: 72rpx;
  border-radius: 16rpx;
  font-size: 28rpx;
  line-height: 40rpx;
  font-weight: 500;
  letter-spacing: 0.4rpx;
}

/* 用户管理页小控件统一为稳定胶囊尺寸 */
.user-status,
.action-btn,
.search-btn,
.clear-btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  line-height: 1;
  white-space: nowrap;
}

.user-status {
  min-width: 88rpx;
  height: 44rpx;
  padding: 0 16rpx;
  border-radius: 22rpx;
  vertical-align: middle;
}

.user-status-text {
  font-size: 22rpx;
  font-weight: 500;
  letter-spacing: 0;
  line-height: 1;
  transform: translateY(-1rpx);
}

.action-btn {
  min-width: 112rpx;
  min-height: 56rpx;
  padding: 0 24rpx;
  border-radius: 28rpx;
  font-size: 24rpx;
  font-weight: 500;
  letter-spacing: 0.4rpx;
}

.search-btn,
.clear-btn {
  min-height: 52rpx;
  padding: 0 20rpx;
  border-radius: 26rpx;
  background: #F8F8F6;
  font-size: 24rpx;
  font-weight: 500;
}
