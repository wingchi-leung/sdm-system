/**
 * 用户列表 - 极简奢华风格
 */

.page {
  min-height: 100vh;
  padding: var(--space-2xl) var(--space-lg);
  background: var(--background);
}

/* ─────────────────────────────────────────────────────────────
 * 搜索栏
 * ───────────────────────────────────────────────────────────── */
.search-section {
  display: flex;
  align-items: center;
  gap: var(--space-md);
  padding-bottom: var(--space-lg);
  border-bottom: 1px solid var(--divider);
  margin-bottom: var(--space-xl);
}

.search-input {
  flex: 1;
  height: 88rpx;
  padding: 0 var(--space-md);
  font-size: 28rpx;
  background: var(--background-warm);
  border: 1px solid var(--border);
  border-radius: var(--radius-md);
  color: var(--text-primary);
  letter-spacing: 0.02em;
  transition: all 0.3s ease;
}

.search-input:focus {
  border-color: var(--accent);
  box-shadow: none;
}

.search-input::placeholder {
  color: var(--text-muted);
}

.search-actions {
  display: flex;
  gap: var(--space-sm);
}

.search-btn,
.clear-btn {
  font-size: 26rpx;
  color: var(--text-secondary);
  letter-spacing: 0.04em;
  padding: var(--space-xs) var(--space-sm);
  transition: all 0.3s ease;
}

.search-btn:active,
.clear-btn:active {
  color: var(--accent);
}

/* ─────────────────────────────────────────────────────────────
 * 统计头部
 * ───────────────────────────────────────────────────────────── */
.stats-header {
  display: flex;
  align-items: baseline;
  gap: var(--space-sm);
  margin-bottom: var(--space-xl);
}

.stats-label {
  font-size: 22rpx;
  color: var(--text-tertiary);
  letter-spacing: 0.08em;
  text-transform: uppercase;
}

.stats-count {
  font-family: var(--font-display);
  font-size: 40rpx;
  font-weight: 300;
  color: var(--text-primary);
  letter-spacing: 0.04em;
}

/* ─────────────────────────────────────────────────────────────
 * 状态页面
 * ───────────────────────────────────────────────────────────── */
.state-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 40vh;
}

.state-title {
  font-family: var(--font-display);
  font-size: 32rpx;
  font-weight: 500;
  color: var(--text-primary);
  letter-spacing: 0.04em;
}

/* ─────────────────────────────────────────────────────────────
 * 用户列表
 * ───────────────────────────────────────────────────────────── */
.list {
  display: flex;
  flex-direction: column;
}

.user-item {
  padding: var(--space-xl) 0;
  border-bottom: 1px solid var(--divider);
  transition: all 0.3s ease;
}

.user-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: var(--space-md);
}

.user-name {
  font-size: 32rpx;
  font-weight: 500;
  color: var(--text-primary);
  letter-spacing: 0.02em;
}

.user-status {
  font-size: 20rpx;
  color: var(--status-ongoing);
  letter-spacing: 0.08em;
  padding: 8rpx 16rpx;
  border-radius: var(--radius-sm);
  background: var(--status-ongoing-bg);
  text-transform: uppercase;
}

.user-status.blocked {
  color: var(--error);
  background: var(--error-bg);
}

.user-info {
  display: flex;
  flex-direction: column;
  gap: var(--space-sm);
}

.info-row {
  display: flex;
  align-items: baseline;
}

.info-label {
  width: 120rpx;
  font-size: 22rpx;
  color: var(--text-tertiary);
  letter-spacing: 0.08em;
  text-transform: uppercase;
}

.info-value {
  font-size: 26rpx;
  color: var(--text-secondary);
  letter-spacing: 0.02em;
}

/* ─────────────────────────────────────────────────────────────
 * 操作按钮
 * ───────────────────────────────────────────────────────────── */
.user-actions {
  display: flex;
  justify-content: flex-end;
  margin-top: var(--space-md);
}

.action-btn {
  font-size: 26rpx;
  padding: var(--space-sm) var(--space-lg);
  border-radius: var(--radius-md);
  letter-spacing: 0.04em;
  font-weight: 500;
  transition: all 0.3s ease;
}

.block-btn {
  color: var(--error);
  background: transparent;
  border: 1px solid var(--error);
}

.block-btn:active {
  background: var(--error-bg);
  transform: translateY(1rpx);
}

.unblock-btn {
  color: var(--success);
  background: transparent;
  border: 1px solid var(--success);
}

.unblock-btn:active {
  background: var(--success-bg);
  transform: translateY(1rpx);
}

.block-reason {
  color: var(--error);
}

/* 视觉降噪：去掉列表分割线，依靠留白分组 */
.header,
.user-item {
  border-bottom: none;
}

/* Product UI refinement：用户列表规格统一 */
.page {
  padding: 24rpx 32rpx;
}

.header {
  margin-bottom: 24rpx;
  padding-bottom: 0;
}

.header-title {
  font-size: 44rpx;
  line-height: 56rpx;
  font-weight: 500;
  letter-spacing: 0.4rpx;
}

.header-subtitle,
.search-placeholder,
.user-phone,
.user-meta,
.empty-text {
  color: #999999;
  font-size: 24rpx;
  line-height: 34rpx;
  font-weight: 400;
  letter-spacing: 0.4rpx;
}

.search-box,
.user-card {
  border-radius: 24rpx;
  box-shadow: none;
}

.user-name {
  font-size: 32rpx;
  line-height: 44rpx;
  font-weight: 500;
  letter-spacing: 0.4rpx;
}

.action-btn {
  min-height: 72rpx;
  border-radius: 16rpx;
  font-size: 28rpx;
  line-height: 40rpx;
  font-weight: 500;
  letter-spacing: 0.4rpx;
}
