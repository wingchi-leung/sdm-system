/**
 * 用户列表 - 奢华简约风格
 */

.page {
  min-height: 100vh;
  padding: 48rpx 32rpx;
  background: var(--background);
}

/* ─────────────────────────────────────────────────────────────
 * 搜索栏
 * ───────────────────────────────────────────────────────────── */
.search-section {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding-bottom: 32rpx;
  border-bottom: 0.5px solid var(--divider);
  margin-bottom: 32rpx;
}

.search-input {
  flex: 1;
  height: 80rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  background: var(--background-card);
  border: 1.5px solid var(--border);
  border-radius: 980rpx;
  color: var(--text-primary);
  letter-spacing: -0.01em;
  transition: all 0.3s ease;
}

.search-input:focus {
  border-color: var(--primary);
  box-shadow: 0 0 0 4rpx var(--primary-light);
}

.search-input::placeholder {
  color: var(--text-muted);
}

.search-actions {
  display: flex;
  gap: 16rpx;
}

.search-btn,
.clear-btn {
  font-size: 26rpx;
  color: var(--text-secondary);
  letter-spacing: 0.02em;
  padding: 8rpx 16rpx;
  transition: all 0.2s ease;
}

.search-btn:active,
.clear-btn:active {
  color: var(--text-primary);
}

/* ─────────────────────────────────────────────────────────────
 * 统计头部
 * ───────────────────────────────────────────────────────────── */
.stats-header {
  display: flex;
  align-items: baseline;
  gap: 12rpx;
  margin-bottom: 32rpx;
}

.stats-label {
  font-size: 24rpx;
  color: var(--text-tertiary);
  letter-spacing: 0.02em;
}

.stats-count {
  font-family: var(--font-display);
  font-size: 36rpx;
  font-weight: 600;
  color: var(--text-primary);
  letter-spacing: -0.02em;
}

/* ─────────────────────────────────────────────────────────────
 * 状态页面
 * ───────────────────────────────────────────────────────────── */
.state-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 40vh;
}

.state-title {
  font-family: var(--font-display);
  font-size: 32rpx;
  font-weight: 500;
  color: var(--text-primary);
  letter-spacing: 0.04em;
}

/* ─────────────────────────────────────────────────────────────
 * 用户列表
 * ───────────────────────────────────────────────────────────── */
.list {
  display: flex;
  flex-direction: column;
}

.user-item {
  padding: 32rpx 0;
  border-bottom: 0.5px solid var(--divider);
}

.user-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.user-name {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
  letter-spacing: -0.01em;
}

.user-status {
  font-size: 22rpx;
  color: var(--status-ongoing);
  letter-spacing: 0.02em;
  padding: 6rpx 16rpx;
  border-radius: 980rpx;
  background: var(--status-ongoing-bg);
}

.user-status.blocked {
  color: var(--error);
  background: var(--error-bg);
}

.user-info {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.info-row {
  display: flex;
  align-items: baseline;
}

.info-label {
  width: 120rpx;
  font-size: 24rpx;
  color: var(--text-tertiary);
  letter-spacing: 0.02em;
}

.info-value {
  font-size: 26rpx;
  color: var(--text-secondary);
  letter-spacing: 0;
}

/* ─────────────────────────────────────────────────────────────
 * 操作按钮
 * ───────────────────────────────────────────────────────────── */
.user-actions {
  display: flex;
  justify-content: flex-end;
  margin-top: 20rpx;
}

.action-btn {
  font-size: 26rpx;
  padding: 12rpx 28rpx;
  border-radius: 980rpx;
  letter-spacing: 0;
  font-weight: 500;
  transition: all 0.3s ease;
}

.block-btn {
  color: var(--error);
  background: transparent;
  border: 1.5px solid var(--error);
}

.block-btn:active {
  background: var(--error-bg);
  transform: scale(0.96);
}

.unblock-btn {
  color: var(--success);
  background: transparent;
  border: 1.5px solid var(--success);
}

.unblock-btn:active {
  background: var(--success-bg);
  transform: scale(0.96);
}

.block-reason {
  color: var(--error);
}