<view class="page" style="--status-bar-height: {{statusBarHeight}}px;">
  <view class="content">
    <page-header title="{{pageTitle}}" statusBarHeight="{{statusBarHeight}}" bindback="onBack">
      <view slot="actions" class="top-pill" bindtap="onPageMenu" aria-label="更多操作">
        <view class="top-pill-left">
          <text class="pill-dots">···</text>
        </view>
        <view class="top-pill-divider"></view>
        <view class="top-pill-right">
          <view class="pill-circle">
            <view class="pill-circle-inner"></view>
          </view>
        </view>
      </view>
    </page-header>

    <view class="hero">
      <text class="hero-label">成员总数</text>
      <text class="hero-count">{{total}}</text>
    </view>

    <view class="search-box">
      <text class="search-icon">⌕</text>
      <input
        class="search-input"
        placeholder="搜索成员"
        value="{{keyword}}"
        bindinput="onSearchInput"
        bindconfirm="onSearch"
        confirm-type="search"
      />
    </view>

    <view wx:if="{{selectionMode}}" class="picker-hint">
      <text class="picker-hint-text">{{selectionHint}}</text>
      <text class="picker-hint-count">已选 {{selectedCount}} 人</text>
    </view>

    <view wx:if="{{loading && users.length === 0}}" class="state-wrap">
      <view class="loading"></view>
      <text class="state-text">加载成员中…</text>
    </view>

    <view wx:elif="{{error && users.length === 0}}" class="state-wrap empty">
      <text class="state-title">暂时无法查看成员</text>
      <text class="state-text">{{error}}</text>
    </view>

    <view wx:elif="{{users.length === 0}}" class="state-wrap empty">
      <text class="state-title">{{emptyTitle}}</text>
      <text class="state-text">{{emptyDescription}}</text>
    </view>

    <view wx:else class="list">
      <view
        wx:for="{{users}}"
        wx:key="id"
        class="user-item {{selectionMode ? 'picker-item' : ''}}"
        data-user="{{item}}"
        bindtap="onUserTap"
      >
        <view class="user-main">
          <view wx:if="{{selectionMode}}" class="picker-check {{item.isSelected ? 'is-selected' : ''}}">
            <text class="picker-check-text">{{item.isSelected ? '✓' : ''}}</text>
          </view>
          <view class="user-left">
            <view class="user-title-row">
              <text class="user-name">{{item.displayName}}</text>
              <text class="user-badge {{item.badgeClass}}">{{item.badgeText}}</text>
            </view>
            <text class="user-meta">{{item.contactText}}</text>
          </view>

          <view wx:if="{{!selectionMode}}" class="user-more" data-user="{{item}}" catchtap="onUserMore">
            <text class="user-more-text">···</text>
          </view>
        </view>
      </view>
    </view>
  </view>

  <view wx:if="{{selectionMode}}" class="bottom-action">
    <view class="invite-btn" bindtap="onInviteMembers">
      <view class="invite-icon">
        <view class="invite-icon-head"></view>
        <view class="invite-icon-body"></view>
        <text class="invite-icon-plus">＋</text>
      </view>
      <text class="invite-text">{{selectedCount > 0 ? confirmText : '请选择成员'}}</text>
    </view>
  </view>
</view>
