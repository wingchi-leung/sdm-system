<view class="page">
  <!-- 加载状态 -->
  <view wx:if="{{loading}}" class="state-wrap">
    <view class="loading"></view>
    <text class="state-text">加载中…</text>
  </view>

  <!-- 错误状态 -->
  <view wx:elif="{{error}}" class="state-wrap error">
    <view class="state-icon">!</view>
    <text class="state-title">加载失败</text>
    <text class="state-text">{{error}}</text>
  </view>

  <!-- 活动详情 -->
  <view wx:elif="{{activity}}" class="content">
    <view class="poster-section">
      <view class="poster-shell">
        <view class="poster-copy">
          <text class="eyebrow-en">Activity</text>
          <text class="eyebrow-cn">活动详情</text>
        </view>
        <view class="poster-frame">
          <image wx:if="{{activity.poster_url && !posterLoadFailed}}" class="poster-image" src="{{activity.poster_url}}" mode="aspectFit" bindload="onPosterLoad" binderror="onPosterError" />
          <view wx:else class="poster-fallback">暂无海报</view>
        </view>
      </view>
    </view>

    <view class="hero-card">
      <view class="hero-status-row">
        <view class="status-badge {{activity.status === 1 ? 'not-started' : (activity.status === 2 ? 'ongoing' : 'ended')}}">
          {{activity.status_text}}
        </view>
        <view wx:if="{{hasRegistered}}" class="status-badge registered">
          {{registrationStatusText}}
        </view>
      </view>
      <text class="activity-title">{{activity.activity_name}}</text>
      <text wx:if="{{activity.activity_type_name || activity.tag}}" class="activity-subtitle">
        {{activity.activity_type_name || ''}}{{activity.activity_type_name && activity.tag ? ' · ' : ''}}{{activity.tag || ''}}
      </text>
    </view>

    <view class="info-card">
      <view class="section-headline">
        <text class="section-kicker">Overview</text>
        <text class="section-title">活动信息</text>
      </view>
      <view class="info-list">
        <view class="info-item" wx:if="{{activity.start_display}}">
          <text class="info-label">开始时间</text>
          <text class="info-value">{{activity.start_display}}</text>
        </view>
        <view class="info-item" wx:if="{{activity.end_display}}">
          <text class="info-label">结束时间</text>
          <text class="info-value">{{activity.end_display}}</text>
        </view>
        <view class="info-item">
          <text class="info-label">活动地点</text>
          <text class="info-value">{{activity.location || '线上活动'}}</text>
        </view>
        <view class="info-item" wx:if="{{activity.activity_type_name}}">
          <text class="info-label">活动类型</text>
          <text class="info-value">{{activity.activity_type_name}}</text>
        </view>
      </view>
    </view>

    <view wx:if="{{showCommunitySection}}" class="community-section">
      <view class="section-headline">
        <view>
          <text class="section-kicker">Field Notes</text>
          <text class="section-title">活动动态</text>
        </view>
        <view class="section-actions">
          <text wx:if="{{communityPosts.length > 0}}" class="section-link" bindtap="onViewCommunityList">查看更多</text>
          <text wx:if="{{showAdminPanel}}" class="section-link primary" bindtap="onCreateCommunityPost">发布动态</text>
        </view>
      </view>

      <view wx:if="{{communityLoading}}" class="community-state">
        <text class="community-state-text">动态加载中…</text>
      </view>

      <view wx:elif="{{communityError}}" class="community-state">
        <text class="community-state-text">{{communityError}}</text>
      </view>

      <view wx:elif="{{communityPosts.length > 0}}" class="community-list">
        <view wx:for="{{communityPosts}}" wx:key="id" class="community-card" data-id="{{item.id}}" bindtap="onViewCommunityPost">
          <image wx:if="{{item.cover_url}}" class="community-cover" src="{{item.cover_url}}" mode="aspectFill" />
          <view class="community-body">
            <text class="community-title">{{item.title}}</text>
            <text class="community-meta">{{item.author_name}} · {{item.create_time_display}}</text>
            <text class="community-summary">{{item.content}}</text>
            <text class="community-comments">{{item.comment_count}} 条评论</text>
          </view>
        </view>
      </view>

      <view wx:else class="community-empty">
        <text class="community-empty-text">暂无活动动态</text>
      </view>
    </view>

    <!-- 管理员面板 -->
    <view wx:if="{{showAdminPanel}}" class="admin-section">
      <view class="section-headline">
        <text class="section-kicker">Manage</text>
        <text class="section-title">管理功能</text>
      </view>
      <view class="admin-grid">
        <view class="admin-action" bindtap="onViewParticipants">
          <view class="action-icon-wrap">
            <text class="action-icon">◉</text>
          </view>
          <text class="action-text">查看人员</text>
        </view>
        <view class="admin-action" bindtap="onViewCheckins">
          <view class="action-icon-wrap">
            <text class="action-icon">✓</text>
          </view>
          <text class="action-text">签到记录</text>
        </view>
        <view class="admin-action" bindtap="onViewStatistics">
          <view class="action-icon-wrap">
            <text class="action-icon">◫</text>
          </view>
          <text class="action-text">报名统计</text>
        </view>
        <view class="admin-action" bindtap="onChangeStatus">
          <view class="action-icon-wrap">
            <text class="action-icon">⟳</text>
          </view>
          <text class="action-text">更改状态</text>
        </view>
        <view class="admin-action" bindtap="onEditActivity">
          <view class="action-icon-wrap">
            <text class="action-icon">✎</text>
          </view>
          <text class="action-text">编辑活动</text>
        </view>
        <view class="admin-action" bindtap="onCreateCommunityPost">
          <view class="action-icon-wrap">
            <text class="action-icon">☰</text>
          </view>
          <text class="action-text">发布动态</text>
        </view>
        <view class="admin-action delete" bindtap="onDeleteActivity">
          <view class="action-icon-wrap">
            <text class="action-icon">✕</text>
          </view>
          <text class="action-text">删除活动</text>
        </view>
      </view>
    </view>

    <view class="action-section">
      <view wx:if="{{canEnroll}}" class="btn-wrap">
        <button class="btn-enroll" bindtap="goRegister">
          <view class="btn-content">
            <view class="btn-copy">
              <text class="btn-caption">Application</text>
              <text class="btn-text">进入报名</text>
            </view>
            <text class="btn-arrow">→</text>
          </view>
        </button>
      </view>
      <view wx:else class="disabled-tip">
        <text>{{actionTipText}}</text>
      </view>
    </view>
  </view>
</view>
