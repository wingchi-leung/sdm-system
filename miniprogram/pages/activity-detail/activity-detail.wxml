<view class="page">
  <!-- 加载状态 -->
  <view wx:if="{{loading}}" class="state-wrap">
    <view class="loading"></view>
    <text class="state-text">加载中…</text>
  </view>

  <!-- 错误状态 -->
  <view wx:elif="{{error}}" class="state-wrap error">
    <view class="error-icon">
      <text>!</text>
    </view>
    <text class="state-title">加载失败</text>
    <text class="state-desc">{{error}}</text>
  </view>

  <!-- 活动详情 -->
  <view wx:elif="{{activity}}" class="content">
    <!-- 状态指示器 -->
    <view class="status-header">
      <view class="status-indicator {{activity.status === 1 ? 'pending' : (activity.status === 2 ? 'active' : 'ended')}}"></view>
      <text class="status-label {{activity.status === 1 ? 'pending' : (activity.status === 2 ? 'active' : 'ended')}}">
        {{activity.status_text}}
      </text>
    </view>

    <!-- 活动标题 -->
    <text class="activity-title">{{activity.activity_name}}</text>

    <!-- 信息卡片 -->
    <view class="info-card">
      <view class="info-row" wx:if="{{activity.start_display}}">
        <text class="info-key">开始时间</text>
        <text class="info-value">{{activity.start_display}}</text>
      </view>
      <view class="info-row" wx:if="{{activity.end_display}}">
        <text class="info-key">结束时间</text>
        <text class="info-value">{{activity.end_display}}</text>
      </view>
      <view class="info-row" wx:if="{{activity.activity_type_name}}">
        <text class="info-key">活动类型</text>
        <text class="info-value">{{activity.activity_type_name}}</text>
      </view>
      <view class="info-row" wx:if="{{activity.tag}}">
        <text class="info-key">标签</text>
        <view class="tag-wrap">
          <text class="tag-text">{{activity.tag}}</text>
        </view>
      </view>
    </view>

    <!-- 管理员面板 -->
    <view wx:if="{{isAdmin}}" class="admin-panel">
      <text class="panel-title">管理功能</text>
      <view class="admin-grid">
        <view class="admin-action" bindtap="onViewParticipants">
          <view class="action-icon">
            <text>◉</text>
          </view>
          <text class="action-label">查看人员</text>
        </view>
        <view class="admin-action" bindtap="onViewCheckins">
          <view class="action-icon">
            <text>✓</text>
          </view>
          <text class="action-label">签到记录</text>
        </view>
        <view class="admin-action" bindtap="onViewStatistics">
          <view class="action-icon">
            <text>◫</text>
          </view>
          <text class="action-label">报名统计</text>
        </view>
        <view class="admin-action" bindtap="onChangeStatus">
          <view class="action-icon">
            <text>⟳</text>
          </view>
          <text class="action-label">更改状态</text>
        </view>
        <view class="admin-action" bindtap="onEditActivity">
          <view class="action-icon">
            <text>✎</text>
          </view>
          <text class="action-label">编辑活动</text>
        </view>
      </view>
    </view>

    <!-- 报名按钮 -->
    <view wx:if="{{!isAdmin}}" class="action-section">
      <view wx:if="{{canEnroll}}">
        <button class="btn-enroll" bindtap="goRegister">
          <text class="enroll-text">立即报名</text>
        </button>
      </view>
      <view wx:else class="disabled-tip">
        <text>活动已结束，无法报名</text>
      </view>
    </view>
  </view>
</view>