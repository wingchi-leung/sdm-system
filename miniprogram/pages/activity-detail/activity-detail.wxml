<view class="page" style="--status-bar-height: {{statusBarHeight}}px;">
  <view wx:if="{{loading}}" class="state-wrap">
    <view class="loading"></view>
    <text class="state-text">加载中…</text>
  </view>

  <view wx:elif="{{error}}" class="state-wrap error">
    <view class="state-icon">!</view>
    <text class="state-title">加载失败</text>
    <text class="state-text">{{error}}</text>
  </view>

  <view wx:elif="{{activity}}">
    <page-header statusBarHeight="{{statusBarHeight}}" bindback="onBack">
      <view slot="actions" class="nav-btn" bindtap="onMore" aria-label="更多">
        <text class="nav-icon more">···</text>
      </view>
    </page-header>

    <view class="content">
      <view class="hero-section">
        <text class="hero-title">{{activity.activity_name}}</text>
        <text wx:if="{{activity.hero_summary}}" class="hero-subtitle">{{activity.hero_summary}}</text>
        <view class="hero-divider"></view>
      </view>

      <view class="poster-card">
        <image
          wx:if="{{activity.poster_url && !posterLoadFailed}}"
          class="poster-image"
          src="{{activity.poster_url}}"
          mode="aspectFill"
          bindload="onPosterLoad"
          binderror="onPosterError"
        />
        <view wx:else class="poster-fallback">
          <text class="poster-fallback-title">FUTURE DESIGN</text>
          <text class="poster-fallback-cn">{{activity.activity_name}}</text>
          <text wx:if="{{activity.poster_fallback_summary}}" class="poster-fallback-subtitle">
            {{activity.poster_fallback_summary}}
          </text>
        </view>
      </view>

      <view class="detail-block">
        <text wx:for="{{activity.detail_paragraphs}}" wx:for-item="paragraph" wx:key="index" class="detail-paragraph">{{paragraph}}</text>
      </view>

      <view class="info-card">
        <view class="info-row">
          <text class="info-label">时间</text>
          <text class="info-value">{{activity.info_rows[0].value}}</text>
        </view>
        <view class="info-row">
          <text class="info-label">地点</text>
          <text class="info-value">{{activity.info_rows[1].value}}</text>
        </view>
        <view class="info-row">
          <text class="info-label">参与方式</text>
          <text class="info-value">{{activity.info_rows[2].value}}</text>
        </view>
      </view>

      <view wx:if="{{showCommunitySection}}" class="section-block">
        <view class="section-headline">
          <text class="section-title">活动动态</text>
          <view class="section-actions">
            <text wx:if="{{communityPosts.length > 0}}" class="section-link" bindtap="onViewCommunityList">查看更多</text>
            <text wx:if="{{showAdminPanel}}" class="section-link primary" bindtap="onCreateCommunityPost">发布动态</text>
          </view>
        </view>

        <view wx:if="{{communityLoading}}" class="community-state">
          <text class="community-state-text">动态加载中…</text>
        </view>

        <view wx:elif="{{communityError}}" class="community-state">
          <text class="community-state-text">{{communityError}}</text>
        </view>

        <view wx:elif="{{communityPosts.length > 0}}" class="community-list">
          <view wx:for="{{communityPosts}}" wx:key="id" class="community-item" data-id="{{item.id}}" bindtap="onViewCommunityPost">
            <image wx:if="{{item.images && item.images.length > 0}}" class="community-cover" src="{{item.images[0]}}" mode="aspectFill" />
            <view class="community-body">
              <text class="community-title">{{item.title}}</text>
              <text class="community-meta">{{item.author_name}} · {{item.create_time_display}}</text>
            </view>
          </view>
        </view>

        <view wx:else class="community-empty">
          <text class="community-empty-text">暂无活动动态</text>
        </view>
      </view>

      <view wx:if="{{showAdminPanel}}" class="section-block">
        <view class="section-headline">
          <text class="section-title">管理功能</text>
        </view>
        <view class="admin-grid">
          <view class="admin-action" bindtap="onViewParticipants">
            <text class="action-icon">◉</text>
            <text class="action-text">查看人员</text>
          </view>
          <view class="admin-action" bindtap="onViewCheckins">
            <text class="action-icon">✓</text>
            <text class="action-text">签到记录</text>
          </view>
          <view class="admin-action" bindtap="onViewStatistics">
            <text class="action-icon">◫</text>
            <text class="action-text">报名统计</text>
          </view>
          <view class="admin-action" bindtap="onChangeStatus">
            <text class="action-icon">⟳</text>
            <text class="action-text">更改状态</text>
          </view>
          <view class="admin-action" bindtap="onEditActivity">
            <text class="action-icon">✎</text>
            <text class="action-text">编辑活动</text>
          </view>
          <view class="admin-action" bindtap="onCreateCommunityPost">
            <text class="action-icon">☰</text>
            <text class="action-text">发布动态</text>
          </view>
          <view class="admin-action delete" bindtap="onDeleteActivity">
            <text class="action-icon">✕</text>
            <text class="action-text">删除活动</text>
          </view>
        </view>
      </view>

      <view class="action-section">
        <view wx:if="{{hasPendingPayment}}" class="cta-wrap pending" bindtap="onPrimaryAction">
          <text class="cta-text">继续支付 <text class="cta-arrow">→</text></text>
          <view class="cta-line"></view>
        </view>
        <view wx:elif="{{canEnroll}}" class="cta-wrap" bindtap="onPrimaryAction">
          <text class="cta-text">报名活动 <text class="cta-arrow">→</text></text>
          <view class="cta-line"></view>
        </view>
        <view wx:else class="disabled-tip">
          <text>{{actionTipText}}</text>
        </view>
      </view>
    </view>
  </view>
</view>
