/**
 * 活动详情页 - 高级简约风格
 */

.page {
  min-height: 100vh;
  padding: var(--space-xl) var(--space-lg);
  padding-bottom: var(--space-3xl);
  background: var(--background);
}

.content {
  animation: fadeIn 0.4s ease;
}

/* ─────────────────────────────────────────────────────────────
 * 状态展示
 * ───────────────────────────────────────────────────────────── */
.state-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: var(--space-3xl) var(--space-lg);
  min-height: 60vh;
}

.state-wrap.error .state-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: var(--error-bg);
  color: var(--error);
  font-size: 40rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: var(--space-lg);
}

.state-title {
  font-size: 34rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: var(--space-sm);
  letter-spacing: 0.02em;
}

.state-text {
  font-size: 26rpx;
  color: var(--text-tertiary);
  text-align: center;
  margin-top: var(--space-sm);
}

/* ─────────────────────────────────────────────────────────────
 * 活动标题区域
 * ───────────────────────────────────────────────────────────── */
.header-section {
  margin-bottom: var(--space-xl);
}

.status-badge {
  display: inline-block;
  padding: 8rpx 20rpx;
  border-radius: var(--radius-full);
  font-size: 22rpx;
  font-weight: 500;
  letter-spacing: 0.04em;
  margin-bottom: var(--space-md);
}

.status-badge.not-started {
  background: var(--status-not-started-bg);
  color: var(--status-not-started);
}

.status-badge.ongoing {
  background: var(--status-ongoing-bg);
  color: var(--status-ongoing);
}

.status-badge.ended {
  background: var(--status-ended-bg);
  color: var(--status-ended);
}

.activity-title {
  display: block;
  font-family: var(--font-display);
  font-size: 44rpx;
  font-weight: 600;
  color: var(--text-primary);
  letter-spacing: -0.01em;
  line-height: 1.3;
}

/* ─────────────────────────────────────────────────────────────
 * 信息卡片
 * ───────────────────────────────────────────────────────────── */
.info-card {
  background: var(--background-card);
  border-radius: var(--radius-lg);
  padding: var(--space-lg);
  margin-bottom: var(--space-xl);
  box-shadow: var(--shadow-xs);
  border: 1px solid var(--border-light);
}

.info-item {
  display: flex;
  align-items: flex-start;
  padding: var(--space-md) 0;
  border-bottom: 1px solid var(--divider);
}

.info-item:last-child {
  border-bottom: none;
  padding-bottom: 0;
}

.info-item:first-child {
  padding-top: 0;
}

.info-label {
  width: 140rpx;
  flex-shrink: 0;
  font-size: 26rpx;
  color: var(--text-tertiary);
  letter-spacing: 0.02em;
}

.info-value {
  flex: 1;
  font-size: 28rpx;
  color: var(--text-primary);
  letter-spacing: 0.02em;
  line-height: 1.5;
}

.tag-value {
  display: inline-block;
  padding: 6rpx 16rpx;
  background: var(--primary-light);
  color: var(--primary);
  border-radius: var(--radius-xs);
  font-size: 24rpx;
}

/* ─────────────────────────────────────────────────────────────
 * 管理员面板
 * ───────────────────────────────────────────────────────────── */
.admin-section {
  margin-bottom: var(--space-xl);
}

.section-title {
  display: block;
  font-size: 24rpx;
  font-weight: 500;
  color: var(--text-tertiary);
  letter-spacing: 0.04em;
  margin-bottom: var(--space-md);
  padding-left: var(--space-xs);
}

.admin-grid {
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-md);
}

.admin-action {
  flex: 0 0 calc((100% - 64rpx) / 5);
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: var(--space-lg) var(--space-sm);
  background: var(--background-card);
  border-radius: var(--radius-lg);
  border: 1px solid var(--border-light);
  box-shadow: var(--shadow-xs);
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}

.admin-action:active {
  transform: scale(0.96);
  background: var(--background-warm);
}

.action-icon-wrap {
  width: 56rpx;
  height: 56rpx;
  border-radius: var(--radius-md);
  background: var(--primary-light);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: var(--space-sm);
}

.action-icon {
  font-size: 28rpx;
  color: var(--primary);
}

.action-text {
  font-size: 22rpx;
  color: var(--text-primary);
  letter-spacing: 0.02em;
  text-align: center;
}

/* ─────────────────────────────────────────────────────────────
 * 报名按钮
 * ───────────────────────────────────────────────────────────── */
.action-section {
  margin-top: var(--space-xl);
}

.btn-wrap {
  padding: var(--space-md);
  background: var(--background-card);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-xs);
  border: 1px solid var(--border-light);
}

.btn-enroll {
  width: 100%;
  height: 100rpx;
  background: var(--primary);
  border-radius: var(--radius-lg);
  border: none;
  box-shadow: var(--shadow-md);
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}

.btn-enroll::after {
  border: none;
}

.btn-enroll:active {
  transform: scale(0.98);
  box-shadow: var(--shadow-sm);
}

.btn-enroll .btn-text {
  font-size: 32rpx;
  font-weight: 500;
  color: #FFFFFF;
  letter-spacing: 0.04em;
}

.disabled-tip {
  padding: var(--space-lg);
  background: var(--background-warm);
  border-radius: var(--radius-lg);
  text-align: center;
  border: 1px solid var(--border-light);
}

.disabled-tip text {
  font-size: 26rpx;
  color: var(--text-tertiary);
  letter-spacing: 0.02em;
}