.page {
  min-height: 100vh;
  padding: 0 0 120rpx;
  background: #fefefe;
  font-family: "PingFang SC", -apple-system, BlinkMacSystemFont, "Helvetica Neue", sans-serif;
}

.content {
  padding: 28rpx 40rpx 0;
  box-sizing: border-box;
}

.poster-section {
  margin-top: 8rpx;
}

.poster-frame {
  width: 100%;
  aspect-ratio: 1.33 / 1;
  border-radius: 18rpx;
  overflow: hidden;
  background: #f3f3f3;
}

.poster-image {
  width: 100%;
  height: 100%;
}

.poster-fallback {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #a3a3a8;
  font-size: 26rpx;
  font-weight: 300;
  letter-spacing: 0.6rpx;
}

.hero-block {
  margin-top: 50rpx;
}

.hero-status-row {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 12rpx;
}

.status-badge {
  min-height: 34rpx;
  padding: 0 14rpx;
  border-radius: 999rpx;
  background: #f7f7f7;
  color: #a8a8ad;
  font-size: 20rpx;
  line-height: 34rpx;
  font-weight: 300;
  letter-spacing: 0.8rpx;
}

.status-badge.ongoing,
.status-badge.registered,
.status-badge.ended,
.status-badge.not-started {
  background: #f7f7f7;
  color: #a8a8ad;
}

.activity-title {
  display: block;
  margin-top: 20rpx;
  color: #16171b;
  font-size: 54rpx;
  line-height: 1.34;
  font-weight: 500;
  letter-spacing: 0.8rpx;
}

.activity-subtitle {
  display: block;
  margin-top: 20rpx;
  color: #8f9298;
  font-size: 26rpx;
  line-height: 1.62;
  font-weight: 300;
  letter-spacing: 0.7rpx;
}

.info-grid {
  margin-top: 58rpx;
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  align-items: start;
  column-gap: 0;
}

.info-col {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
  padding: 0 20rpx;
  position: relative;
}

.info-col::before {
  content: "";
  position: absolute;
  left: 0;
  top: 6rpx;
  bottom: 6rpx;
  width: 1rpx;
  background: rgba(29, 31, 36, 0.08);
}

.info-col:first-child {
  padding-left: 0;
}

.info-col:first-child::before {
  display: none;
}

.info-col:last-child {
  padding-right: 0;
}

.info-label {
  color: #b0b3ba;
  font-size: 22rpx;
  line-height: 1.42;
  font-weight: 300;
  letter-spacing: 0.9rpx;
}

.info-value {
  display: block;
  color: #2d2f34;
  font-size: 31rpx;
  line-height: 1.5;
  font-weight: 400;
  letter-spacing: 0.45rpx;
  word-break: break-word;
}

.intro-block {
  margin-top: 92rpx;
}

.section-title {
  display: block;
  color: #23252a;
  font-size: 26rpx;
  line-height: 1.5;
  font-weight: 450;
  letter-spacing: 1rpx;
}

.intro-text {
  display: block;
  margin-top: 28rpx;
  color: #4e5158;
  font-size: 29rpx;
  line-height: 1.9;
  font-weight: 350;
  letter-spacing: 0.7rpx;
  white-space: pre-wrap;
}

.community-section,
.admin-section {
  margin-top: 92rpx;
}

.action-section {
  margin-top: 108rpx;
}

.section-headline {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 34rpx;
}

.section-actions {
  display: flex;
  align-items: center;
  gap: 26rpx;
}

.section-link {
  color: #9a9ca3;
  font-size: 23rpx;
  line-height: 1.45;
  font-weight: 300;
  letter-spacing: 0.6rpx;
}

.section-link.primary {
  color: #62656c;
}

.community-state,
.community-empty {
  padding: 24rpx 0;
}

.community-state-text,
.community-empty-text {
  color: #a2a5ab;
  font-size: 24rpx;
  line-height: 1.8;
  font-weight: 300;
  letter-spacing: 0.5rpx;
}

.community-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.community-item {
  display: flex;
  gap: 18rpx;
  padding: 18rpx 0;
}

.community-cover {
  width: 108rpx;
  height: 108rpx;
  border-radius: 10rpx;
  flex-shrink: 0;
}

.community-body {
  flex: 1;
  min-width: 0;
  padding-top: 2rpx;
}

.community-title {
  display: block;
  color: #2c2e33;
  font-size: 28rpx;
  line-height: 1.6;
  font-weight: 400;
  letter-spacing: 0.5rpx;
}

.community-meta {
  display: block;
  margin-top: 10rpx;
  color: #a1a4ab;
  font-size: 22rpx;
  line-height: 1.6;
  font-weight: 300;
  letter-spacing: 0.5rpx;
}

.admin-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
}

.admin-action {
  min-height: 108rpx;
  padding: 14rpx 10rpx;
  border-radius: 14rpx;
  border: 1rpx solid #f0f0f1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: #fefefe;
}

.admin-action.delete {
  grid-column: span 3;
}

.action-icon-wrap {
  height: 30rpx;
  display: flex;
  align-items: center;
}

.action-icon {
  color: #9a9da3;
  font-size: 24rpx;
}

.admin-action.delete .action-icon,
.admin-action.delete .action-text {
  color: #ab6464;
}

.action-text {
  margin-top: 10rpx;
  color: #7b7f87;
  font-size: 22rpx;
  line-height: 1.45;
  font-weight: 300;
  letter-spacing: 0.5rpx;
}

.cta-wrap {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  padding: 12rpx 0 18rpx;
}

.cta-text {
  color: #1f2125;
  font-size: 30rpx;
  line-height: 1.3;
  font-weight: 420;
  letter-spacing: 0.95rpx;
}

.cta-arrow {
  margin-left: 8rpx;
  font-size: 25rpx;
  font-weight: 350;
}

.cta-line {
  width: 100%;
  height: 1rpx;
  margin-top: 10rpx;
  background: #37393e;
  opacity: 0.55;
}

.disabled-tip {
  padding: 20rpx 0 0;
}

.disabled-tip text {
  color: #a6a9b0;
  font-size: 23rpx;
  line-height: 1.7;
  font-weight: 300;
  letter-spacing: 0.5rpx;
}

.state-wrap {
  min-height: 62vh;
  padding: 90rpx 56rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.state-wrap.error .state-icon {
  width: 72rpx;
  height: 72rpx;
  margin-bottom: 28rpx;
  background: rgba(178, 65, 55, 0.06);
  border-radius: 50%;
  color: #b24137;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 34rpx;
}

.state-title {
  color: #2b2e33;
  font-size: 31rpx;
  font-weight: 450;
  letter-spacing: 0.8rpx;
}

.state-text {
  margin-top: 14rpx;
  color: #a0a3a9;
  font-size: 25rpx;
  text-align: center;
  line-height: 1.7;
  letter-spacing: 0.4rpx;
}
