/**
 * 活动详情页
 */

.page {
  min-height: 100vh;
  padding: var(--space-lg);
  padding-bottom: var(--space-xl);
  background: var(--background);
}

/* 状态展示 */
.loading-wrap,
.error-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: var(--space-xl) var(--space-lg);
  min-height: 50vh;
}

.loading-tip {
  margin-top: var(--space-md);
  font-size: 28rpx;
  color: var(--text-secondary);
}

.error-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: var(--space-sm);
}

.error-msg {
  font-size: 28rpx;
  color: var(--text-secondary);
  text-align: center;
  margin-top: var(--space-sm);
}

/* 信息卡片 */
.info-card {
  margin-bottom: var(--space-lg);
  background: var(--background-card);
  border-radius: 12rpx;
  padding: var(--space-lg);
  box-shadow: var(--shadow);
  border: 1px solid var(--border);
}

.info-row {
  display: flex;
  align-items: flex-start;
  margin-bottom: var(--space-md);
}

.info-row:last-child {
  margin-bottom: 0;
}

.label {
  width: 140rpx;
  flex-shrink: 0;
  font-size: 28rpx;
  color: var(--text-secondary);
}

.value {
  flex: 1;
  font-size: 28rpx;
  color: var(--text-primary);
  line-height: 1.5;
}

.value.status {
  font-weight: 500;
}

.status-not-started {
  color: var(--status-not-started);
}

.status-ongoing {
  color: var(--status-ongoing);
}

.status-ended {
  color: var(--status-ended);
}

/* 管理员面板 */
.admin-panel {
  margin-bottom: var(--space-lg);
  background: var(--background-card);
  border-radius: 12rpx;
  padding: var(--space-lg);
  box-shadow: var(--shadow);
  border: 1px solid var(--border);
}

.panel-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: var(--space-md);
  padding-bottom: var(--space-sm);
  border-bottom: 1rpx solid var(--border);
}

.admin-actions {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.admin-action-item {
  flex: 0 0 calc((100% - 64rpx) / 5);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 24rpx 12rpx;
  background: var(--background);
  border-radius: 12rpx;
  border: 1rpx solid var(--border);
  transition: all 0.2s;
}

.admin-action-item:active {
  background: var(--background-input);
  transform: scale(0.98);
}

.action-icon {
  font-size: 36rpx;
  margin-bottom: 8rpx;
}

.action-text {
  font-size: 24rpx;
  color: var(--text-primary);
  text-align: center;
}

/* 按钮区域 */
.btn-wrap {
  margin-top: var(--space-md);
  padding: var(--space-md);
  background: var(--background-card);
  border-radius: 12rpx;
  box-shadow: var(--shadow);
  border: 1px solid var(--border);
}

.full {
  width: 100%;
  padding: 24rpx;
  font-size: 30rpx;
}

.disabled-tip {
  margin-top: var(--space-md);
  padding: var(--space-md);
  background: var(--background-input);
  border-radius: 8rpx;
  text-align: center;
  font-size: 26rpx;
  color: var(--text-secondary);
}
