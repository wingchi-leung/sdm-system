.page {
  min-height: 100vh;
  padding: 0 0 210rpx;
  background: #ffffff;
}

.content {
  padding: 22rpx 32rpx 0;
  box-sizing: border-box;
}

.poster-section {
  margin-top: 6rpx;
  display: flex;
  justify-content: center;
}

.poster-frame {
  width: 67%;
  aspect-ratio: 1 / 1;
  border-radius: 18rpx;
  overflow: hidden;
  background: #f3f3f3;
}

.poster-image {
  width: 100%;
  height: 100%;
}

.poster-fallback {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #8e8e93;
  font-family: "Songti SC", "STSong", "SimSun", serif;
  font-size: 28rpx;
}

.hero-block {
  margin-top: 24rpx;
}

.hero-status-row {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 10rpx;
}

.status-badge {
  min-height: 36rpx;
  padding: 0 14rpx;
  border-radius: 999rpx;
  background: #f4f4f6;
  color: #8e8e93;
  font-size: 22rpx;
  line-height: 36rpx;
  font-family: "Songti SC", "STSong", "SimSun", serif;
  font-weight: 400;
  letter-spacing: 0.5rpx;
}

.status-badge.ongoing,
.status-badge.registered {
  background: #f2f2f4;
  color: #8e8e93;
}

.status-badge.ended,
.status-badge.not-started {
  background: #f2f2f4;
  color: #8e8e93;
}

.activity-title {
  display: block;
  margin-top: 10rpx;
  color: #111111;
  font-family: "PingFang SC", -apple-system, BlinkMacSystemFont, sans-serif;
  font-size: 48rpx;
  line-height: 1.35;
  font-weight: 500;
}

.activity-subtitle {
  display: block;
  margin-top: 8rpx;
  color: #666666;
  font-family: "Source Han Sans SC", "Noto Sans SC", "PingFang SC", sans-serif;
  font-size: 28rpx;
  line-height: 1.4;
  font-weight: 400;
}

.info-grid {
  display: grid;
  grid-template-columns: 1.05fr 1fr 0.95fr;
  gap: 0;
  margin-top: 28rpx;
  align-items: start;
}

.info-col {
  padding: 0 14rpx;
  border-left: 1rpx solid #ececef;
}

.info-col:first-child {
  padding-left: 0;
  border-left: 0;
}

.info-col:last-child {
  padding-right: 0;
}

.info-label-row {
  display: flex;
  align-items: center;
  gap: 6rpx;
}

.meta-icon {
  color: #8e8e93;
  font-size: 22rpx;
  line-height: 1.4;
}

.info-label {
  color: #8e8e93;
  font-family: "Songti SC", "STSong", "SimSun", serif;
  font-size: 22rpx;
  line-height: 1.4;
  font-weight: 400;
}

.info-value {
  display: block;
  margin-top: 10rpx;
  color: #1a1a1a;
  font-family: "Songti SC", "STSong", "SimSun", serif;
  font-size: 34rpx;
  line-height: 1.4;
  font-weight: 400;
  word-break: break-all;
}

.section-divider {
  margin-top: 28rpx;
  height: 1rpx;
  background: #e5e5ea;
}

.intro-block {
  margin-top: 24rpx;
}

.section-title {
  display: block;
  color: #111111;
  font-family: "Source Han Sans SC", "Noto Sans SC", "PingFang SC", sans-serif;
  font-size: 32rpx;
  line-height: 1.35;
  font-weight: 500;
}

.intro-text {
  display: block;
  margin-top: 12rpx;
  color: #444444;
  font-family: "PingFang SC", -apple-system, BlinkMacSystemFont, sans-serif;
  font-size: 28rpx;
  line-height: 1.45;
  white-space: pre-wrap;
}

.community-section,
.admin-section {
  margin-top: 28rpx;
}

.action-section {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 20;
  margin-top: 0;
  padding: 16rpx 32rpx calc(env(safe-area-inset-bottom) + 16rpx);
  background: #ffffff;
}

.section-headline {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12rpx;
}

.section-actions {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.section-link {
  color: #8e8e93;
  font-size: 24rpx;
  line-height: 1.4;
}

.section-link.primary {
  color: #1a1a1a;
}

.community-state,
.community-empty {
  padding: 22rpx 0;
}

.community-state-text,
.community-empty-text {
  color: #8e8e93;
  font-size: 24rpx;
  line-height: 1.4;
}

.community-list {
  display: flex;
  flex-direction: column;
}

.community-item {
  display: flex;
  gap: 16rpx;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.community-cover {
  width: 112rpx;
  height: 112rpx;
  border-radius: 12rpx;
  flex-shrink: 0;
}

.community-body {
  flex: 1;
  min-width: 0;
}

.community-title {
  display: block;
  color: #1a1a1a;
  font-family: "Songti SC", "STSong", "SimSun", serif;
  font-size: 28rpx;
  line-height: 1.35;
}

.community-meta {
  display: block;
  margin-top: 8rpx;
  color: #8e8e93;
  font-size: 22rpx;
  line-height: 1.4;
}

.admin-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12rpx;
}

.admin-action {
  min-height: 104rpx;
  padding: 14rpx 8rpx;
  border-radius: 14rpx;
  border: 1rpx solid #efefef;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: #ffffff;
}

.admin-action.delete {
  grid-column: span 3;
}

.action-icon-wrap {
  height: 30rpx;
  display: flex;
  align-items: center;
}

.action-icon {
  color: #7d7d82;
  font-size: 24rpx;
}

.admin-action.delete .action-icon,
.admin-action.delete .action-text {
  color: #a55656;
}

.action-text {
  margin-top: 8rpx;
  color: #666666;
  font-size: 22rpx;
  line-height: 1.35;
}

.btn-enroll {
  width: 100%;
  min-height: 76rpx;
  border: 0;
  border-radius: 16rpx;
  background: #111111;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 24rpx;
}

.btn-enroll::after {
  border: 0;
}

.btn-text {
  color: #ffffff;
  font-family: var(--font-display);
  font-size: 30rpx;
  line-height: 1.3;
  font-weight: 500;
}

.disabled-tip {
  padding: 22rpx 0;
  text-align: center;
}

.disabled-tip text {
  color: #8e8e93;
  font-size: 24rpx;
  line-height: 1.4;
}

.state-wrap {
  min-height: 62vh;
  padding: 90rpx 56rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.state-wrap.error .state-icon {
  width: 72rpx;
  height: 72rpx;
  margin-bottom: 28rpx;
  background: rgba(178, 65, 55, 0.06);
  border-radius: 50%;
  color: var(--error);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 34rpx;
}

.state-title {
  color: #1a1a1a;
  font-size: 32rpx;
  font-family: "Source Han Sans SC", "Noto Sans SC", "PingFang SC", sans-serif;
  font-weight: 500;
}

.state-text {
  margin-top: 14rpx;
  color: #8e8e93;
  font-family: "PingFang SC", -apple-system, BlinkMacSystemFont, sans-serif;
  font-size: 26rpx;
  text-align: center;
  line-height: 1.6;
}
