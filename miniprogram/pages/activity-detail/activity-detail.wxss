.page {
  min-height: 100vh;
  padding-bottom: 72rpx;
  background: #FFFFFF;
}

.content {
  animation: fadeIn 0.35s ease;
}

.poster-section {
  width: 100%;
  height: 470rpx;
  overflow: hidden;
  background: #F6F6F6;
}

.poster-image {
  width: 100%;
  height: 100%;
}

.poster-fallback {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #B7BBB8;
  font-size: 24rpx;
  letter-spacing: 0.16em;
}

.state-wrap {
  min-height: 62vh;
  padding: 90rpx 56rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.state-wrap.error .state-icon {
  width: 72rpx;
  height: 72rpx;
  margin-bottom: 28rpx;
  background: rgba(178, 65, 55, 0.06);
  border-radius: 50%;
  color: var(--error);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 34rpx;
}

.state-title {
  color: var(--ink);
  font-size: 32rpx;
  font-weight: 400;
}

.state-text {
  margin-top: 14rpx;
  color: var(--text-soft);
  font-size: 24rpx;
  text-align: center;
}

.header-section {
  margin: -42rpx 32rpx 0;
  padding: 38rpx 32rpx 34rpx;
  background: #FFFFFF;
  border-radius: 8rpx 8rpx 0 0;
  position: relative;
  z-index: 1;
}

.status-badge {
  display: inline-flex;
  height: 44rpx;
  padding: 0 18rpx;
  align-items: center;
  background: rgba(28, 47, 38, 0.08);
  color: var(--green);
  font-size: 21rpx;
  letter-spacing: 0.08em;
}

.status-badge.ongoing {
  background: var(--green);
  color: #FFFFFF;
}

.status-badge.ended,
.status-badge.not-started {
  color: #6B7280;
  background: #F4F4F2;
}

.activity-title {
  display: block;
  margin-top: 22rpx;
  color: var(--ink);
  font-size: 40rpx;
  line-height: 1.35;
  font-weight: 400;
  letter-spacing: 0.02em;
}

.info-card {
  margin: 6rpx 56rpx 48rpx;
}

.info-item {
  display: flex;
  align-items: flex-start;
  padding: 20rpx 0;
}

.info-label {
  width: 150rpx;
  flex-shrink: 0;
  color: var(--text-soft);
  font-size: 23rpx;
  letter-spacing: 0.04em;
}

.info-value {
  flex: 1;
  color: var(--ink);
  font-size: 27rpx;
  line-height: 1.5;
  letter-spacing: 0.02em;
}

.admin-section {
  margin: 0 56rpx 48rpx;
  padding-top: 22rpx;
}

.section-title {
  display: block;
  margin-bottom: 22rpx;
  color: var(--text-soft);
  font-size: 22rpx;
  letter-spacing: 0.08em;
}

.admin-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 14rpx;
}

.admin-action {
  min-height: 112rpx;
  padding: 18rpx 8rpx;
  background: #F8F8F6;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}

.admin-action:active {
  opacity: 0.72;
}

.admin-action.delete {
  grid-column: span 3;
  background: rgba(178, 65, 55, 0.04);
}

.action-icon-wrap {
  height: 34rpx;
  display: flex;
  align-items: center;
}

.action-icon {
  color: var(--green);
  font-size: 26rpx;
  font-weight: 300;
}

.admin-action.delete .action-icon,
.admin-action.delete .action-text {
  color: var(--error);
}

.action-text {
  margin-top: 8rpx;
  color: var(--text-soft);
  font-size: 22rpx;
  letter-spacing: 0.04em;
}

.action-section {
  margin: 0 56rpx;
  padding-top: 12rpx;
}

.btn-enroll {
  width: 100%;
  height: 92rpx;
  border: 0;
  border-radius: 4rpx;
  background: var(--green);
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn-enroll::after {
  border: 0;
}

.btn-enroll:active {
  opacity: 0.88;
}

.btn-enroll .btn-text {
  color: #FFFFFF;
  font-size: 28rpx;
  letter-spacing: 0.08em;
}

.disabled-tip {
  padding: 28rpx;
  background: #F8F8F6;
  text-align: center;
}

.disabled-tip text {
  color: var(--text-soft);
  font-size: 24rpx;
  letter-spacing: 0.04em;
}

/* Product UI refinement：不改结构，仅收敛视觉规格 */
.poster-section {
  height: 360rpx;
  background: #F6F6F6;
}

.header-section {
  margin: -24rpx 32rpx 0;
  padding: 24rpx;
  border-radius: 24rpx 24rpx 0 0;
}

.activity-title {
  margin-top: 16rpx;
  font-size: 44rpx;
  line-height: 56rpx;
  font-weight: 500;
  letter-spacing: 0.4rpx;
}

.status-badge {
  height: 40rpx;
  padding: 0 12rpx;
  border-radius: 12rpx;
  font-size: 22rpx;
  line-height: 32rpx;
  letter-spacing: 0.4rpx;
}

.info-card,
.admin-section,
.action-section {
  margin-left: 32rpx;
  margin-right: 32rpx;
}

.info-item {
  padding: 12rpx 0;
}

.info-label,
.action-text,
.disabled-tip text {
  color: #999999;
  font-size: 24rpx;
  line-height: 34rpx;
  font-weight: 400;
  letter-spacing: 0.4rpx;
}

.info-value {
  font-size: 28rpx;
  line-height: 40rpx;
  font-weight: 400;
  letter-spacing: 0.4rpx;
}

.admin-action {
  min-height: 88rpx;
  border-radius: 24rpx;
}

.btn-enroll {
  height: 88rpx;
  border-radius: 16rpx;
  background: #2F4F46;
}

.btn-enroll .btn-text {
  font-size: 28rpx;
  font-weight: 500;
  letter-spacing: 0.4rpx;
}
