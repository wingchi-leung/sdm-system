.page {
  min-height: 100vh;
  padding: 0 0 72rpx;
  background:
    linear-gradient(180deg, #f6f8fb 0%, #ffffff 280rpx, #ffffff 100%);
}

.content {
  animation: fadeIn 0.35s ease;
}

.poster-section {
  padding: 44rpx 32rpx 0;
}

.poster-shell {
  display: flex;
  flex-direction: column;
  gap: 28rpx;
}

.poster-copy {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.eyebrow-en,
.section-kicker,
.btn-caption {
  display: block;
  font-family: "Canela", "Editorial New", "Iowan Old Style", Georgia, serif;
  font-size: 24rpx;
  line-height: 1.3;
  letter-spacing: 0.18em;
  color: #8b97a8;
  text-transform: uppercase;
}

.eyebrow-cn {
  display: block;
  font-family: "Source Han Serif SC", "Noto Serif SC", "Songti SC", serif;
  font-size: 24rpx;
  line-height: 1.5;
  font-weight: 600;
  color: #20324d;
}

.poster-frame {
  width: 100%;
  height: 686rpx;
  border-radius: 36rpx;
  background:
    linear-gradient(180deg, rgba(255, 255, 255, 0.98), rgba(243, 246, 250, 0.98));
  border: 1rpx solid rgba(20, 38, 61, 0.08);
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}

.poster-image {
  width: 100%;
  height: 100%;
}

.poster-fallback {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 100%;
  color: #9aa6b7;
  font-size: 24rpx;
  letter-spacing: 0.18em;
}

.state-wrap {
  min-height: 62vh;
  padding: 90rpx 56rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.state-wrap.error .state-icon {
  width: 72rpx;
  height: 72rpx;
  margin-bottom: 28rpx;
  background: rgba(178, 65, 55, 0.06);
  border-radius: 50%;
  color: var(--error);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 34rpx;
}

.state-title {
  color: #14263d;
  font-size: 32rpx;
  font-family: "Source Han Serif SC", "Noto Serif SC", "Songti SC", serif;
  font-weight: 600;
}

.state-text {
  margin-top: 14rpx;
  color: #6d7a8b;
  font-size: 26rpx;
  text-align: center;
  line-height: 1.8;
}

.hero-card,
.info-card,
.community-section,
.admin-section,
.action-section {
  margin-left: 32rpx;
  margin-right: 32rpx;
}

.hero-card,
.info-card,
.community-section,
.admin-section {
  background: rgba(255, 255, 255, 0.92);
  border: 1rpx solid rgba(20, 38, 61, 0.08);
  border-radius: 32rpx;
}

.hero-card {
  margin-top: 28rpx;
  padding: 36rpx 32rpx 40rpx;
}

.hero-status-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 22rpx;
}

.status-badge {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 48rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  background: rgba(25, 63, 118, 0.08);
  color: #17345d;
  font-size: 22rpx;
  letter-spacing: 0.08em;
}

.status-badge.ongoing,
.status-badge.registered {
  background: #17345d;
  color: #ffffff;
}

.status-badge.ended,
.status-badge.not-started {
  background: rgba(108, 124, 145, 0.1);
  color: #6c7c91;
}

.activity-title {
  display: block;
  font-family: "Source Han Serif SC", "Noto Serif SC", "Songti SC", serif;
  font-size: 48rpx;
  line-height: 1.38;
  font-weight: 600;
  color: #14263d;
  letter-spacing: 0.02em;
}

.activity-subtitle {
  display: block;
  margin-top: 20rpx;
  font-family: "HarmonyOS Sans SC", "Inter", "PingFang SC", sans-serif;
  font-size: 28rpx;
  line-height: 1.9;
  color: #55667e;
}

.info-card {
  margin-top: 24rpx;
  padding: 34rpx 32rpx;
}

.section-headline {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 28rpx;
}

.section-title {
  display: block;
  margin-top: 10rpx;
  font-family: "Source Han Serif SC", "Noto Serif SC", "Songti SC", serif;
  font-size: 40rpx;
  line-height: 1.4;
  font-weight: 600;
  color: #14263d;
}

.info-list {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.info-item {
  display: flex;
  gap: 24rpx;
  padding: 18rpx 0;
  border-top: 1rpx solid rgba(20, 38, 61, 0.06);
}

.info-item:first-child {
  border-top: 0;
  padding-top: 0;
}

.info-item:last-child {
  padding-bottom: 0;
}

.info-label {
  width: 156rpx;
  flex-shrink: 0;
  font-family: "HarmonyOS Sans SC", "Inter", "PingFang SC", sans-serif;
  color: #7a8797;
  font-size: 24rpx;
  line-height: 1.8;
  letter-spacing: 0.08em;
}

.info-value {
  flex: 1;
  font-family: "HarmonyOS Sans SC", "Inter", "PingFang SC", sans-serif;
  color: #1f314a;
  font-size: 30rpx;
  line-height: 1.9;
}

.community-section,
.admin-section {
  margin-top: 24rpx;
  padding: 34rpx 32rpx;
}

.section-actions {
  display: flex;
  align-items: center;
  gap: 18rpx;
  padding-top: 4rpx;
}

.section-link {
  color: #6d7a8b;
  font-size: 24rpx;
  line-height: 1.6;
}

.section-link.primary {
  color: #17345d;
}

.community-state,
.community-empty {
  padding: 32rpx 24rpx;
  border-radius: 24rpx;
  background: rgba(246, 248, 251, 0.9);
  border: 1rpx solid rgba(20, 38, 61, 0.06);
  text-align: center;
}

.community-state-text,
.community-empty-text {
  color: #6d7a8b;
  font-size: 24rpx;
  line-height: 1.8;
}

.community-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.community-card {
  overflow: hidden;
  border-radius: 24rpx;
  background: #f9fbfd;
  border: 1rpx solid rgba(20, 38, 61, 0.06);
  box-sizing: border-box;
}

.community-card:active {
  opacity: 0.84;
}

.community-cover {
  width: 100%;
  height: 280rpx;
}

.community-body {
  padding: 26rpx 24rpx 28rpx;
}

.community-title {
  display: block;
  color: #14263d;
  font-family: "Source Han Serif SC", "Noto Serif SC", "Songti SC", serif;
  font-size: 32rpx;
  line-height: 1.55;
  font-weight: 600;
}

.community-meta,
.community-comments {
  display: block;
  margin-top: 12rpx;
  color: #6d7a8b;
  font-size: 22rpx;
  line-height: 1.7;
}

.community-summary {
  display: -webkit-box;
  margin-top: 16rpx;
  color: #31445e;
  font-size: 26rpx;
  line-height: 1.9;
  overflow: hidden;
  text-overflow: ellipsis;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.admin-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
}

.admin-action {
  min-height: 132rpx;
  padding: 22rpx 10rpx;
  border-radius: 24rpx;
  background: #f9fbfd;
  border: 1rpx solid rgba(20, 38, 61, 0.06);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}

.admin-action:active {
  opacity: 0.78;
}

.admin-action.delete {
  grid-column: span 3;
  background: rgba(178, 65, 55, 0.04);
  border-color: rgba(178, 65, 55, 0.12);
}

.action-icon-wrap {
  height: 36rpx;
  display: flex;
  align-items: center;
}

.action-icon {
  color: #17345d;
  font-size: 26rpx;
}

.admin-action.delete .action-icon,
.admin-action.delete .action-text {
  color: var(--error);
}

.action-text {
  margin-top: 12rpx;
  color: #5d6d82;
  font-size: 22rpx;
  line-height: 1.6;
  letter-spacing: 0.04em;
}

.action-section {
  margin-top: 28rpx;
}

.btn-enroll {
  width: 100%;
  min-height: 112rpx;
  border: 0;
  border-radius: 999rpx;
  background: #17345d;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 32rpx;
}

.btn-enroll::after {
  border: 0;
}

.btn-enroll:active {
  opacity: 0.9;
}

.btn-content {
  width: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
}

.btn-copy {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  text-align: center;
}

.btn-caption {
  color: rgba(255, 255, 255, 0.7);
}

.btn-text {
  color: #ffffff;
  font-family: "Source Han Serif SC", "Noto Serif SC", "Songti SC", serif;
  font-size: 36rpx;
  line-height: 1.4;
  font-weight: 600;
}

.btn-arrow {
  color: #ffffff;
  font-size: 34rpx;
  position: absolute;
  right: 0;
  top: 50%;
  transform: translateY(-50%);
}

.disabled-tip {
  padding: 30rpx 24rpx;
  background: rgba(255, 255, 255, 0.92);
  border: 1rpx solid rgba(20, 38, 61, 0.08);
  border-radius: 24rpx;
  text-align: center;
}

.disabled-tip text {
  color: #6d7a8b;
  font-size: 24rpx;
  line-height: 1.8;
}
