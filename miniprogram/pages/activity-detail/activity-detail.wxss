.page {
  min-height: 100vh;
  padding: 0 0 calc(env(safe-area-inset-bottom) + 128rpx);
  box-sizing: border-box;
  background: #ffffff;
  color: #111827;
  font-family: "LorchinSansP0", "PingFang SC", -apple-system, BlinkMacSystemFont, "Helvetica Neue", sans-serif;
}

.content {
  padding: 0 40rpx;
  box-sizing: border-box;
}

.top-bar {
  padding-top: calc(var(--status-bar-height, 0px) + 10rpx);
  display: flex;
  align-items: center;
  justify-content: space-between;
  min-height: 92rpx;
}

.nav-btn {
  width: auto;
  height: auto;
  padding: 0;
  border-radius: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  background: transparent;
  color: #2a4d87;
}

.nav-icon {
  font-size: 48rpx;
  line-height: 1;
  font-weight: 300;
}

.nav-icon.more {
  font-size: 34rpx;
  letter-spacing: 5rpx;
}

.hero-title {
  display: block;
  margin-top: 76rpx;
  color: #111111;
  font-family: "LorchinSansP0", "PingFang SC", -apple-system, BlinkMacSystemFont, "Helvetica Neue", sans-serif;
  font-size: 74rpx;
  line-height: 1.16;
  font-weight: 400;
  letter-spacing: 0.04em;
  word-break: break-word;
}

.hero-subtitle {
  display: block;
  margin-top: 28rpx;
  color: #1f2a3a;
  font-size: 30rpx;
  line-height: 1.8;
  font-weight: 400;
  letter-spacing: 0.06em;
}

.hero-divider {
  width: 84rpx;
  height: 4rpx;
  margin-top: 34rpx;
  border-radius: 999rpx;
  background: #2a4d87;
}

.poster-card {
  margin-top: 48rpx;
  border-radius: 24rpx;
  overflow: hidden;
  background: #f4f5f8;
  box-shadow: 0 18rpx 46rpx rgba(31, 53, 98, 0.08);
}

.poster-image {
  width: 100%;
  height: 540rpx;
}

.poster-fallback {
  min-height: 540rpx;
  padding: 56rpx 52rpx;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  justify-content: center;
  gap: 18rpx;
  background:
    radial-gradient(circle at 78% 18%, rgba(42, 77, 135, 0.14) 0, rgba(42, 77, 135, 0.04) 26%, transparent 42%),
    linear-gradient(180deg, rgba(244, 246, 249, 0.96) 0%, rgba(239, 242, 247, 1) 100%);
}

.poster-fallback-title {
  color: #3e4653;
  font-family: "LorchinSansP0", "PingFang SC", -apple-system, BlinkMacSystemFont, "Helvetica Neue", sans-serif;
  font-size: 42rpx;
  line-height: 1.1;
  font-weight: 400;
  letter-spacing: 0.16em;
}

.poster-fallback-cn {
  color: #18202d;
  font-size: 34rpx;
  line-height: 1.5;
  font-weight: 400;
  letter-spacing: 0.08em;
}

.poster-fallback-subtitle {
  color: #1f2a3a;
  font-size: 25rpx;
  line-height: 1.7;
  font-weight: 400;
  letter-spacing: 0.06em;
}

.detail-block {
  margin-top: 36rpx;
}

.detail-paragraph {
  display: block;
  color: #202533;
  font-size: 30rpx;
  line-height: 1.95;
  font-weight: 400;
  letter-spacing: 0.06em;
  white-space: pre-wrap;
  margin-bottom: 10rpx;
}

.info-card {
  margin-top: 44rpx;
  padding-top: 28rpx;
}

.info-row {
  display: flex;
  align-items: flex-start;
  gap: 24rpx;
  padding: 18rpx 0;
}

.info-row-schedule {
  align-items: flex-start;
}

.info-label {
  width: 128rpx;
  flex-shrink: 0;
  color: #111827;
  font-size: 28rpx;
  line-height: 1.7;
  font-weight: 500;
  letter-spacing: 0.06em;
}

.info-value {
  flex: 1;
  color: #1e2330;
  font-size: 28rpx;
  line-height: 1.8;
  font-weight: 400;
  letter-spacing: 0.04em;
  word-break: break-word;
}

.info-schedule {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.info-schedule-line {
  display: flex;
  align-items: baseline;
  gap: 12rpx;
}

.info-schedule-tag {
  flex-shrink: 0;
  min-width: 72rpx;
  color: #6b7280;
  font-size: 24rpx;
  line-height: 1.5;
  letter-spacing: 0.04em;
}

.section-block {
  margin-top: 56rpx;
  padding-top: 32rpx;
}

.section-headline {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 34rpx;
}

.section-title {
  display: block;
  color: #111111;
  font-size: 26rpx;
  line-height: 1.45;
  font-weight: 600;
  letter-spacing: 0.22em;
}

.section-actions {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.section-link {
  color: #111111;
  font-size: 23rpx;
  line-height: 1.45;
  font-weight: 400;
  letter-spacing: 0.08em;
}

.section-link.primary {
  color: #111111;
}

.community-state,
.community-empty {
  padding: 10rpx 0 0;
}

.community-state-text,
.community-empty-text {
  color: #111111;
  font-size: 24rpx;
  line-height: 1.8;
  font-weight: 400;
  letter-spacing: 0.04em;
}

.community-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.community-item {
  display: flex;
  gap: 18rpx;
  padding: 18rpx 0;
}

.community-cover {
  width: 108rpx;
  height: 108rpx;
  border-radius: 12rpx;
  flex-shrink: 0;
  background: #f2f4f8;
}

.community-body {
  flex: 1;
  min-width: 0;
}

.community-title {
  display: block;
  color: #172033;
  font-size: 28rpx;
  line-height: 1.6;
  font-weight: 500;
  letter-spacing: 0.04em;
}

.community-meta {
  display: block;
  margin-top: 10rpx;
  color: #8e97aa;
  font-size: 22rpx;
  line-height: 1.6;
  font-weight: 400;
  letter-spacing: 0.04em;
}

.admin-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.admin-action {
  flex: 0 0 calc(33.333% - 11rpx);
  min-height: 108rpx;
  padding: 14rpx 10rpx;
  border-radius: 18rpx;
  border: 1rpx solid rgba(42, 77, 135, 0.12);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: #ffffff;
  box-sizing: border-box;
}

.admin-action.delete {
  flex-basis: 100%;
}

.action-icon {
  color: #111111;
  font-size: 24rpx;
  line-height: 1;
}

.admin-action.delete .action-icon,
.admin-action.delete .action-text {
  color: #a25454;
}

.action-text {
  margin-top: 10rpx;
  color: #111111;
  font-size: 22rpx;
  line-height: 1.45;
  font-weight: 400;
  letter-spacing: 0.04em;
}

.action-section {
  margin-top: 68rpx;
}

.cta-wrap {
  display: inline-flex;
  flex-direction: column;
  align-items: flex-end;
  color: #111111;
}

.cta-wrap.pending {
  color: #111111;
}

.cta-text-row {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
}

.cta-wrap.pending .cta-text {
  color: #111111;
}

.cta-wrap.pending .cta-line {
  background: rgba(17, 17, 17, 0.72);
}

.cta-text {
  color: inherit;
  font-size: 30rpx;
  line-height: 1.35;
  font-weight: 500;
  letter-spacing: 0.12em;
}

.cta-arrow {
  color: inherit;
}

.cta-line {
  width: 100%;
  height: 2rpx;
  margin-top: 12rpx;
  background: rgba(17, 17, 17, 0.7);
}

.disabled-tip {
  padding: 10rpx 0 0;
}

.disabled-tip text {
  color: #7f8aa4;
  font-size: 24rpx;
  line-height: 1.8;
  font-weight: 400;
  letter-spacing: 0.04em;
}

.state-wrap {
  min-height: 62vh;
  padding: 120rpx 56rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.state-wrap.error .state-icon {
  width: 72rpx;
  height: 72rpx;
  margin-bottom: 28rpx;
  background: rgba(42, 77, 135, 0.08);
  border-radius: 50%;
  color: #2a4d87;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 34rpx;
}

.state-title {
  color: #162033;
  font-size: 31rpx;
  font-weight: 500;
  letter-spacing: 0.06em;
}

.state-text {
  margin-top: 14rpx;
  color: #8f97ab;
  font-size: 25rpx;
  text-align: center;
  line-height: 1.7;
  letter-spacing: 0.04em;
}
