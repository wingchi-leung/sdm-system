/**
 * 活动详情页 - 高级简约风格
 */

.page {
  min-height: 100vh;
  padding: var(--space-xl) var(--space-lg);
  padding-bottom: var(--space-3xl);
  background: var(--background);
}

.content {
  animation: fadeIn 0.4s ease;
}

/* ─────────────────────────────────────────────────────────────
 * 海报展示
 * ───────────────────────────────────────────────────────────── */
.poster-section {
  margin: 0 calc(-1 * var(--space-lg)) var(--space-lg);
  width: calc(100% + 2 * var(--space-lg));
}

.poster-image {
  width: 100%;
  display: block;
}

/* ─────────────────────────────────────────────────────────────
 * 状态展示
 * ───────────────────────────────────────────────────────────── */
.state-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: var(--space-3xl) var(--space-lg);
  min-height: 60vh;
}

.state-wrap.error .state-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: var(--error-bg);
  color: var(--error);
  font-size: 36rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: var(--space-lg);
}

.state-title {
  font-family: var(--font-display);
  font-size: 32rpx;
  font-weight: 500;
  color: var(--text-primary);
  margin-bottom: var(--space-sm);
  letter-spacing: 0.04em;
}

.state-text {
  font-size: 24rpx;
  color: var(--text-tertiary);
  text-align: center;
  margin-top: var(--space-sm);
  letter-spacing: 0.02em;
}

/* ─────────────────────────────────────────────────────────────
 * 活动标题区域
 * ───────────────────────────────────────────────────────────── */
.header-section {
  margin-bottom: var(--space-xl);
  padding-bottom: var(--space-lg);
  border-bottom: 1px solid var(--divider);
}

.status-badge {
  display: inline-block;
  padding: 6rpx 16rpx;
  font-size: 20rpx;
  font-weight: 500;
  letter-spacing: 0.08em;
  margin-bottom: var(--space-md);
  text-transform: uppercase;
}

.status-badge.not-started {
  color: var(--status-not-started);
}

.status-badge.ongoing {
  color: var(--status-ongoing);
}

.status-badge.ended {
  color: var(--status-ended);
}

.activity-title {
  display: block;
  font-family: var(--font-display);
  font-size: 40rpx;
  font-weight: 500;
  color: var(--text-primary);
  letter-spacing: 0.04em;
  line-height: 1.4;
}

/* ─────────────────────────────────────────────────────────────
 * 信息卡片
 * ───────────────────────────────────────────────────────────── */
.info-card {
  margin-bottom: var(--space-xl);
}

.info-item {
  display: flex;
  align-items: flex-start;
  padding: var(--space-md) 0;
  border-bottom: 1px solid var(--divider);
}

.info-item:last-child {
  border-bottom: none;
  padding-bottom: 0;
}

.info-item:first-child {
  padding-top: 0;
}

.info-label {
  width: 120rpx;
  flex-shrink: 0;
  font-size: 22rpx;
  color: var(--text-muted);
  letter-spacing: 0.08em;
  text-transform: uppercase;
}

.info-value {
  flex: 1;
  font-size: 26rpx;
  color: var(--text-primary);
  letter-spacing: 0.02em;
  line-height: 1.5;
}

.tag-value {
  display: inline-block;
  padding: 4rpx 12rpx;
  background: var(--primary-light);
  color: var(--primary);
  font-size: 22rpx;
  letter-spacing: 0.04em;
}

/* ─────────────────────────────────────────────────────────────
 * 管理员面板
 * ───────────────────────────────────────────────────────────── */
.admin-section {
  margin-bottom: var(--space-xl);
  padding-top: var(--space-lg);
  border-top: 1px solid var(--divider);
}

.section-title {
  display: block;
  font-size: 20rpx;
  font-weight: 500;
  color: var(--text-muted);
  letter-spacing: 0.16em;
  margin-bottom: var(--space-lg);
  padding-left: var(--space-xs);
  text-transform: uppercase;
}

.admin-grid {
  display: flex;
  flex-wrap: wrap;
  margin: 0 -8rpx;
}

.admin-action {
  flex: 0 0 calc(20% - 16rpx);
  margin: 0 8rpx;
  margin-bottom: var(--space-md);
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: var(--space-md) 0;
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}

.admin-action:active {
  opacity: 0.6;
}

/* 删除按钮单独一行，红色样式 */
.admin-action.delete {
  flex: 0 0 100%;
  margin: var(--space-lg) 0 0 0;
  padding: var(--space-lg);
  background: var(--error-bg);
  border-radius: var(--radius-md);
}

.admin-action.delete .action-icon {
  color: var(--error);
}

.admin-action.delete .action-text {
  color: var(--error);
}

.admin-action.delete:active {
  background: var(--error);
}

.admin-action.delete:active .action-icon,
.admin-action.delete:active .action-text {
  color: #FFFFFF;
}

.action-icon-wrap {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: var(--space-sm);
}

.action-icon {
  font-size: 24rpx;
  color: var(--text-primary);
}

.action-text {
  font-size: 20rpx;
  color: var(--text-secondary);
  letter-spacing: 0.04em;
  text-align: center;
}

/* ─────────────────────────────────────────────────────────────
 * 报名按钮
 * ───────────────────────────────────────────────────────────── */
.action-section {
  margin-top: var(--space-xl);
  padding-top: var(--space-lg);
  border-top: 1px solid var(--divider);
}

.btn-wrap {
  padding: var(--space-md) 0;
}

.btn-enroll {
  width: 100%;
  height: 96rpx;
  background: var(--primary);
  border-radius: var(--radius-xs);
  border: none;
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}

.btn-enroll::after {
  border: none;
}

.btn-enroll:active {
  opacity: 0.85;
}

.btn-enroll .btn-text {
  font-size: 28rpx;
  font-weight: 500;
  color: #FFFFFF;
  letter-spacing: 0.12em;
}

.disabled-tip {
  padding: var(--space-lg);
  background: var(--background-subtle);
  text-align: center;
}

.disabled-tip text {
  font-size: 24rpx;
  color: var(--text-tertiary);
  letter-spacing: 0.04em;
}