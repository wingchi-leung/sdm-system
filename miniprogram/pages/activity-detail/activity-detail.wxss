/**
 * 活动详情页 - Bold Minimal
 */

.page {
  min-height: 100vh;
  padding: var(--space-xl) var(--space-lg);
  padding-bottom: var(--space-3xl);
  background: var(--bg-secondary);
}

.content {
  animation: fadeIn 0.4s ease;
}

/* ─────────────────────────────────────────────────────────────
 * 状态展示
 * ───────────────────────────────────────────────────────────── */
.state-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 60vh;
}

.state-text {
  font-size: 26rpx;
  color: var(--text-tertiary);
  margin-top: var(--space-md);
}

.error-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: var(--error-bg);
  display: flex;
  align-items: center;
  justify-content: center;
}

.error-icon text {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--error);
}

.state-title {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--text-primary);
  margin-top: var(--space-lg);
}

.state-desc {
  font-size: 26rpx;
  color: var(--text-tertiary);
  margin-top: var(--space-sm);
}

/* ─────────────────────────────────────────────────────────────
 * 状态指示器
 * ───────────────────────────────────────────────────────────── */
.status-header {
  display: flex;
  align-items: center;
  gap: var(--space-sm);
  margin-bottom: var(--space-lg);
}

.status-indicator {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
}

.status-indicator.pending {
  background: var(--status-pending);
}

.status-indicator.active {
  background: var(--accent);
  box-shadow: 0 0 12rpx var(--accent-glow);
}

.status-indicator.ended {
  background: var(--text-primary);
}

.status-label {
  font-size: 24rpx;
  font-weight: 600;
  letter-spacing: 0.08em;
  text-transform: uppercase;
}

.status-label.pending {
  color: var(--status-pending);
}

.status-label.active {
  color: var(--accent);
}

.status-label.ended {
  color: var(--text-primary);
}

/* ─────────────────────────────────────────────────────────────
 * 活动标题
 * ───────────────────────────────────────────────────────────── */
.activity-title {
  display: block;
  font-family: var(--font-display);
  font-size: 48rpx;
  font-weight: 700;
  color: var(--text-primary);
  letter-spacing: -0.02em;
  line-height: 1.3;
  margin-bottom: var(--space-xl);
}

/* ─────────────────────────────────────────────────────────────
 * 信息卡片
 * ───────────────────────────────────────────────────────────── */
.info-card {
  background: var(--bg-card);
  border-radius: var(--radius-xl);
  padding: var(--space-lg);
  margin-bottom: var(--space-xl);
  box-shadow: var(--shadow-sm);
}

.info-row {
  display: flex;
  align-items: flex-start;
  padding: var(--space-md) 0;
  border-bottom: 1rpx solid var(--border);
}

.info-row:last-child {
  border-bottom: none;
  padding-bottom: 0;
}

.info-row:first-child {
  padding-top: 0;
}

.info-key {
  width: 140rpx;
  flex-shrink: 0;
  font-size: 26rpx;
  font-weight: 600;
  color: var(--text-tertiary);
  letter-spacing: 0.02em;
}

.info-value {
  flex: 1;
  font-size: 28rpx;
  color: var(--text-primary);
  letter-spacing: 0.01em;
}

.tag-wrap {
  display: inline-block;
  padding: 6rpx 16rpx;
  background: var(--accent-light);
  border-radius: var(--radius-sm);
}

.tag-text {
  font-size: 24rpx;
  font-weight: 600;
  color: var(--accent);
  letter-spacing: 0.02em;
}

/* ─────────────────────────────────────────────────────────────
 * 管理员面板
 * ───────────────────────────────────────────────────────────── */
.admin-panel {
  margin-bottom: var(--space-xl);
}

.panel-title {
  display: block;
  font-size: 22rpx;
  font-weight: 700;
  color: var(--text-tertiary);
  letter-spacing: 0.08em;
  text-transform: uppercase;
  margin-bottom: var(--space-md);
}

.admin-grid {
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-md);
}

.admin-action {
  flex: 0 0 calc((100% - 64rpx) / 5);
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: var(--space-lg) var(--space-sm);
  background: var(--bg-card);
  border-radius: var(--radius-xl);
  box-shadow: var(--shadow-sm);
  transition: all 0.2s ease;
}

.admin-action:active {
  transform: scale(0.95);
  background: var(--bg-tertiary);
}

.action-icon {
  width: 56rpx;
  height: 56rpx;
  border-radius: var(--radius-lg);
  background: var(--bg-tertiary);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: var(--space-sm);
}

.action-icon text {
  font-size: 28rpx;
  color: var(--text-primary);
}

.action-label {
  font-size: 20rpx;
  font-weight: 600;
  color: var(--text-primary);
  letter-spacing: 0.02em;
}

/* ─────────────────────────────────────────────────────────────
 * 报名按钮
 * ───────────────────────────────────────────────────────────── */
.action-section {
  margin-top: var(--space-xl);
}

.btn-enroll {
  width: 100%;
  height: 108rpx;
  background: var(--accent);
  border-radius: var(--radius-full);
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: var(--shadow-accent);
  transition: all 0.3s ease;
}

.btn-enroll::after {
  border: none;
}

.btn-enroll:active {
  transform: scale(0.97);
  box-shadow: var(--shadow-sm);
}

.enroll-text {
  font-size: 32rpx;
  font-weight: 600;
  color: #FFFFFF;
  letter-spacing: 0.04em;
}

.disabled-tip {
  padding: var(--space-xl);
  background: var(--bg-card);
  border-radius: var(--radius-xl);
  text-align: center;
  box-shadow: var(--shadow-sm);
}

.disabled-tip text {
  font-size: 28rpx;
  color: var(--text-tertiary);
}