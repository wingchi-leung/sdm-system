.page {
  min-height: 100vh;
  background: #ffffff;
  padding: 24rpx 32rpx;
  box-sizing: border-box;
  color: #111111;
  font-family: var(--font-body);
}

.group {
  margin-bottom: 24rpx;
}

.item {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 24rpx 0;
  border-bottom: 1rpx solid var(--divider);
}

.item:last-child {
  border-bottom: none;
}

.item-icon {
  width: 48rpx;
  text-align: center;
  color: #999999;
}

.item-copy {
  flex: 1;
  min-width: 0;
}

.item-title {
  display: block;
  color: #111111;
  font-size: 30rpx;
  line-height: 42rpx;
}

.item-desc {
  display: block;
  margin-top: 6rpx;
  color: #999999;
  font-size: 24rpx;
  line-height: 34rpx;
}

.row-arrow {
  color: #bbbbbb;
}

.danger-text {
  color: #b24137;
}
