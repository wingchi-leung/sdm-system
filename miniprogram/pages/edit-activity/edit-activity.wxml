<view class="page">
  <page-header title="编辑活动"></page-header>
  <view class="form">
    <view class="field">
      <text class="field-label">活动名称</text>
      <input class="input" value="{{activityName}}" bindinput="onNameInput" placeholder="请输入活动名称" placeholder-class="input-placeholder" />
    </view>

    <view class="field">
      <text class="field-label">活动类型</text>
      <input class="input" value="{{activityTypeName}}" bindinput="onTypeNameInput" placeholder="请输入活动类型" placeholder-class="input-placeholder" />
    </view>

    <!-- 公开设置 -->
    <view class="field">
      <view class="switch-row">
        <text class="switch-label">设为公开活动</text>
        <switch checked="{{isPublic}}" bindchange="onIsPublicChange" color="var(--primary)" />
      </view>
      <text class="field-hint">公开活动所有用户可见，非公开活动仅关联用户可见</text>
    </view>

    <!-- 活动海报 -->
    <view class="field">
      <text class="field-label">活动海报</text>
      <view class="poster-section">
        <view wx:if="{{posterLocalPath || posterUrl}}" class="poster-preview">
          <image class="poster-image" src="{{posterLocalPath || posterUrl}}" mode="aspectFill" />
          <view class="poster-remove" bindtap="onRemovePoster">
            <text class="remove-icon">×</text>
          </view>
        </view>
        <view wx:else class="poster-upload" bindtap="onChoosePoster">
          <view class="upload-icon">+</view>
          <text class="upload-text">上传海报</text>
          <text class="upload-hint">支持PNG、JPG格式，最大5MB</text>
        </view>
      </view>      
      <text class="field-hint" wx:if="{{posterLocalPath}}">已选择新海报，保存修改后会自动上传</text>
      <text class="field-hint" wx:elif="{{posterUrl}}">点击下方按钮可重新选择海报</text>
      <button class="btn-submit" type="default" bindtap="onChoosePoster" disabled="{{submitting}}" style="margin-top: 16rpx;">
        <text class="btn-text">{{posterLocalPath || posterUrl ? '重新选择海报' : '选择海报'}}</text>
      </button>
    </view>

    <!-- 活动地点 -->
    <view class="field">
      <text class="field-label">活动地点</text>
      <input class="input" value="{{location}}" bindinput="onLocationInput" placeholder="不填则默认为线上活动" placeholder-class="input-placeholder" />
    </view>

    <view class="field">
      <view class="field-head">
        <text class="field-label">活动时间</text>
        <text class="field-required">*</text>
      </view>
      <view class="datetime-stack">
        <view class="datetime-row">
          <text class="datetime-label">开始</text>
          <view class="datetime-pickers">
            <picker mode="date" value="{{startDate}}" start="2020-01-01" end="2030-12-31" bindchange="onStartDateChange">
              <view class="time-chip">
                <view class="time-chip-icon time-chip-icon-calendar">
                  <view class="time-chip-icon-calendar-ring"></view>
                  <view class="time-chip-icon-calendar-line"></view>
                </view>
                <text class="time-chip-text">{{startDate || '选择日期'}}</text>
                <text class="time-chip-arrow ui-chevron ui-chevron--sm">⌄</text>
              </view>
            </picker>
            <picker mode="time" value="{{startTime}}" start="00:00" end="23:59" bindchange="onStartTimeChange">
              <view class="time-chip">
                <view class="time-chip-icon time-chip-icon-clock">
                  <view class="time-chip-icon-clock-hand time-chip-icon-clock-hand-hour"></view>
                  <view class="time-chip-icon-clock-hand time-chip-icon-clock-hand-minute"></view>
                </view>
                <text class="time-chip-text">{{startTime || '选择时间'}}</text>
                <text class="time-chip-arrow ui-chevron ui-chevron--sm">⌄</text>
              </view>
            </picker>
          </view>
        </view>
        <view class="datetime-row">
          <text class="datetime-label">结束</text>
          <view class="datetime-pickers">
            <picker mode="date" value="{{endDate}}" start="2020-01-01" end="2030-12-31" bindchange="onEndDateChange">
              <view class="time-chip">
                <view class="time-chip-icon time-chip-icon-calendar">
                  <view class="time-chip-icon-calendar-ring"></view>
                  <view class="time-chip-icon-calendar-line"></view>
                </view>
                <text class="time-chip-text">{{endDate || '选择日期'}}</text>
                <text class="time-chip-arrow ui-chevron ui-chevron--sm">⌄</text>
              </view>
            </picker>
            <picker mode="time" value="{{endTime}}" start="00:00" end="23:59" bindchange="onEndTimeChange">
              <view class="time-chip">
                <view class="time-chip-icon time-chip-icon-clock">
                  <view class="time-chip-icon-clock-hand time-chip-icon-clock-hand-hour"></view>
                  <view class="time-chip-icon-clock-hand time-chip-icon-clock-hand-minute"></view>
                </view>
                <text class="time-chip-text">{{endTime || '选择时间'}}</text>
                <text class="time-chip-arrow ui-chevron ui-chevron--sm">⌄</text>
              </view>
            </picker>
          </view>
        </view>
      </view>
    </view>

    <view class="field">
      <text class="field-label">报名成功通知</text>
      <view class="field-card" bindtap="goNotificationConfig">
        <view class="field-card-copy">
          <text class="field-card-title">通知配置</text>
          <text class="field-card-desc">{{registrationNotificationSummary}}</text>
        </view>
        <text class="field-card-arrow">›</text>
      </view>
      <text class="field-hint">进入后可单独维护当前活动的报名成功订阅消息模板与消息体。</text>
    </view>

    <button class="btn-submit" bindtap="submit" disabled="{{submitting}}">
      <text class="btn-text">{{submitting ? '提交中…' : '保存修改'}}</text>
    </button>
  </view>
</view>
