.page {
  min-height: 100vh;
  padding: 24rpx 32rpx calc(148rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
  background: #ffffff;
  color: #111111;
  font-family: var(--font-body);
}

.form {
  animation: fadeIn 0.4s ease;
}

.field {
  margin-bottom: 40rpx;
  padding-bottom: 18rpx;
}

.field:last-child {
  margin-bottom: 0;
  padding-bottom: 0;
  border-bottom: none;
}

.field-label {
  display: block;
  margin-bottom: 16rpx;
  color: #111111;
  font-size: 28rpx;
  line-height: 1.4;
  font-weight: 500;
}

.input {
  width: 100%;
  height: 84rpx;
  padding: 0 0 12rpx;
  font-size: 28rpx;
  background: transparent;
  border: none;
  border-bottom: 1rpx solid var(--divider);
  border-radius: 0;
  box-sizing: border-box;
  color: #111111;
}

.input:focus {
  border-bottom-color: rgba(17, 17, 17, 0.22);
}

.input-placeholder {
  color: #bbbbbb;
}

.datetime-row {
  display: flex;
  gap: 16rpx;
}

.datetime-row picker {
  flex: 1;
}

.picker-value {
  display: flex;
  align-items: center;
  height: 84rpx;
  padding: 0 0 12rpx;
  font-size: 28rpx;
  color: #111111;
  border-bottom: 1rpx solid var(--divider);
  box-sizing: border-box;
}

.field-hint {
  display: block;
  margin-top: 12rpx;
  color: #999999;
  font-size: 22rpx;
  line-height: 32rpx;
}

.field-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  padding: 20rpx 0 14rpx;
}

.field-card-copy {
  flex: 1;
  min-width: 0;
}

.field-card-title {
  display: block;
  color: #111111;
  font-size: 28rpx;
  line-height: 1.45;
  font-weight: 500;
}

.field-card-desc {
  display: block;
  margin-top: 8rpx;
  color: #888888;
  font-size: 22rpx;
  line-height: 1.6;
}

.field-card-arrow {
  flex-shrink: 0;
  color: #999999;
  font-size: 32rpx;
  line-height: 1;
}

.btn-submit {
  width: 100%;
  height: 86rpx;
  background: #ffffff;
  border-radius: 999rpx;
  border: 1rpx solid rgba(17, 17, 17, 0.12);
  margin-top: 56rpx;
  box-shadow: 0 12rpx 28rpx rgba(15, 23, 42, 0.04);
}

.btn-submit::after {
  border: none;
}

.btn-submit:active {
  opacity: 0.88;
}

.btn-submit[disabled] {
  opacity: 0.5;
}

.btn-submit .btn-text {
  font-size: 28rpx;
  font-weight: 500;
  color: #111111;
  line-height: 1.35;
  letter-spacing: 0.06em;
}

.poster-section {
  margin-top: 8rpx;
}

.poster-upload {
  width: 100%;
  min-height: 240rpx;
  border: 1rpx dashed var(--border);
  border-radius: 24rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: #ffffff;
  padding: 28rpx;
  box-sizing: border-box;
}

.poster-upload:active {
  border-color: rgba(17, 17, 17, 0.22);
}

.upload-icon {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: #f7f7f5;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 44rpx;
  color: #999999;
  margin-bottom: 12rpx;
}

.upload-text {
  font-size: 28rpx;
  color: #111111;
}

.upload-hint {
  font-size: 22rpx;
  color: #999999;
  margin-top: 6rpx;
}

.poster-preview {
  position: relative;
  width: 100%;
  height: 240rpx;
  border-radius: 24rpx;
  overflow: hidden;
}

.poster-image {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.poster-remove {
  position: absolute;
  top: 16rpx;
  right: 16rpx;
  width: 48rpx;
  height: 48rpx;
  background: rgba(17, 17, 17, 0.64);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.remove-icon {
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 300;
}
