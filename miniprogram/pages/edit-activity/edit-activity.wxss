/**
 * 编辑活动页 - 高级简约风格
 */

.page {
  min-height: 100vh;
  padding: var(--space-xl) var(--space-lg);
  background: var(--background);
}

.form {
  animation: fadeIn 0.4s ease;
}

/* ─────────────────────────────────────────────────────────────
 * 表单字段
 * ───────────────────────────────────────────────────────────── */
.field {
  margin-bottom: var(--space-xl);
}

.field:last-child {
  margin-bottom: 0;
}

.field-label {
  display: block;
  font-size: 22rpx;
  color: var(--text-muted);
  margin-bottom: var(--space-sm);
  font-weight: 500;
  letter-spacing: 0.1em;
  text-transform: uppercase;
}

.field-label.optional::after {
  content: '';
}

.input {
  width: 100%;
  height: 88rpx;
  padding: 0 0;
  font-size: 28rpx;
  background: transparent;
  border: none;
  border-bottom: 1px solid var(--border);
  border-radius: 0;
  box-sizing: border-box;
  color: var(--text-primary);
  transition: all 0.3s ease;
  letter-spacing: 0.04em;
}

.input:focus {
  border-bottom-color: var(--text-primary);
}

.input-placeholder {
  color: var(--text-muted);
}

/* ─────────────────────────────────────────────────────────────
 * 日期时间选择
 * ───────────────────────────────────────────────────────────── */
.datetime-row {
  display: flex;
  gap: var(--space-lg);
}

.datetime-row picker {
  flex: 1;
}

.picker-value {
  height: 88rpx;
  line-height: 88rpx;
  font-size: 26rpx;
  color: var(--text-primary);
  letter-spacing: 0.04em;
  border-bottom: 1px solid var(--border);
  transition: all 0.3s ease;
}

/* ─────────────────────────────────────────────────────────────
 * 提交按钮
 * ───────────────────────────────────────────────────────────── */
.btn-submit {
  width: 100%;
  height: 96rpx;
  background: var(--primary);
  border-radius: var(--radius-xs);
  border: none;
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  margin-top: var(--space-2xl);
}

.btn-submit::after {
  border: none;
}

.btn-submit:active {
  opacity: 0.85;
}

.btn-submit[disabled] {
  opacity: 0.5;
}

.btn-submit .btn-text {
  font-size: 28rpx;
  font-weight: 500;
  color: #FFFFFF;
  letter-spacing: 0.12em;
}

/* ─────────────────────────────────────────────────────────────
 * 海报上传
 * ───────────────────────────────────────────────────────────── */
.poster-section {
  margin-top: var(--space-sm);
}

.poster-upload {
  width: 100%;
  height: 300rpx;
  border: 2rpx dashed var(--border);
  border-radius: var(--radius-lg);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: var(--background-subtle);
  transition: all 0.3s ease;
}

.poster-upload:active {
  border-color: var(--primary);
  background: var(--primary-light);
}

.upload-icon {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: var(--border);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 44rpx;
  color: var(--text-tertiary);
  margin-bottom: var(--space-sm);
}

.upload-text {
  font-size: 28rpx;
  color: var(--text-secondary);
  letter-spacing: 0.04em;
}

.upload-hint {
  font-size: 22rpx;
  color: var(--text-muted);
  margin-top: var(--space-xs);
  letter-spacing: 0.02em;
}

.poster-preview {
  position: relative;
  width: 100%;
  height: 300rpx;
  border-radius: var(--radius-lg);
  overflow: hidden;
}

.poster-image {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.poster-remove {
  position: absolute;
  top: 16rpx;
  right: 16rpx;
  width: 48rpx;
  height: 48rpx;
  background: rgba(0, 0, 0, 0.6);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.remove-icon {
  color: #fff;
  font-size: 32rpx;
  font-weight: 300;
}

/* 视觉降噪：去掉表单分割线，改用浅底块承载输入 */
.input,
.picker-value {
  padding: 0 var(--space-md);
  border-bottom: none;
  border-radius: 6rpx;
  background: #F8F8F6;
}

.input:focus {
  border-bottom-color: transparent;
}

/* Product UI refinement：表单页规格统一 */
.page {
  padding: 24rpx 32rpx;
}

.field {
  margin-bottom: 24rpx;
}

.field-label,
.upload-hint {
  color: #999999;
  font-size: 24rpx;
  line-height: 34rpx;
  font-weight: 400;
  letter-spacing: 0.4rpx;
  text-transform: none;
}

.input,
.picker-value {
  height: 88rpx;
  border-radius: 16rpx;
  font-size: 28rpx;
  line-height: 40rpx;
  letter-spacing: 0.4rpx;
}

.btn-submit {
  height: 88rpx;
  margin-top: 24rpx;
  border-radius: 16rpx;
  background: #2F4F46;
  box-shadow: none;
}

.btn-submit .btn-text,
.upload-text {
  font-size: 28rpx;
  line-height: 40rpx;
  font-weight: 500;
  letter-spacing: 0.4rpx;
}

.poster-upload,
.poster-preview {
  height: 240rpx;
  border-radius: 24rpx;
}

.upload-icon {
  font-size: 44rpx;
}
