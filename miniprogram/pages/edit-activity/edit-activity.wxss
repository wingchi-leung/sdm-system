/**
 * 编辑活动页 - 高级简约风格
 */

.page {
  min-height: 100vh;
  padding: var(--space-xl) var(--space-lg);
  background: var(--background);
}

.form {
  animation: fadeIn 0.4s ease;
}

/* ─────────────────────────────────────────────────────────────
 * 表单字段
 * ───────────────────────────────────────────────────────────── */
.field {
  margin-bottom: var(--space-xl);
}

.field:last-child {
  margin-bottom: 0;
}

.field-label {
  display: block;
  font-size: 22rpx;
  color: var(--text-muted);
  margin-bottom: var(--space-sm);
  font-weight: 500;
  letter-spacing: 0.1em;
  text-transform: uppercase;
}

.field-label.optional::after {
  content: '';
}

.input {
  width: 100%;
  height: 88rpx;
  padding: 0 0;
  font-size: 28rpx;
  background: transparent;
  border: none;
  border-bottom: 1px solid var(--border);
  border-radius: 0;
  box-sizing: border-box;
  color: var(--text-primary);
  transition: all 0.3s ease;
  letter-spacing: 0.04em;
}

.input:focus {
  border-bottom-color: var(--text-primary);
}

.input-placeholder {
  color: var(--text-muted);
}

/* ─────────────────────────────────────────────────────────────
 * 日期时间选择
 * ───────────────────────────────────────────────────────────── */
.datetime-row {
  display: flex;
  gap: var(--space-lg);
}

.datetime-row picker {
  flex: 1;
}

.picker-value {
  height: 88rpx;
  line-height: 88rpx;
  font-size: 26rpx;
  color: var(--text-primary);
  letter-spacing: 0.04em;
  border-bottom: 1px solid var(--border);
  transition: all 0.3s ease;
}

/* ─────────────────────────────────────────────────────────────
 * 提交按钮
 * ───────────────────────────────────────────────────────────── */
.btn-submit {
  width: 100%;
  height: 96rpx;
  background: var(--primary);
  border-radius: var(--radius-xs);
  border: none;
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  margin-top: var(--space-2xl);
}

.btn-submit::after {
  border: none;
}

.btn-submit:active {
  opacity: 0.85;
}

.btn-submit[disabled] {
  opacity: 0.5;
}

.btn-submit .btn-text {
  font-size: 28rpx;
  font-weight: 500;
  color: #FFFFFF;
  letter-spacing: 0.12em;
}