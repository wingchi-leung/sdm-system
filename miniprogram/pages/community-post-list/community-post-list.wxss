.page {
  min-height: 100vh;
  box-sizing: border-box;
  padding-bottom: calc(154rpx + env(safe-area-inset-bottom));
  background: #ffffff;
  color: #14213a;
}

.state-wrap,
.empty-box {
  min-height: 56vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  text-align: center;
}

.state-title,
.empty-title {
  color: #14213a;
  font-size: 34rpx;
  line-height: 1.35;
  font-weight: 500;
}

.state-text,
.empty-text {
  margin-top: 14rpx;
  color: #8995a9;
  font-size: 25rpx;
  line-height: 1.7;
}

.content {
  padding: 0 38rpx 34rpx;
}

.toolbar {
  min-height: 124rpx;
  display: flex;
  align-items: flex-start;
  justify-content: flex-end;
  padding-top: 20rpx;
  box-sizing: border-box;
}

.toolbar-actions {
  display: flex;
  align-items: center;
  gap: 50rpx;
}

.toolbar-btn {
  height: 48rpx;
  display: inline-flex;
  align-items: center;
  color: #172238;
}

.toolbar-btn:active,
.write-comment-btn:active {
  opacity: 0.72;
}

.toolbar-btn-text {
  margin-left: 13rpx;
  font-size: 27rpx;
  line-height: 1;
}

.toolbar-btn-arrow {
  margin-left: 12rpx;
  color: #172238;
  font-size: 33rpx;
  line-height: 1;
  font-weight: 300;
}

.toolbar-calendar {
  position: relative;
  width: 28rpx;
  height: 28rpx;
  border: 2rpx solid #172238;
  border-radius: 5rpx;
  box-sizing: border-box;
}

.toolbar-calendar::before {
  content: '';
  position: absolute;
  left: -2rpx;
  right: -2rpx;
  top: 7rpx;
  height: 2rpx;
  background: #172238;
}

.toolbar-calendar__rings::before,
.toolbar-calendar__rings::after {
  content: '';
  position: absolute;
  top: -6rpx;
  width: 2rpx;
  height: 8rpx;
  border-radius: 2rpx;
  background: #172238;
}

.toolbar-calendar__rings::before { left: 6rpx; }
.toolbar-calendar__rings::after { right: 6rpx; }

.toolbar-calendar__dots {
  position: absolute;
  left: 6rpx;
  top: 14rpx;
  width: 3rpx;
  height: 3rpx;
  border-radius: 50%;
  background: #172238;
  box-shadow: 7rpx 0 #172238, 14rpx 0 #172238;
}

.toolbar-members {
  position: relative;
  width: 31rpx;
  height: 29rpx;
}

.toolbar-members__head {
  position: absolute;
  top: 1rpx;
  width: 10rpx;
  height: 10rpx;
  border: 2rpx solid #172238;
  border-radius: 50%;
  box-sizing: border-box;
}

.toolbar-members__head--left { left: 4rpx; }
.toolbar-members__head--right { right: 3rpx; top: 7rpx; }

.toolbar-members__body {
  position: absolute;
  left: 0;
  bottom: 0;
  width: 19rpx;
  height: 11rpx;
  border: 2rpx solid #172238;
  border-bottom: 0;
  border-radius: 15rpx 15rpx 0 0;
  box-sizing: border-box;
}

.toolbar-members__body::after {
  content: '';
  position: absolute;
  left: 17rpx;
  bottom: 0;
  width: 10rpx;
  height: 8rpx;
  border: 2rpx solid #172238;
  border-left: 0;
  border-bottom: 0;
  border-radius: 0 12rpx 0 0;
}

.section-head {
  height: 91rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  border-bottom: 1rpx solid #dfe5ed;
}

.section-label {
  color: #111d34;
  font-size: 34rpx;
  line-height: 1;
  font-weight: 650;
}

.section-head__dash {
  width: 24rpx;
  height: 2rpx;
  background: #cbd4e2;
}

.feed-list {
  padding-top: 34rpx;
  display: flex;
  flex-direction: column;
  gap: 28rpx;
}

.feed-card {
  padding: 30rpx 30rpx 26rpx;
  overflow: hidden;
  border: 1rpx solid rgba(49, 68, 101, 0.07);
  border-radius: 26rpx;
  background: #ffffff;
  box-shadow: 0 10rpx 32rpx rgba(34, 53, 82, 0.09);
}

.announcement-meta,
.announcement-meta__left {
  display: flex;
  align-items: center;
}

.announcement-meta {
  justify-content: space-between;
}

.announcement-icon-wrap {
  width: 58rpx;
  height: 58rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: #f1f3f7;
}

.announcement-icon {
  width: 35rpx;
  height: 35rpx;
}

.announcement-copy {
  margin-left: 18rpx;
  display: flex;
  flex-direction: column;
}

.announcement-title {
  color: #14213a;
  font-size: 28rpx;
  line-height: 1.2;
}

.announcement-subtitle,
.announcement-date {
  color: #9aa6ba;
  font-size: 23rpx;
  line-height: 1.4;
}

.announcement-subtitle { margin-top: 5rpx; }

.feed-title {
  display: block;
  margin-top: 32rpx;
  color: #111e36;
  font-size: 38rpx;
  line-height: 1.45;
  font-weight: 650;
}

.feed-source {
  margin-top: 18rpx;
  display: flex;
  align-items: center;
  overflow: hidden;
  color: #929eb2;
  font-size: 22rpx;
  line-height: 1.4;
  white-space: nowrap;
}

.feed-source__divider {
  margin: 0 14rpx;
  color: #d0d6df;
}

.feed-grid,
.feed-inline-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 12rpx;
  margin-top: 27rpx;
}

.feed-grid-cell {
  position: relative;
  min-width: 0;
  overflow: hidden;
  border-radius: 15rpx;
}

.feed-grid-cell:nth-child(n+4) {
  display: none;
}

.feed-grid-image,
.feed-inline-image {
  width: 100%;
  height: 196rpx;
  display: block;
  border-radius: 15rpx;
  background: #f2f4f7;
}

.feed-grid-more {
  position: absolute;
  right: 0;
  bottom: 0;
  width: 50rpx;
  height: 50rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 14rpx 0 14rpx 0;
  color: #ffffff;
  font-size: 22rpx;
  background: rgba(28, 34, 45, 0.50);
}

.feed-content-expanded {
  margin-top: 22rpx;
}

.feed-blocks {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.feed-summary {
  display: block;
  margin-top: 25rpx;
  color: #56647a;
  font-size: 27rpx;
  line-height: 1.68;
}

.expand-row {
  height: 68rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.action-link {
  color: #3979ed;
  font-size: 24rpx;
  line-height: 1.6;
}

.action-link--expand {
  font-size: 26rpx;
}

.expand-row__arrow {
  margin-left: 10rpx;
  color: #3979ed;
  font-size: 25rpx;
  transform: translateY(-4rpx);
}

.feed-actions {
  min-height: 78rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  border-bottom: 1rpx solid #e7ebf1;
}

.reply-count {
  display: flex;
  align-items: center;
  color: #17243a;
  font-size: 24rpx;
}

.reply-icon {
  position: relative;
  width: 26rpx;
  height: 23rpx;
  margin-right: 13rpx;
  border: 2rpx solid #17243a;
  border-radius: 50%;
  box-sizing: border-box;
}

.reply-icon::after {
  content: '';
  position: absolute;
  left: 2rpx;
  bottom: -5rpx;
  width: 7rpx;
  height: 7rpx;
  border-left: 2rpx solid #17243a;
  transform: rotate(28deg);
  background: #ffffff;
}

.write-comment-btn {
  min-width: 128rpx;
  height: 50rpx;
  padding: 0 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 1rpx solid #b9d0fc;
  border-radius: 999rpx;
  color: #3677ed;
  font-size: 24rpx;
  box-sizing: border-box;
}

.write-comment-btn__icon {
  margin-right: 8rpx;
  font-size: 28rpx;
  transform: rotate(-28deg);
}

.comment-preview-list {
  padding: 10rpx 0 0;
}

.comment-preview {
  display: flex;
  gap: 16rpx;
  align-items: flex-start;
  padding-top: 22rpx;
}

.avatar,
.comment-avatar {
  flex-shrink: 0;
  border-radius: 50%;
  background: #f2f4f7;
}

.comment-avatar {
  width: 42rpx;
  height: 42rpx;
}

.comment-main {
  flex: 1;
  min-width: 0;
}

.comment-meta-row {
  display: flex;
  align-items: center;
}

.comment-user {
  color: #344054;
  font-size: 22rpx;
  line-height: 1.5;
  font-weight: 300;
}

.comment-time {
  margin-left: 9rpx;
  color: #98a2b3;
  font-size: 20rpx;
  line-height: 1.5;
}

.comment-content {
  display: block;
  margin-top: 7rpx;
  color: #475467;
  font-size: 24rpx;
  line-height: 1.7;
}

.comment-image-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 12rpx;
}

.comment-image {
  width: 150rpx;
  height: 150rpx;
  border-radius: 14rpx;
  background: #f2f4f7;
}

.comment-empty-line {
  margin-top: 16rpx;
}

.comment-empty-text {
  color: #98a2b3;
  font-size: 22rpx;
  line-height: 1.6;
}

.comment-loadmore {
  height: 65rpx;
  display: flex;
  align-items: flex-end;
  justify-content: center;
}

.comment-loadmore__arrow {
  margin-left: 9rpx;
  color: #3979ed;
  font-size: 30rpx;
  line-height: 0.8;
}

.comment-composer {
  margin-top: 18rpx;
  padding: 20rpx;
  border-radius: 22rpx;
  background: #f8fafc;
}

.comment-upload-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 14rpx;
}

.comment-upload-item {
  position: relative;
  width: 150rpx;
  height: 150rpx;
  overflow: hidden;
  border-radius: 16rpx;
  background: #e5e7eb;
}

.comment-upload-preview {
  width: 100%;
  height: 100%;
}

.comment-upload-remove {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  width: 32rpx;
  height: 32rpx;
  border-radius: 50%;
  background: rgba(15, 23, 42, 0.72);
  color: #ffffff;
  font-size: 22rpx;
  line-height: 32rpx;
  text-align: center;
}

.comment-tool-row {
  display: flex;
  align-items: center;
  margin-bottom: 14rpx;
}

.comment-add-image {
  color: #3979ed;
  font-size: 22rpx;
  line-height: 1.6;
}

.comment-action-row {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.comment-input {
  width: 100%;
  min-height: 140rpx;
  padding: 18rpx 20rpx;
  box-sizing: border-box;
  border: 1rpx solid #e5e7eb;
  border-radius: 18rpx;
  background: #ffffff;
  color: #101828;
  font-size: 26rpx;
  line-height: 1.7;
}

.comment-placeholder { color: #98a2b3; }

.comment-submit {
  align-self: flex-end;
  min-width: 92rpx;
  height: 54rpx;
  padding: 0 22rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  border-radius: 999rpx;
  background: #3979ed;
  color: #ffffff;
  font-size: 22rpx;
  box-sizing: border-box;
}

.post-loadmore {
  padding-top: 28rpx;
  display: flex;
  justify-content: center;
}

.floating-create-btn {
  position: fixed;
  right: 31rpx;
  bottom: calc(34rpx + env(safe-area-inset-bottom));
  z-index: 40;
  width: 88rpx;
  height: 88rpx;
  padding: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 0;
  border-radius: 50%;
  background: linear-gradient(145deg, #3379f4, #155ad8);
  box-shadow: 0 8rpx 22rpx rgba(32, 101, 224, 0.28);
}

.floating-create-btn--active {
  transform: translateY(1rpx) scale(0.98);
}

.floating-create-btn__icon {
  width: 38rpx;
  height: 38rpx;
  display: block;
  filter: brightness(0) invert(1);
}

.floating-create-btn__label { display: none; }
