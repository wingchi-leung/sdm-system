.page {
  min-height: 100vh;
  background: #FFFFFF;
  padding: 24rpx 32rpx 48rpx;
}

.state-wrap,
.empty-box {
  min-height: 50vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  text-align: center;
}

.state-title,
.empty-title,
.page-title {
  color: var(--ink);
  font-size: 38rpx;
  line-height: 1.35;
  font-weight: 500;
}

.state-text,
.empty-text,
.page-subtitle,
.post-meta,
.post-comments,
.page-caption {
  color: var(--text-soft);
  font-size: 24rpx;
  line-height: 1.6;
}

.page-head {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 24rpx;
  margin-bottom: 32rpx;
}

.page-head-main {
  flex: 1;
  min-width: 0;
}

.page-caption {
  display: block;
  margin-bottom: 8rpx;
  letter-spacing: 0.12em;
}

.page-subtitle {
  display: block;
  margin-top: 10rpx;
  font-size: 25rpx;
  line-height: 1.7;
}

.create-btn {
  min-width: 176rpx;
  height: 72rpx;
  margin: 0;
  border: 0;
  border-radius: 16rpx;
  background: #000000;
  color: #FFFFFF;
  font-size: 24rpx;
  line-height: 72rpx;
}

.create-btn::after {
  border: 0;
}

.post-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.post-card {
  overflow: hidden;
  border: 1px solid var(--form-border);
  border-radius: 24rpx;
  background: #FFFFFF;
  box-shadow: var(--form-shadow);
}

.post-card:active {
  opacity: 0.86;
}

.post-body {
  padding: 24rpx 24rpx 28rpx;
}

.post-meta-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.post-title {
  display: block;
  margin-top: 14rpx;
  color: var(--ink);
  font-size: 32rpx;
  line-height: 1.45;
  font-weight: 500;
}

.post-summary {
  display: -webkit-box;
  margin-top: 16rpx;
  color: var(--ink);
  font-size: 25rpx;
  line-height: 1.9;
  overflow: hidden;
  text-overflow: ellipsis;
  -webkit-line-clamp: 3;
  -webkit-box-orient: vertical;
}

.post-inline-image {
  width: 100%;
  height: 260rpx;
  margin-top: 16rpx;
  border-radius: 16rpx;
}

.post-comments,
.post-link {
  display: block;
  margin-top: 16rpx;
}

.post-comments {
  flex-shrink: 0;
  text-align: right;
}

.post-link {
  color: var(--link);
  font-size: 24rpx;
  line-height: 1.6;
}

/* ===== Phase 2 批次 3: 2 列瀑布流 ===== */
.waterfall {
  display: flex;
  flex-direction: row;
  gap: var(--space-sm);
  padding: 0 var(--space-md);
  align-items: flex-start; /* 两列独立高度,矮列向上对齐 */
}

.waterfall-col {
  flex: 1 1 0;
  display: flex;
  flex-direction: column;
  gap: var(--space-sm);
  min-width: 0;
}

.waterfall-col .post-card {
  margin: 0; /* 瀑布流用 gap,去掉卡片自身 margin */
  width: 100%;
}

.waterfall-col .post-cover {
  width: 100%;
  background: var(--background);
  overflow: hidden;
  border-radius: var(--radius-md);
  position: relative;
}

.waterfall-col .post-cover-image {
  width: 100%;
  display: block;
}

.waterfall-col .post-cover-count {
  position: absolute;
  right: 12rpx;
  bottom: 12rpx;
  padding: 4rpx 12rpx;
  background: rgba(17, 17, 17, 0.55);
  color: #ffffff;
  font-size: 20rpx;
  border-radius: var(--radius-md);
}

.waterfall-col .post-body {
  padding: 0 8rpx;
}

.waterfall-col .post-title {
  display: block;
  font-size: 30rpx;
  font-weight: 500;
  color: var(--text-primary);
  margin: 16rpx 0 8rpx;
  line-height: 1.4;
}

.waterfall-col .post-summary {
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 3;
  overflow: hidden;
  font-size: 26rpx;
  color: var(--text-secondary);
  line-height: 1.5;
  margin-bottom: 12rpx;
  word-break: break-all;
}

.waterfall-col .post-meta-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 0 8rpx 16rpx;
}

.waterfall-col .post-meta {
  font-size: 22rpx;
  color: var(--text-tertiary);
}

.waterfall-col .post-comments {
  font-size: 22rpx;
  color: var(--text-tertiary);
}


