.page {
  min-height: 100vh;
  background: #FFFFFF;
  padding: 24rpx 32rpx 48rpx;
}

.state-wrap,
.empty-box {
  min-height: 50vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  text-align: center;
}

.state-title,
.empty-title,
.page-title {
  color: var(--ink);
  font-size: 38rpx;
  line-height: 1.35;
  font-weight: 500;
}

.state-text,
.empty-text,
.page-subtitle,
.post-meta,
.post-comments,
.page-caption {
  color: var(--text-soft);
  font-size: 24rpx;
  line-height: 1.6;
}

.page-head {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 24rpx;
  margin-bottom: 32rpx;
}

.page-head-main {
  flex: 1;
  min-width: 0;
}

.page-caption {
  display: block;
  margin-bottom: 8rpx;
  letter-spacing: 0.12em;
}

.page-subtitle {
  display: block;
  margin-top: 10rpx;
  font-size: 25rpx;
  line-height: 1.7;
}

.create-btn {
  min-width: 176rpx;
  height: 72rpx;
  margin: 0;
  border: 0;
  border-radius: 16rpx;
  background: #2F4F46;
  color: #FFFFFF;
  font-size: 24rpx;
  line-height: 72rpx;
}

.create-btn::after {
  border: 0;
}

.post-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.post-card {
  overflow: hidden;
  border: 1px solid var(--form-border);
  border-radius: 24rpx;
  background: #FFFFFF;
  box-shadow: var(--form-shadow);
}

.post-card:active {
  opacity: 0.86;
}

.post-cover {
  width: 100%;
  height: 280rpx;
}

.post-body {
  padding: 24rpx 24rpx 28rpx;
}

.post-meta-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.post-title {
  display: block;
  margin-top: 14rpx;
  color: var(--ink);
  font-size: 32rpx;
  line-height: 1.45;
  font-weight: 500;
}

.post-summary {
  display: -webkit-box;
  margin-top: 16rpx;
  color: var(--ink);
  font-size: 25rpx;
  line-height: 1.9;
  overflow: hidden;
  text-overflow: ellipsis;
  -webkit-line-clamp: 3;
  -webkit-box-orient: vertical;
}

.post-comments,
.post-link {
  display: block;
  margin-top: 16rpx;
}

.post-comments {
  flex-shrink: 0;
  text-align: right;
}

.post-link {
  color: var(--green);
  font-size: 24rpx;
  line-height: 1.6;
}
