.page {
  min-height: 100vh;
  padding: 28rpx 36rpx 72rpx;
  box-sizing: border-box;
  background: #ffffff;
}

.state-wrap,
.empty-box {
  min-height: 56vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  text-align: center;
}

.state-title,
.empty-title {
  color: #101828;
  font-size: 38rpx;
  line-height: 1.35;
  font-weight: 500;
}

.state-text,
.empty-text {
  margin-top: 14rpx;
  color: #667085;
  font-size: 25rpx;
  line-height: 1.7;
}

.page-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.head-actions {
  display: flex;
  align-items: center;
  gap: 14rpx;
  flex-shrink: 0;
}

.page-copy {
  flex: 1;
  min-width: 0;
}

.page-channel {
  display: block;
  color: #2f6fe8;
  font-size: 28rpx;
  line-height: 1.5;
  font-weight: 500;
}

.page-title {
  display: block;
  margin-top: 10rpx;
  color: #101828;
  font-size: 62rpx;
  line-height: 1.14;
  font-weight: 500;
  letter-spacing: 0.02em;
}

.create-btn {
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: transparent;
  color: #101828;
  font-size: 68rpx;
  line-height: 1;
  font-weight: 300;
}

.manage-btn {
  min-width: 128rpx;
  height: 72rpx;
  padding: 0 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 20rpx;
  background: #f2f4f7;
}

.manage-btn-text {
  color: #101828;
  font-size: 24rpx;
  line-height: 1;
  font-weight: 500;
}

.head-accent {
  width: 66rpx;
  height: 6rpx;
  margin: 28rpx 0 18rpx;
  border-radius: 999rpx;
  background: #2f6fe8;
}

.feed-list {
  display: flex;
  flex-direction: column;
}

.feed-thread {
  padding: 22rpx 0 34rpx;
  border-bottom: 2rpx solid #eaecf0;
}

.feed-thread + .feed-thread {
  margin-top: 6rpx;
}

.feed-author-row {
  display: flex;
  align-items: center;
  gap: 18rpx;
}

.avatar,
.comment-avatar {
  flex-shrink: 0;
  border-radius: 50%;
  background: #f2f4f7;
}

.avatar {
  width: 54rpx;
  height: 54rpx;
}

.author-meta {
  display: flex;
  align-items: center;
  gap: 12rpx;
  min-width: 0;
}

.author-name {
  color: #101828;
  font-size: 24rpx;
  line-height: 1.5;
  font-weight: 500;
}

.author-date {
  color: #98a2b3;
  font-size: 22rpx;
  line-height: 1.5;
}

.feed-title {
  display: block;
  margin-top: 22rpx;
  color: #101828;
  font-size: 48rpx;
  line-height: 1.35;
  font-weight: 500;
}

.feed-summary {
  display: block;
  margin-top: 14rpx;
  color: #1d2939;
  font-size: 28rpx;
  line-height: 1.85;
}

.feed-content-expanded {
  margin-top: 14rpx;
}

.feed-html {
  color: #1d2939;
  font-size: 28rpx;
  line-height: 1.85;
}

.feed-blocks {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.feed-cover-wrap {
  position: relative;
  margin-top: 22rpx;
  overflow: hidden;
  border-radius: 18rpx;
}

.feed-cover {
  width: 100%;
  height: 246rpx;
  display: block;
  background: #eef2f6;
}

.feed-cover-badge {
  position: absolute;
  right: 18rpx;
  bottom: 18rpx;
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  background: rgba(15, 23, 42, 0.72);
  color: #ffffff;
  font-size: 22rpx;
  line-height: 1.2;
}

.feed-inline-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12rpx;
  margin-top: 10rpx;
}

.feed-inline-image {
  width: 100%;
  height: 180rpx;
  border-radius: 14rpx;
  background: #f2f4f7;
}

.feed-actions {
  display: flex;
  align-items: center;
  gap: 24rpx;
  margin-top: 18rpx;
}

.action-link {
  color: #2f6fe8;
  font-size: 24rpx;
  line-height: 1.6;
}

.feed-footnote {
  margin-top: 10rpx;
}

.feed-time {
  display: block;
  color: #98a2b3;
  font-size: 24rpx;
  line-height: 1.6;
}

.comment-preview-list {
  margin-top: 10rpx;
}

.comment-preview {
  display: flex;
  gap: 18rpx;
  align-items: flex-start;
  padding: 22rpx 0 18rpx;
  border-top: 2rpx solid #f2f4f7;
}

.comment-avatar {
  width: 48rpx;
  height: 48rpx;
}

.comment-main {
  flex: 1;
  min-width: 0;
}

.comment-user {
  display: block;
  color: #101828;
  font-size: 24rpx;
  line-height: 1.5;
  font-weight: 500;
}

.comment-content {
  display: block;
  margin-top: 6rpx;
  color: #1d2939;
  font-size: 28rpx;
  line-height: 1.7;
}

.comment-image-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 12rpx;
}

.comment-image {
  width: 160rpx;
  height: 160rpx;
  border-radius: 14rpx;
  background: #f2f4f7;
}

.comment-time {
  display: block;
  margin-top: 8rpx;
  color: #98a2b3;
  font-size: 22rpx;
  line-height: 1.5;
}

.comment-mark {
  flex-shrink: 0;
  padding-top: 8rpx;
  color: #667085;
  font-size: 22rpx;
  line-height: 1.6;
}

.comment-empty-line {
  margin-top: 10rpx;
  padding-top: 18rpx;
  border-top: 2rpx solid #f2f4f7;
}

.comment-empty-text {
  color: #98a2b3;
  font-size: 24rpx;
  line-height: 1.6;
}

.comment-loadmore,
.post-loadmore {
  padding-top: 20rpx;
}

.post-loadmore {
  display: flex;
  justify-content: center;
}
