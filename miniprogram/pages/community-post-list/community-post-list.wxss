.page {
  min-height: 100vh;
  box-sizing: border-box;
  padding-bottom: calc(164rpx + env(safe-area-inset-bottom));
  background: #ffffff;
}

.header-actions {
  display: flex;
  align-items: center;
  justify-content: flex-end;
}

.header-menu-pill {
  min-width: 164rpx;
  height: 70rpx;
  padding: 0 22rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-sizing: border-box;
  border-radius: 999rpx;
  border: 1rpx solid rgba(17, 24, 39, 0.12);
  background: rgba(255, 255, 255, 0.92);
  box-shadow: 0 10rpx 28rpx rgba(15, 23, 42, 0.06);
}

.header-menu-dots {
  color: #111111;
  font-size: 30rpx;
  line-height: 1;
  letter-spacing: 10rpx;
  transform: translateX(4rpx);
}

.header-menu-circle {
  width: 34rpx;
  height: 34rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  border: 4rpx solid #111111;
  border-radius: 50%;
}

.header-menu-circle-inner {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #111111;
}

.state-wrap,
.empty-box {
  min-height: 56vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  text-align: center;
}

.state-title,
.empty-title {
  color: #101828;
  font-size: 34rpx;
  line-height: 1.35;
  font-weight: 500;
}

.state-text,
.empty-text {
  margin-top: 14rpx;
  color: #667085;
  font-size: 25rpx;
  line-height: 1.7;
}

.content {
  padding: 26rpx 24rpx 0;
}

.toolbar {
  display: flex;
  justify-content: flex-end;
  margin-bottom: 22rpx;
}

.toolbar-actions {
  display: flex;
  align-items: center;
  gap: 18rpx;
}

.toolbar-btn {
  min-height: 64rpx;
  padding: 0 24rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  box-sizing: border-box;
  border-radius: 999rpx;
  font-size: 24rpx;
  line-height: 1;
  font-weight: 500;
}

.toolbar-btn--ghost {
  border: 1rpx solid rgba(17, 24, 39, 0.12);
  background: rgba(255, 255, 255, 0.9);
  color: #1d2939;
  box-shadow: 0 10rpx 26rpx rgba(15, 23, 42, 0.05);
}

.toolbar-btn--primary {
  background: rgba(167, 164, 164, 0.08);
  color: #111111;
}

.toolbar-btn-text {
  line-height: 1;
}

.toolbar-btn-arrow {
  color: #98a2b3;
  font-size: 18rpx;
  line-height: 1;
  font-weight: 300;
}

.announcement-section {
  margin-bottom: 28rpx;
}

.section-label {
  display: block;
  margin-bottom: 16rpx;
  color: #1d2939;
  font-size: 32rpx;
  line-height: 1.35;
  font-weight: 600;
  letter-spacing: 0.01em;
}

.announcement-card {
  padding: 6rpx 0;
}

.announcement-row {
  display: flex;
  align-items: flex-start;
  gap: 18rpx;
  padding: 16rpx 0;
}

.announcement-row--secondary {
  border-top: 1rpx solid rgba(15, 23, 42, 0.06);
}

.announcement-icon {
  width: 36rpx;
  height: 36rpx;
  flex-shrink: 0;
  margin-top: 4rpx;
}

.announcement-icon--muted {
  opacity: 0.88;
}

.announcement-copy {
  flex: 1;
  min-width: 0;
}

.announcement-title {
  display: block;
  color: #1d2939;
  font-size: 25rpx;
  line-height: 1.55;
  font-weight: 400;
}

.announcement-title--secondary {
  color: #365cad;
}

.announcement-subtitle {
  display: block;
  margin-top: 6rpx;
  color: #667085;
  font-size: 21rpx;
  line-height: 1.5;
}

.announcement-arrow {
  flex-shrink: 0;
  color: #1d2939;
  font-size: 28rpx;
  line-height: 1;
  font-weight: 300;
  margin-top: 2rpx;
}

.announcement-create-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  margin-top: 16rpx;
  gap: 10rpx;
}

.announcement-create-btn {
  width: 78rpx;
  height: 78rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  border-radius: 999rpx;
  border: 1rpx solid rgba(17, 24, 39, 0.10);
  background: rgba(255, 255, 255, 0.98);
  box-shadow: 0 18rpx 44rpx rgba(15, 23, 42, 0.14);
}

.announcement-create-btn--active {
  transform: translateY(1rpx) scale(0.98);
}

.announcement-create-btn__icon {
  color: #111111;
  font-size: 52rpx;
  line-height: 1;
  font-weight: 300;
  transform: translateY(-2rpx);
}

.announcement-create-btn__text {
  color: #111111;
  font-size: 22rpx;
  line-height: 1.4;
  font-weight: 500;
}

.feed-list {
  display: flex;
  flex-direction: column;
}

.feed-card {
  padding: 30rpx 4rpx 28rpx;
  border-top: 0;
}

.feed-card:first-child {
  border-top: 0;
}

.feed-author-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.avatar,
.comment-avatar {
  flex-shrink: 0;
  border-radius: 50%;
  background: #f2f4f7;
}

.avatar {
  width: 54rpx;
  height: 54rpx;
}

.author-meta {
  display: flex;
  align-items: center;
  gap: 12rpx;
  min-width: 0;
}

.author-name {
  color: #101828;
  font-size: 23rpx;
  line-height: 1.5;
  font-weight: 600;
}

.author-date {
  color: #98a2b3;
  font-size: 21rpx;
  line-height: 1.5;
}

.feed-title {
  display: block;
  margin-top: 20rpx;
  color: #101828;
  font-size: 36rpx;
  line-height: 1.32;
  font-weight: 500;
  letter-spacing: 0.01em;
}

.feed-summary {
  display: block;
  margin-top: 14rpx;
  color: #344054;
  font-size: 26rpx;
  line-height: 1.8;
}

.feed-content-expanded {
  margin-top: 14rpx;
}

.feed-blocks {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.feed-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 10rpx;
  margin-top: 18rpx;
}

.feed-grid-image {
  width: 100%;
  height: 220rpx;
  border-radius: 18rpx;
  background: #f2f4f7;
}

.feed-inline-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 10rpx;
}

.feed-inline-image {
  width: 100%;
  height: 220rpx;
  border-radius: 18rpx;
  background: #f2f4f7;
}

.feed-actions {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  margin-top: 22rpx;
}

.reply-count {
  color: #365cad;
  font-size: 25rpx;
  line-height: 1.5;
  font-weight: 500;
}

.feed-actions-right {
  display: flex;
  align-items: center;
  gap: 22rpx;
  flex-wrap: wrap;
  justify-content: flex-end;
}

.action-link {
  color: #365cad;
  font-size: 24rpx;
  line-height: 1.6;
}

.comment-preview-list {
  margin-top: 18rpx;
  padding-left: 0;
  border-left: 0;
}

.comment-preview {
  display: flex;
  gap: 16rpx;
  align-items: flex-start;
  padding: 18rpx 0 0;
}

.comment-preview + .comment-preview {
  margin-top: 10rpx;
}

.comment-avatar {
  width: 48rpx;
  height: 48rpx;
}

.comment-main {
  flex: 1;
  min-width: 0;
}

.comment-user {
  display: block;
  color: #344054;
  font-size: 22rpx;
  line-height: 1.5;
  font-weight: 600;
}

.comment-content {
  display: block;
  margin-top: 6rpx;
  color: #475467;
  font-size: 24rpx;
  line-height: 1.75;
}

.comment-image-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 12rpx;
}

.comment-image {
  width: 160rpx;
  height: 160rpx;
  border-radius: 16rpx;
  background: #f2f4f7;
}

.comment-time {
  display: block;
  margin-top: 8rpx;
  color: #98a2b3;
  font-size: 20rpx;
  line-height: 1.5;
}

.comment-empty-line {
  margin-top: 16rpx;
  padding-left: 0;
  border-left: 0;
}

.comment-empty-text {
  color: #98a2b3;
  font-size: 22rpx;
  line-height: 1.6;
}

.comment-loadmore,
.post-loadmore {
  padding-top: 20rpx;
}

.comment-composer {
  margin-top: 18rpx;
  padding: 20rpx;
  border-radius: 22rpx;
  background: #f8fafc;
}

.comment-upload-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 14rpx;
}

.comment-upload-item {
  position: relative;
  width: 160rpx;
  height: 160rpx;
  border-radius: 16rpx;
  overflow: hidden;
  background: #e5e7eb;
}

.comment-upload-preview {
  width: 100%;
  height: 100%;
}

.comment-upload-remove {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  width: 32rpx;
  height: 32rpx;
  border-radius: 50%;
  background: rgba(15, 23, 42, 0.72);
  color: #ffffff;
  font-size: 22rpx;
  line-height: 32rpx;
  text-align: center;
}

.comment-tool-row {
  display: flex;
  align-items: center;
  margin-bottom: 14rpx;
}

.comment-add-image {
  color: #365cad;
  font-size: 22rpx;
  line-height: 1.6;
}

.comment-action-row {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.comment-input {
  width: 100%;
  min-height: 140rpx;
  padding: 18rpx 20rpx;
  box-sizing: border-box;
  border: 1rpx solid #e5e7eb;
  border-radius: 18rpx;
  background: #ffffff;
  color: #101828;
  font-size: 26rpx;
  line-height: 1.7;
}

.comment-placeholder {
  color: #98a2b3;
}

.comment-btn {
  min-width: 160rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  margin-left: auto;
  padding: 0 28rpx;
  height: 64rpx;
  border-radius: 999rpx;
  background: #101828;
  color: #ffffff;
  font-size: 22rpx;
  line-height: 64rpx;
}

.comment-btn::after {
  border: 0;
}

.comment-submit {
  align-self: flex-end;
  min-width: 92rpx;
  padding: 0 22rpx;
  height: 54rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  border-radius: 999rpx;
  background: #f2f4f7;
  color: #344054;
  font-size: 22rpx;
  line-height: 1;
  font-weight: 500;
}

.post-loadmore {
  display: flex;
  justify-content: center;
}

.floating-create-btn {
  position: fixed;
  right: 26rpx;
  bottom: calc(32rpx + env(safe-area-inset-bottom));
  width: 88rpx;
  height: 88rpx;
  padding: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.98);
  border: 1rpx solid rgba(17, 24, 39, 0.08);
  box-shadow: 0 20rpx 48rpx rgba(15, 23, 42, 0.16);
  z-index: 40;
}

.floating-create-btn--active {
  transform: translateY(1rpx) scale(0.98);
}

.floating-create-btn__icon {
  width: 34rpx;
  height: 34rpx;
  display: block;
}

.floating-create-btn__label {
  display: none;
}
