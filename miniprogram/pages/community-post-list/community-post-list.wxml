<view class="page">
  <view class="page-header-sticky">
    <page-header title=""></page-header>
  </view>
  <view wx:if="{{loading}}" class="state-wrap">
    <text class="state-text">加载中…</text>
  </view>

  <view wx:elif="{{error}}" class="state-wrap">
    <text class="state-title">暂时无法查看社区动态</text>
    <text class="state-text">{{error}}</text>
  </view>

  <view wx:else class="content">
      <view class="page-head">
        <view class="page-copy">
          <text class="page-title">社区动态</text>
        </view>
        <view class="head-actions">
        <view wx:if="{{showManageButton}}" class="manage-btn" bindtap="onManageMembers">
          <text class="manage-btn-text">成员管理</text>
          <text class="manage-btn-arrow ui-chevron ui-chevron--sm">›</text>
        </view>
        <view wx:if="{{showCreateButton}}" class="create-btn" bindtap="onCreatePost">+</view>
      </view>
    </view>

    <view class="head-accent"></view>

    <view wx:if="{{posts.length > 0}}" class="feed-list">
      <view wx:for="{{posts}}" wx:key="id" class="feed-thread">
        <view class="feed-author-row">
          <image class="avatar" src="{{item.author_avatar_display_url}}" mode="aspectFill" />
          <view class="author-meta">
            <text class="author-name">{{item.author_name}}</text>
            <text class="author-date">· {{item.create_time_display}}</text>
          </view>
        </view>

        <text class="feed-title">{{item.title}}</text>
        <view wx:if="{{item.content_expanded}}" class="feed-content-expanded">
          <view class="feed-blocks">
            <view wx:for="{{item.parsed.blocks}}" wx:for-item="block" wx:key="index">
              <text wx:if="{{block.type === 'text'}}" class="feed-summary">{{block.text}}</text>
              <view wx:elif="{{block.type === 'images'}}" class="feed-inline-grid">
                <image
                  wx:for="{{block.images}}"
                  wx:for-item="imageUrl"
                  wx:key="imageUrl"
                  class="feed-inline-image"
                  src="{{imageUrl}}"
                  mode="aspectFill"
                  data-id="{{item.id}}"
                  data-url="{{imageUrl}}"
                  bindtap="onPreviewPostImage"
                />
              </view>
            </view>
          </view>
        </view>
        <text wx:elif="{{item.content_summary}}" class="feed-summary">{{item.content_summary}}<text wx:if="{{item.parsed.text.length > item.content_summary.length}}"> …</text></text>

        <view wx:if="{{!item.content_expanded && item.parsed.images && item.parsed.images.length > 0}}" class="feed-grid">
          <image
            wx:for="{{item.parsed.images}}"
            wx:for-item="imageUrl"
            wx:key="imageUrl"
            class="feed-grid-image"
            src="{{imageUrl}}"
            mode="aspectFill"
            data-id="{{item.id}}"
            data-url="{{imageUrl}}"
            bindtap="onPreviewPostImage"
          />
        </view>

        <view class="feed-actions">
          <text class="action-link" data-id="{{item.id}}" bindtap="onToggleContent">
            {{item.content_expanded ? '收起全文' : '加载更多'}}
          </text>
          <text wx:if="{{item.comment_count > 0}}" class="action-link" data-id="{{item.id}}" bindtap="onToggleComments">
            {{item.comments_collapsed ? '展开评论' : '折叠评论'}}
          </text>
          <text wx:if="{{canComment}}" class="action-link" data-id="{{item.id}}" bindtap="onToggleCommentComposer">
            {{item.comment_compose_open ? '收起评论' : '写评论'}}
          </text>
        </view>

        <view class="feed-footnote">
          <text class="feed-time">{{item.publish_time_ago}}</text>
        </view>

        <view wx:if="{{!item.comments_collapsed && item.comments.length > 0}}" class="comment-preview-list">
          <view wx:for="{{item.comments}}" wx:for-item="comment" wx:key="id" class="comment-preview">
            <image class="comment-avatar" src="{{comment.user_avatar_display_url}}" mode="aspectFill" />
            <view class="comment-main">
              <text class="comment-user">{{comment.user_name}}</text>
              <text class="comment-content">{{comment.content}}</text>
              <view wx:if="{{comment.images && comment.images.length > 0}}" class="comment-image-grid">
                <image
                  wx:for="{{comment.images}}"
                  wx:for-item="commentImage"
                  wx:key="commentImage"
                  class="comment-image"
                  src="{{commentImage}}"
                  mode="aspectFill"
                  data-post-id="{{item.id}}"
                  data-comment-id="{{comment.id}}"
                  data-url="{{commentImage}}"
                  bindtap="onPreviewCommentImage"
                />
              </view>
              <text class="comment-time">{{comment.create_time_display}}</text>
            </view>
          </view>
        </view>

        <view wx:elif="{{item.comment_count > 0}}" class="comment-empty-line">
          <text class="comment-empty-text">评论 {{item.comment_count}}</text>
        </view>

        <view wx:if="{{!item.comments_collapsed && !item.comments_loaded_all}}" class="comment-loadmore">
          <text class="action-link" data-id="{{item.id}}" bindtap="onLoadMoreComments">
            {{item.comments_loading ? '加载中…' : '加载更多评论'}}
          </text>
        </view>

        <view wx:if="{{canComment && item.comment_compose_open}}" class="comment-composer">
          <view wx:if="{{item.commentImageLocalPaths.length > 0}}" class="comment-upload-grid">
            <view wx:for="{{item.commentImageLocalPaths}}" wx:for-item="imgUrl" wx:for-index="imgIndex" wx:key="imgUrl" class="comment-upload-item">
              <image class="comment-upload-preview" src="{{imgUrl}}" mode="aspectFill" />
              <view class="comment-upload-remove" data-post-id="{{item.id}}" data-index="{{imgIndex}}" bindtap="onRemoveCommentImage">×</view>
            </view>
          </view>
          <view class="comment-tool-row">
            <view class="comment-add-image" data-id="{{item.id}}" bindtap="onChooseCommentImages">+ 图片 {{item.commentImageLocalPaths.length}}/9</view>
          </view>
          <view class="comment-action-row">
            <textarea
              class="comment-input"
              placeholder="写下你的评论"
              placeholder-class="comment-placeholder"
              value="{{item.commentContent}}"
              maxlength="1000"
              auto-height
              data-id="{{item.id}}"
              bindinput="onCommentInput"
            ></textarea>
            <button class="comment-btn" data-id="{{item.id}}" disabled="{{item.commentSubmitting}}" bindtap="onSubmitComment">
              {{item.commentSubmitting ? '提交中' : '发送'}}
            </button>
          </view>
        </view>
      </view>
    </view>

    <view wx:if="{{hasMorePosts}}" class="post-loadmore">
      <text class="action-link" bindtap="onLoadMorePosts">{{loadingMore ? '加载中…' : '加载更多动态'}}</text>
    </view>

    <view wx:elif="{{showEmptyState}}" class="empty-box">
      <text class="empty-title">还没有社区动态</text>
      <text class="empty-text">社区成员发布后，会在这里展示。</text>
    </view>
  </view>
</view>
