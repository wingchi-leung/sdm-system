<view class="page">
  <view wx:if="{{loading}}" class="state-wrap">
    <text class="state-text">加载中…</text>
  </view>

  <view wx:elif="{{error}}" class="state-wrap">
    <text class="state-title">暂时无法查看活动动态</text>
    <text class="state-text">{{error}}</text>
  </view>

  <view wx:else class="content">
    <view class="page-head">
      <view class="page-head-main">
        <text class="page-caption">社区频道</text>
        <text class="page-title">频道动态</text>
        <text wx:if="{{channelName}}" class="page-subtitle">{{channelName}}</text>
      </view>
      <button wx:if="{{showCreateButton}}" class="create-btn" bindtap="onCreatePost">发布动态</button>
    </view>

    <!-- 2 列瀑布流(矮列优先分列) -->
    <view wx:if="{{colA.length > 0 || colB.length > 0}}" class="waterfall">
      <view class="waterfall-col">
        <view wx:for="{{colA}}" wx:key="id" class="post-card" data-id="{{item.id}}" bindtap="onOpenPost">
          <view wx:if="{{item.images && item.images.length > 0}}" class="post-cover">
            <image class="post-cover-image" src="{{item.images[0]}}" mode="widthFix" />
            <text wx:if="{{item.images.length > 1}}" class="post-cover-count">+{{item.images.length - 1}}</text>
          </view>
          <view class="post-body">
            <text class="post-title">{{item.title}}</text>
            <text wx:if="{{item.content_summary}}" class="post-summary">{{item.content_summary}}</text>
            <view class="post-meta-row">
              <text class="post-meta">{{item.author_name}} · {{item.create_time_display}}</text>
              <text class="post-comments">💬 {{item.comment_count}}</text>
            </view>
          </view>
        </view>
      </view>
      <view class="waterfall-col">
        <view wx:for="{{colB}}" wx:key="id" class="post-card" data-id="{{item.id}}" bindtap="onOpenPost">
          <view wx:if="{{item.images && item.images.length > 0}}" class="post-cover">
            <image class="post-cover-image" src="{{item.images[0]}}" mode="widthFix" />
            <text wx:if="{{item.images.length > 1}}" class="post-cover-count">+{{item.images.length - 1}}</text>
          </view>
          <view class="post-body">
            <text class="post-title">{{item.title}}</text>
            <text wx:if="{{item.content_summary}}" class="post-summary">{{item.content_summary}}</text>
            <view class="post-meta-row">
              <text class="post-meta">{{item.author_name}} · {{item.create_time_display}}</text>
              <text class="post-comments">💬 {{item.comment_count}}</text>
            </view>
          </view>
        </view>
      </view>
    </view>

    <view wx:elif="{{posts.length === 0}}" class="empty-box">
      <text class="empty-title">还没有活动动态</text>
      <text class="empty-text">频道成员发布后，会在这里展示。</text>
    </view>
  </view>
</view>
