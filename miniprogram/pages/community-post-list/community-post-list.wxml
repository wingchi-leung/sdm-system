<view class="page">
  <page-header title="社区动态" statusBarHeight="{{statusBarHeight}}">
  </page-header>

  <view wx:if="{{loading}}" class="state-wrap">
    <text class="state-text">加载中…</text>
  </view>

  <view wx:elif="{{error}}" class="state-wrap">
    <text class="state-title">暂时无法查看社区动态</text>
    <text class="state-text">{{error}}</text>
  </view>

  <view wx:else class="content">
    <view class="toolbar">
      <view class="toolbar-actions">
        <!-- <view wx:if="{{showCalendarButton}}" class="toolbar-btn" bindtap="onOpenCalendar">
          <view class="toolbar-calendar" aria-hidden="true">
            <view class="toolbar-calendar__rings"></view>
            <view class="toolbar-calendar__dots"></view>
          </view>
          <text class="toolbar-btn-text">社区日历</text>
          <text class="toolbar-btn-arrow ui-chevron ui-chevron--sm">›</text>
        </view> -->
        <view wx:if="{{showManageButton}}" class="toolbar-btn" bindtap="onManageMembers">
          <view class="toolbar-members" aria-hidden="true">
            <view class="toolbar-members__head toolbar-members__head--left"></view>
            <view class="toolbar-members__head toolbar-members__head--right"></view>
            <view class="toolbar-members__body"></view>
          </view>
          <text class="toolbar-btn-text">社区管理</text>
        </view>
      </view>
    </view>

    <view class="section-head">
      <text class="section-label">最新公告</text>
      <view class="section-head__dash"></view>
    </view>

    <view wx:if="{{showAnnouncementEntry}}" class="announcement-banner" bindtap="onOpenAnnouncementList">
      <view class="announcement-banner__head">
        <view class="announcement-icon-wrap announcement-icon-wrap--banner">
          <image class="announcement-icon" src="/assets/icons/announcement.png" mode="aspectFit" />
        </view>
        <text class="announcement-banner__title">公告</text>
        <text class="announcement-banner__more">全部公告 ›</text>
      </view>
      <view class="announcement-banner__line">
        <text class="announcement-banner__dot">•</text>
        <text class="announcement-banner__hint">点击进入公告栏</text>
      </view>
    </view>

    <view wx:if="{{posts.length > 0}}" class="feed-list">
      <view wx:for="{{posts}}" wx:for-index="postIndex" wx:key="id" class="feed-card">
        <text class="feed-title">{{item.title}}</text>

        <view class="feed-source">
          <text>来源：社区</text>
          <text class="feed-source__divider">|</text>
          <text>作者：{{item.author_name}}</text>
          <text class="feed-source__divider">|</text>
          <text>{{item.create_time_display}}</text>
        </view>

        <view wx:if="{{!item.content_expanded && item.parsed.images && item.parsed.images.length > 0}}" class="feed-grid">
          <view
            wx:for="{{item.parsed.images}}"
            wx:for-item="imageUrl"
            wx:for-index="imageIndex"
            wx:key="imageUrl"
            class="feed-grid-cell"
          >
            <image
              class="feed-grid-image"
              src="{{imageUrl}}"
              mode="aspectFill"
              data-id="{{item.id}}"
              data-url="{{imageUrl}}"
              bindtap="onPreviewPostImage"
            />
            <view wx:if="{{imageIndex === 2 && item.parsed.images.length > 3}}" class="feed-grid-more">
              +{{item.parsed.images.length - 3}}
            </view>
          </view>
        </view>

        <view wx:if="{{item.content_expanded}}" class="feed-content-expanded">
          <view class="feed-blocks">
            <view wx:for="{{item.parsed.blocks}}" wx:for-item="block" wx:key="index">
              <text wx:if="{{block.type === 'text'}}" class="feed-summary">{{block.text}}</text>
              <view wx:elif="{{block.type === 'images'}}" class="feed-inline-grid">
                <image
                  wx:for="{{block.images}}"
                  wx:for-item="imageUrl"
                  wx:key="imageUrl"
                  class="feed-inline-image"
                  src="{{imageUrl}}"
                  mode="aspectFill"
                  data-id="{{item.id}}"
                  data-url="{{imageUrl}}"
                  bindtap="onPreviewPostImage"
                />
              </view>
            </view>
          </view>
        </view>

        <text wx:elif="{{item.content_summary}}" class="feed-summary">
          {{item.content_summary}}{{item.parsed.text.length > item.content_summary.length ? '……' : ''}}
        </text>

        <view class="expand-row">
          <text class="action-link action-link--expand" data-id="{{item.id}}" bindtap="onToggleContent">
            {{item.content_expanded ? '收起全文' : '展开全文'}}
          </text>
        </view>

        <view class="feed-actions">
          <view class="reply-count">
            <view class="reply-icon"></view>
            <text>{{item.comment_count || 0}} 条评论</text>
          </view>
          <view wx:if="{{canComment}}" class="write-comment-btn" data-id="{{item.id}}" bindtap="onToggleCommentComposer">
            <text class="write-comment-btn__icon">▱</text>
            <text>{{item.comment_compose_open ? '收起评论' : '写评论'}}</text>
          </view>
        </view>

        <view wx:if="{{!item.comments_collapsed && item.comments.length > 0}}" class="comment-preview-list">
          <view wx:for="{{item.comments}}" wx:for-item="comment" wx:key="id" class="comment-preview">
            <image class="comment-avatar" src="{{comment.user_avatar_display_url}}" mode="aspectFill" />
            <view class="comment-main">
              <view class="comment-meta-row">
                <text class="comment-user">{{comment.user_name}}</text>
                <text class="comment-time">· {{comment.create_time_display}}</text>
              </view>
              <text class="comment-content">{{comment.content}}</text>
              <view wx:if="{{comment.images && comment.images.length > 0}}" class="comment-image-grid">
                <image
                  wx:for="{{comment.images}}"
                  wx:for-item="commentImage"
                  wx:key="commentImage"
                  class="comment-image"
                  src="{{commentImage}}"
                  mode="aspectFill"
                  data-post-id="{{item.id}}"
                  data-comment-id="{{comment.id}}"
                  data-url="{{commentImage}}"
                  bindtap="onPreviewCommentImage"
                />
              </view>
            </view>
          </view>
        </view>

        <view wx:elif="{{item.comment_count > 0}}" class="comment-empty-line">
          <text class="comment-empty-text">评论 {{item.comment_count}}</text>
        </view>

        <view wx:if="{{!item.comments_collapsed && !item.comments_loaded_all}}" class="comment-loadmore">
          <text class="action-link" data-id="{{item.id}}" bindtap="onLoadMoreComments">
            {{item.comments_loading ? '加载中…' : '查看更多评论'}}
          </text>
        </view>

        <view wx:if="{{canComment && item.comment_compose_open}}" class="comment-composer">
          <view wx:if="{{item.commentImageLocalPaths.length > 0}}" class="comment-upload-grid">
            <view wx:for="{{item.commentImageLocalPaths}}" wx:for-item="imgUrl" wx:for-index="imgIndex" wx:key="imgUrl" class="comment-upload-item">
              <image class="comment-upload-preview" src="{{imgUrl}}" mode="aspectFill" />
              <view class="comment-upload-remove" data-post-id="{{item.id}}" data-index="{{imgIndex}}" bindtap="onRemoveCommentImage">×</view>
            </view>
          </view>
          <view class="comment-tool-row">
            <view class="comment-add-image" data-id="{{item.id}}" bindtap="onChooseCommentImages">+ 图片 {{item.commentImageLocalPaths.length}}/9</view>
          </view>
          <view class="comment-action-row">
            <textarea
              class="comment-input"
              placeholder="写下你的评论"
              placeholder-class="comment-placeholder"
              value="{{item.commentContent}}"
              maxlength="1000"
              auto-height
              data-id="{{item.id}}"
              bindinput="onCommentInput"
            ></textarea>
            <view class="comment-submit" data-id="{{item.id}}" bindtap="onSubmitComment">
              {{item.commentSubmitting ? '提交中' : '发送'}}
            </view>
          </view>
        </view>
      </view>
    </view>

    <view wx:if="{{hasMorePosts}}" class="post-loadmore">
      <text class="action-link" bindtap="onLoadMorePosts">{{loadingMore ? '加载中…' : '加载更多动态'}}</text>
    </view>

    <view wx:elif="{{showEmptyState}}" class="empty-box">
      <text class="empty-title">还没有社区动态</text>
      <text class="empty-text">社区成员发布后，会在这里展示。</text>
    </view>
  </view>

  <view wx:if="{{showCreateButton}}" class="floating-create-btn" bindtap="onCreatePost" hover-class="floating-create-btn--active">
    <image class="floating-create-btn__icon" src="/assets/icons/pen.png" mode="aspectFit" />
    <text class="floating-create-btn__label">写点什么</text>
  </view>
</view>
