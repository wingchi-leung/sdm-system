<view class="page">
  <view class="form">
    <!-- 活动名称 -->
    <view class="field">
      <text class="field-label">活动名称</text>
      <input
        class="input"
        placeholder="请输入活动名称"
        placeholder-class="input-placeholder"
        value="{{activityName}}"
        bindinput="onNameInput"
      />
    </view>

    <!-- 活动类型 -->
    <view class="field">
      <text class="field-label">活动类型</text>
      <picker
        mode="selector"
        range="{{activityTypeOptions}}"
        range-key="name"
        value="{{activityTypeIndex}}"
        bindchange="onActivityTypeChange"
      >
        <view class="picker-row">
          <text class="picker-value">{{activityTypeName || '请选择活动类型'}}</text>
          <text class="picker-arrow">→</text>
        </view>
      </picker>
      <input
        wx:if="{{isSuperAdmin}}"
        class="input"
        placeholder="超级管理员可直接输入类型"
        placeholder-class="input-placeholder"
        value="{{activityTypeName}}"
        bindinput="onActivityTypeInput"
        style="margin-top: 16rpx;"
      />
    </view>

    <!-- 报名限额 -->
    <view class="field">
      <text class="field-label">报名限额</text>
      <input
        class="input"
        type="number"
        placeholder="不填则不限制人数"
        placeholder-class="input-placeholder"
        value="{{maxParticipants}}"
        bindinput="onMaxParticipantsInput"
      />
      <text class="field-hint">设置后，超额报名将进入候补状态</text>
    </view>

    <!-- 支付设置 -->
    <view class="field payment-section">
      <view class="payment-header">
        <text class="field-label">支付设置</text>
      </view>
      <view class="switch-row">
        <text class="switch-label">需要支付</text>
        <switch checked="{{requirePayment}}" bindchange="onRequirePaymentChange" color="var(--primary)" />
      </view>
      <!-- 费用输入（开启支付时显示） -->
      <view class="fee-input-section" wx:if="{{requirePayment}}">
        <text class="fee-label">建议费用（元）</text>
        <view class="fee-input-wrapper">
          <text class="fee-currency">¥</text>
          <input
            class="input fee-input"
            type="digit"
            placeholder="0.00"
            placeholder-class="input-placeholder"
            value="{{suggestedFeeYuan}}"
            bindinput="onSuggestedFeeInput"
            bindblur="onSuggestedFeeBlur"
          />
        </view>
        <text class="fee-hint">用户可支付等于或高于此金额</text>
      </view>
    </view>

    <!-- 活动地点 -->
    <view class="field">
      <text class="field-label">活动地点</text>
      <input
        class="input"
        placeholder="不填则默认为线上活动"
        placeholder-class="input-placeholder"
        value="{{location}}"
        bindinput="onLocationInput"
      />
    </view>

    <!-- 开始时间 -->
    <view class="field">
      <text class="field-label">开始时间</text>
      <view class="datetime-row">
        <picker mode="date" value="{{startDate}}" start="2020-01-01" end="2030-12-31" bindchange="onDateChange">
          <view class="picker-value">{{startDate || '选择日期'}}</view>
        </picker>
        <picker mode="time" value="{{startTime}}" start="00:00" end="23:59" bindchange="onTimeChange">
          <view class="picker-value">{{startTime || '选择时间'}}</view>
        </picker>
      </view>
    </view>

    <!-- 结束时间 -->
    <view class="field">
      <text class="field-label">结束时间</text>
      <view class="datetime-row">
        <picker mode="date" value="{{endDate}}" start="2020-01-01" end="2030-12-31" bindchange="onEndDateChange">
          <view class="picker-value">{{endDate || '选择日期'}}</view>
        </picker>
        <picker mode="time" value="{{endTime}}" start="00:00" end="23:59" bindchange="onEndTimeChange">
          <view class="picker-value">{{endTime || '选择时间'}}</view>
        </picker>
      </view>
    </view>

    <!-- 活动海报 -->
    <view class="field">
      <text class="field-label">活动海报</text>
      <view class="poster-section">
        <view wx:if="{{posterLocalPath}}" class="poster-preview">
          <image class="poster-image" src="{{posterLocalPath}}" mode="aspectFill" />
          <view class="poster-remove" bindtap="onRemovePoster">
            <text class="remove-icon">×</text>
          </view>
        </view>
        <view wx:else class="poster-upload" bindtap="onChoosePoster">
          <view class="upload-icon">+</view>
          <text class="upload-text">上传海报</text>
          <text class="upload-hint">支持PNG、JPG格式，最大5MB</text>
        </view>
      </view>
    </view>

    <!-- 错误提示 -->
    <view class="error-box" wx:if="{{error}}">
      <text class="error-text">{{error}}</text>
    </view>

    <!-- 提交按钮 -->
    <button class="btn-submit" disabled="{{submitting || uploading}}" bindtap="submit">
      <text class="btn-text">{{uploading ? '上传中…' : submitting ? '发布中…' : '发布活动'}}</text>
    </button>
  </view>
</view>