<view class="page">
  <view class="form">
    <!-- 活动名称 -->
    <view class="field">
      <text class="field-label">活动名称</text>
      <input
        class="input"
        placeholder="请输入活动名称"
        placeholder-class="input-placeholder"
        value="{{activityName}}"
        bindinput="onNameInput"
      />
    </view>

    <!-- 活动类型 -->
    <view class="field">
      <text class="field-label">活动类型</text>
      <picker
        mode="selector"
        range="{{activityTypeOptions}}"
        range-key="name"
        value="{{activityTypeIndex}}"
        bindchange="onActivityTypeChange"
      >
        <view class="picker-row">
          <text class="picker-value">{{activityTypeName || '请选择活动类型'}}</text>
          <text class="picker-arrow">→</text>
        </view>
      </picker>
      <input
        wx:if="{{isSuperAdmin}}"
        class="input"
        placeholder="超级管理员可直接输入类型"
        placeholder-class="input-placeholder"
        value="{{activityTypeName}}"
        bindinput="onActivityTypeInput"
        style="margin-top: 16rpx;"
      />
    </view>

    <!-- 开始日期 -->
    <view class="field">
      <text class="field-label">开始日期</text>
      <picker mode="date" value="{{startDate}}" bindchange="onDateChange">
        <view class="picker-row">
          <text class="picker-value">{{startDate || '请选择日期'}}</text>
          <text class="picker-arrow">→</text>
        </view>
      </picker>
    </view>

    <!-- 开始时间 -->
    <view class="field">
      <text class="field-label">开始时间</text>
      <picker mode="time" value="{{startTime}}" bindchange="onTimeChange">
        <view class="picker-row">
          <text class="picker-value">{{startTime || '请选择时间'}}</text>
          <text class="picker-arrow">→</text>
        </view>
      </picker>
    </view>

    <!-- 支付设置 -->
    <view class="field payment-section">
      <view class="payment-header">
        <text class="field-label">支付设置</text>
      </view>
      <view class="switch-row">
        <text class="switch-label">需要支付</text>
        <switch checked="{{requirePayment}}" bindchange="onRequirePaymentChange" color="var(--primary)" />
      </view>
      <!-- 费用输入（开启支付时显示） -->
      <view class="fee-input-section" wx:if="{{requirePayment}}">
        <text class="fee-label">建议费用（元）</text>
        <view class="fee-input-wrapper">
          <text class="fee-currency">¥</text>
          <input
            class="input fee-input"
            type="digit"
            placeholder="0.00"
            placeholder-class="input-placeholder"
            value="{{suggestedFeeYuan}}"
            bindinput="onSuggestedFeeInput"
            bindblur="onSuggestedFeeBlur"
          />
        </view>
        <text class="fee-hint">用户可支付等于或高于此金额</text>
      </view>
    </view>

    <!-- 错误提示 -->
    <view class="error-box" wx:if="{{error}}">
      <text class="error-text">{{error}}</text>
    </view>

    <!-- 提交按钮 -->
    <button class="btn-submit" disabled="{{submitting}}" bindtap="submit">
      <text class="btn-text">{{submitting ? '发布中…' : '发布活动'}}</text>
    </button>
  </view>
</view>