<view class="page">
  <view class="form">
    <view class="field">
      <text class="field-label">活动名称 *</text>
      <input
        class="input"
        placeholder="请输入活动名称"
        value="{{activityName}}"
        bindinput="onNameInput"
      />
    </view>
    <view class="field">
      <text class="field-label">活动类型 *</text>
      <picker
        mode="selector"
        range="{{activityTypeOptions}}"
        range-key="name"
        value="{{activityTypeIndex}}"
        bindchange="onActivityTypeChange"
      >
        <view class="picker-value">{{activityTypeName || (isTypeAdmin ? '请选择活动类型' : '常见类型快速选择（可选）')}}</view>
      </picker>
      <input
        wx:if="{{isSuperAdmin}}"
        class="input type-input"
        placeholder="超级管理员可直接输入类型，如：参、健康锻炼"
        value="{{activityTypeName}}"
        bindinput="onActivityTypeInput"
      />
    </view>
    <view class="field">
      <text class="field-label">标签（选填）</text>
      <input
        class="input"
        placeholder="如：培训、沙龙"
        value="{{tag}}"
        bindinput="onTagInput"
      />
    </view>
    <view class="field">
      <text class="field-label">开始日期 *</text>
      <picker mode="date" value="{{startDate}}" bindchange="onDateChange">
        <view class="picker-value">{{startDate || '请选择日期'}}</view>
      </picker>
    </view>
    <view class="field">
      <text class="field-label">开始时间 *</text>
      <picker mode="time" value="{{startTime}}" bindchange="onTimeChange">
        <view class="picker-value">{{startTime || '请选择时间'}}</view>
      </picker>
    </view>

    <view class="error-box" wx:if="{{error}}">
      <text class="error-text">{{error}}</text>
    </view>

    <button class="btn-primary submit-btn" disabled="{{submitting}}" bindtap="submit">
      {{submitting ? '发布中…' : '发布活动'}}
    </button>
  </view>
</view>
