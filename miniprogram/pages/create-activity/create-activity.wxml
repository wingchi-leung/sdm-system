<view class="page">
  <page-header title="发布活动" statusBarHeight="{{statusBarHeight}}" autoBack="{{false}}" bindback="onBackTap">
    <view slot="actions" class="header-pill" bindtap="onMoreTap" hover-class="header-action--active">
      <text class="header-pill-dots">···</text>
      <view class="header-pill-divider"></view>
      <text class="header-pill-circle">◉</text>
    </view>
  </page-header>

  <scroll-view class="content" style="height: calc(100vh - {{statusBarHeight}}px - 92rpx - 144rpx);" scroll-y="true" show-scrollbar="{{false}}">
    <view class="content-inner">
      <view class="field">
        <view class="field-head">
          <text class="field-label">活动名称</text>
          <text class="field-required">*</text>
          <text class="field-counter field-counter-inline">{{activityNameCount}}/50</text>
        </view>
        <input
          class="input input-line"
          placeholder="请输入活动名称"
          placeholder-class="input-placeholder"
          maxlength="50"
          value="{{activityName}}"
          bindinput="onNameInput"
        />
      </view>

      <view class="field">
        <view class="field-head">
          <text class="field-label">活动类型</text>
          <text class="field-required">*</text>
        </view>
        <picker
          mode="selector"
          range="{{activityTypeOptions}}"
          range-key="name"
          value="{{activityTypeIndex}}"
          bindchange="onActivityTypeChange"
        >
          <view class="picker-row">
            <text class="picker-value">{{activityTypeName || '请选择活动类型'}}</text>
            <text class="picker-arrow ui-chevron ui-chevron--md ui-chevron--right"></text>
          </view>
        </picker>
        <input
          wx:if="{{isSuperAdmin}}"
          class="input input-line input-line-secondary"
          placeholder="超级管理员可直接输入类型（选填）"
          placeholder-class="input-placeholder"
          value="{{activityTypeName}}"
          bindinput="onActivityTypeInput"
        />
      </view>

      <view class="field">
        <view class="field-head">
          <text class="field-label">活动时间</text>
          <text class="field-required">*</text>
        </view>
        <view class="datetime-stack">
          <view class="datetime-row">
            <text class="datetime-label">开始</text>
            <view class="datetime-pickers">
              <picker mode="date" value="{{startDate}}" start="2020-01-01" end="2030-12-31" bindchange="onDateChange">
                <view class="time-chip">
                  <text class="time-chip-text">{{startDate || '选择日期'}}</text>
                  <text class="time-chip-arrow ui-chevron ui-chevron--sm ui-chevron--down"></text>
                </view>
              </picker>
              <picker mode="time" value="{{startTime}}" start="00:00" end="23:59" bindchange="onTimeChange">
                <view class="time-chip">
                  <text class="time-chip-text">{{startTime || '选择时间'}}</text>
                  <text class="time-chip-arrow ui-chevron ui-chevron--sm ui-chevron--down"></text>
                </view>
              </picker>
            </view>
          </view>
          <view class="datetime-row">
            <text class="datetime-label">结束</text>
            <view class="datetime-pickers">
              <picker mode="date" value="{{endDate}}" start="2020-01-01" end="2030-12-31" bindchange="onEndDateChange">
                <view class="time-chip">
                  <text class="time-chip-text">{{endDate || '选择日期'}}</text>
                  <text class="time-chip-arrow ui-chevron ui-chevron--sm ui-chevron--down"></text>
                </view>
              </picker>
              <picker mode="time" value="{{endTime}}" start="00:00" end="23:59" bindchange="onEndTimeChange">
                <view class="time-chip">
                  <text class="time-chip-text">{{endTime || '选择时间'}}</text>
                  <text class="time-chip-arrow ui-chevron ui-chevron--sm ui-chevron--down"></text>
                </view>
              </picker>
            </view>
          </view>
        </view>
      </view>

      <view class="field">
        <view class="switch-row">
          <view class="switch-copy">
            <text class="switch-label">设为公开活动</text>
            <text class="field-hint field-hint-inline">公开活动所有用户可见，非公开活动仅关联用户可见</text>
          </view>
          <switch checked="{{isPublic}}" bindchange="onIsPublicChange" color="var(--primary)" />
        </view>
      </view>

      <view class="field">
        <view class="field-head">
          <text class="field-label">报名限额</text>
        </view>
        <input
          class="input input-line"
          type="number"
          placeholder="不填则不限制人数"
          placeholder-class="input-placeholder"
          value="{{maxParticipants}}"
          bindinput="onMaxParticipantsInput"
        />
        <text class="field-hint">设置后，超额报名将进入候补状态</text>
      </view>

      <view class="field payment-section">
        <view class="field-head">
          <text class="field-label">支付设置</text>
        </view>
        <view class="switch-row">
          <text class="switch-label">需要支付</text>
          <switch checked="{{requirePayment}}" bindchange="onRequirePaymentChange" color="var(--primary)" />
        </view>
        <view class="fee-card" wx:if="{{requirePayment}}">
          <text class="fee-label">建议费用（元）</text>
          <view class="fee-input-wrapper">
            <text class="fee-currency">¥</text>
            <input
              class="input fee-input input-line"
              type="digit"
              placeholder="0.00"
              placeholder-class="input-placeholder"
              value="{{suggestedFeeYuan}}"
              bindinput="onSuggestedFeeInput"
              bindblur="onSuggestedFeeBlur"
            />
          </view>
          <text class="fee-hint">用户可支付等于或高于此金额</text>
        </view>
      </view>

      <view class="field">
        <view class="field-head">
          <text class="field-label">活动地点</text>
        </view>
        <input
          class="input input-line"
          placeholder="不填则默认为线上活动"
          placeholder-class="input-placeholder"
          value="{{location}}"
          bindinput="onLocationInput"
        />
      </view>

      <view class="field">
        <view class="field-head">
          <text class="field-label">活动介绍</text>
        </view>
        <view class="textarea-card">
          <textarea
            class="textarea-input"
            placeholder="请输入活动介绍"
            placeholder-class="input-placeholder"
            maxlength="1000"
            value="{{activityIntro}}"
            bindinput="onActivityIntroInput"
          />
        </view>
      </view>

      <view wx:if="{{error}}" class="error-box">
        <text class="error-text">{{error}}</text>
      </view>

      <view class="page-spacer"></view>
    </view>
  </scroll-view>

  <view class="footer-bar">
    <button class="footer-btn footer-btn-primary" disabled="{{submitting || uploading}}" bindtap="submit">
      <text class="footer-btn-text">{{uploading ? '上传中…' : submitting ? '发布中…' : '发布活动'}}</text>
      <text class="footer-btn-arrow ui-chevron ui-chevron--md ui-chevron--right"></text>
    </button>
  </view>
</view>
