.page {
  min-height: 100vh;
  box-sizing: border-box;
  background: #ffffff;
  color: #111111;
  overflow: hidden;
}

.header-pill {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  box-sizing: border-box;
}

.header-pill {
  min-width: 180rpx;
  height: 72rpx;
  padding: 0 20rpx;
  gap: 20rpx;
  border-radius: 999rpx;
  border: 1rpx solid #e5e7eb;
  background: #ffffff;
  box-shadow: none;
}

.header-action--active {
  background: rgba(17, 17, 17, 0.04);
}

.header-pill-dots {
  color: #111111;
  font-size: 32rpx;
  line-height: 1;
  letter-spacing: 2rpx;
  font-weight: 700;
}

.header-pill-divider {
  width: 1rpx;
  height: 28rpx;
  background: #e5e7eb;
}

.header-pill-circle {
  color: #111111;
  font-size: 32rpx;
  line-height: 1;
  font-weight: 500;
}

.content {
  box-sizing: border-box;
}

.content-inner {
  padding: 28rpx 32rpx 320rpx;
  box-sizing: border-box;
}

.field {
  margin-bottom: 72rpx;
}

.field-head {
  display: flex;
  align-items: center;
  gap: 10rpx;
  margin-bottom: 20rpx;
}

.field-label {
  color: #111111;
  font-size: 28rpx;
  line-height: 1.25;
  font-weight: 500;
}

.field-required {
  color: #e5483b;
  font-size: 28rpx;
  line-height: 1;
}

.field-counter {
  margin-left: auto;
  color: #9a9a9a;
  font-size: 22rpx;
  line-height: 1.4;
}

.field-counter-inline {
  margin-left: auto;
}

.input {
  width: 100%;
  font-size: 28rpx;
  color: #111111;
  background: transparent;
  border: none;
  box-sizing: border-box;
}

.input-line {
  height: 84rpx;
  padding: 0 0 12rpx;
  border-bottom: 1rpx solid rgba(17, 17, 17, 0.12);
  border-radius: 0;
}

.input-line-secondary {
  margin-top: 20rpx;
}

.input-placeholder {
  color: #b4b4b4;
}

.picker-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 84rpx;
  padding: 0 0 12rpx;
  border-bottom: 1rpx solid rgba(17, 17, 17, 0.12);
  box-sizing: border-box;
}

.picker-value {
  font-size: 28rpx;
  color: #111111;
}

.picker-arrow {
  color: #9a9a9a;
  font-size: 30rpx;
  line-height: 1;
  font-weight: 300;
}

.datetime-stack {
  display: flex;
  flex-direction: column;
  gap: 32rpx;
}

.datetime-row {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.datetime-label {
  flex-shrink: 0;
  width: 52rpx;
  color: #666666;
  font-size: 24rpx;
  line-height: 1.4;
}

.datetime-pickers {
  flex: 1;
  display: flex;
  align-items: center;
  gap: 22rpx;
}

.time-chip {
  min-width: 0;
  flex: 1;
  height: 84rpx;
  padding: 0 0 12rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  border-bottom: 1rpx solid rgba(17, 17, 17, 0.12);
  border-radius: 0;
  background: transparent;
  color: #111111;
  font-size: 26rpx;
  box-sizing: border-box;
}

.time-chip-text {
  flex: 1;
  min-width: 0;
  color: #111111;
  font-size: 26rpx;
  line-height: 1;
}

.time-chip-arrow {
  color: #9a9a9a;
  font-size: 20rpx;
  line-height: 1;
  margin-left: 10rpx;
}

.field-hint {
  display: block;
  margin-top: 16rpx;
  color: #9a9a9a;
  font-size: 22rpx;
  line-height: 1.5;
}

.field-hint-inline {
  margin-top: 6rpx;
}

.switch-row {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
}

.switch-copy {
  flex: 1;
  min-width: 0;
}

.switch-label {
  display: block;
  color: #111111;
  font-size: 28rpx;
  line-height: 1.4;
  font-weight: 500;
}

.payment-section {
  margin-bottom: 34rpx;
}

.fee-card {
  margin-top: 22rpx;
}

.fee-label {
  display: block;
  color: #666666;
  font-size: 24rpx;
  line-height: 1.4;
  margin-bottom: 12rpx;
}

.fee-input-wrapper {
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.fee-currency {
  color: #111111;
  font-size: 34rpx;
  line-height: 1;
  font-weight: 500;
}

.fee-input {
  flex: 1;
}

.fee-hint {
  display: block;
  margin-top: 10rpx;
  color: #9a9a9a;
  font-size: 22rpx;
  line-height: 1.5;
}

.textarea-card {
  position: relative;
  padding: 0;
  border: 1rpx solid #eef0ee;
  border-radius: 18rpx;
  background: #ffffff;
}

.textarea-input {
  width: 100%;
  min-height: 320rpx;
  padding: 24rpx 22rpx 28rpx;
  box-sizing: border-box;
  color: #111111;
  font-size: 28rpx;
  line-height: 1.75;
}

.textarea-count {
  position: absolute;
  right: 20rpx;
  bottom: 14rpx;
  color: #9a9a9a;
  font-size: 22rpx;
  line-height: 1;
}

.error-box {
  margin-top: 24rpx;
  padding: 18rpx 20rpx;
  border-radius: 18rpx;
  background: rgba(178, 65, 55, 0.08);
}

.error-text {
  color: #b24137;
  font-size: 24rpx;
  line-height: 1.6;
}

.page-spacer {
  height: 48rpx;
}

.footer-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  padding: 24rpx 32rpx calc(34rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
  background: #ffffff;
  border-top: 1rpx solid #f0f1f0;
}

.footer-btn {
  flex: 1;
  height: 90rpx;
  margin: 0;
  padding: 0;
  border-radius: 16rpx;
  box-sizing: border-box;
}

.footer-btn::after {
  border: none;
}

.footer-btn-primary {
  background: #111111;
  border: 1rpx solid #111111;
}

.footer-btn-text {
  color: #ffffff;
  font-size: 28rpx;
  line-height: 1;
  font-weight: 500;
}
