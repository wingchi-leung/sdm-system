/**
 * 创建活动页 - Linear风格设计
 */
.page {
  min-height: 100vh;
  padding: @space-lg) @space-xl) @space-2xl);
  background: var(--background);
}

/* ====== Linear风格表单 ====== */
.form {
  background: var(--background-card);
  border-radius: 24rpx;
  padding: @space-2xl);
  box-shadow: var(--shadow-md);
  border: 1px solid var(--border);
}

.field {
  margin-bottom: @space-2xl);
}

.field:last-child {
  margin-bottom: 0;
}

.field-label {
  display: block;
  font-size: 28rpx;
  color: var(--text-secondary);
  margin-bottom: @space-sm);
  font-weight: 500;
}

.field-label.required::after {
  content: ' *';
  color: var(--error);
}

.input {
  width: 100%;
  height: 96rpx;
  padding: 0 @space-md);
  font-size: 30rpx;
  background: var(--background-input);
  border-radius: 14rpx;
  box-sizing: border-box;
  border: 1px solid var(--border);
  color: var(--text-primary);
  transition: all 0.2s;
}

.input:focus {
  border-color: var(--primary);
  box-shadow: 0 0 0 4rpx var(--primary-light);
}

.input::placeholder {
  color: var(--text-tertiary);
}

.type-input {
  margin-top: @space-sm);
}

/* ====== Linear风格选择器 ====== */
.picker-value {
  height: 96rpx;
  line-height: 96rpx;
  padding: 0 @space-md);
  font-size: 30rpx;
  background: var(--background-input);
  border-radius: 14rpx;
  color: var(--text-primary);
  border: 1px solid var(--border);
  transition: all 0.2s;
  position: relative;
}

.picker-value::after {
  content: '▼';
  position: absolute;
  right: @space-md);
  top: 50%;
  transform: translateY(-50%);
  font-size: 20rpx;
  color: var(--text-tertiary);
}

.picker-value:active {
  background: var(--background-elevated);
  border-color: var(--primary);
}

.picker-value:empty::before,
.picker-value.placeholder {
  color: var(--text-tertiary);
}

/* ====== Linear风格错误提示 ====== */
.error-box {
  margin: @space-lg) 0;
  padding: @space-lg);
  background: var(--error-bg);
  border-radius: 14rpx;
  border: 1px solid rgba(239, 68, 68, 0.2);
  display: flex;
  align-items: center;
  gap: @space-sm);
}

.error-box::before {
  content: '✕';
  font-size: 24rpx;
  width: 32rpx;
  height: 32rpx;
  background: var(--error);
  color: #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.error-text {
  font-size: 28rpx;
  color: var(--error);
  flex: 1;
}

/* ====== Linear风格提交按钮 ====== */
.submit-btn {
  width: 100%;
  margin-top: @space-2xl);
  padding: @space-lg);
  font-size: 32rpx;
  font-weight: 600;
  box-shadow: var(--shadow-glow);
}

/* ====== Linear风格文本域 ====== */
.textarea {
  width: 100%;
  min-height: 200rpx;
  padding: @space-md);
  font-size: 30rpx;
  background: var(--background-input);
  border-radius: 14rpx;
  border: 1px solid var(--border);
  color: var(--text-primary);
  line-height: 1.6;
  box-sizing: border-box;
}

.textarea:focus {
  border-color: var(--primary);
  box-shadow: 0 0 0 4rpx var(--primary-light);
}

/* ====== Linear风格字段组 ====== */
.field-group {
  margin-bottom: @space-2xl);
}

.field-group-title {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--text-secondary);
  margin-bottom: @space-lg);
  letter-spacing: 0.5rpx;
  text-transform: uppercase;
  padding-bottom: @space-sm);
  border-bottom: 1px solid var(--border);
}
