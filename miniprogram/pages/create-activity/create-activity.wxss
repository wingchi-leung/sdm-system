.page {
  min-height: 100vh;
  box-sizing: border-box;
  background: #ffffff;
  color: #111111;
  overflow-x: hidden;
}

.header-pill {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  box-sizing: border-box;
}

.header-pill {
  min-width: 180rpx;
  height: 72rpx;
  padding: 0 20rpx;
  gap: 20rpx;
  border-radius: 999rpx;
  border: 1rpx solid #e5e7eb;
  background: #ffffff;
  box-shadow: none;
}

.header-action--active {
  background: rgba(17, 17, 17, 0.04);
}

.header-pill-dots {
  color: #111111;
  font-size: 32rpx;
  line-height: 1;
  letter-spacing: 2rpx;
  font-weight: 700;
}

.header-pill-divider {
  width: 1rpx;
  height: 28rpx;
  background: #e5e7eb;
}

.header-pill-circle {
  color: #111111;
  font-size: 32rpx;
  line-height: 1;
  font-weight: 500;
}

.content {
  box-sizing: border-box;
}

.content-inner {
  padding: 28rpx 32rpx 280rpx;
  box-sizing: border-box;
}

.field {
  margin-bottom: 56rpx;
}

.poster-upload {
  position: relative;
  width: 100%;
  height: 340rpx;
  overflow: hidden;
  border-radius: 24rpx;
  background: linear-gradient(180deg, #f7f7f7 0%, #eef1f5 100%);
  border: 1rpx solid rgba(17, 17, 17, 0.08);
  box-sizing: border-box;
}

.poster-upload--active {
  opacity: 0.96;
}

.poster-preview {
  width: 100%;
  height: 100%;
  display: block;
}

.poster-placeholder {
  width: 100%;
  height: 100%;
  padding: 34rpx 28rpx;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  justify-content: center;
  gap: 14rpx;
}

.poster-placeholder-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(17, 17, 17, 0.06);
  color: #111111;
  font-size: 44rpx;
  line-height: 1;
  font-weight: 300;
}

.poster-placeholder-text {
  color: #111111;
  font-size: 30rpx;
  line-height: 1.35;
  font-weight: 500;
}

.poster-placeholder-hint {
  max-width: 560rpx;
  color: #8f8f8f;
  font-size: 22rpx;
  line-height: 1.55;
}

.poster-overlay {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 22rpx 24rpx;
  box-sizing: border-box;
  background: linear-gradient(180deg, rgba(255, 255, 255, 0) 0%, rgba(17, 17, 17, 0.36) 100%);
}

.poster-overlay-text {
  color: #ffffff;
  font-size: 24rpx;
  line-height: 1.4;
  letter-spacing: 0.04em;
}

.poster-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 16rpx;
}

.poster-action {
  flex: 1;
  min-height: 72rpx;
  padding: 0 20rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  font-size: 24rpx;
  line-height: 1;
}

.poster-action-primary {
  background: #111111;
  color: #ffffff;
}

.poster-action-ghost {
  background: rgba(17, 17, 17, 0.04);
  color: #111111;
}

.poster-action--active {
  opacity: 0.86;
}

.field-head {
  display: flex;
  align-items: center;
  gap: 10rpx;
  margin-bottom: 16rpx;
}

.field-head-compact {
  margin-top: 20rpx;
  margin-bottom: 10rpx;
}

.field-label {
  color: #111111;
  font-size: 28rpx;
  line-height: 1.4;
  font-weight: 500;
}

.field-required {
  color: #e5483b;
  font-size: 24rpx;
  line-height: 1;
}

.field-counter {
  margin-left: auto;
  color: #9a9a9a;
  font-size: 22rpx;
  line-height: 1.4;
}

.field-counter-inline {
  margin-left: auto;
}

.input {
  width: 100%;
  font-size: 28rpx;
  color: #111111;
  background: transparent;
  border: none;
  box-sizing: border-box;
}

.input-line {
  height: 84rpx;
  padding: 0 0 12rpx;
  border-bottom: 1rpx solid var(--divider);
  border-radius: 0;
}

.input-line-secondary {
  margin-top: 20rpx;
}

.input-placeholder {
  color: #b4b4b4;
}

.picker-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 84rpx;
  padding: 0 0 12rpx;
  border-bottom: 1rpx solid var(--divider);
  box-sizing: border-box;
}

.picker-value {
  font-size: 28rpx;
  color: #111111;
}

.picker-arrow {
  color: #9a9a9a;
  font-size: 30rpx;
  line-height: 1;
  font-weight: 300;
}

.datetime-stack {
  display: flex;
  flex-direction: column;
  gap: 32rpx;
}

.datetime-row {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.datetime-label {
  flex-shrink: 0;
  width: 52rpx;
  color: #666666;
  font-size: 24rpx;
  line-height: 1.4;
}

.datetime-pickers {
  flex: 1;
  display: flex;
  align-items: center;
  gap: 22rpx;
}

.time-chip {
  min-width: 0;
  flex: 1;
  height: 84rpx;
  padding: 0 0 12rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  border-bottom: 1rpx solid var(--divider);
  border-radius: 0;
  background: transparent;
  color: #111111;
  font-size: 26rpx;
  box-sizing: border-box;
}

.time-chip-text {
  flex: 1;
  min-width: 0;
  color: #111111;
  font-size: 26rpx;
  line-height: 1;
}

.time-chip-arrow {
  color: #9a9a9a;
  font-size: 20rpx;
  line-height: 1;
  margin-left: 10rpx;
}

.field-hint {
  display: block;
  margin-top: 14rpx;
  color: #9a9a9a;
  font-size: 22rpx;
  line-height: 1.5;
}

.field-hint-inline {
  margin-top: 6rpx;
}

.switch-row {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
  padding: 4rpx 0;
}

.switch-copy {
  flex: 1;
  min-width: 0;
}

.switch-label {
  display: block;
  color: #111111;
  font-size: 28rpx;
  line-height: 1.4;
  font-weight: 500;
}

.payment-section {
  margin-bottom: 24rpx;
}

.fee-card {
  margin-top: 18rpx;
}

.fee-label {
  display: block;
  color: #666666;
  font-size: 24rpx;
  line-height: 1.4;
  margin-bottom: 10rpx;
}

.fee-input-wrapper {
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.fee-currency {
  color: #111111;
  font-size: 34rpx;
  line-height: 1;
  font-weight: 500;
}

.fee-input {
  flex: 1;
}

.fee-hint {
  display: block;
  margin-top: 10rpx;
  color: #9a9a9a;
  font-size: 22rpx;
  line-height: 1.5;
}

.textarea-card {
  position: relative;
  padding: 0;
  border: 1rpx solid var(--border-light);
  border-radius: 18rpx;
  background: #ffffff;
}

.textarea-input {
  width: 100%;
  min-height: 300rpx;
  padding: 22rpx 22rpx 26rpx;
  box-sizing: border-box;
  color: #111111;
  font-size: 28rpx;
  line-height: 1.75;
}

.textarea-input-compact {
  min-height: 260rpx;
}

.textarea-count {
  position: absolute;
  right: 20rpx;
  bottom: 14rpx;
  color: #9a9a9a;
  font-size: 22rpx;
  line-height: 1;
}

.error-box {
  margin-top: 24rpx;
  padding: 18rpx 20rpx;
  border-radius: 18rpx;
  background: rgba(178, 65, 55, 0.08);
}

.error-text {
  color: #b24137;
  font-size: 24rpx;
  line-height: 1.6;
}

.page-spacer {
  height: 48rpx;
}

.footer-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  justify-content: center;
  padding: 20rpx 32rpx calc(30rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
  background: linear-gradient(180deg, rgba(255, 255, 255, 0), rgba(255, 255, 255, 0.92) 32%, #ffffff 100%);
  border-top: 1rpx solid var(--divider);
}

.footer-btn {
  flex: 1;
  height: 86rpx;
  margin: 0;
  padding: 0 28rpx;
  border-radius: 999rpx;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  box-shadow: 0 12rpx 28rpx rgba(15, 23, 42, 0.04);
}

.footer-btn::after {
  border: none;
}

.footer-btn-primary {
  background: #ffffff;
  border: 1rpx solid rgba(17, 17, 17, 0.12);
  color: #111111;
}

.footer-btn-text {
  color: #111111;
  font-size: 28rpx;
  line-height: 1.35;
  font-weight: 500;
  letter-spacing: 0.06em;
}

.footer-btn-arrow {
  color: #111111;
  font-size: 28rpx;
  line-height: 1;
  font-weight: 300;
  margin-top: -2rpx;
}
