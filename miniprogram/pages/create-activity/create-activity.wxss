/**
 * 创建活动页 - 高级简约风格
 */

.page {
  min-height: 100vh;
  padding: var(--space-xl) var(--space-lg);
  background: var(--background);
}

.form {
  animation: fadeIn 0.4s ease;
}

/* ─────────────────────────────────────────────────────────────
 * 表单字段
 * ───────────────────────────────────────────────────────────── */
.field {
  margin-bottom: var(--space-xl);
}

.field:last-child {
  margin-bottom: 0;
}

.field-label {
  display: block;
  font-size: 22rpx;
  color: var(--text-muted);
  margin-bottom: var(--space-sm);
  font-weight: 500;
  letter-spacing: 0.1em;
  text-transform: uppercase;
}

.input {
  width: 100%;
  height: 88rpx;
  padding: 0;
  font-size: 28rpx;
  background: transparent;
  border: none;
  border-bottom: 1px solid var(--border);
  border-radius: 0;
  box-sizing: border-box;
  color: var(--text-primary);
  transition: border-color 0.3s ease;
  letter-spacing: 0.04em;
}

.input:focus {
  border-bottom-color: var(--text-primary);
}

.input-placeholder {
  color: var(--text-muted);
}

/* ─────────────────────────────────────────────────────────────
 * 选择器
 * ───────────────────────────────────────────────────────────── */
.picker-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 88rpx;
  border-bottom: 1px solid var(--border);
  transition: border-color 0.3s ease;
}

.picker-row:active {
  border-bottom-color: var(--text-tertiary);
}

.picker-value {
  font-size: 28rpx;
  color: var(--text-primary);
  letter-spacing: 0.04em;
}

.picker-arrow {
  font-size: 24rpx;
  color: var(--text-muted);
  font-weight: 300;
}

/* ─────────────────────────────────────────────────────────────
 * 日期时间选择
 * ───────────────────────────────────────────────────────────── */
.datetime-row {
  display: flex;
  gap: var(--space-lg);
}

.datetime-row picker {
  flex: 1;
}

.datetime-row .picker-value {
  height: 88rpx;
  line-height: 88rpx;
  font-size: 26rpx;
  color: var(--text-primary);
  letter-spacing: 0.04em;
  border-bottom: 1px solid var(--border);
  transition: all 0.3s ease;
}

/* ─────────────────────────────────────────────────────────────
 * 错误提示
 * ───────────────────────────────────────────────────────────── */
.error-box {
  margin: var(--space-lg) 0;
  padding: var(--space-md);
  background: var(--error-bg);
  border-left: 2px solid var(--error);
}

.error-text {
  font-size: 24rpx;
  color: var(--error);
  letter-spacing: 0.02em;
}

/* ─────────────────────────────────────────────────────────────
 * 提交按钮
 * ───────────────────────────────────────────────────────────── */
.btn-submit {
  width: 100%;
  height: 96rpx;
  background: var(--primary);
  border-radius: 0;
  border: none;
  transition: opacity 0.3s ease;
  margin-top: var(--space-2xl);
}

.btn-submit::after {
  border: none;
}

.btn-submit:active {
  opacity: 0.85;
}

.btn-submit[disabled] {
  opacity: 0.5;
}

.btn-submit .btn-text {
  font-size: 28rpx;
  font-weight: 500;
  color: #FFFFFF;
  letter-spacing: 0.12em;
}

/* ─────────────────────────────────────────────────────────────
 * 支付设置
 * ───────────────────────────────────────────────────────────── */
.payment-section {
  padding-top: var(--space-lg);
  border-top: 1px solid var(--divider);
}

.payment-header {
  margin-bottom: var(--space-md);
}

.switch-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 88rpx;
  border-bottom: 1px solid var(--border);
}

.switch-label {
  font-size: 28rpx;
  color: var(--text-primary);
  letter-spacing: 0.04em;
}

.fee-input-section {
  margin-top: var(--space-lg);
}

.fee-label {
  display: block;
  font-size: 24rpx;
  color: var(--text-muted);
  margin-bottom: var(--space-sm);
  letter-spacing: 0.02em;
}

.fee-input-wrapper {
  display: flex;
  align-items: center;
}

.fee-currency {
  font-size: 32rpx;
  font-weight: 500;
  color: var(--text-primary);
  margin-right: var(--space-sm);
}

.fee-input {
  flex: 1;
}

.fee-hint {
  display: block;
  font-size: 22rpx;
  color: var(--text-tertiary);
  margin-top: var(--space-xs);
  letter-spacing: 0.02em;
}