.page {
  min-height: 100vh;
  box-sizing: border-box;
  padding: calc(env(safe-area-inset-top) + 18rpx) 28rpx calc(48rpx + env(safe-area-inset-bottom));
  background: #ffffff;
}

.topbar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  min-height: 84rpx;
}

.topbar-left {
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #111111;
}

.back-icon {
  font-size: 56rpx;
  line-height: 1;
  font-weight: 300;
}

.topbar-title {
  flex: 1;
  color: #111111;
  font-size: 32rpx;
  line-height: 1;
  font-weight: 500;
  text-align: center;
  letter-spacing: 0.04em;
}

.topbar-actions {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  gap: 14rpx;
  min-width: 150rpx;
}

.topbar-pill {
  height: 60rpx;
  padding: 0 20rpx;
  border-radius: 999rpx;
  border: 1rpx solid rgba(17, 17, 17, 0.12);
  background: rgba(255, 255, 255, 0.9);
  display: flex;
  align-items: center;
  justify-content: center;
}

.topbar-pill-text {
  color: #111111;
  font-size: 22rpx;
  line-height: 1;
}

.topbar-menu {
  position: relative;
  width: 72rpx;
  height: 72rpx;
  border-radius: 999rpx;
  border: 1rpx solid rgba(17, 17, 17, 0.08);
  display: flex;
  align-items: center;
  justify-content: center;
}

.topbar-menu-dots {
  color: #111111;
  font-size: 26rpx;
  line-height: 1;
  letter-spacing: 0.04em;
  transform: translateY(-2rpx);
}

.topbar-menu-ring {
  position: absolute;
  right: 10rpx;
  width: 18rpx;
  height: 18rpx;
  border-radius: 999rpx;
  border: 4rpx solid #111111;
  box-sizing: border-box;
}

.hero {
  position: relative;
  overflow: hidden;
  min-height: 560rpx;
  margin-top: 6rpx;
  border-radius: 28rpx;
  background: #ffffff;
}

.hero-bg {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  opacity: 0.92;
}

.hero-mask {
  position: absolute;
  inset: 0;
  background:
    linear-gradient(180deg, rgba(255, 255, 255, 0.88) 0%, rgba(255, 255, 255, 0.68) 38%, rgba(255, 255, 255, 0.94) 100%),
    radial-gradient(circle at 18% 18%, rgba(255, 255, 255, 0.6) 0%, rgba(255, 255, 255, 0) 26%);
}

.hero-copy {
  position: absolute;
  left: 14rpx;
  top: 122rpx;
  z-index: 2;
}

.hero-title {
  display: block;
  color: #111111;
  font-size: 60rpx;
  line-height: 1.08;
  font-weight: 300;
  letter-spacing: 0.08em;
  font-family: "Songti SC", "STSong", "Times New Roman", serif;
}

.hero-subtitle {
  display: block;
  margin-top: 18rpx;
  color: #7a7a7a;
  font-size: 32rpx;
  line-height: 1.45;
  font-weight: 300;
  letter-spacing: 0.02em;
}

.state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  text-align: center;
}

.state-loading {
  min-height: 32vh;
}

.state-error {
  min-height: 32vh;
}

.state-empty-title {
  color: #111111;
  font-size: 34rpx;
  line-height: 1.4;
  font-weight: 500;
}

.state-text {
  margin-top: 12rpx;
  color: #888888;
  font-size: 24rpx;
  line-height: 1.7;
}

.empty-state {
  min-height: 58vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 10rpx 0 24rpx;
}

.empty-orbit {
  position: relative;
  width: 360rpx;
  height: 360rpx;
  margin-bottom: 28rpx;
}

.empty-orbit-dot {
  position: absolute;
  border-radius: 999rpx;
  box-sizing: border-box;
}

.empty-orbit-dot-big {
  left: 50%;
  top: 50%;
  width: 54rpx;
  height: 54rpx;
  margin-left: -27rpx;
  margin-top: -27rpx;
  background: #111111;
}

.empty-orbit-dot-outline {
  left: 74rpx;
  top: 132rpx;
  width: 34rpx;
  height: 34rpx;
  border: 2rpx solid rgba(17, 17, 17, 0.75);
  background: transparent;
}

.empty-orbit-dot-solid {
  right: 104rpx;
  top: 70rpx;
  width: 62rpx;
  height: 62rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.9);
  background: #cfcfcf;
}

.empty-orbit-dot-small {
  left: 138rpx;
  top: 88rpx;
  width: 12rpx;
  height: 12rpx;
  background: #c5c5c5;
}

.empty-orbit-dot-tiny {
  right: 128rpx;
  bottom: 78rpx;
  width: 10rpx;
  height: 10rpx;
  background: #bfbfbf;
}

.empty-title {
  color: #777777;
  font-size: 38rpx;
  line-height: 1.35;
  font-weight: 400;
  letter-spacing: 0.03em;
  font-family: "Songti SC", "STSong", "Times New Roman", serif;
}

.empty-divider {
  width: 108rpx;
  height: 2rpx;
  margin: 26rpx 0 30rpx;
  background: rgba(17, 17, 17, 0.15);
}

.empty-hint {
  color: #7e7e7e;
  font-size: 28rpx;
  line-height: 1.6;
  letter-spacing: 0.04em;
}

.list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-top: 20rpx;
}

.item {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  padding: 24rpx 0 28rpx;
  border-bottom: 1rpx solid rgba(17, 17, 17, 0.08);
}

.item.unread {
  border-bottom-color: rgba(17, 17, 17, 0.14);
}

.item-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.item-title-wrap {
  flex: 1;
  min-width: 0;
  display: flex;
  align-items: flex-start;
  gap: 10rpx;
}

.unread-dot {
  width: 14rpx;
  height: 14rpx;
  margin-top: 14rpx;
  border-radius: 999rpx;
  background: #111111;
  flex-shrink: 0;
}

.item-title {
  flex: 1;
  min-width: 0;
  color: #111111;
  font-size: 32rpx;
  line-height: 1.4;
  font-weight: 500;
}

.item-labels {
  display: flex;
  flex-wrap: wrap;
  justify-content: flex-end;
  gap: 8rpx;
}

.type-pill,
.state-pill {
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  font-size: 20rpx;
  line-height: 1.25;
}

.type-pill {
  background: rgba(17, 17, 17, 0.04);
  color: #606060;
}

.state-pill {
  border: 1rpx solid rgba(17, 17, 17, 0.06);
  background: #ffffff;
  color: #8a8a8a;
}

.state-pill.success {
  border-color: rgba(17, 17, 17, 0.08);
  background: rgba(17, 17, 17, 0.04);
  color: #606060;
}

.state-pill.warning {
  border-color: rgba(17, 17, 17, 0.08);
  background: rgba(17, 17, 17, 0.04);
  color: #6f6f6f;
}

.state-pill.muted {
  border-color: rgba(17, 17, 17, 0.06);
  background: rgba(17, 17, 17, 0.02);
  color: #8a8a8a;
}

.item-content {
  color: #5f5f5f;
  font-size: 24rpx;
  line-height: 1.7;
}

.meta-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.meta-text {
  color: #9a9a9a;
  font-size: 22rpx;
  line-height: 1.5;
}

.item-actions {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.btn {
  min-height: 62rpx;
  height: 62rpx;
  padding: 0 22rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  line-height: 1;
}

.btn::after {
  border: 0;
}

.btn-primary {
  background: #111111;
  color: #ffffff;
  border: 1rpx solid #111111;
}

.btn-ghost {
  background: #ffffff;
  color: #111111;
  border: 1rpx solid rgba(17, 17, 17, 0.12);
}
