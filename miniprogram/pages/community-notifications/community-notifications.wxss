.page {
  min-height: 100vh;
  box-sizing: border-box;
  padding: 28rpx 28rpx 48rpx;
  background: linear-gradient(180deg, #f5f7fb 0%, #ffffff 36%);
}

.header {
  margin-bottom: 24rpx;
  padding: 32rpx;
  background: #ffffff;
  border: 1px solid rgba(17, 17, 17, 0.06);
  border-radius: 28rpx;
  box-shadow: 0 16rpx 40rpx rgba(15, 26, 23, 0.05) !important;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.header-copy {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.eyebrow {
  color: #7c8794;
  font-size: 20rpx;
  line-height: 1.4;
  font-weight: 600;
  letter-spacing: 0.22em;
}

.title {
  color: #111111;
  font-family: var(--font-display);
  font-size: 42rpx;
  line-height: 1.2;
  font-weight: 600;
}

.subtitle {
  color: #6b7280;
  font-size: 26rpx;
  line-height: 1.7;
}

.header-actions {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 12rpx;
}

.count-pill {
  height: 56rpx;
  padding: 0 20rpx;
  border-radius: 999rpx;
  background: rgba(17, 24, 39, 0.06);
  color: #111827;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  font-weight: 600;
}

.read-all-btn {
  min-height: 56rpx;
  height: 56rpx;
  padding: 0 22rpx;
  border-radius: 999rpx;
  background: #111827;
  color: #ffffff;
  border: 1px solid #111827;
  font-size: 22rpx;
  font-weight: 500;
  line-height: 1;
}

.read-all-btn::after {
  border: 0;
}

.state {
  padding: 72rpx 12rpx;
  text-align: center;
  color: #7a7f87;
  font-size: 26rpx;
}

.list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.item {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
  padding: 24rpx;
  background: #ffffff;
  border: 1px solid rgba(17, 17, 17, 0.06);
  border-radius: 24rpx;
  box-shadow: 0 12rpx 32rpx rgba(15, 26, 23, 0.04) !important;
}

.item.unread {
  border-color: rgba(17, 24, 39, 0.16);
  box-shadow: 0 16rpx 36rpx rgba(17, 24, 39, 0.05) !important;
}

.item:active {
  transform: translateY(1rpx);
}

.item-top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.item-title-wrap {
  flex: 1;
  min-width: 0;
  display: flex;
  align-items: flex-start;
  gap: 10rpx;
}

.unread-dot {
  width: 16rpx;
  height: 16rpx;
  margin-top: 12rpx;
  border-radius: 50%;
  background: #111827;
  flex-shrink: 0;
}

.item-title {
  flex: 1;
  min-width: 0;
  color: #111111;
  font-size: 32rpx;
  line-height: 1.4;
  font-weight: 600;
}

.item-labels {
  display: flex;
  flex-wrap: wrap;
  justify-content: flex-end;
  gap: 8rpx;
}

.type-pill,
.state-pill {
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  font-size: 20rpx;
  line-height: 1.3;
  font-weight: 500;
}

.type-pill {
  background: #f4f6f8;
  color: #374151;
}

.state-pill {
  background: #fafafa;
  color: #6b7280;
  border: 1px solid rgba(17, 17, 17, 0.05);
}

.state-pill.success {
  background: rgba(39, 174, 96, 0.08);
  color: #1f7a45;
  border-color: rgba(39, 174, 96, 0.12);
}

.state-pill.warning {
  background: rgba(245, 158, 11, 0.1);
  color: #9a6700;
  border-color: rgba(245, 158, 11, 0.14);
}

.state-pill.muted {
  background: rgba(107, 114, 128, 0.08);
  color: #6b7280;
  border-color: rgba(107, 114, 128, 0.12);
}

.item-content {
  color: #475467;
  font-size: 24rpx;
  line-height: 1.7;
}

.meta-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.meta-text {
  color: #8c93a0;
  font-size: 22rpx;
  line-height: 1.5;
}

.row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.btn {
  min-height: 64rpx;
  height: 64rpx;
  padding: 0 22rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  font-weight: 500;
  line-height: 1;
}

.btn::after {
  border: 0;
}

.btn.primary {
  background: #111827;
  color: #ffffff;
  border: 1px solid #111827;
}

.btn.ghost {
  background: #ffffff;
  color: #111827;
  border: 1px solid rgba(17, 24, 39, 0.12);
}
