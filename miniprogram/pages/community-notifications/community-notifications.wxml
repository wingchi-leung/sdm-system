<view class="page">
  <page-header title="消息"></page-header>

  <view class="hero">
    <image class="hero-bg" src="/assets/communtiy_banner.png" mode="aspectFill" />
    <view class="hero-mask"></view>

    <view class="hero-actions">
      <view wx:if="{{unreadCount > 0}}" class="count-pill" bindtap="onReadAll">
        <text class="count-pill-text">全部已读</text>
      </view>
     
    </view>

    <view class="hero-copy">
      <text class="hero-title">收件箱</text>
      <text class="hero-subtitle">Inbox.</text>
    </view>
  </view>

  <view wx:if="{{loading}}" class="state state-loading">
    <text class="state-text">加载中…</text>
  </view>

  <view wx:elif="{{error}}" class="state state-error">
    <text class="state-empty-title">暂时无法查看消息</text>
    <text class="state-text">{{error}}</text>
  </view>

  <view wx:elif="{{items.length === 0}}" class="empty-state">
    <view class="empty-orbit">
      <view class="empty-orbit-dot empty-orbit-dot-big"></view>
      <view class="empty-orbit-dot empty-orbit-dot-outline"></view>
      <view class="empty-orbit-dot empty-orbit-dot-solid"></view>
      <view class="empty-orbit-dot empty-orbit-dot-small"></view>
      <view class="empty-orbit-dot empty-orbit-dot-tiny"></view>
    </view>
    <text class="empty-title">Nothing here yet.</text>
    <view class="empty-divider"></view>
    <text class="empty-hint">新的邀请与提醒</text>
    <text class="empty-hint">将在这里出现</text>
  </view>

  <view wx:else class="list">
    <view
      wx:for="{{items}}"
      wx:key="id"
      class="item {{item.is_unread ? 'unread' : ''}}"
      data-item="{{item}}"
      bindtap="onOpenNotification"
    >
      <view class="item-head">
        <view class="item-title-wrap">
          <view wx:if="{{item.is_unread}}" class="unread-dot"></view>
          <text class="item-title">{{item.title}}</text>
        </view>
        <view class="item-labels">
          <text class="type-pill">{{item.type_label}}</text>
          <text wx:if="{{item.status_label}}" class="state-pill {{item.status_class}}">{{item.status_label}}</text>
        </view>
      </view>

      <text wx:if="{{item.content}}" class="item-content">{{item.content}}</text>

      <view class="meta-row">
        <text wx:if="{{item.time_display}}" class="meta-text">{{item.time_display}}</text>
        <text wx:if="{{item.channel_name}}" class="meta-text">{{item.channel_name}}</text>
        <text wx:elif="{{item.inviter_name}}" class="meta-text">{{item.inviter_name}}</text>
      </view>

      <view class="item-actions">
        <button wx:if="{{item.can_respond}}" class="btn btn-primary" data-id="{{item.id}}" catchtap="onAccept">接受邀请</button>
        <button wx:if="{{item.can_respond}}" class="btn btn-ghost" data-id="{{item.id}}" catchtap="onReject">拒绝</button>
        <button wx:elif="{{item.has_channel}}" class="btn btn-ghost" data-item="{{item}}" catchtap="onOpenNotification">查看社区</button>
      </view>
    </view>
  </view>
</view>
