<view class="page">
  <page-header title="报名活动"></page-header>


  <view wx:if="{{loading}}" class="state-wrap">
    <view class="loading"></view>
    <text class="state-text">加载中…</text>
  </view>

  <view wx:elif="{{error}}" class="state-wrap">
    <text class="state-title">加载失败</text>
    <text class="state-text">{{error}}</text>
  </view>

  <view wx:elif="{{activities.length}}" class="list">
    <view
      class="activity-card"
      wx:for="{{activities}}"
      wx:key="participant_id"
      data-id="{{item.id}}"
      bindtap="goActivityDetail"
    >
      <image wx:if="{{item.poster_url}}" class="activity-poster" src="{{item.poster_url}}" mode="aspectFill" />
      <view wx:else class="activity-poster placeholder">暂无海报</view>
      <view class="activity-body">
        <view class="activity-head">
          <text class="activity-title">{{item.activity_name}}</text>
          <text class="activity-status {{item.enroll_status_class}}">{{item.enroll_status_text}}</text>
        </view>
        <view class="activity-meta">
          <text class="activity-time">{{item.start_time_display}}</text>
          <text class="activity-location">{{item.location_display}}</text>
        </view>
        <view class="activity-arrow-row">
          <text class="activity-arrow-text">查看详情</text>
          <text class="activity-arrow ui-chevron ui-chevron--md">›</text>
        </view>
      </view>
    </view>
  </view>

  <view wx:else class="state-wrap">
    <text class="state-title">还没有报名活动</text>
    <text class="state-text">报名、支付成功后会在这里看到全部历史活动</text>
  </view>
</view>
