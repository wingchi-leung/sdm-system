.page {
  min-height: 100vh;
  padding: 32rpx;
  background: #FFFFFF;
  box-sizing: border-box;
}

.state-wrap {
  min-height: 62vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  text-align: center;
}

.state-title {
  color: var(--ink);
  font-size: 30rpx;
  line-height: 42rpx;
  font-weight: 500;
}

.state-text {
  margin-top: 12rpx;
  color: #999999;
  font-size: 24rpx;
  line-height: 34rpx;
}

.list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.activity-card {
  overflow: hidden;
  background: #FFFFFF;
  border: 1rpx solid #ECECEC;
  border-radius: 24rpx;
}

.activity-poster {
  width: 100%;
  height: 280rpx;
  display: block;
}

.activity-body {
  padding: 24rpx;
}

.activity-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.activity-title {
  flex: 1;
  color: var(--ink);
  font-size: 30rpx;
  line-height: 42rpx;
  font-weight: 500;
}

.activity-status {
  flex-shrink: 0;
  padding: 8rpx 14rpx;
  color: var(--green);
  font-size: 22rpx;
  line-height: 1;
  background: #F4F8F6;
  border-radius: 999rpx;
}

.activity-time {
  display: block;
  margin-top: 14rpx;
  color: #999999;
  font-size: 24rpx;
  line-height: 34rpx;
}
