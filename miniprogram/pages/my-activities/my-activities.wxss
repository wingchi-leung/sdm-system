.page {
  min-height: 100vh;
  padding: 24rpx 32rpx 120rpx;
  background: #ffffff;
  box-sizing: border-box;
  color: #111111;
  font-family: var(--font-body);
}

.hero {
  margin-bottom: 24rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid var(--divider);
}

.hero-title {
  display: block;
  color: #111111;
  font-size: 44rpx;
  line-height: 56rpx;
  font-weight: 500;
}

.hero-text {
  display: block;
  margin-top: 8rpx;
  color: #999999;
  font-size: 24rpx;
  line-height: 34rpx;
}

.state-wrap {
  min-height: 62vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  text-align: center;
}

.state-title {
  color: #111111;
  font-size: 30rpx;
  line-height: 42rpx;
  font-weight: 500;
}

.state-text {
  margin-top: 12rpx;
  color: #999999;
  font-size: 24rpx;
  line-height: 34rpx;
}

.list {
  display: flex;
  flex-direction: column;
}

.activity-card {
  padding: 0 0 20rpx;
  margin-bottom: 20rpx;
  border-bottom: 1rpx solid var(--divider);
}

.activity-card:last-child {
  margin-bottom: 0;
  border-bottom: none;
}

.activity-poster {
  width: 100%;
  height: 300rpx;
  display: block;
  border-radius: 24rpx;
  background: #f7f7f5;
}

.activity-poster.placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  color: #bbbbbb;
  font-size: 24rpx;
  letter-spacing: 0.08em;
}

.activity-body {
  padding-top: 20rpx;
}

.activity-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.activity-title {
  flex: 1;
  color: #111111;
  font-size: 32rpx;
  line-height: 44rpx;
  font-weight: 500;
}

.activity-status {
  flex-shrink: 0;
  padding: 6rpx 12rpx;
  color: #111111;
  font-size: 22rpx;
  line-height: 32rpx;
  background: rgba(17, 17, 17, 0.05);
  border-radius: 999rpx;
}

.activity-status.is-waiting,
.activity-status.is-pending {
  background: rgba(17, 17, 17, 0.05);
}

.activity-meta {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  margin-top: 14rpx;
}

.activity-time,
.activity-location {
  display: block;
  color: #999999;
  font-size: 24rpx;
  line-height: 34rpx;
}

.activity-arrow-row {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  margin-top: 14rpx;
  color: #111111;
}

.activity-arrow-text {
  font-size: 24rpx;
  line-height: 34rpx;
}

.activity-arrow {
  color: inherit;
}
