.page {
  min-height: 100vh;
  padding: 32rpx;
  background: #FFFFFF;
  box-sizing: border-box;
}

.hero {
  margin-bottom: 24rpx;
  padding: 28rpx;
  background: #F7FAF8;
  border: 1rpx solid #E8EEEA;
  border-radius: 24rpx;
}

.hero-title {
  display: block;
  color: var(--ink);
  font-size: 36rpx;
  line-height: 48rpx;
  font-weight: 500;
}

.hero-text {
  display: block;
  margin-top: 8rpx;
  color: #999999;
  font-size: 24rpx;
  line-height: 34rpx;
}

.state-wrap {
  min-height: 62vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  text-align: center;
}

.state-title {
  color: var(--ink);
  font-size: 30rpx;
  line-height: 42rpx;
  font-weight: 500;
}

.state-text {
  margin-top: 12rpx;
  color: #999999;
  font-size: 24rpx;
  line-height: 34rpx;
}

.list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.activity-card {
  overflow: hidden;
  background: #FFFFFF;
  border: 1rpx solid #ECECEC;
  border-radius: 24rpx;
}

.activity-poster {
  width: 100%;
  height: 280rpx;
  display: block;
}

.activity-poster.placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  color: #B7BBB8;
  font-size: 24rpx;
  letter-spacing: 0.12em;
  background: #F7F7F7;
}

.activity-body {
  padding: 24rpx;
}

.activity-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.activity-title {
  flex: 1;
  color: var(--ink);
  font-size: 30rpx;
  line-height: 42rpx;
  font-weight: 500;
}

.activity-status {
  flex-shrink: 0;
  padding: 8rpx 14rpx;
  color: var(--green);
  font-size: 22rpx;
  line-height: 1;
  background: #F4F8F6;
  border-radius: 999rpx;
}

.activity-status.is-waiting {
  color: #9A6700;
  background: #FFF7E6;
}

.activity-meta {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  margin-top: 14rpx;
}

.activity-time,
.activity-location {
  display: block;
  color: #999999;
  font-size: 24rpx;
  line-height: 34rpx;
}

.activity-arrow {
  display: block;
  margin-top: 14rpx;
  color: var(--green);
  font-size: 24rpx;
  line-height: 34rpx;
}
