.page {
  min-height: 100vh;
  padding: 32rpx;
  background: #FFFFFF;
  box-sizing: border-box;
}

.state-wrap {
  min-height: 60vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  text-align: center;
}

.state-title {
  color: var(--ink);
  font-size: 32rpx;
  line-height: 44rpx;
  font-weight: 500;
}

.state-text {
  margin-top: 12rpx;
  color: #999999;
  font-size: 24rpx;
  line-height: 34rpx;
}

.content {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.hero {
  padding: 28rpx;
  background: #F7FAF8;
  border: 1rpx solid #E8EEEA;
  border-radius: 24rpx;
}

.hero-title {
  display: block;
  color: var(--ink);
  font-size: 36rpx;
  line-height: 48rpx;
  font-weight: 500;
}

.hero-text {
  display: block;
  margin-top: 8rpx;
  color: #999999;
  font-size: 24rpx;
  line-height: 34rpx;
}

.preview-card {
  padding: 32rpx 24rpx;
  background: #FFFFFF;
  border: 1rpx solid #ECECEC;
  border-radius: 24rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.preview-avatar {
  width: 180rpx;
  height: 180rpx;
  border-radius: 50%;
  background: #F7F7F7;
}

.preview-hint {
  margin-top: 16rpx;
  color: #999999;
  font-size: 24rpx;
  line-height: 34rpx;
}

.section-title {
  display: block;
  margin-bottom: 16rpx;
  color: var(--ink);
  font-size: 28rpx;
  line-height: 40rpx;
  font-weight: 500;
}

.avatar-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 16rpx;
}

.avatar-option {
  padding: 8rpx;
  border: 2rpx solid #ECECEC;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #FFFFFF;
}

.avatar-option.active {
  border-color: #2F4F46;
  box-shadow: 0 0 0 4rpx rgba(47, 79, 70, 0.08);
}

.avatar-image {
  width: 112rpx;
  height: 112rpx;
  border-radius: 50%;
}

.upload-card {
  padding: 24rpx;
  border: 1rpx solid #ECECEC;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.upload-info {
  flex: 1;
  min-width: 0;
}

.upload-title {
  display: block;
  color: var(--ink);
  font-size: 28rpx;
  line-height: 40rpx;
}

.upload-text {
  display: block;
  margin-top: 6rpx;
  color: #999999;
  font-size: 24rpx;
  line-height: 34rpx;
}

.upload-btn,
.save-btn {
  border: 0;
  border-radius: 16rpx;
  background: #2F4F46;
  color: #FFFFFF;
  font-size: 28rpx;
}

.upload-btn {
  min-width: 176rpx;
  height: 76rpx;
  margin: 0;
  padding: 0 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.upload-btn::after,
.save-btn::after {
  border: 0;
}

.error-box {
  padding: 20rpx 24rpx;
  border-radius: 16rpx;
  background: #FEF3F2;
}

.error-text {
  color: #B42318;
  font-size: 24rpx;
  line-height: 34rpx;
}

.save-btn {
  width: 100%;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
