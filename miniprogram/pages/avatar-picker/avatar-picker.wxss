.page {
  min-height: 100vh;
  padding: 24rpx 32rpx;
  background: #ffffff;
  box-sizing: border-box;
  color: #111111;
  font-family: "PingFang SC", -apple-system, BlinkMacSystemFont, "Helvetica Neue", sans-serif;
}

.state-wrap {
  min-height: 60vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  text-align: center;
}

.state-title {
  color: #111111;
  font-size: 32rpx;
  line-height: 44rpx;
  font-weight: 500;
}

.state-text {
  margin-top: 12rpx;
  color: #999999;
  font-size: 24rpx;
  line-height: 34rpx;
}

.content {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.preview-card {
  padding: 32rpx 24rpx 28rpx;
  background: #ffffff;
  border: 1rpx solid var(--border-light);
  border-radius: 28rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.preview-shell {
  width: 228rpx;
  height: 228rpx;
  border-radius: 50%;
  background: #f7f7f5;
  border: 1rpx solid var(--border-light);
  display: flex;
  align-items: center;
  justify-content: center;
}

.preview-avatar-wrap {
  width: 188rpx;
  height: 188rpx;
  border-radius: 50%;
  overflow: hidden;
}

.preview-avatar {
  width: 100%;
  height: 100%;
  background: #f7f7f7;
}

.section-title {
  display: block;
  margin-bottom: 16rpx;
  color: #111111;
  font-size: 28rpx;
  line-height: 40rpx;
  font-weight: 500;
}

.avatar-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 16rpx;
}

.avatar-option {
  padding: 10rpx;
  border: 1rpx solid var(--border-light);
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #ffffff;
  transition: transform 0.2s ease, border-color 0.2s ease;
}

.avatar-option.active {
  border-color: #111111;
}

.avatar-option:active {
  transform: scale(0.97);
}

.avatar-image {
  width: 112rpx;
  height: 112rpx;
  border-radius: 50%;
}

.upload-card {
  padding: 22rpx 24rpx;
  border: 1rpx solid var(--border-light);
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  background: #ffffff;
}

.upload-copy {
  flex: 1;
  min-width: 0;
}

.upload-title {
  display: block;
  color: #111111;
  font-size: 26rpx;
  line-height: 38rpx;
  font-weight: 500;
}

.upload-text {
  display: block;
  margin-top: 4rpx;
  color: #999999;
  font-size: 22rpx;
  line-height: 32rpx;
}

.upload-btn,
.save-btn {
  border: 0;
  border-radius: 999rpx;
  color: #ffffff;
  font-size: 28rpx;
  overflow: hidden;
}

.upload-btn {
  min-width: 132rpx;
  height: 56rpx;
  margin: 0;
  padding: 0 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #111111;
}

.upload-btn::after,
.save-btn::after {
  border: 0;
}

.upload-btn:active,
.save-btn:active {
  opacity: 0.9;
}

.upload-btn-label,
.save-btn-label {
  display: block;
  font-size: 24rpx;
  line-height: 1;
  font-weight: 500;
}

.error-box {
  padding: 16rpx 18rpx;
  border-radius: 16rpx;
  background: var(--error-bg);
}

.error-text {
  color: var(--error);
  font-size: 24rpx;
  line-height: 34rpx;
}

.save-btn {
  min-width: 224rpx;
  width: auto;
  height: 68rpx;
  padding: 0 34rpx;
  margin: 8rpx auto 0;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #111111;
}

.save-btn[disabled] {
  opacity: 0.6;
}

