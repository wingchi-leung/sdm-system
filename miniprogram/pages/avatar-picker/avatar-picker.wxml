<view class="page">
  <page-header title="头像" autoBack="{{false}}" bindback="onCancel"></page-header>

  <view wx:if="{{loading}}" class="state-wrap">
    <view class="loading"></view>
    <text class="state-text">加载中…</text>
  </view>

  <view wx:elif="{{error && !currentAvatarDisplayUrl}}" class="state-wrap">
    <text class="state-title">加载失败</text>
    <text class="state-text">{{error}}</text>
  </view>

  <view wx:else class="content">
    <view class="panel">
      <view class="status-pill" aria-hidden="true"></view>
      <view class="avatar-stage">
        <view class="avatar-frame">
          <image
            class="avatar-image"
            src="{{selectedAvatarDisplayUrl || currentAvatarDisplayUrl}}"
            mode="aspectFill"
            bindtap="onPreviewTap"
          />
        </view>
      </view>

      <button class="swap-btn" bindtap="onChooseAvatar" loading="{{choosing}}" disabled="{{choosing || saving}}">
        <text class="swap-btn-text">{{selectedAvatarTempPath ? '重新修改头像' : '修改头像'}}</text>
      </button>

      <view wx:if="{{error}}" class="error">
        <text class="error-text">{{error}}</text>
      </view>
    </view>

    <view class="footer">
      <text class="cancel-btn" bindtap="onCancel">取消</text>
      <button class="preview-btn" bindtap="onPreviewTap">
        <text class="preview-btn-text">预览</text>
      </button>
      <button class="confirm-btn" bindtap="onSave" loading="{{saving}}" disabled="{{choosing || saving}}">
        <text class="confirm-btn-text">{{saving ? '保存中' : '确定'}}</text>
      </button>
    </view>
  </view>
</view>
