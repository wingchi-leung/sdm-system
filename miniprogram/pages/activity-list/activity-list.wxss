.container {
  padding: 20rpx;
  background: #f5f5f5;
  min-height: 100vh;
}

.loading, .empty {
  text-align: center;
  padding: 100rpx 0;
  color: #999;
}

.activity-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.activity-item {
  background: #fff;
  border-radius: 12rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.05);
}

.activity-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.activity-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.activity-status {
  font-size: 24rpx;
  font-weight: 500;
}

.activity-info {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 8rpx;
}

.info-label {
  color: #999;
}

.activity-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid #eee;
}

.action-btn {
  flex: 1;
  font-size: 26rpx;
}

.action-btn.delete {
  color: #ef4444;
  border-color: #ef4444;
}