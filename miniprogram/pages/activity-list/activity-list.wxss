/**
 * 活动列表页 - 单列大卡片样式
 */

.page {
  min-height: 100vh;
  padding: 24rpx 24rpx;
  background: #f5f5f5;
  box-sizing: border-box;
}

/* ─────────────────────────────────────────────────────────────
 * 状态页面
 * ───────────────────────────────────────────────────────────── */
.state-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 60vh;
}

.loading {
  width: 40rpx;
  height: 40rpx;
  border: 3rpx solid #ddd;
  border-top-color: #1890ff;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.state-text {
  font-size: 28rpx;
  color: #999;
  margin-top: 20rpx;
}

.state-title {
  font-size: 32rpx;
  font-weight: 500;
  color: #333;
  margin-top: 24rpx;
}

/* ─────────────────────────────────────────────────────────────
 * 空状态插画
 * ───────────────────────────────────────────────────────────── */
.empty-illustration {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.empty-circle {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: #eee;
  margin-bottom: 16rpx;
}

.empty-line {
  width: 140rpx;
  height: 4rpx;
  background: #ddd;
  margin-bottom: 12rpx;
}

.empty-line.short {
  width: 100rpx;
}

/* ─────────────────────────────────────────────────────────────
 * 活动列表 - 单列大卡片
 * ───────────────────────────────────────────────────────────── */
.list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.activity-item {
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
}

.activity-item:active {
  opacity: 0.9;
}

/* 海报区域 - 大图展示 */
.item-poster {
  width: 100%;
  height: 400rpx;
  background: #f0f0f0;
  position: relative;
}

.poster-img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

/* 无海报时的占位 */
.item-poster .no-poster {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #bbb;
  font-size: 28rpx;
}

/* 内容区 */
.item-content {
  padding: 24rpx;
}

/* 头部 - 名称 + 状态 */
.item-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 16rpx;
}

.item-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  flex: 1;
  line-height: 1.4;
  margin-right: 16rpx;
}

/* 状态标签 */
.status-tag {
  font-size: 24rpx;
  font-weight: 500;
  padding: 8rpx 16rpx;
  border-radius: 8rpx;
  flex-shrink: 0;
}

.status-tag.status-1 {
  color: #1890ff;
  background: #e6f7ff;
}

.status-tag.status-2 {
  color: #52c41a;
  background: #f6ffed;
}

.status-tag.status-3 {
  color: #8c8c8c;
  background: #f5f5f5;
}

/* 信息行 */
.item-info {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.info-row {
  display: flex;
  align-items: center;
  font-size: 26rpx;
}

.info-icon {
  font-size: 20rpx;
  color: #1890ff;
  margin-right: 12rpx;
}

.info-icon.location {
  color: #52c41a;
}

.info-value {
  color: #666;
}

/* ─────────────────────────────────────────────────────────────
 * 加载更多状态
 * ───────────────────────────────────────────────────────────── */
.load-more-wrap {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx 0;
}

.loading-more {
  width: 32rpx;
  height: 32rpx;
  border: 2rpx solid #ddd;
  border-top-color: #1890ff;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

.load-more-text {
  font-size: 26rpx;
  color: #999;
  margin-left: 12rpx;
}

.no-more-wrap {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx 0;
}

.no-more-text {
  font-size: 26rpx;
  color: #999;
}