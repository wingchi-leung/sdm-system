/**
 * 活动列表页 - 高级简约风格
 */

.page {
  min-height: 100vh;
  padding: var(--space-xl) var(--space-lg);
  background: var(--background);
}

/* ─────────────────────────────────────────────────────────────
 * 状态页面
 * ───────────────────────────────────────────────────────────── */
.state-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 60vh;
}

.state-text {
  font-size: 24rpx;
  color: var(--text-tertiary);
  margin-top: var(--space-md);
  letter-spacing: 0.04em;
}

.state-title {
  font-family: var(--font-display);
  font-size: 32rpx;
  font-weight: 500;
  color: var(--text-primary);
  margin-top: var(--space-lg);
  letter-spacing: 0.04em;
}

/* ─────────────────────────────────────────────────────────────
 * 空状态插画
 * ───────────────────────────────────────────────────────────── */
.empty-illustration {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.empty-circle {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: var(--background-subtle);
  border: 1px solid var(--border);
  margin-bottom: var(--space-md);
}

.empty-line {
  width: 120rpx;
  height: 2rpx;
  background: var(--border);
  margin-bottom: var(--space-sm);
}

.empty-line.short {
  width: 80rpx;
}

/* ─────────────────────────────────────────────────────────────
 * 活动列表
 * ───────────────────────────────────────────────────────────── */
.list {
  display: flex;
  flex-direction: column;
}

.activity-item {
  padding: var(--space-lg) 0;
  border-bottom: 1px solid var(--divider);
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  opacity: 0;
}

.activity-item:active {
  background: var(--background-subtle);
  margin: 0 calc(-1 * var(--space-lg));
  padding-left: var(--space-lg);
  padding-right: var(--space-lg);
}

/* 头部 */
.item-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: var(--space-sm);
}

.item-name {
  font-size: 28rpx;
  font-weight: 500;
  color: var(--text-primary);
  letter-spacing: 0.04em;
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  margin-right: var(--space-md);
}

/* 状态标签 */
.status-tag {
  font-size: 20rpx;
  font-weight: 500;
  padding: 4rpx 12rpx;
  letter-spacing: 0.08em;
  flex-shrink: 0;
  text-transform: uppercase;
}

.status-tag.status-1 {
  color: var(--status-not-started);
}

.status-tag.status-2 {
  color: var(--status-ongoing);
}

.status-tag.status-3 {
  color: var(--status-ended);
}

/* 信息行 */
.item-info {
  font-size: 24rpx;
  color: var(--text-tertiary);
  margin-bottom: var(--space-xs);
  letter-spacing: 0.02em;
}

.info-label {
  color: var(--text-muted);
}

.info-value {
  color: var(--text-secondary);
}

/* ─────────────────────────────────────────────────────────────
 * 管理员工具栏 - 精致克制
 * ───────────────────────────────────────────────────────────── */
.admin-toolbar {
  margin-top: var(--space-lg);
  padding-top: var(--space-md);
  border-top: 1px solid var(--divider);
}

.toolbar-inner {
  display: flex;
  align-items: center;
  background: var(--background-subtle);
  border-radius: var(--radius-lg);
  overflow: hidden;
}

.toolbar-btn {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: var(--space-md) var(--space-lg);
  background: transparent;
  border: none;
  border-radius: 0;
  transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
  position: relative;
}

.toolbar-btn::after {
  border: none;
}

.toolbar-btn:active {
  transform: scale(0.97);
}

.btn-icon {
  width: 44rpx;
  height: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: var(--space-xs);
  transition: transform 0.25s ease;
}

.toolbar-btn:active .btn-icon {
  transform: scale(0.9);
}

.btn-label {
  font-size: 22rpx;
  font-weight: 500;
  letter-spacing: 0.1em;
  transition: color 0.25s ease;
}

/* 编辑按钮 */
.toolbar-btn.edit {
  color: var(--primary);
}

.toolbar-btn.edit:active {
  background: var(--primary-light);
}

.toolbar-btn.edit .btn-label {
  color: var(--text-secondary);
}

.toolbar-btn.edit:active .btn-label {
  color: var(--primary);
}

/* 删除按钮 */
.toolbar-btn.delete {
  color: var(--error);
}

.toolbar-btn.delete:active {
  background: var(--error-bg);
}

.toolbar-btn.delete .btn-label {
  color: var(--text-secondary);
}

.toolbar-btn.delete:active .btn-label {
  color: var(--error);
}

/* 分隔线 */
.toolbar-divider {
  width: 1px;
  height: 48rpx;
  background: linear-gradient(
    to bottom,
    transparent,
    var(--border) 20%,
    var(--border) 80%,
    transparent
  );
  flex-shrink: 0;
}

/* ─────────────────────────────────────────────────────────────
 * 纯 CSS 图标
 * ───────────────────────────────────────────────────────────── */
/* 编辑图标 - 铅笔 */
.icon-edit {
  width: 28rpx;
  height: 28rpx;
  border: 2rpx solid var(--primary);
  border-radius: 2rpx;
  position: relative;
  transform: rotate(-45deg);
}

.icon-edit::before {
  content: '';
  position: absolute;
  bottom: 4rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 4rpx;
  height: 12rpx;
  background: var(--primary);
  border-radius: 1rpx;
}

/* 删除图标 - 垃圾桶 */
.icon-delete {
  width: 26rpx;
  height: 28rpx;
  border: 2rpx solid var(--error);
  border-radius: 2rpx 2rpx 4rpx 4rpx;
  border-top: none;
  position: relative;
}

.icon-delete::before {
  content: '';
  position: absolute;
  top: -10rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 16rpx;
  height: 6rpx;
  border: 2rpx solid var(--error);
  border-radius: 2rpx 2rpx 0 0;
  border-bottom: none;
}

.icon-delete::after {
  content: '';
  position: absolute;
  top: 4rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 10rpx;
  height: 2rpx;
  background: var(--error);
  opacity: 0.4;
  border-radius: 1rpx;
}

/* ─────────────────────────────────────────────────────────────
 * 加载更多状态
 * ───────────────────────────────────────────────────────────── */
.load-more-wrap {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: var(--space-xl) 0;
}

.loading-more {
  width: 32rpx;
  height: 32rpx;
  border: 2rpx solid var(--border);
  border-top-color: var(--primary);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.load-more-text {
  font-size: 24rpx;
  color: var(--text-tertiary);
  margin-left: var(--space-sm);
  letter-spacing: 0.04em;
}

.no-more-wrap {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: var(--space-xl) 0;
}

.no-more-text {
  font-size: 24rpx;
  color: var(--text-tertiary);
  letter-spacing: 0.04em;
}