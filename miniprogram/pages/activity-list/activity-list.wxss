.page {
  min-height: 100vh;
  padding: 28rpx 32rpx 140rpx;
  background: #FFFFFF;
  box-sizing: border-box;
}

.state-wrap {
  min-height: 62vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 40rpx;
}

.loading,
.loading-more {
  width: 42rpx;
  height: 42rpx;
  border: 2rpx solid var(--line);
  border-top-color: var(--green);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.state-title {
  margin-top: 18rpx;
  color: var(--ink);
  font-size: 32rpx;
  font-weight: 400;
  letter-spacing: 0.04em;
}

.state-text {
  margin-top: 14rpx;
  color: var(--text-soft);
  font-size: 24rpx;
  letter-spacing: 0.04em;
}

.empty-image {
  width: 220rpx;
  height: 260rpx;
}

.list {
  display: flex;
  flex-direction: column;
  gap: 34rpx;
}

.activity-item {
  overflow: hidden;
  background: #FFFFFF;
  box-shadow: none;
}

.activity-item:active {
  transform: translateY(2rpx);
}

.item-poster {
  width: 100%;
  height: 350rpx;
  background: #F4F4F2;
  position: relative;
}

.poster-img {
  width: 100%;
  height: 100%;
}

.item-poster .no-poster {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #B7BBB8;
  font-size: 24rpx;
  letter-spacing: 0.12em;
}

.item-content {
  padding: 28rpx 32rpx 34rpx;
}

.item-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
  margin-bottom: 22rpx;
}

.item-name {
  flex: 1;
  color: var(--ink);
  font-size: 34rpx;
  line-height: 1.35;
  font-weight: 400;
  letter-spacing: 0.02em;
}

.status-tag {
  flex-shrink: 0;
  padding: 8rpx 16rpx;
  color: var(--green);
  background: rgba(28, 47, 38, 0.08);
  font-size: 21rpx;
  letter-spacing: 0.06em;
}

.status-tag.status-1 {
  color: #6B7280;
  background: #F4F4F2;
}

.status-tag.status-2 {
  color: #FFFFFF;
  background: var(--green);
}

.status-tag.status-3 {
  color: #A4A9A5;
  background: #F5F5F5;
}

.item-info {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.info-row {
  display: flex;
  align-items: center;
}

.info-icon {
  width: 12rpx;
  margin-right: 14rpx;
  color: var(--green);
  font-size: 18rpx;
}

.info-icon.location {
  color: var(--ink);
}

.info-value {
  color: var(--text-soft);
  font-size: 25rpx;
  letter-spacing: 0.03em;
}

.load-more-wrap,
.no-more-wrap {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 42rpx 0;
}

.load-more-text,
.no-more-text {
  margin-left: 12rpx;
  color: #A4A9A5;
  font-size: 24rpx;
  letter-spacing: 0.04em;
}

/* Product UI refinement：不改结构，仅收敛视觉规格 */
.page {
  padding: 24rpx 32rpx 112rpx;
}

.activity-item {
  border-radius: 24rpx;
  box-shadow: none;
}

.item-poster {
  height: 300rpx;
  background: #F6F6F6;
}

.item-content {
  padding: 24rpx;
}

.item-name {
  font-size: 32rpx;
  line-height: 44rpx;
  font-weight: 500;
  letter-spacing: 0.4rpx;
}

.status-tag {
  padding: 4rpx 12rpx;
  border-radius: 12rpx;
  font-size: 22rpx;
  line-height: 32rpx;
  letter-spacing: 0.4rpx;
}

.info-value,
.state-text,
.load-more-text,
.no-more-text {
  color: #999999;
  font-size: 24rpx;
  line-height: 34rpx;
  letter-spacing: 0.4rpx;
}
