/**
 * 活动列表页 - Bold Minimal
 */

.page {
  min-height: 100vh;
  padding: var(--space-xl) var(--space-lg);
  background: var(--bg-secondary);
}

.state-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 60vh;
}

.state-text {
  font-size: 26rpx;
  color: var(--text-tertiary);
  margin-top: var(--space-md);
}

.state-title {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--text-primary);
  margin-top: var(--space-lg);
}

.empty-graphic {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: var(--space-sm);
}

.empty-circle {
  width: 80rpx;
  height: 80rpx;
  border: 4rpx solid var(--border-strong);
  border-radius: 50%;
}

.empty-line {
  width: 120rpx;
  height: 4rpx;
  background: var(--border-strong);
  border-radius: 2rpx;
}

.activity-list {
  display: flex;
  flex-direction: column;
  gap: var(--space-md);
}

.activity-item {
  position: relative;
  background: var(--bg-card);
  border-radius: var(--radius-xl);
  padding: var(--space-lg);
  padding-left: var(--space-xl);
  box-shadow: var(--shadow-sm);
  overflow: hidden;
  opacity: 0;
  transition: all 0.3s ease;
}

.activity-item:active {
  transform: translateY(4rpx);
}

.item-indicator {
  position: absolute;
  left: 0;
  top: 20rpx;
  bottom: 20rpx;
  width: 6rpx;
  border-radius: 0 3rpx 3rpx 0;
}

.item-indicator.pending { background: var(--status-pending); }
.item-indicator.active { background: var(--accent); }
.item-indicator.ended { background: var(--text-primary); }

.item-content {
  display: flex;
  flex-direction: column;
  gap: var(--space-xs);
}

.item-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: var(--space-sm);
}

.item-name {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
  letter-spacing: -0.01em;
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.status-tag {
  font-size: 20rpx;
  font-weight: 600;
  padding: 6rpx 14rpx;
  border-radius: var(--radius-sm);
  letter-spacing: 0.04em;
  flex-shrink: 0;
}

.status-tag.pending { background: var(--status-pending-bg); color: var(--status-pending); }
.status-tag.active { background: var(--status-active-bg); color: var(--status-active); }
.status-tag.ended { background: var(--status-ended-bg); color: var(--status-ended); }

.item-time {
  font-size: 24rpx;
  color: var(--text-tertiary);
}

.item-tag {
  font-size: 22rpx;
  color: var(--accent);
  font-weight: 500;
}

.item-actions {
  display: flex;
  gap: var(--space-sm);
  margin-top: var(--space-lg);
  padding-top: var(--space-md);
  border-top: 1rpx solid var(--border);
}

.action-btn {
  flex: 1;
  font-size: 26rpx;
  font-weight: 600;
  border-radius: var(--radius-lg);
  padding: 16rpx 24rpx;
  height: auto;
  line-height: 1.4;
}

.action-btn.edit {
  background: var(--bg-secondary);
  color: var(--text-primary);
  border: none;
}

.action-btn.edit:active {
  background: var(--bg-tertiary);
}

.action-btn.delete {
  background: var(--error-bg);
  color: var(--error);
  border: none;
}

.action-btn.delete:active {
  opacity: 0.8;
}