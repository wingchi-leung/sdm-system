<view class="page">
  <!-- 加载状态 -->
  <view wx:if="{{loading}}" class="state-wrap">
    <view class="loading"></view>
    <text class="state-text">加载中…</text>
  </view>

  <!-- 空状态 -->
  <view wx:elif="{{activities.length === 0 && !loading}}" class="state-wrap empty">
    <view class="empty-illustration">
      <view class="empty-circle"></view>
      <view class="empty-line"></view>
      <view class="empty-line short"></view>
    </view>
    <text class="state-title">暂无活动</text>
  </view>

  <!-- 活动列表 -->
  <view wx:else class="list">
    <view
      class="activity-item slide-up delay-{{index % 4 + 1}}"
      wx:for="{{activities}}"
      wx:key="id"
      bindtap="onViewDetail"
      data-id="{{item.id}}"
    >
      <!-- 海报 -->
      <view wx:if="{{item.poster_url}}" class="item-poster">
        <image class="poster-img" src="{{item.poster_url}}" mode="aspectFill" lazy-load />
      </view>

      <!-- 内容区 -->
      <view class="item-content">
        <!-- 头部 -->
        <view class="item-header">
          <text class="item-name">{{item.activity_name}}</text>
          <view class="status-tag status-{{item.status}}">
            {{item.status === 1 ? '未开始' : item.status === 2 ? '进行中' : '已结束'}}
          </view>
        </view>

        <!-- 信息 -->
        <view class="item-info">
          <view class="info-row">
            <text class="info-icon">●</text>
            <text class="info-value">{{item.start_time}}</text>
          </view>
          <view class="info-row">
            <text class="info-icon location">◆</text>
            <text class="info-value">{{item.location || '线上活动'}}</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 加载更多状态 -->
    <view wx:if="{{loadingMore}}" class="load-more-wrap">
      <view class="loading-more"></view>
      <text class="load-more-text">加载中…</text>
    </view>

    <!-- 没有更多 -->
    <view wx:elif="{{!hasMore && activities.length > 0}}" class="no-more-wrap">
      <text class="no-more-text">没有更多了</text>
    </view>
  </view>
</view>