<view class="page">
  <view wx:if="{{loading}}" class="state-wrap">
    <view class="loading"></view>
    <text class="state-text">加载中…</text>
  </view>

  <view wx:elif="{{activities.length === 0}}" class="state-wrap empty">
    <view class="empty-graphic">
      <view class="empty-circle"></view>
      <view class="empty-line"></view>
    </view>
    <text class="state-title">暂无活动</text>
  </view>

  <view wx:else class="activity-list">
    <view
      class="activity-item slide-up delay-{{index % 5 + 1}}"
      wx:for="{{activities}}"
      wx:key="id"
      bindtap="onViewDetail"
      data-id="{{item.id}}"
    >
      <view class="item-indicator {{item.status === 2 ? 'active' : (item.status === 1 ? 'pending' : 'ended')}}"></view>
      <view class="item-content">
        <view class="item-header">
          <text class="item-name">{{item.activity_name}}</text>
          <view class="status-tag {{item.status === 2 ? 'active' : (item.status === 1 ? 'pending' : 'ended')}}">
            {{item.status === 1 ? '未开始' : item.status === 2 ? '进行中' : '已结束'}}
          </view>
        </view>
        <text class="item-time">{{item.start_time}}</text>
        <text class="item-tag" wx:if="{{item.tag}}">{{item.tag}}</text>
      </view>
      <view wx:if="{{isAdmin}}" class="item-actions" catchtap="stopPropagation">
        <button class="action-btn edit" bindtap="onEditActivity" data-id="{{item.id}}">编辑</button>
        <button class="action-btn delete" bindtap="onDeleteActivity" data-id="{{item.id}}" data-name="{{item.activity_name}}">删除</button>
      </view>
    </view>
  </view>
</view>