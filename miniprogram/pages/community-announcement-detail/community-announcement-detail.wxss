.page {
  min-height: 100vh;
  background: #ffffff;
  color: #101828;
  padding-bottom: calc(132rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

.page-header-sticky {
  position: sticky;
  top: 0;
  z-index: 10;
  background: #ffffff;
}

.state-wrap {
  min-height: 40vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 60rpx 0;
  text-align: center;
}

.state-title {
  color: #101828;
  font-size: 32rpx;
  line-height: 1.4;
  font-weight: 500;
}

.state-text {
  margin-top: 16rpx;
  color: #6f6f6f;
  font-size: 24rpx;
  line-height: 1.6;
}

.content {
  padding: 0 28rpx;
}

.ann-card {
  margin-top: 24rpx;
  background: #ffffff;
  border: 1rpx solid rgba(17, 17, 17, 0.06);
  border-radius: 16rpx;
  padding: 32rpx 28rpx;
  box-sizing: border-box;
}

.ann-caption {
  display: block;
  color: #98a2b3;
  font-size: 22rpx;
  line-height: 1.4;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  margin-bottom: 8rpx;
}

.ann-title {
  display: block;
  color: #101828;
  font-size: 36rpx;
  line-height: 1.4;
  font-weight: 600;
  letter-spacing: 0.01em;
}

.ann-meta {
  display: flex;
  align-items: center;
  margin-top: 20rpx;
  gap: 6rpx;
  flex-wrap: wrap;
}

.ann-meta-avatar {
  width: 36rpx;
  height: 36rpx;
  border-radius: 999rpx;
  background: #f2f4f7;
  margin-right: 4rpx;
  flex-shrink: 0;
}

.ann-meta-name {
  color: #344054;
  font-size: 24rpx;
  line-height: 1.5;
}

.ann-meta-dot {
  color: #98a2b3;
  font-size: 24rpx;
  line-height: 1.5;
  margin: 0 4rpx;
}

.ann-meta-time {
  color: #98a2b3;
  font-size: 24rpx;
  line-height: 1.5;
}

.ann-html {
  margin-top: 28rpx;
  color: #101828;
  font-size: 28rpx;
  line-height: 1.75;
}

.ann-html image {
  max-width: 100% !important;
  height: auto !important;
}

.ann-text {
  display: block;
  margin-top: 28rpx;
  color: #101828;
  font-size: 28rpx;
  line-height: 1.75;
  white-space: pre-wrap;
}

.ann-actions {
  display: flex;
  justify-content: center;
  margin-top: 40rpx;
}

.ann-delete {
  min-width: 240rpx;
  height: 80rpx;
  border-radius: 999rpx;
  border: 1rpx solid rgba(217, 45, 32, 0.30);
  color: #d92d20;
  font-size: 28rpx;
  line-height: 80rpx;
  text-align: center;
  letter-spacing: 0.02em;
}
