.page {
  min-height: 100vh;
  background:
    radial-gradient(circle at top left, rgba(255, 213, 142, 0.18), transparent 34%),
    radial-gradient(circle at top right, rgba(170, 223, 255, 0.18), transparent 28%),
    #f6f7fb;
  color: #101828;
  padding-bottom: calc(132rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

.header-actions {
  display: flex;
  align-items: center;
  justify-content: flex-end;
}

.state-wrap {
  min-height: 40vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 60rpx 0;
  text-align: center;
}

.state-title {
  color: #101828;
  font-size: 32rpx;
  line-height: 1.4;
  font-weight: 500;
}

.state-text {
  margin-top: 16rpx;
  color: #6f6f6f;
  font-size: 24rpx;
  line-height: 1.6;
}

.content {
  padding: 24rpx 24rpx 0;
}

.ann-card {
  background: #ffffff;
  border: 1rpx solid rgba(15, 23, 42, 0.06);
  border-radius: 28rpx;
  padding: 28rpx 24rpx 26rpx;
  box-sizing: border-box;
  box-shadow: 0 16rpx 42rpx rgba(15, 23, 42, 0.06);
}

.ann-badge-row {
  margin-bottom: 12rpx;
}

.ann-badge {
  display: inline-flex;
  align-items: center;
  padding: 4rpx 14rpx;
  border-radius: 999rpx;
  background: #f2f4f7;
  color: #667085;
  font-size: 20rpx;
  line-height: 1.4;
  font-weight: 500;
}

.ann-title {
  display: block;
  color: #101828;
  font-size: 42rpx;
  line-height: 1.28;
  font-weight: 700;
  letter-spacing: 0.01em;
}

.ann-meta {
  display: flex;
  align-items: center;
  margin-top: 18rpx;
  gap: 8rpx;
  flex-wrap: wrap;
}

.ann-meta-avatar {
  width: 42rpx;
  height: 42rpx;
  border-radius: 999rpx;
  background: #f2f4f7;
  flex-shrink: 0;
}

.ann-meta-name {
  color: #344054;
  font-size: 24rpx;
  line-height: 1.5;
}

.ann-meta-dot {
  color: #98a2b3;
  font-size: 24rpx;
  line-height: 1.5;
  margin: 0 4rpx;
}

.ann-meta-time {
  color: #98a2b3;
  font-size: 24rpx;
  line-height: 1.5;
}

.ann-html {
  margin-top: 24rpx;
  color: #101828;
  font-size: 28rpx;
  line-height: 1.8;
}

.ann-html image {
  max-width: 100% !important;
  height: auto !important;
}

.ann-text {
  display: block;
  margin-top: 24rpx;
  color: #101828;
  font-size: 28rpx;
  line-height: 1.8;
  white-space: pre-wrap;
}

.header-delete-btn {
  min-width: 112rpx;
  height: 64rpx;
  padding: 0 22rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  border-radius: 999rpx;
  border: 1rpx solid rgba(217, 45, 32, 0.18);
  background: rgba(255, 255, 255, 0.92);
  color: #d92d20;
  box-shadow: 0 10rpx 24rpx rgba(15, 23, 42, 0.05);
}

.header-delete-btn__text {
  font-size: 24rpx;
  line-height: 1;
  font-weight: 500;
}

.ann-actions {
  display: flex;
  justify-content: center;
  margin-top: 32rpx;
}

.ann-delete {
  display: none;
}
