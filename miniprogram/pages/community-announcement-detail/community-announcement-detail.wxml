<view class="page">
  <page-header title="" statusBarHeight="{{statusBarHeight}}">
    <view wx:if="{{canDelete}}" slot="actions" class="header-actions">
      <view class="header-delete-btn" bindtap="onDelete">
        <text class="header-delete-btn__text">删除</text>
      </view>
    </view>
  </page-header>

  <view wx:if="{{loading}}" class="state-wrap">
    <text class="state-text">加载中…</text>
  </view>

  <view wx:elif="{{error}}" class="state-wrap">
    <text class="state-title">暂时无法查看公告</text>
    <text class="state-text">{{error}}</text>
  </view>

  <view wx:else class="content">
    <view class="ann-card">
      <text class="ann-title">{{announcement.title}}</text>
      <view class="ann-meta">
        <image class="ann-meta-avatar" src="{{announcement.author_avatar_display_url}}" mode="aspectFill" />
        <text class="ann-meta-name">{{announcement.author_name}}</text>
        <text class="ann-meta-dot">·</text>
        <text class="ann-meta-time">{{announcement.create_time_display}}</text>
      </view>

      <view wx:if="{{announcement.content_format === 'html'}}" class="ann-html">
        <rich-text nodes="{{announcement.content}}" />
      </view>
      <text wx:else class="ann-text">{{announcement.plain_text}}</text>
    </view>
  </view>
</view>
