<view class="page">
  <!-- 品牌区域 -->
  <view class="brand-section">
    <view class="brand-icon" bindtap="onGateIconTap">
      <image class="gate-icon" src="/assets/icons/mainlogo-door.png" mode="aspectFit" />
    </view>
    <text class="brand-title">{{isAdminMode ? '管理员登录' : 'PANDORA'}}</text>
    <text class="brand-subtitle">{{isAdminMode ? 'CONSULTING ADMIN' : 'CONSULTING'}}</text>
  </view>

  <!-- 安全提示 -->
  <view class="unsafe-tip" wx:if="{{unsafeTip}}">
    <view class="tip-icon">
      <text>!</text>
    </view>
    <text class="tip-text">当前使用非加密连接，请仅在可信网络下使用。</text>
  </view>

  <!-- 登录表单 -->
  <view class="form-section">
    <!-- 错误提示 -->
    <view class="error-box" wx:if="{{error}}">
      <text class="error-text">{{error}}</text>
    </view>

    <!-- 管理员登录表单 -->
    <block wx:if="{{isAdminMode}}">
      <view class="field">
        <text class="field-label">用户名</text>
        <view class="input-wrap">
          <input
            class="input"
            type="text"
            placeholder="请输入用户名"
            placeholder-class="input-placeholder"
            value="{{account}}"
            bindinput="onAccountInput"
          />
        </view>
      </view>
      <view class="field">
        <text class="field-label">密码</text>
        <view class="input-wrap">
          <input
            class="input"
            type="password"
            placeholder="请输入密码"
            placeholder-class="input-placeholder"
            value="{{password}}"
            bindinput="onPasswordInput"
          />
        </view>
      </view>
      <button class="btn-submit" disabled="{{submitting}}" bindtap="submit">
        <text class="btn-text">{{submitting ? '登录中...' : '登录'}}</text>
      </button>
      <view class="switch-mode">
        <text class="switch-link" bindtap="exitAdminMode">返回微信登录</text>
      </view>
    </block>

    <!-- 微信登录 -->
    <block wx:else>
      <!-- 手机号一键登录 -->
      <button class="btn-wechat" disabled="{{submitting}}" open-type="getPhoneNumber" bindgetphonenumber="onGetPhoneNumber">
        <view class="wechat-icon">
          <text>W</text>
        </view>
        <text class="wechat-text">微信手机号一键登录</text>
      </button>
    </block>
  </view>

  <!-- 底部装饰 -->
  <view class="footer-decoration">
    <view class="decoration-line"></view>
  </view>
</view>
