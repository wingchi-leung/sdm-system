<view class="page {{isAdminMode ? 'page-admin' : ''}}">
  <block wx:if="{{isAdminMode}}">
    <view class="admin-legacy-page">
      <view class="admin-brand-section">
        <view class="admin-brand-icon" bindtap="onGateIconTap">
          <image class="admin-gate-icon" src="/assets/icons/mainlogo-door.webp" mode="aspectFit" />
        </view>
        <text class="admin-brand-title">管理员登录</text>
        <text class="admin-brand-subtitle">CONSULTING ADMIN</text>
      </view>

      <view class="admin-unsafe-tip" wx:if="{{unsafeTip}}">
        <view class="admin-tip-icon">
          <text>!</text>
        </view>
        <text class="admin-tip-text">当前使用非加密连接，请仅在可信网络下使用。</text>
      </view>

      <view class="admin-form-section">
        <view class="admin-error-box" wx:if="{{error}}">
          <text class="admin-error-text">{{error}}</text>
        </view>

        <view class="admin-field">
          <text class="admin-field-label">用户名</text>
          <view class="admin-input-wrap">
            <input
              class="admin-input"
              type="text"
              placeholder="请输入用户名"
              placeholder-class="admin-input-placeholder"
              value="{{account}}"
              bindinput="onAccountInput"
            />
          </view>
        </view>
        <view class="admin-field">
          <text class="admin-field-label">密码</text>
          <view class="admin-input-wrap">
            <input
              class="admin-input"
              type="password"
              placeholder="请输入密码"
              placeholder-class="admin-input-placeholder"
              value="{{password}}"
              bindinput="onPasswordInput"
            />
          </view>
        </view>
        <button class="admin-btn-submit" disabled="{{submitting}}" bindtap="submit">
          <text class="admin-btn-text">{{submitting ? '登录中...' : '登录'}}</text>
        </button>
        <view class="admin-switch-mode">
          <text class="admin-switch-link" bindtap="exitAdminMode">返回微信登录</text>
        </view>
      </view>
    </view>
  </block>

  <block wx:else>
    <view class="poster-page safe-area-bottom">
      <view class="poster-paper"></view>
      <view class="poster-noise"></view>
      <view class="poster-wash poster-wash-left"></view>
      <view class="poster-wash poster-wash-right"></view>
      <image class="poster-mountain poster-mountain-side" src="/assets/login_background.webp" mode="aspectFill" />
      <image class="poster-mountain poster-mountain-main" src="/assets/login_mountain_sharp.jpg" mode="aspectFill" />

      <view class="poster-top">
        <view class="poster-altitude" bindtap="onGateIconTap">
          <view class="poster-altitude-mark"></view>
          <view class="poster-altitude-copy">
            <text class="poster-meta-number">8848M</text>
            <text class="poster-meta-label">ALTITUDE</text>
          </view>
        </view>

        <view class="poster-coordinates">
          <text class="poster-meta-number">27.9881° N</text>
          <text class="poster-meta-number">86.9250° E</text>
        </view>
      </view>

      <view class="poster-plus">
        <view class="poster-plus-h"></view>
        <view class="poster-plus-v"></view>
      </view>

      <view class="poster-copy" bindtap="onGateIconTap">
        <text class="poster-title poster-title-main">Explore</text>
        <text class="poster-title poster-title-secondary">the</text>
        <text class="poster-title poster-title-italic">Unexplored.</text>
      </view>

      <view class="poster-caption">
        <view class="poster-caption-line"></view>
        <view class="poster-caption-copy">
          <text class="poster-caption-text">探索未知，</text>
          <text class="poster-caption-text">超越所见。</text>
        </view>
      </view>

      <view class="poster-route route-a"></view>
      <view class="poster-route route-b"></view>
      <view class="poster-route route-c"></view>

      <view class="poster-footprint">
        <view class="footprint-line footprint-line-a"></view>
        <view class="footprint-line footprint-line-b"></view>
        <view class="footprint-line footprint-line-c"></view>
        <view class="footprint-line footprint-line-d"></view>
      </view>

      <view class="poster-message-stack" wx:if="{{unsafeTip || error}}">
        <view class="poster-message poster-warning" wx:if="{{unsafeTip}}">
          <text class="poster-message-text">当前使用非加密连接，请仅在可信网络下使用。</text>
        </view>
        <view class="poster-message poster-error" wx:if="{{error}}">
          <text class="poster-message-text">{{error}}</text>
        </view>
      </view>

      <button class="poster-login-trigger" disabled="{{submitting}}" open-type="getPhoneNumber" bindgetphonenumber="onGetPhoneNumber">
        <view class="login-axis-vertical"></view>
        <view class="login-axis-dot"></view>
        <view class="login-axis-horizontal"></view>
        <text class="login-axis-label">{{submitting ? 'LOADING' : 'LOGIN'}}</text>
        <view class="login-axis-arrow">
          <view class="login-axis-arrow-line"></view>
          <view class="login-axis-arrow-head login-axis-arrow-head-top"></view>
          <view class="login-axis-arrow-head login-axis-arrow-head-bottom"></view>
        </view>
      </button>
    </view>
  </block>
</view>
