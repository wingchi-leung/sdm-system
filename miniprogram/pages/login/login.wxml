<view class="page {{isAdminMode ? 'page-admin' : ''}}">
  <block wx:if="{{isAdminMode}}">
    <view class="admin-legacy-page">
      <view class="admin-brand-section">
        <view class="admin-brand-icon" bindtap="onGateIconTap">
          <image class="admin-gate-icon" src="/assets/icons/mainlogo-door.webp" mode="aspectFit" />
        </view>
        <text class="admin-brand-title">管理员登录</text>
        <text class="admin-brand-subtitle">CONSULTING ADMIN</text>
      </view>

      <view class="admin-unsafe-tip" wx:if="{{unsafeTip}}">
        <view class="admin-tip-icon">
          <text>!</text>
        </view>
        <text class="admin-tip-text">当前使用非加密连接，请仅在可信网络下使用。</text>
      </view>

      <view class="admin-form-section">
        <view class="admin-error-box" wx:if="{{error}}">
          <text class="admin-error-text">{{error}}</text>
        </view>

        <view class="admin-field">
          <text class="admin-field-label">用户名</text>
          <view class="admin-input-wrap">
            <input
              class="admin-input"
              type="text"
              placeholder="请输入用户名"
              placeholder-class="admin-input-placeholder"
              value="{{account}}"
              bindinput="onAccountInput"
            />
          </view>
        </view>
        <view class="admin-field">
          <text class="admin-field-label">密码</text>
          <view class="admin-input-wrap">
            <input
              class="admin-input"
              type="password"
              placeholder="请输入密码"
              placeholder-class="admin-input-placeholder"
              value="{{password}}"
              bindinput="onPasswordInput"
            />
          </view>
        </view>
        <button class="admin-btn-submit" disabled="{{submitting}}" bindtap="submit">
          <text class="admin-btn-text">{{submitting ? '登录中...' : '登录'}}</text>
        </button>
        <view class="admin-switch-mode">
          <text class="admin-switch-link" bindtap="exitAdminMode">返回微信登录</text>
        </view>
      </view>
    </view>
  </block>

  <block wx:else>
    <image class="login-bg-image" src="/assets/login_background.webp" mode="aspectFill" />
    <view class="login-bg-fade"></view>

    <view class="hero-header">
      <view class="hero-title-row">
        <text class="hero-caption"></text>
      </view>
    </view>

    <view class="hero-body">
      <view class="brand-section">
        <view class="brand-icon" bindtap="onGateIconTap">
          <image class="gate-icon" src="/assets/icons/mainlogo-door.webp" mode="aspectFit" />
        </view>
        <text class="brand-title">开启成长之门</text>
        <text class="brand-subtitle">探索知识，遇见更好的自己</text>
      </view>

      <view class="message-wrap">
        <view class="unsafe-tip" wx:if="{{unsafeTip}}">
          <view class="tip-icon">
            <text>!</text>
          </view>
          <text class="tip-text">当前使用非加密连接，请仅在可信网络下使用。</text>
        </view>

        <view class="error-box" wx:if="{{error}}">
          <text class="error-text">{{error}}</text>
        </view>
      </view>

      <view class="login-action-section">
        <button class="btn-wechat hero-login-btn" disabled="{{submitting}}" open-type="getPhoneNumber" bindgetphonenumber="onGetPhoneNumber">
          <text class="wechat-text">{{submitting ? '登录中...' : '微信一键登录'}}</text>
        </button>
        <text class="login-hint">授权后快速登录</text>
      </view>
    </view>
  </block>
</view>
