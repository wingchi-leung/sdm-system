<view class="page {{isAdminMode ? 'page-admin' : ''}}">
  <block wx:if="{{isAdminMode}}">
    <view class="admin-wrap">
      <view class="admin-header">
        <text class="admin-title">管理员登录</text>
        <text class="admin-subtitle">请输入账号密码继续</text>
      </view>

      <view class="unsafe-tip" wx:if="{{unsafeTip}}">
        <view class="tip-icon">
          <text>!</text>
        </view>
        <text class="tip-text">当前使用非加密连接，请仅在可信网络下使用。</text>
      </view>

      <view class="error-box" wx:if="{{error}}">
        <text class="error-text">{{error}}</text>
      </view>

      <view class="field">
        <text class="field-label">用户名</text>
        <view class="input-wrap">
          <input
            class="input"
            type="text"
            placeholder="请输入用户名"
            placeholder-class="input-placeholder"
            value="{{account}}"
            bindinput="onAccountInput"
          />
        </view>
      </view>
      <view class="field">
        <text class="field-label">密码</text>
        <view class="input-wrap">
          <input
            class="input"
            type="password"
            placeholder="请输入密码"
            placeholder-class="input-placeholder"
            value="{{password}}"
            bindinput="onPasswordInput"
          />
        </view>
      </view>
      <button class="btn-submit" disabled="{{submitting}}" bindtap="submit">
        <text class="btn-text">{{submitting ? '登录中...' : '登录'}}</text>
      </button>
      <view class="switch-mode">
        <text class="switch-link" bindtap="exitAdminMode">返回微信登录</text>
      </view>
    </view>
  </block>

  <block wx:else>
    <view class="bg-orb orb-left"></view>
    <view class="bg-orb orb-right"></view>

    <view class="hero-header">
      <view class="hero-title-row">
        <text class="hero-spark">✦</text>
        <text class="hero-title">登录</text>
      </view>
    </view>

    <view class="hero-body">
      <view class="brand-section">
        <view class="brand-icon" bindtap="onGateIconTap">
          <image class="gate-icon" src="/assets/icons/mainlogo-door.png" mode="aspectFit" />
        </view>
        <text class="brand-title">开启成长之门</text>
        <text class="brand-subtitle">探索知识，遇见更好的自己</text>
      </view>

      <view class="message-wrap">
        <view class="unsafe-tip" wx:if="{{unsafeTip}}">
          <view class="tip-icon">
            <text>!</text>
          </view>
          <text class="tip-text">当前使用非加密连接，请仅在可信网络下使用。</text>
        </view>

        <view class="error-box" wx:if="{{error}}">
          <text class="error-text">{{error}}</text>
        </view>
      </view>

      <view class="login-action-section">
        <button class="btn-wechat hero-login-btn" disabled="{{submitting}}" open-type="getPhoneNumber" bindgetphonenumber="onGetPhoneNumber">
          <text class="wechat-text">{{submitting ? '登录中...' : '微信一键登录'}}</text>
        </button>
        <text class="login-hint">授权手机号后即可快速登录或自动创建账号</text>
      </view>
    </view>
  </block>
</view>
