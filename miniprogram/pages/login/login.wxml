<view class="page {{isAdminMode ? 'page-admin' : ''}}">
  <view class="poster-page safe-area-bottom">
    <image
      class="poster-background"
      src="{{usePngBackground ? '/assets/loginclean.png' : '/assets/loginclean.webp'}}"
      mode="aspectFill"
      binderror="onBackgroundLoadError"
    />
    <block wx:if="{{isAdminMode}}">
      <view class="admin-page">
        <view class="admin-card">
          <view class="admin-card-head">
            <text class="admin-brand-title">管理员登录</text>
            <text class="admin-brand-subtitle">CONSULTING ADMIN</text>
          </view>

          <view class="admin-unsafe-tip" wx:if="{{unsafeTip}}">
            <text class="admin-tip-text">当前使用非加密连接，请仅在可信网络下使用。</text>
          </view>

          <view class="admin-error-box" wx:if="{{error}}">
            <text class="admin-error-text">{{error}}</text>
          </view>

          <view class="admin-field">
            <text class="admin-field-label">用户名</text>
            <view class="admin-input-wrap">
              <input
                class="admin-input"
                type="text"
                placeholder="请输入用户名"
                placeholder-class="admin-input-placeholder"
                value="{{account}}"
                bindinput="onAccountInput"
              />
            </view>
          </view>

          <view class="admin-field">
            <text class="admin-field-label">密码</text>
            <view class="admin-input-wrap">
              <input
                class="admin-input"
                type="password"
                placeholder="请输入密码"
                placeholder-class="admin-input-placeholder"
                value="{{password}}"
                bindinput="onPasswordInput"
              />
            </view>
          </view>

          <button class="admin-btn-submit" disabled="{{submitting}}" bindtap="submit">
            <text class="admin-btn-text">{{submitting ? '登录中...' : '登录'}}</text>
          </button>
          <view class="admin-switch-mode">
            <text class="admin-switch-link" bindtap="exitAdminMode">返回普通登录</text>
          </view>
        </view>
      </view>
    </block>

    <block wx:else>
      <view class="poster-admin-hotspot" bindtap="onGateIconTap"></view>

      <view class="poster-message-stack" wx:if="{{unsafeTip || error}}">
        <view class="poster-message poster-warning" wx:if="{{unsafeTip}}">
          <text class="poster-message-text">当前使用非加密连接，请仅在可信网络下使用。</text>
        </view>
        <view class="poster-message poster-error" wx:if="{{error}}">
          <text class="poster-message-text">{{error}}</text>
        </view>
      </view>

      <button class="poster-login-trigger" disabled="{{submitting}}" bindtap="onPhoneAuthTap" open-type="getPhoneNumber" bindgetphonenumber="onGetPhoneNumber"></button>

      <view class="poster-loading-tip" wx:if="{{submitting}}">
        <text class="poster-loading-text">登录中...</text>
      </view>
    </block>
  </view>
</view>
