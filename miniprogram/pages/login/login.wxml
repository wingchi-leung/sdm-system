<view class="page">
  <view class="header">
    <image class="gate-icon" src="/assets/icons/gate_welcome.svg" bindtap="onGateIconTap" />
    <text class="title">{{isAdminMode ? '管理员登录' : '欢迎'}}</text>
  </view>

  <view class="unsafe-tip" wx:if="{{unsafeTip}}">
    <text>当前使用非加密连接，请仅在可信网络下使用。</text>
  </view>

  <view class="form">
    <view class="error-box" wx:if="{{error}}">
      <text class="error-text">{{error}}</text>
    </view>

    <!-- 管理员登录表单 -->
    <block wx:if="{{isAdminMode}}">
      <view class="field">
        <text class="field-label required">用户名</text>
        <input class="input" type="text" placeholder="请输入用户名" value="{{account}}" bindinput="onAccountInput" />
      </view>
      <view class="field">
        <text class="field-label required">密码</text>
        <input class="input" type="password" placeholder="请输入密码" value="{{password}}" bindinput="onPasswordInput" />
      </view>
      <button class="btn-primary submit-btn" disabled="{{submitting}}" bindtap="submit">
        {{submitting ? '登录中...' : '登录'}}
      </button>
      <view class="toggle-row">
        <text class="toggle-link" bindtap="exitAdminMode">返回微信登录</text>
      </view>
    </block>

    <!-- 微信登录 -->
    <block wx:else>
      <button class="btn-wechat" disabled="{{submitting}}" bindtap="wechatLogin">
        <text>微信一键登录</text>
      </button>
    </block>
  </view>
</view>
