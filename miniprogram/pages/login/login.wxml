<view class="page">
  <view class="header">
    <image class="gate-icon" src="/assets/icons/gate_welcome.svg" />
    <text class="title">欢迎</text>
  </view>

  <view class="unsafe-tip" wx:if="{{unsafeTip}}">
    <text>当前使用非加密连接，请仅在可信网络下使用。</text>
  </view>

  <view class="form">
    <view class="error-box" wx:if="{{error}}">
      <text class="error-text">{{error}}</text>
    </view>

    <button class="btn-wechat" disabled="{{submitting}}" bindtap="wechatLogin">
      <text>微信一键登录</text>
    </button>
  </view>
</view>
