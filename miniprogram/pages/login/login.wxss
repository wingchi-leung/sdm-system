.page {
  position: relative;
  min-height: 100vh;
  background: #F5F1EA;
  box-sizing: border-box;
  overflow: hidden;
}

.page-admin {
  padding: 0 32rpx;
  overflow-y: auto;
}

.poster-page {
  position: relative;
  min-height: 100vh;
  overflow: hidden;
  background: #F7F3EE;
}

.poster-background {
  display: block;
  width: 100%;
}

.poster-admin-hotspot {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 1260rpx;
  z-index: 2;
}

.poster-message-stack {
  position: absolute;
  left: 40rpx;
  right: 40rpx;
  bottom: 240rpx;
  z-index: 4;
}

.poster-message {
  margin-top: 18rpx;
  padding: 20rpx 24rpx;
  border: 1px solid rgba(22, 58, 107, 0.12);
  border-radius: 16rpx;
  background: rgba(255, 255, 255, 0.74);
}

.poster-warning {
  color: #8A7451;
}

.poster-error {
  color: var(--error);
}

.poster-message-text {
  font-size: 24rpx;
  line-height: 34rpx;
}

.poster-login-trigger {
  position: absolute;
  left: 320rpx;
  bottom: 220rpx;
  width: 260rpx;
  height: 170rpx;
  min-height: 170rpx;
  padding: 0;
  background: transparent;
  border: 0;
  display: block;
  z-index: 5;
}

.poster-login-trigger::after {
  border: 0;
}

.poster-login-trigger[disabled] {
  opacity: 0.72;
}

.poster-loading-tip {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 170rpx;
  z-index: 6;
  text-align: center;
}

.poster-loading-text {
  display: inline-block;
  padding: 10rpx 20rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.8);
  color: #163A6B;
  font-size: 22rpx;
  line-height: 30rpx;
}

.admin-legacy-page {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  box-sizing: border-box;
}

.admin-brand-section {
  flex: 1;
  min-height: 560rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: flex-end;
  padding-bottom: 48rpx;
}

.admin-brand-icon {
  width: 300rpx;
  height: 300rpx;
  margin-bottom: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.admin-gate-icon {
  width: 280rpx;
  height: 280rpx;
}

.admin-brand-title {
  color: var(--ink);
  font-size: 44rpx;
  line-height: 56rpx;
  font-weight: 500;
}

.admin-brand-subtitle {
  margin-top: 14rpx;
  color: var(--ink);
  font-size: 24rpx;
  line-height: 34rpx;
  font-weight: 400;
}

.admin-unsafe-tip,
.admin-error-box {
  margin-bottom: 28rpx;
  padding: 22rpx 24rpx;
  border-left: 3rpx solid var(--warning);
  background: var(--warning-bg);
  display: flex;
  align-items: flex-start;
  gap: 14rpx;
}

.admin-error-box {
  border-left-color: var(--error);
  background: var(--error-bg);
}

.admin-tip-icon {
  width: 28rpx;
  height: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.admin-tip-icon text,
.admin-tip-text {
  color: var(--warning);
  font-size: 24rpx;
  line-height: 34rpx;
  font-weight: 400;
}

.admin-error-text {
  color: var(--error);
  font-size: 24rpx;
  line-height: 34rpx;
  font-weight: 400;
}

.admin-form-section {
  padding-bottom: 34rpx;
}

.admin-field {
  margin-bottom: 24rpx;
}

.admin-field-label {
  display: block;
  margin-bottom: 12rpx;
  color: var(--text-secondary);
  font-size: 24rpx;
  line-height: 34rpx;
}

.admin-input-wrap {
  position: relative;
}

.admin-input {
  width: 100%;
  height: 88rpx;
  padding: 0 28rpx;
  box-sizing: border-box;
  border: 1px solid var(--form-border);
  border-radius: 20rpx;
  background: var(--form-surface);
  color: var(--ink);
  font-size: 28rpx;
  line-height: 40rpx;
}

.admin-input-placeholder {
  color: #B7BBB8;
}

.admin-btn-submit {
  width: 100%;
  height: 88rpx;
  min-height: 88rpx;
  margin-top: 28rpx;
  border: 0;
  border-radius: 16rpx;
  background: #2F4F46;
  display: flex;
  align-items: center;
  justify-content: center;
}

.admin-btn-submit::after {
  border: 0;
}

.admin-btn-submit:active {
  opacity: 0.88;
}

.admin-btn-submit[disabled] {
  opacity: 0.46;
}

.admin-btn-text {
  color: #FFFFFF;
  font-size: 28rpx;
  font-weight: 500;
}

.admin-switch-mode {
  margin-top: 28rpx;
  text-align: center;
}

.admin-switch-link {
  color: var(--text-soft);
  font-size: 24rpx;
  line-height: 34rpx;
}
