.page {
  position: relative;
  min-height: 100vh;
  background: #F5F7FA;
  box-sizing: border-box;
  overflow: hidden;
}

.page-admin {
  padding: 0 32rpx;
  overflow-y: auto;
}

.login-bg-image {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 76vh;
  pointer-events: none;
}

.login-sky-mask {
  position: absolute;
  inset: 0;
  pointer-events: none;
  background:
    linear-gradient(180deg, rgba(255, 255, 255, 0) 0%, rgba(255, 255, 255, 0) 54%, rgba(245, 247, 250, 0.62) 74%, #F5F7FA 100%),
    linear-gradient(90deg, rgba(255, 255, 255, 0.10) 0%, rgba(255, 255, 255, 0.02) 48%, rgba(13, 38, 65, 0.04) 100%);
}

.top-actions {
  position: relative;
  z-index: 2;
  display: flex;
  justify-content: flex-end;
  padding: 92rpx 46rpx 0;
}

.setting-btn {
  width: 72rpx;
  height: 72rpx;
  min-height: 72rpx;
  padding: 0;
  border: 0;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.96);
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 6rpx;
}

.setting-btn::after {
  border: 0;
}

.setting-dot {
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  background: #101923;
}

.hero-copy {
  position: relative;
  z-index: 2;
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  padding: 22rpx 56rpx 0;
}

.hero-title {
  color: #111923;
  font-size: 54rpx;
  line-height: 68rpx;
  font-weight: 700;
}

.hero-subtitle {
  margin-top: 18rpx;
  color: rgba(35, 55, 79, 0.48);
  font-size: 26rpx;
  line-height: 38rpx;
  font-weight: 500;
}

.hero-line {
  width: 34rpx;
  height: 4rpx;
  margin-top: 22rpx;
  border-radius: 999rpx;
  background: rgba(35, 55, 79, 0.18);
}

.login-panel {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 3;
  min-height: 410rpx;
  padding: 126rpx 56rpx 48rpx;
  box-sizing: border-box;
  background: #F8F9FB;
}

.panel-curve {
  position: absolute;
  left: -76rpx;
  right: -76rpx;
  top: -76rpx;
  height: 172rpx;
  border-radius: 0 0 50% 50%;
  background: #F8F9FB;
  transform: rotate(-5deg);
  transform-origin: 50% 100%;
}

.message-wrap {
  position: relative;
  z-index: 2;
  margin-bottom: 28rpx;
}

.unsafe-tip,
.error-box {
  margin-bottom: 20rpx;
  padding: 22rpx 24rpx;
  border-radius: 24rpx;
  border: 1px solid rgba(17, 25, 35, 0.06);
  background: rgba(255, 255, 255, 0.92);
  display: flex;
  align-items: flex-start;
  gap: 14rpx;
}

.unsafe-tip {
  color: #8A7451;
}

.error-box {
  color: var(--error);
}

.tip-icon {
  width: 28rpx;
  height: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 4rpx;
}

.tip-icon text,
.tip-text,
.error-text {
  font-size: 24rpx;
  line-height: 36rpx;
  font-weight: 400;
}

.btn-wechat {
  position: relative;
  z-index: 2;
  width: 100%;
  height: 94rpx;
  min-height: 94rpx;
  border: 0;
  border-radius: 999rpx;
  background: #101923;
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn-wechat::after {
  border: 0;
}

.btn-wechat:active {
  transform: translateY(2rpx);
  opacity: 0.94;
}

.btn-wechat[disabled] {
  opacity: 0.52;
}

.wechat-text {
  color: #FFFFFF;
  font-size: 30rpx;
  line-height: 42rpx;
  font-weight: 600;
}

.login-hint {
  position: relative;
  z-index: 2;
  display: block;
  margin-top: 28rpx;
  color: rgba(17, 25, 35, 0.42);
  font-size: 24rpx;
  line-height: 34rpx;
  text-align: center;
}

.admin-legacy-page {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  box-sizing: border-box;
}

.admin-brand-section {
  flex: 1;
  min-height: 560rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: flex-end;
  padding-bottom: 48rpx;
}

.admin-brand-icon {
  width: 300rpx;
  height: 300rpx;
  margin-bottom: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.admin-gate-icon {
  width: 280rpx;
  height: 280rpx;
}

.admin-brand-title {
  color: var(--ink);
  font-size: 44rpx;
  line-height: 56rpx;
  font-weight: 500;
}

.admin-brand-subtitle {
  margin-top: 14rpx;
  color: var(--ink);
  font-size: 24rpx;
  line-height: 34rpx;
  font-weight: 400;
}

.admin-unsafe-tip,
.admin-error-box {
  margin-bottom: 28rpx;
  padding: 22rpx 24rpx;
  border-left: 3rpx solid var(--warning);
  background: var(--warning-bg);
  display: flex;
  align-items: flex-start;
  gap: 14rpx;
}

.admin-error-box {
  border-left-color: var(--error);
  background: var(--error-bg);
}

.admin-tip-icon {
  width: 28rpx;
  height: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.admin-tip-icon text,
.admin-tip-text {
  color: var(--warning);
  font-size: 24rpx;
  line-height: 34rpx;
  font-weight: 400;
}

.admin-error-text {
  color: var(--error);
  font-size: 24rpx;
  line-height: 34rpx;
  font-weight: 400;
}

.admin-form-section {
  padding-bottom: 34rpx;
}

.admin-field {
  margin-bottom: 24rpx;
}

.admin-field-label {
  display: block;
  margin-bottom: 12rpx;
  color: var(--text-secondary);
  font-size: 24rpx;
  line-height: 34rpx;
}

.admin-input-wrap {
  position: relative;
}

.admin-input {
  width: 100%;
  height: 88rpx;
  padding: 0 28rpx;
  box-sizing: border-box;
  border: 1px solid var(--form-border);
  border-radius: 20rpx;
  background: var(--form-surface);
  color: var(--ink);
  font-size: 28rpx;
  line-height: 40rpx;
}

.admin-input-placeholder {
  color: #B7BBB8;
}

.admin-btn-submit {
  width: 100%;
  height: 88rpx;
  min-height: 88rpx;
  margin-top: 28rpx;
  border: 0;
  border-radius: 16rpx;
  background: #2F4F46;
  display: flex;
  align-items: center;
  justify-content: center;
}

.admin-btn-submit::after {
  border: 0;
}

.admin-btn-submit:active {
  opacity: 0.88;
}

.admin-btn-submit[disabled] {
  opacity: 0.46;
}

.admin-btn-text {
  color: #FFFFFF;
  font-size: 28rpx;
  font-weight: 500;
}

.admin-switch-mode {
  margin-top: 28rpx;
  text-align: center;
}

.admin-switch-link {
  color: var(--text-soft);
  font-size: 24rpx;
  line-height: 34rpx;
}
