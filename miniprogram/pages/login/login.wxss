.page {
  position: relative;
  min-height: 100vh;
  background: #ffffff;
  box-sizing: border-box;
  overflow: hidden;
  color: #111111;
  font-family: var(--font-body);
}

.page-admin {
  padding: 0;
  overflow: hidden;
}

.poster-page {
  position: relative;
  min-height: 100vh;
  overflow: hidden;
  background: #ffffff;
  box-sizing: border-box;
}

.poster-background {
  position: absolute;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  width: 100%;
  height: 100%;
  pointer-events: none;
}

.poster-mark {
  position: absolute;
  left: 80rpx;
  top: 460rpx;
  z-index: 2;
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  pointer-events: none;
}

.poster-mark-en {
  display: flex;
  align-items: center;
  color: #123d97;
  font-family: "LorchinSansP0", "PingFang SC", "SF Pro Text", -apple-system, BlinkMacSystemFont, sans-serif;
  font-size: 22rpx;
  line-height: 1.2;
  transform: translateX(5rpx);
}

.poster-letter {
  margin-right: 10rpx;
}

.poster-letter:last-child {
  margin-right: 0;
}

.poster-admin-hotspot {
  position: absolute;
  top: 408rpx;
  right: 0;
  width: 360rpx;
  height: 450rpx;
  z-index: 6;
}

.login-page {
  position: absolute;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  z-index: 3;
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
  padding: 0 0 calc(24rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

.admin-page {
  position: absolute;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  z-index: 4;
  display: flex;
  align-items: flex-end;
  justify-content: center;
  padding: 0 32rpx 52rpx;
  box-sizing: border-box;
}

.admin-card {
  width: 100%;
  padding: 32rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.94);
  border: 1rpx solid rgba(17, 17, 17, 0.08);
  box-sizing: border-box;
}

.admin-card-head {
  margin-bottom: 24rpx;
}

.poster-message-stack {
  margin: 0 40rpx 18rpx;
  max-width: 78%;
}

.poster-message {
  margin-top: 14rpx;
  padding: 18rpx 20rpx;
  border: 1rpx solid rgba(17, 17, 17, 0.08);
  border-radius: 16rpx;
  background: rgba(255, 255, 255, 0.78);
}

.poster-warning {
  color: #8a7451;
}

.poster-error {
  color: #b24137;
}

.poster-message-text {
  font-size: 24rpx;
  line-height: 34rpx;
}

.poster-login-action {
  position: absolute;
  right: 0rpx;
  bottom: calc(380rpx + env(safe-area-inset-bottom));
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  z-index: 4;
}

.poster-login-trigger {
  width: 274rpx;
  height: 64rpx;
  min-height: 64rpx;
  padding: 0;
  margin: 0;
  background: transparent;
  border: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  gap: 18rpx;
}

.poster-login-trigger::after {
  border: 0;
}

.poster-login-trigger-text {
  color: #123d97;
  font-size: 26rpx;
  line-height: 42rpx;
  font-weight: 500;
  letter-spacing: 0.24em;
}

.poster-login-trigger-arrow {
  color: #123d97;
  font-size: 36rpx;
  line-height: 42rpx;
  font-weight: 300;
  transform: translateY(-2rpx);
}

.poster-login-trigger[disabled] {
  opacity: 0.46;
}

.poster-loading-tip {
  margin-top: 14rpx;
  text-align: center;
  pointer-events: none;
}

.poster-loading-text {
  display: inline-block;
  padding: 12rpx 22rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.72);
  color: rgba(17, 17, 17, 0.82);
  font-size: 22rpx;
  line-height: 30rpx;
  border: 1rpx solid rgba(17, 17, 17, 0.08);
}

.admin-brand-title {
  display: block;
  color: #111111;
  font-size: 40rpx;
  line-height: 54rpx;
  font-weight: 500;
}

.admin-brand-subtitle {
  display: block;
  margin-top: 8rpx;
  color: #999999;
  font-size: 20rpx;
  line-height: 28rpx;
  letter-spacing: 0.18em !important;
  font-weight: 400;
}

.admin-unsafe-tip,
.admin-error-box {
  margin-bottom: 18rpx;
  padding: 16rpx 18rpx;
  border-radius: 16rpx;
  border: 1rpx solid rgba(17, 17, 17, 0.08);
  background: rgba(17, 17, 17, 0.03);
}

.admin-unsafe-tip {
  color: #8a7451;
}

.admin-error-box {
  color: #b24137;
}

.admin-tip-text,
.admin-error-text {
  font-size: 24rpx;
  line-height: 34rpx;
  font-weight: 400;
}

.admin-field {
  margin-bottom: 22rpx;
}

.admin-field-label {
  display: block;
  margin-bottom: 12rpx;
  color: #666666;
  font-size: 24rpx;
  line-height: 34rpx;
}

.admin-input-wrap {
  position: relative;
}

.admin-input {
  width: 100%;
  height: 88rpx;
  padding: 0 24rpx;
  box-sizing: border-box;
  border: 1rpx solid rgba(17, 17, 17, 0.08);
  border-radius: 20rpx;
  background: #ffffff;
  color: #111111;
  font-size: 28rpx;
  line-height: 40rpx;
}

.admin-input-placeholder {
  color: #bbbbbb;
}

.admin-btn-submit {
  width: 100%;
  height: 88rpx;
  min-height: 88rpx;
  margin-top: 24rpx;
  border: 0;
  border-radius: 16rpx;
  background: #111111;
  display: flex;
  align-items: center;
  justify-content: center;
}

.admin-btn-submit::after {
  border: 0;
}

.admin-btn-submit:active {
  opacity: 0.88;
}

.admin-btn-submit[disabled] {
  opacity: 0.46;
}

.admin-btn-text {
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 500;
}

.admin-switch-mode {
  margin-top: 20rpx;
  text-align: center;
}

.admin-switch-link {
  color: #666666;
  font-size: 24rpx;
  line-height: 34rpx;
}
