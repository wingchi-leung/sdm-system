/**
 * 登录页 - Bold Minimal
 * 设计亮点：大胆的品牌展示 + 极简登录
 */

.page {
  min-height: 100vh;
  padding: 0 var(--space-xl);
  background: var(--bg-primary);
  display: flex;
  flex-direction: column;
}

/* ─────────────────────────────────────────────────────────────
 * 品牌区域 - 戏剧性设计
 * ───────────────────────────────────────────────────────────── */
.brand-section {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: var(--space-3xl) 0;
}

.brand-logo {
  width: 140rpx;
  height: 140rpx;
  border-radius: var(--radius-2xl);
  background: var(--text-primary);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: var(--space-2xl);
  box-shadow: var(--shadow-bold);
}

.logo-text {
  font-family: var(--font-display);
  font-size: 44rpx;
  font-weight: 800;
  color: #FFFFFF;
  letter-spacing: -0.02em;
}

.brand-title {
  font-family: var(--font-display);
  font-size: 52rpx;
  font-weight: 700;
  color: var(--text-primary);
  letter-spacing: -0.03em;
  margin-bottom: var(--space-sm);
}

.brand-subtitle {
  font-size: 28rpx;
  color: var(--text-tertiary);
  letter-spacing: 0.01em;
}

/* ─────────────────────────────────────────────────────────────
 * 警告提示
 * ───────────────────────────────────────────────────────────── */
.warning-tip {
  display: flex;
  align-items: center;
  gap: var(--space-sm);
  margin-bottom: var(--space-xl);
  padding: var(--space-md) var(--space-lg);
  background: var(--warning-bg);
  border-radius: var(--radius-lg);
  border-left: 6rpx solid var(--warning);
}

.warning-icon {
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  background: var(--warning);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.warning-icon text {
  font-size: 24rpx;
  color: #FFFFFF;
  font-weight: 700;
}

.warning-text {
  font-size: 26rpx;
  color: var(--warning);
  font-weight: 500;
}

/* ─────────────────────────────────────────────────────────────
 * 表单区域
 * ───────────────────────────────────────────────────────────── */
.form-section {
  padding-bottom: var(--space-3xl);
}

.input-group {
  display: flex;
  flex-direction: column;
  gap: var(--space-lg);
  margin-bottom: var(--space-xl);
}

.input-item {
  display: flex;
  flex-direction: column;
  gap: var(--space-sm);
}

.input-label {
  font-size: 24rpx;
  font-weight: 600;
  color: var(--text-secondary);
  letter-spacing: 0.04em;
  text-transform: uppercase;
}

.input {
  width: 100%;
  height: 104rpx;
  padding: 0 var(--space-lg);
  font-size: 32rpx;
  background: var(--bg-secondary);
  border: 2rpx solid transparent;
  border-radius: var(--radius-xl);
  box-sizing: border-box;
  color: var(--text-primary);
  transition: all 0.25s ease;
}

.input:focus {
  background: var(--bg-primary);
  border-color: var(--accent);
  box-shadow: 0 0 0 6rpx var(--accent-light);
}

.input-placeholder {
  color: var(--text-muted);
}

/* ─────────────────────────────────────────────────────────────
 * 错误提示
 * ───────────────────────────────────────────────────────────── */
.error-box {
  margin-bottom: var(--space-lg);
  padding: var(--space-md) var(--space-lg);
  background: var(--error-bg);
  border-radius: var(--radius-lg);
  border-left: 6rpx solid var(--error);
}

.error-text {
  font-size: 26rpx;
  color: var(--error);
  font-weight: 500;
}

/* ─────────────────────────────────────────────────────────────
 * 提交按钮
 * ───────────────────────────────────────────────────────────── */
.btn-submit {
  width: 100%;
  height: 108rpx;
  background: var(--text-primary);
  border-radius: var(--radius-full);
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  box-shadow: var(--shadow-bold);
}

.btn-submit::after {
  border: none;
}

.btn-submit:active {
  transform: scale(0.97);
  box-shadow: var(--shadow-md);
}

.btn-submit[disabled] {
  opacity: 0.5;
  transform: none;
}

.submit-text {
  font-size: 32rpx;
  font-weight: 600;
  color: #FFFFFF;
  letter-spacing: 0.04em;
}

/* 切换链接 */
.switch-row {
  margin-top: var(--space-xl);
  text-align: center;
}

.switch-text {
  font-size: 28rpx;
  color: var(--text-tertiary);
  font-weight: 500;
}

/* ─────────────────────────────────────────────────────────────
 * 微信登录按钮 - 大胆设计
 * ───────────────────────────────────────────────────────────── */
.btn-wechat {
  width: 100%;
  height: 112rpx;
  background: var(--accent);
  border-radius: var(--radius-full);
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: var(--space-md);
  box-shadow: var(--shadow-accent);
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}

.btn-wechat::after {
  border: none;
}

.btn-wechat:active {
  transform: scale(0.97);
  box-shadow: var(--shadow-sm);
}

.btn-wechat[disabled] {
  opacity: 0.5;
}

.wechat-icon {
  width: 48rpx;
  height: 48rpx;
  border-radius: var(--radius-md);
  background: rgba(255, 255, 255, 0.25);
  display: flex;
  align-items: center;
  justify-content: center;
}

.wechat-icon text {
  font-size: 24rpx;
  font-weight: 700;
  color: #FFFFFF;
}

.wechat-text {
  font-size: 32rpx;
  font-weight: 600;
  color: #FFFFFF;
  letter-spacing: 0.04em;
}

/* ─────────────────────────────────────────────────────────────
 * 底部装饰
 * ───────────────────────────────────────────────────────────── */
.footer-decoration {
  padding: var(--space-2xl) 0;
  display: flex;
  justify-content: center;
}

.deco-dots {
  display: flex;
  gap: var(--space-sm);
}

.deco-dots .dot {
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  background: var(--border-strong);
}

.deco-dots .dot.active {
  width: 24rpx;
  border-radius: 4rpx;
  background: var(--accent);
}