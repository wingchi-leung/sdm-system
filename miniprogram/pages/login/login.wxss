.page {
  position: relative;
  min-height: 100vh;
  background: #F5F1EA;
  box-sizing: border-box;
  overflow: hidden;
}

.page-admin {
  padding: 0 32rpx;
  overflow-y: auto;
}

.poster-page {
  position: relative;
  min-height: 100vh;
  overflow: hidden;
  background:
    radial-gradient(circle at 24% 18%, rgba(255, 255, 255, 0.94) 0%, rgba(255, 255, 255, 0.88) 28%, rgba(245, 241, 234, 0.82) 62%, rgba(241, 236, 229, 0.96) 100%),
    linear-gradient(180deg, #F7F3EE 0%, #F5F1EA 100%);
}

.poster-paper,
.poster-noise,
.poster-wash {
  position: absolute;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  pointer-events: none;
}

.poster-paper {
  background:
    radial-gradient(circle at 15% 20%, rgba(255, 255, 255, 0.72) 0%, rgba(255, 255, 255, 0.08) 30%, transparent 56%),
    radial-gradient(circle at 84% 36%, rgba(255, 255, 255, 0.82) 0%, rgba(255, 255, 255, 0.08) 24%, transparent 54%),
    linear-gradient(180deg, rgba(255, 255, 255, 0.46) 0%, rgba(255, 255, 255, 0.16) 20%, rgba(255, 255, 255, 0.04) 54%, rgba(255, 255, 255, 0.28) 100%);
}

.poster-noise {
  opacity: 0.32;
  background:
    linear-gradient(120deg, rgba(10, 57, 112, 0.015) 0%, transparent 18%, rgba(10, 57, 112, 0.012) 41%, transparent 59%, rgba(10, 57, 112, 0.013) 82%, transparent 100%),
    linear-gradient(60deg, rgba(255, 255, 255, 0.24) 0%, transparent 32%, rgba(255, 255, 255, 0.18) 68%, transparent 100%);
}

.poster-wash-left {
  background: radial-gradient(circle at 12% 42%, rgba(209, 221, 242, 0.14) 0%, rgba(209, 221, 242, 0.08) 18%, transparent 44%);
}

.poster-wash-right {
  background: radial-gradient(circle at 83% 63%, rgba(180, 204, 233, 0.18) 0%, rgba(180, 204, 233, 0.08) 18%, transparent 46%);
}

.poster-mountain {
  position: absolute;
  width: 100%;
  pointer-events: none;
}

.poster-mountain-side {
  left: -62rpx;
  bottom: 372rpx;
  width: 290rpx;
  height: 720rpx;
  opacity: 0.22;
}

.poster-mountain-main {
  right: -120rpx;
  bottom: 120rpx;
  width: 600rpx;
  height: 980rpx;
  opacity: 0.28;
  transform: scaleX(-1);
}

.poster-top {
  position: absolute;
  top: 118rpx;
  left: 42rpx;
  right: 42rpx;
  z-index: 2;
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
}

.poster-altitude {
  display: flex;
  align-items: center;
}

.poster-altitude-mark {
  width: 0;
  height: 0;
  border-left: 12rpx solid transparent;
  border-right: 12rpx solid transparent;
  border-bottom: 34rpx solid #163A6B;
  margin-right: 18rpx;
}

.poster-altitude-copy,
.poster-coordinates {
  display: flex;
  flex-direction: column;
}

.poster-coordinates {
  align-items: flex-end;
}

.poster-coordinates .poster-meta-number + .poster-meta-number {
  margin-top: 4rpx;
}

.poster-meta-number,
.poster-meta-label {
  color: #163A6B;
  font-size: 20rpx;
  line-height: 28rpx;
  letter-spacing: 5rpx !important;
}

.poster-meta-label {
  margin-top: 6rpx;
  font-size: 18rpx;
  line-height: 24rpx;
}

.poster-plus {
  position: absolute;
  top: 176rpx;
  right: 44rpx;
  width: 34rpx;
  height: 34rpx;
  z-index: 2;
}

.poster-plus-h,
.poster-plus-v {
  position: absolute;
  background: rgba(22, 58, 107, 0.92);
  border-radius: 999rpx;
}

.poster-plus-h {
  top: 16rpx;
  left: 0;
  width: 34rpx;
  height: 2rpx;
}

.poster-plus-v {
  top: 0;
  left: 16rpx;
  width: 2rpx;
  height: 34rpx;
}

.poster-copy {
  position: relative;
  z-index: 2;
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  padding: 346rpx 0 0 72rpx;
}

.poster-title {
  color: #153B6D;
  font-family: "Times New Roman", "Noto Serif SC", serif;
  font-weight: 400;
}

.poster-title-main {
  font-size: 112rpx;
  line-height: 1;
}

.poster-title-secondary {
  margin-top: 10rpx;
  font-size: 92rpx;
  line-height: 0.96;
}

.poster-title-italic {
  margin-top: 44rpx;
  font-size: 98rpx;
  line-height: 1;
  font-style: italic;
}

.poster-caption {
  position: absolute;
  top: 1028rpx;
  left: 76rpx;
  z-index: 2;
  display: flex;
  align-items: flex-start;
}

.poster-caption-line {
  width: 2rpx;
  height: 84rpx;
  background: rgba(22, 58, 107, 0.72);
  margin-right: 28rpx;
}

.poster-caption-copy {
  display: flex;
  flex-direction: column;
  padding-top: 6rpx;
}

.poster-caption-text {
  color: #163A6B;
  font-size: 22rpx;
  line-height: 30rpx;
  font-weight: 600;
  letter-spacing: 4rpx !important;
}

.poster-caption-text + .poster-caption-text {
  margin-top: 10rpx;
}

.poster-route {
  position: absolute;
  border: 2rpx solid rgba(93, 136, 188, 0.7);
  border-color: rgba(93, 136, 188, 0.72) transparent transparent transparent;
  border-radius: 50% 50% 0 0;
  pointer-events: none;
}

.route-a {
  left: -72rpx;
  top: 1046rpx;
  width: 408rpx;
  height: 204rpx;
  transform: rotate(-22deg);
}

.route-b {
  left: 236rpx;
  top: 934rpx;
  width: 422rpx;
  height: 230rpx;
  transform: rotate(14deg);
}

.route-c {
  left: 464rpx;
  top: 818rpx;
  width: 256rpx;
  height: 182rpx;
  transform: rotate(38deg);
}

.poster-message-stack {
  position: absolute;
  left: 52rpx;
  right: 52rpx;
  bottom: 404rpx;
  z-index: 4;
}

.poster-message {
  margin-top: 18rpx;
  padding: 20rpx 24rpx;
  border: 1px solid rgba(22, 58, 107, 0.12);
  border-radius: 16rpx;
  background: rgba(255, 255, 255, 0.74);
}

.poster-warning {
  color: #8A7451;
}

.poster-error {
  color: var(--error);
}

.poster-message-text {
  font-size: 24rpx;
  line-height: 34rpx;
}

.poster-login-trigger {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 3;
  height: 520rpx;
  min-height: 520rpx;
  padding: 0;
  background: transparent;
  border: 0;
  display: block;
}

.poster-login-trigger::after {
  border: 0;
}

.poster-login-trigger[disabled] {
  opacity: 0.72;
}

.login-axis-vertical {
  position: absolute;
  left: 336rpx;
  bottom: 104rpx;
  width: 2rpx;
  height: 342rpx;
  background: rgba(22, 58, 107, 0.84);
}

.login-axis-dot {
  position: absolute;
  left: 332rpx;
  bottom: 440rpx;
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  background: rgba(22, 58, 107, 0.94);
}

.login-axis-horizontal {
  position: absolute;
  left: 336rpx;
  bottom: 338rpx;
  width: 222rpx;
  height: 2rpx;
  background: rgba(22, 58, 107, 0.84);
}

.login-axis-label {
  position: absolute;
  left: 360rpx;
  bottom: 358rpx;
  color: #163A6B;
  font-size: 24rpx;
  line-height: 32rpx;
  letter-spacing: 8rpx !important;
  font-weight: 500;
}

.login-axis-arrow {
  position: absolute;
  left: 540rpx;
  bottom: 324rpx;
  width: 34rpx;
  height: 34rpx;
}

.login-axis-arrow-line {
  position: absolute;
  top: 16rpx;
  left: 0;
  width: 28rpx;
  height: 2rpx;
  background: rgba(22, 58, 107, 0.92);
}

.login-axis-arrow-head {
  position: absolute;
  right: 2rpx;
  width: 16rpx;
  height: 2rpx;
  background: rgba(22, 58, 107, 0.92);
  transform-origin: right center;
}

.login-axis-arrow-head-top {
  top: 10rpx;
  transform: rotate(45deg);
}

.login-axis-arrow-head-bottom {
  top: 22rpx;
  transform: rotate(-45deg);
}

.poster-footprint {
  position: absolute;
  left: -48rpx;
  right: -48rpx;
  bottom: -12rpx;
  height: 238rpx;
  pointer-events: none;
}

.footprint-line {
  position: absolute;
  left: 0;
  right: 0;
  border-top: 1px solid rgba(120, 144, 178, 0.12);
  border-radius: 50% 50% 0 0;
}

.footprint-line-a {
  bottom: 0;
  height: 92rpx;
}

.footprint-line-b {
  bottom: 22rpx;
  left: -20rpx;
  right: -20rpx;
  height: 120rpx;
}

.footprint-line-c {
  bottom: 44rpx;
  left: -36rpx;
  right: -36rpx;
  height: 150rpx;
}

.footprint-line-d {
  bottom: 66rpx;
  left: -56rpx;
  right: -56rpx;
  height: 182rpx;
}

.admin-legacy-page {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  box-sizing: border-box;
}

.admin-brand-section {
  flex: 1;
  min-height: 560rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: flex-end;
  padding-bottom: 48rpx;
}

.admin-brand-icon {
  width: 300rpx;
  height: 300rpx;
  margin-bottom: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.admin-gate-icon {
  width: 280rpx;
  height: 280rpx;
}

.admin-brand-title {
  color: var(--ink);
  font-size: 44rpx;
  line-height: 56rpx;
  font-weight: 500;
}

.admin-brand-subtitle {
  margin-top: 14rpx;
  color: var(--ink);
  font-size: 24rpx;
  line-height: 34rpx;
  font-weight: 400;
}

.admin-unsafe-tip,
.admin-error-box {
  margin-bottom: 28rpx;
  padding: 22rpx 24rpx;
  border-left: 3rpx solid var(--warning);
  background: var(--warning-bg);
  display: flex;
  align-items: flex-start;
  gap: 14rpx;
}

.admin-error-box {
  border-left-color: var(--error);
  background: var(--error-bg);
}

.admin-tip-icon {
  width: 28rpx;
  height: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.admin-tip-icon text,
.admin-tip-text {
  color: var(--warning);
  font-size: 24rpx;
  line-height: 34rpx;
  font-weight: 400;
}

.admin-error-text {
  color: var(--error);
  font-size: 24rpx;
  line-height: 34rpx;
  font-weight: 400;
}

.admin-form-section {
  padding-bottom: 34rpx;
}

.admin-field {
  margin-bottom: 24rpx;
}

.admin-field-label {
  display: block;
  margin-bottom: 12rpx;
  color: var(--text-secondary);
  font-size: 24rpx;
  line-height: 34rpx;
}

.admin-input-wrap {
  position: relative;
}

.admin-input {
  width: 100%;
  height: 88rpx;
  padding: 0 28rpx;
  box-sizing: border-box;
  border: 1px solid var(--form-border);
  border-radius: 20rpx;
  background: var(--form-surface);
  color: var(--ink);
  font-size: 28rpx;
  line-height: 40rpx;
}

.admin-input-placeholder {
  color: #B7BBB8;
}

.admin-btn-submit {
  width: 100%;
  height: 88rpx;
  min-height: 88rpx;
  margin-top: 28rpx;
  border: 0;
  border-radius: 16rpx;
  background: #2F4F46;
  display: flex;
  align-items: center;
  justify-content: center;
}

.admin-btn-submit::after {
  border: 0;
}

.admin-btn-submit:active {
  opacity: 0.88;
}

.admin-btn-submit[disabled] {
  opacity: 0.46;
}

.admin-btn-text {
  color: #FFFFFF;
  font-size: 28rpx;
  font-weight: 500;
}

.admin-switch-mode {
  margin-top: 28rpx;
  text-align: center;
}

.admin-switch-link {
  color: var(--text-soft);
  font-size: 24rpx;
  line-height: 34rpx;
}
