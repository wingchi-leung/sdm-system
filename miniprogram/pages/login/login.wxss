/**
 * 登录页
 */

.page {
  min-height: 100vh;
  padding: var(--space-lg);
  background: var(--background);
}

/* 头部 */
.header {
  text-align: center;
  padding: var(--space-xl) 0;
  margin-bottom: var(--space-lg);
}

.gate-icon {
  width: 80rpx;
  height: 80rpx;
  margin-bottom: var(--space-md);
}

.title {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: var(--space-sm);
}

.subtitle {
  font-size: 28rpx;
  color: var(--text-secondary);
}

/* 警告提示 */
.unsafe-tip {
  margin-bottom: var(--space-lg);
  padding: var(--space-md);
  background: var(--warning-bg);
  border-radius: 8rpx;
  font-size: 26rpx;
  color: var(--warning);
  border: 1px solid rgba(243, 156, 18, 0.3);
}

/* 表单 */
.form {
  background: var(--background-card);
  border-radius: 12rpx;
  padding: var(--space-lg);
  box-shadow: var(--shadow);
  border: 1px solid var(--border);
}

.field {
  margin-bottom: var(--space-lg);
}

.field:last-child {
  margin-bottom: 0;
}

.field-label {
  display: block;
  font-size: 28rpx;
  color: var(--text-secondary);
  margin-bottom: var(--space-sm);
  font-weight: 500;
}

.field-label.required::after {
  content: ' *';
  color: var(--error);
}

/* 错误提示 */
.error-box {
  margin: var(--space-md) 0;
  padding: var(--space-md);
  background: var(--error-bg);
  border-radius: 8rpx;
  font-size: 26rpx;
  color: var(--error);
  border: 1px solid rgba(231, 76, 60, 0.2);
}

/* 按钮 */
.submit-btn {
  width: 100%;
  margin-top: var(--space-lg);
  padding: 24rpx;
  font-size: 30rpx;
}

/* 微信登录 */
.wechat-row {
  margin-top: var(--space-md);
}

.btn-wechat {
  width: 100%;
  padding: 24rpx;
  font-size: 28rpx;
  color: #07C160;
  background: transparent;
  border: 1px solid #07C160;
  border-radius: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: 500;
}

.btn-wechat::after {
  border: none;
}

.btn-wechat-icon {
  margin-right: var(--space-sm);
  font-size: 28rpx;
}

/* 注册引导 */
.register-row {
  margin-top: var(--space-lg);
  text-align: center;
}

.hint {
  font-size: 28rpx;
  color: var(--text-secondary);
}

.link {
  color: var(--primary);
  font-weight: 500;
}

/* 切换链接 */
.toggle-row {
  margin-top: var(--space-lg);
  text-align: center;
}

.toggle-link {
  font-size: 28rpx;
  color: var(--text-secondary);
}

/* 角色切换 */
.role-toggle {
  display: flex;
  background: var(--background-input);
  border-radius: 8rpx;
  padding: 4rpx;
  margin-bottom: var(--space-lg);
}

.role-toggle-item {
  flex: 1;
  text-align: center;
  padding: 12rpx;
  font-size: 26rpx;
  color: var(--text-secondary);
  border-radius: 6rpx;
}

.role-toggle-item.active {
  background: var(--background-card);
  color: var(--text-primary);
  font-weight: 500;
}
