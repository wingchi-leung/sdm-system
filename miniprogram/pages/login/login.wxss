.page {
  position: relative;
  min-height: 100vh;
  padding: 0 40rpx 56rpx;
  background: #FFFFFF;
  box-sizing: border-box;
  overflow: hidden;
}

.page-admin {
  padding-top: 72rpx;
}

.bg-orb {
  position: absolute;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(47, 79, 70, 0.08) 0%, rgba(47, 79, 70, 0) 72%);
  filter: blur(10rpx);
  pointer-events: none;
}

.orb-left {
  top: 120rpx;
  left: -120rpx;
  width: 420rpx;
  height: 420rpx;
}

.orb-right {
  right: -140rpx;
  bottom: 260rpx;
  width: 460rpx;
  height: 460rpx;
  background: radial-gradient(circle, rgba(17, 17, 17, 0.05) 0%, rgba(17, 17, 17, 0) 74%);
}

.hero-header {
  position: relative;
  z-index: 1;
  padding-top: 104rpx;
}

.hero-title-row {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.hero-spark {
  color: #111111;
  font-size: 50rpx;
  line-height: 1;
  font-weight: 500;
}

.hero-title {
  color: #111111;
  font-size: 64rpx;
  line-height: 1.1;
  font-weight: 600;
  letter-spacing: 1rpx;
}

.hero-body {
  position: relative;
  z-index: 1;
  min-height: calc(100vh - 220rpx);
  display: flex;
  flex-direction: column;
}

.brand-section {
  flex: 1;
  min-height: 720rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-top: 40rpx;
}

.brand-icon {
  width: 320rpx;
  height: 320rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 44rpx;
}

.gate-icon {
  width: 260rpx;
  height: 260rpx;
}

.brand-title {
  color: #111111;
  font-size: 68rpx;
  line-height: 1.18;
  font-weight: 600;
  letter-spacing: 1rpx;
}

.brand-subtitle {
  margin-top: 18rpx;
  color: #A0A0A0;
  font-size: 30rpx;
  line-height: 44rpx;
  font-weight: 400;
  letter-spacing: 0.6rpx;
}

.message-wrap {
  margin-top: -36rpx;
}

.unsafe-tip,
.error-box {
  margin-bottom: 20rpx;
  padding: 22rpx 24rpx;
  border-radius: 24rpx;
  border: 1px solid rgba(17, 17, 17, 0.06);
  background: rgba(255, 255, 255, 0.92);
  display: flex;
  align-items: flex-start;
  gap: 14rpx;
}

.unsafe-tip {
  color: #8A7451;
}

.error-box {
  color: var(--error);
}

.tip-icon {
  width: 28rpx;
  height: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 4rpx;
}

.tip-icon text,
.tip-text,
.error-text {
  font-size: 24rpx;
  line-height: 36rpx;
  font-weight: 400;
  letter-spacing: 0.4rpx;
}

.login-action-section {
  padding: 24rpx 0 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.btn-wechat {
  width: 100%;
  height: 104rpx;
  border: 0;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #0F1619 0%, #132126 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 18rpx 42rpx rgba(15, 22, 25, 0.14);
}

.btn-wechat::after {
  border: 0;
}

.btn-wechat:active {
  transform: translateY(2rpx);
  opacity: 0.94;
}

.btn-wechat[disabled] {
  opacity: 0.5;
}

.wechat-text {
  color: #FFFFFF;
  font-size: 32rpx;
  line-height: 44rpx;
  font-weight: 600;
  letter-spacing: 1rpx;
}

.login-hint {
  margin-top: 22rpx;
  color: #A0A0A0;
  font-size: 24rpx;
  line-height: 36rpx;
  text-align: center;
  letter-spacing: 0.4rpx;
}

.admin-wrap {
  max-width: 100%;
}

.admin-header {
  margin-bottom: 36rpx;
}

.admin-title {
  display: block;
  color: #111111;
  font-size: 52rpx;
  line-height: 64rpx;
  font-weight: 600;
}

.admin-subtitle {
  display: block;
  margin-top: 10rpx;
  color: #999999;
  font-size: 24rpx;
  line-height: 34rpx;
}

.field {
  margin-bottom: 24rpx;
}

.field-label {
  display: block;
  margin-bottom: 12rpx;
  color: var(--text-secondary);
  font-size: 24rpx;
  line-height: 34rpx;
  letter-spacing: 0.4rpx;
}

.input-wrap {
  position: relative;
}

.input {
  width: 100%;
  height: 92rpx;
  padding: 0 28rpx;
  box-sizing: border-box;
  border: 1px solid var(--form-border);
  border-radius: 24rpx;
  background: #FFFFFF;
  color: #111111;
  font-size: 28rpx;
  line-height: 40rpx;
}

.input:focus {
  border-color: var(--form-border-strong);
}

.input-placeholder {
  color: #B7BBB8;
}

.btn-submit {
  width: 100%;
  height: 92rpx;
  margin-top: 28rpx;
  border: 0;
  border-radius: 24rpx;
  background: #2F4F46;
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn-submit::after {
  border: 0;
}

.btn-submit:active {
  opacity: 0.88;
}

.btn-submit[disabled] {
  opacity: 0.46;
}

.btn-text {
  color: #FFFFFF;
  font-size: 28rpx;
  font-weight: 500;
  letter-spacing: 0.4rpx;
}

.switch-mode {
  margin-top: 28rpx;
  text-align: center;
}

.switch-link {
  color: #8C8C8C;
  font-size: 24rpx;
  line-height: 34rpx;
  letter-spacing: 0.4rpx;
}
