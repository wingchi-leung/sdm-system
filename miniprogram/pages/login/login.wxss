.page {
  position: relative;
  min-height: 100vh;
  background: #ffffff;
  box-sizing: border-box;
  overflow: hidden;
  color: #111111;
  font-family: "PingFang SC", -apple-system, BlinkMacSystemFont, "Helvetica Neue", sans-serif;
}

.page-admin {
  padding: 0;
  overflow: hidden;
}

.poster-page {
  position: relative;
  min-height: 100vh;
  overflow: hidden;
  background: #ffffff;
  box-sizing: border-box;
}

.poster-background {
  position: absolute;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  width: 100%;
  height: 100%;
}

.poster-admin-hotspot {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 1260rpx;
  z-index: 2;
}

.admin-page {
  position: absolute;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  z-index: 4;
  display: flex;
  align-items: flex-end;
  justify-content: center;
  padding: 0 32rpx 52rpx;
  box-sizing: border-box;
}

.admin-card {
  width: 100%;
  padding: 32rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.94);
  border: 1rpx solid rgba(17, 17, 17, 0.08);
  box-sizing: border-box;
}

.admin-card-head {
  margin-bottom: 24rpx;
}

.poster-message-stack {
  position: absolute;
  left: 32rpx;
  right: 32rpx;
  bottom: 220rpx;
  z-index: 4;
}

.poster-message {
  margin-top: 16rpx;
  padding: 18rpx 20rpx;
  border: 1rpx solid rgba(17, 17, 17, 0.08);
  border-radius: 16rpx;
  background: rgba(255, 255, 255, 0.78);
}

.poster-warning {
  color: #8a7451;
}

.poster-error {
  color: #b24137;
}

.poster-message-text {
  font-size: 24rpx;
  line-height: 34rpx;
}

.poster-login-trigger {
  position: absolute;
  left: 320rpx;
  bottom: 220rpx;
  width: 260rpx;
  height: 170rpx;
  min-height: 170rpx;
  padding: 0;
  margin: 0;
  background: rgba(255, 255, 255, 0.01);
  border: 0;
  display: block;
  z-index: 5;
  opacity: 0.01;
  color: transparent;
  overflow: hidden;
}

.poster-login-trigger::after {
  border: 0;
}

.poster-login-trigger-text {
  font-size: 0;
  line-height: 0;
  color: transparent;
}

.poster-login-trigger[disabled] {
  opacity: 0.01;
}

.poster-loading-tip {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 146rpx;
  z-index: 6;
  text-align: center;
  pointer-events: none;
}

.poster-privacy-note {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 184rpx;
  z-index: 6;
  text-align: center;
}

.poster-privacy-note-text {
  display: inline-block;
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.7);
  color: rgba(17, 17, 17, 0.64);
  font-size: 20rpx;
  line-height: 28rpx;
}

.poster-loading-text {
  display: inline-block;
  padding: 12rpx 22rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.72);
  color: rgba(17, 17, 17, 0.82);
  font-size: 22rpx;
  line-height: 30rpx;
  border: 1rpx solid rgba(17, 17, 17, 0.08);
}

.admin-brand-title {
  display: block;
  color: #111111;
  font-size: 40rpx;
  line-height: 54rpx;
  font-weight: 500;
}

.admin-brand-subtitle {
  display: block;
  margin-top: 8rpx;
  color: #999999;
  font-size: 20rpx;
  line-height: 28rpx;
  letter-spacing: 0.18em !important;
  font-weight: 400;
}

.admin-unsafe-tip,
.admin-error-box {
  margin-bottom: 18rpx;
  padding: 16rpx 18rpx;
  border-radius: 16rpx;
  border: 1rpx solid rgba(17, 17, 17, 0.08);
  background: rgba(17, 17, 17, 0.03);
}

.admin-unsafe-tip {
  color: #8a7451;
}

.admin-error-box {
  color: #b24137;
}

.admin-tip-text,
.admin-error-text {
  font-size: 24rpx;
  line-height: 34rpx;
  font-weight: 400;
}

.admin-field {
  margin-bottom: 22rpx;
}

.admin-field-label {
  display: block;
  margin-bottom: 12rpx;
  color: #666666;
  font-size: 24rpx;
  line-height: 34rpx;
}

.admin-input-wrap {
  position: relative;
}

.admin-input {
  width: 100%;
  height: 88rpx;
  padding: 0 24rpx;
  box-sizing: border-box;
  border: 1rpx solid rgba(17, 17, 17, 0.08);
  border-radius: 20rpx;
  background: #ffffff;
  color: #111111;
  font-size: 28rpx;
  line-height: 40rpx;
}

.admin-input-placeholder {
  color: #bbbbbb;
}

.admin-btn-submit {
  width: 100%;
  height: 88rpx;
  min-height: 88rpx;
  margin-top: 24rpx;
  border: 0;
  border-radius: 16rpx;
  background: #111111;
  display: flex;
  align-items: center;
  justify-content: center;
}

.admin-btn-submit::after {
  border: 0;
}

.admin-btn-submit:active {
  opacity: 0.88;
}

.admin-btn-submit[disabled] {
  opacity: 0.46;
}

.admin-btn-text {
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 500;
}

.admin-switch-mode {
  margin-top: 20rpx;
  text-align: center;
}

.admin-switch-link {
  color: #666666;
  font-size: 24rpx;
  line-height: 34rpx;
}
