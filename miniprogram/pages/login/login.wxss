/**
 * 登录页 - 奢华简约风格
 */

.page {
  min-height: 100vh;
  padding: 0 48rpx;
  background: var(--background);
  display: flex;
  flex-direction: column;
}

/* ─────────────────────────────────────────────────────────────
 * 品牌区域
 * ───────────────────────────────────────────────────────────── */
.brand-section {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 160rpx 0 80rpx;
}

.brand-icon {
  width: 96rpx;
  height: 96rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 48rpx;
}

.gate-icon {
  width: 72rpx;
  height: 72rpx;
}

.brand-title {
  font-family: var(--font-display);
  font-size: 52rpx;
  font-weight: 600;
  color: var(--text-primary);
  letter-spacing: -0.02em;
  margin-bottom: 12rpx;
}

.brand-subtitle {
  font-size: 26rpx;
  color: var(--text-tertiary);
  letter-spacing: 0.02em;
  font-weight: 400;
}

/* ─────────────────────────────────────────────────────────────
 * 安全提示
 * ───────────────────────────────────────────────────────────── */
.unsafe-tip {
  display: flex;
  align-items: flex-start;
  gap: var(--space-sm);
  margin-bottom: var(--space-xl);
  padding: var(--space-md);
  background: var(--warning-bg);
  border-left: 2px solid var(--warning);
}

.tip-icon {
  width: 32rpx;
  height: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.tip-icon text {
  font-size: 20rpx;
  color: var(--warning);
  font-weight: 600;
}

.tip-text {
  font-size: 22rpx;
  color: var(--warning);
  line-height: 1.5;
  letter-spacing: 0.02em;
}

/* ─────────────────────────────────────────────────────────────
 * 表单区域
 * ───────────────────────────────────────────────────────────── */
.form-section {
  padding-bottom: 80rpx;
}

.field {
  margin-bottom: 32rpx;
}

.field-label {
  display: block;
  font-size: 24rpx;
  color: var(--text-tertiary);
  margin-bottom: 12rpx;
  font-weight: 500;
  letter-spacing: 0.02em;
}

.input-wrap {
  position: relative;
}

.input {
  width: 100%;
  height: 96rpx;
  padding: 0 24rpx;
  font-size: 30rpx;
  background: var(--background-card);
  border: 1.5px solid var(--border);
  border-radius: 16rpx;
  box-sizing: border-box;
  color: var(--text-primary);
  transition: all 0.3s ease;
  letter-spacing: -0.01em;
}

.input:focus {
  border-color: var(--primary);
  box-shadow: 0 0 0 4rpx var(--primary-light);
}

.input-placeholder {
  color: var(--text-muted);
}

/* ─────────────────────────────────────────────────────────────
 * 错误提示
 * ───────────────────────────────────────────────────────────── */
.error-box {
  margin-bottom: var(--space-lg);
  padding: var(--space-md);
  background: var(--error-bg);
  border-left: 2px solid var(--error);
}

.error-text {
  font-size: 24rpx;
  color: var(--error);
  letter-spacing: 0.02em;
}

/* ─────────────────────────────────────────────────────────────
 * 提交按钮
 * ───────────────────────────────────────────────────────────── */
.btn-submit {
  width: 100%;
  height: 104rpx;
  background: var(--primary);
  border-radius: 980rpx;
  border: none;
  transition: all 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  margin-top: 48rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.12);
}

.btn-submit::after {
  border: none;
}

.btn-submit:active {
  transform: scale(0.97);
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
}

.btn-submit[disabled] {
  opacity: 0.4;
}

.btn-submit .btn-text {
  font-size: 32rpx;
  font-weight: 500;
  color: #FFFFFF;
  letter-spacing: -0.01em;
}

/* ─────────────────────────────────────────────────────────────
 * 微信登录按钮
 * ───────────────────────────────────────────────────────────── */
.btn-wechat {
  width: 100%;
  height: 104rpx;
  background: var(--background-card);
  border-radius: 980rpx;
  border: 1.5px solid var(--border);
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  transition: all 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94);
}

.btn-wechat::after {
  border: none;
}

.btn-wechat:active {
  background: var(--background-subtle);
  transform: scale(0.97);
}

.btn-wechat[disabled] {
  opacity: 0.4;
}

.wechat-icon {
  width: 40rpx;
  height: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.wechat-icon text {
  font-size: 28rpx;
  color: #07C160;
  font-weight: 700;
}

.wechat-text {
  font-size: 32rpx;
  font-weight: 500;
  color: var(--text-primary);
  letter-spacing: -0.01em;
}

/* ─────────────────────────────────────────────────────────────
 * 切换模式
 * ───────────────────────────────────────────────────────────── */
.switch-mode {
  margin-top: var(--space-xl);
  text-align: center;
}

.switch-link {
  font-size: 24rpx;
  color: var(--text-tertiary);
  letter-spacing: 0.06em;
  transition: color 0.2s ease;
}

.switch-link:active {
  color: var(--text-secondary);
}

/* ─────────────────────────────────────────────────────────────
 * 底部装饰
 * ───────────────────────────────────────────────────────────── */
.footer-decoration {
  padding: var(--space-2xl) 0;
  display: flex;
  justify-content: center;
}

.decoration-line {
  width: 40rpx;
  height: 1px;
  background: var(--border);
}

/* ─────────────────────────────────────────────────────────────
 * 登录分隔线
 * ───────────────────────────────────────────────────────────── */
.login-divider {
  display: flex;
  align-items: center;
  justify-content: center;
  margin: var(--space-xl) 0;
}

.divider-line {
  flex: 1;
  height: 1px;
  background: var(--border);
}

.divider-text {
  padding: 0 var(--space-md);
  font-size: 22rpx;
  color: var(--text-muted);
  letter-spacing: 0.05em;
}

/* ─────────────────────────────────────────────────────────────
 * 次要按钮
 * ───────────────────────────────────────────────────────────── */
.btn-secondary {
  width: 100%;
  height: 88rpx;
  background: transparent;
  border: 1px solid var(--border);
  border-radius: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}

.btn-secondary::after {
  border: none;
}

.btn-secondary:active {
  background: var(--background-subtle);
}

.btn-secondary[disabled] {
  opacity: 0.5;
}

.btn-secondary-text {
  font-size: 26rpx;
  font-weight: 400;
  color: var(--text-secondary);
  letter-spacing: 0.06em;
}