.page {
  position: relative;
  height: 100vh;
  background: #FFFFFF;
  box-sizing: border-box;
  overflow: hidden;
}

.page-admin {
  padding: 0;
  overflow: hidden;
}

.poster-page {
  position: relative;
  height: 100vh;
  overflow: hidden;
  background: #FFFFFF;
  box-sizing: border-box;
}

.poster-background {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: 1;
}

.poster-admin-hotspot {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 1260rpx;
  z-index: 2;
}

.admin-page {
  position: absolute;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  z-index: 4;
  display: flex;
  align-items: flex-end;
  justify-content: center;
  padding: 0 28rpx 56rpx;
  box-sizing: border-box;
}

.admin-card {
  width: 100%;
  padding: 38rpx 34rpx 34rpx;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.9);
  border: 1rpx solid rgba(29, 52, 79, 0.08);
  box-sizing: border-box;
}

.admin-card-head {
  margin-bottom: 28rpx;
}

.poster-message-stack {
  position: absolute;
  left: 40rpx;
  right: 40rpx;
  bottom: 240rpx;
  z-index: 4;
}

.poster-message {
  margin-top: 18rpx;
  padding: 20rpx 24rpx;
  border: 1px solid rgba(22, 58, 107, 0.12);
  border-radius: 16rpx;
  background: rgba(255, 255, 255, 0.74);
}

.poster-warning {
  color: #8A7451;
}

.poster-error {
  color: var(--error);
}

.poster-message-text {
  font-size: 24rpx;
  line-height: 34rpx;
}

.poster-login-trigger {
  position: absolute;
  left: 320rpx;
  bottom: 220rpx;
  width: 260rpx;
  height: 170rpx;
  min-height: 170rpx;
  padding: 0;
  margin: 0;
  background: rgba(255, 255, 255, 0.01);
  border: 0;
  display: block;
  z-index: 5;
  opacity: 0.01;
  color: transparent;
  overflow: hidden;
}

.poster-login-trigger::after {
  border: 0;
}

.poster-login-trigger-text {
  font-size: 0;
  line-height: 0;
  color: transparent;
}

.poster-login-trigger[disabled] {
  opacity: 0.01;
}

.poster-loading-tip {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 146rpx;
  z-index: 6;
  text-align: center;
  pointer-events: none;
}

.poster-privacy-note {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 184rpx;
  z-index: 6;
  text-align: center;
}

.poster-privacy-note-text {
  display: inline-block;
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.62);
  color: rgba(29, 52, 79, 0.72);
  font-size: 20rpx;
  line-height: 28rpx;
}

.poster-loading-text {
  display: inline-block;
  padding: 12rpx 24rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.3);
  color: rgba(22, 58, 107, 0.92);
  font-size: 22rpx;
  line-height: 30rpx;
  border: 1rpx solid rgba(22, 58, 107, 0.1);
  backdrop-filter: blur(10rpx);
  text-shadow: 0 1rpx 2rpx rgba(255, 255, 255, 0.58);
}

.admin-brand-title {
  display: block;
  color: #1D344F;
  font-size: 38rpx;
  line-height: 50rpx;
  font-weight: 500;
}

.admin-brand-subtitle {
  display: block;
  margin-top: 8rpx;
  color: rgba(29, 52, 79, 0.48);
  font-size: 20rpx;
  line-height: 28rpx;
  letter-spacing: 1.6rpx !important;
  font-weight: 400;
}

.admin-unsafe-tip,
.admin-error-box {
  margin-bottom: 22rpx;
  padding: 18rpx 20rpx;
  border-radius: 16rpx;
  border: 1rpx solid rgba(29, 52, 79, 0.08);
  background: rgba(255, 255, 255, 0.74);
}

.admin-unsafe-tip {
  color: #8A7451;
}

.admin-error-box {
  color: var(--error);
}

.admin-tip-text {
  font-size: 24rpx;
  line-height: 34rpx;
  font-weight: 400;
}

.admin-error-text {
  color: var(--error);
  font-size: 24rpx;
  line-height: 34rpx;
  font-weight: 400;
}

.admin-field {
  margin-bottom: 24rpx;
}

.admin-field-label {
  display: block;
  margin-bottom: 12rpx;
  color: var(--text-secondary);
  font-size: 24rpx;
  line-height: 34rpx;
}

.admin-input-wrap {
  position: relative;
}

.admin-input {
  width: 100%;
  height: 88rpx;
  padding: 0 28rpx;
  box-sizing: border-box;
  border: 1rpx solid rgba(29, 52, 79, 0.12);
  border-radius: 20rpx;
  background: rgba(255, 255, 255, 0.88);
  color: #1D344F;
  font-size: 28rpx;
  line-height: 40rpx;
}

.admin-input-placeholder {
  color: #B7BBB8;
}

.admin-btn-submit {
  width: 100%;
  height: 88rpx;
  min-height: 88rpx;
  margin-top: 28rpx;
  border: 0;
  border-radius: 999rpx;
  background: #1D344F;
  display: flex;
  align-items: center;
  justify-content: center;
}

.admin-btn-submit::after {
  border: 0;
}

.admin-btn-submit:active {
  opacity: 0.88;
}

.admin-btn-submit[disabled] {
  opacity: 0.46;
}

.admin-btn-text {
  color: #FFFFFF;
  font-size: 28rpx;
  font-weight: 500;
}

.admin-switch-mode {
  margin-top: 28rpx;
  text-align: center;
}

.admin-switch-link {
  color: rgba(29, 52, 79, 0.58);
  font-size: 24rpx;
  line-height: 34rpx;
}
