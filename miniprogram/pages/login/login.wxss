.page {
  min-height: 100vh;
  padding: 0 56rpx;
  background: #FFFFFF;
  display: flex;
  flex-direction: column;
  box-sizing: border-box;
}

.brand-section {
  flex: 1;
  min-height: 660rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: flex-end;
  padding-bottom: 78rpx;
}

.brand-icon {
  width: 340rpx;
  height: 340rpx;
  margin-bottom: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.gate-icon {
  width: 320rpx;
  height: 320rpx;
}

.brand-title {
  color: var(--ink);
  font-family: Georgia, 'Times New Roman', serif;
  font-size: 34rpx;
  line-height: 1.2;
  font-weight: 400;
  letter-spacing: 0.42em;
  text-indent: 0.42em;
}

.brand-subtitle {
  margin-top: 14rpx;
  color: var(--ink);
  font-size: 15rpx;
  letter-spacing: 0.44em;
  text-indent: 0.44em;
}

.unsafe-tip,
.error-box {
  margin-bottom: 28rpx;
  padding: 22rpx 24rpx;
  border-left: 3rpx solid var(--warning);
  background: var(--warning-bg);
  display: flex;
  align-items: flex-start;
  gap: 14rpx;
}

.error-box {
  border-left-color: var(--error);
  background: var(--error-bg);
}

.tip-icon {
  width: 28rpx;
  height: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.tip-icon text,
.tip-text {
  color: var(--warning);
  font-size: 22rpx;
  line-height: 1.5;
}

.error-text {
  color: var(--error);
  font-size: 23rpx;
  line-height: 1.5;
}

.form-section {
  padding-bottom: 34rpx;
}

.field {
  margin-bottom: 28rpx;
}

.field-label {
  display: block;
  margin-bottom: 12rpx;
  color: var(--text-soft);
  font-size: 22rpx;
  letter-spacing: 0.08em;
}

.input-wrap {
  position: relative;
}

.input {
  width: 100%;
  height: 88rpx;
  padding: 0 28rpx;
  box-sizing: border-box;
  border: 0;
  border-radius: 6rpx;
  background: #F8F8F6;
  color: var(--ink);
  font-size: 28rpx;
  letter-spacing: 0.03em;
}

.input-placeholder {
  color: #B7BBB8;
}

.btn-submit,
.btn-wechat {
  width: 100%;
  height: 92rpx;
  margin-top: 28rpx;
  border: 0;
  border-radius: 4rpx;
  background: var(--green);
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn-submit::after,
.btn-wechat::after {
  border: 0;
}

.btn-submit:active,
.btn-wechat:active {
  opacity: 0.88;
}

.btn-submit[disabled],
.btn-wechat[disabled] {
  opacity: 0.46;
}

.btn-submit .btn-text,
.wechat-text {
  color: #FFFFFF;
  font-size: 28rpx;
  font-weight: 400;
  letter-spacing: 0.08em;
}

.wechat-icon {
  display: none;
}

.switch-mode {
  margin-top: 28rpx;
  text-align: center;
}

.switch-link {
  color: var(--text-soft);
  font-size: 24rpx;
  letter-spacing: 0.06em;
}

.footer-decoration {
  padding: 48rpx 0 58rpx;
  display: flex;
  justify-content: center;
}

.decoration-line {
  display: none;
}

.login-divider,
.btn-secondary {
  display: none;
}

/* Product UI refinement：不改结构，仅收敛视觉规格 */
.page {
  padding: 0 32rpx;
}

.brand-section {
  min-height: 560rpx;
  padding-bottom: 48rpx;
}

.brand-icon {
  width: 300rpx;
  height: 300rpx;
  margin-bottom: 16rpx;
}

.gate-icon {
  width: 280rpx;
  height: 280rpx;
}

.brand-title {
  font-family: "PingFang SC", -apple-system, BlinkMacSystemFont, sans-serif;
  font-size: 44rpx;
  line-height: 56rpx;
  font-weight: 500;
  letter-spacing: 0.5rpx;
  text-indent: 0;
}

.brand-subtitle,
.field-label,
.switch-link,
.tip-text,
.error-text {
  font-size: 24rpx;
  line-height: 34rpx;
  font-weight: 400;
  letter-spacing: 0.4rpx;
}

.field {
  margin-bottom: 24rpx;
}

.input {
  height: 88rpx;
  border-radius: 16rpx;
  font-size: 28rpx;
  line-height: 40rpx;
}

.btn-submit,
.btn-wechat {
  height: 88rpx;
  border-radius: 16rpx;
  background: #2F4F46;
}

.btn-submit .btn-text,
.wechat-text {
  font-size: 28rpx;
  font-weight: 500;
  letter-spacing: 0.4rpx;
}
