.page {
  min-height: 100vh;
  padding: 48rpx 48rpx 64rpx;
  background: var(--background);
}

.header {
  text-align: center;
  margin-bottom: 48rpx;
}

.title {
  display: block;
  font-size: 40rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 8rpx;
}

.subtitle {
  font-size: 28rpx;
  color: var(--text-secondary);
}

.unsafe-tip {
  margin-bottom: 32rpx;
  padding: 28rpx;
  background: var(--warning-bg);
  border-radius: 16rpx;
  border: 1rpx solid rgba(255,149,0,0.3);
  font-size: 26rpx;
  color: #b86a00;
}

.form {
  background: var(--surface);
  border-radius: 24rpx;
  padding: 40rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.04);
}

.field {
  margin-bottom: 32rpx;
}

.label {
  display: block;
  font-size: 28rpx;
  color: var(--text-secondary);
  margin-bottom: 16rpx;
}

.input {
  width: 100%;
  height: 88rpx;
  padding: 0 24rpx;
  font-size: 30rpx;
  background: var(--background);
  border-radius: 16rpx;
  box-sizing: border-box;
}

.error-box {
  margin: 24rpx 0;
  padding: 24rpx;
  background: var(--error-bg);
  border-radius: 16rpx;
}

.error-text {
  font-size: 28rpx;
  color: var(--error);
}

.submit-btn {
  width: 100%;
  margin-top: 32rpx;
  padding: 32rpx;
  font-size: 32rpx;
}

.wechat-row {
  margin-top: 24rpx;
}

.btn-wechat {
  width: 100%;
  padding: 28rpx;
  font-size: 30rpx;
  color: #07c160;
  background: #fff;
  border: 2rpx solid #07c160;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn-wechat::after {
  border: none;
}

.btn-wechat-icon {
  margin-right: 12rpx;
  font-weight: 600;
}

.register-row {
  margin-top: 32rpx;
  text-align: center;
}

.hint {
  font-size: 28rpx;
  color: var(--text-secondary);
}

.link {
  font-size: 28rpx;
  color: var(--primary);
  margin-left: 8rpx;
}

.toggle-row {
  margin-top: 24rpx;
  text-align: center;
}

.toggle-link {
  font-size: 28rpx;
  color: var(--text-secondary);
}
