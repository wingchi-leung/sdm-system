.page {
  position: relative;
  min-height: 100vh;
  padding: 0 40rpx 56rpx;
  background: #FFFFFF;
  box-sizing: border-box;
  overflow: hidden;
}

.page-admin {
  padding: 0 32rpx;
}

.bg-orb {
  position: absolute;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(47, 79, 70, 0.08) 0%, rgba(47, 79, 70, 0) 72%);
  filter: blur(10rpx);
  pointer-events: none;
}

.orb-left {
  top: 120rpx;
  left: -120rpx;
  width: 420rpx;
  height: 420rpx;
}

.orb-right {
  right: -140rpx;
  bottom: 260rpx;
  width: 460rpx;
  height: 460rpx;
  background: radial-gradient(circle, rgba(17, 17, 17, 0.05) 0%, rgba(17, 17, 17, 0) 74%);
}

.hero-header {
  position: relative;
  z-index: 1;
  padding-top: 92rpx;
}

.hero-title-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.hero-spark {
  color: #111111;
  font-size: 38rpx;
  line-height: 1;
  font-weight: 400;
}

.hero-title {
  color: #111111;
  font-size: 54rpx;
  line-height: 1.12;
  font-weight: 500;
  letter-spacing: 0.4rpx;
}

.hero-body {
  position: relative;
  z-index: 1;
  min-height: calc(100vh - 220rpx);
  display: flex;
  flex-direction: column;
}

.brand-section {
  flex: 1;
  min-height: 660rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-top: 20rpx;
}

.brand-icon {
  width: 280rpx;
  height: 280rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 32rpx;
}

.gate-icon {
  width: 220rpx;
  height: 220rpx;
}

.brand-title {
  color: #111111;
  font-size: 50rpx;
  line-height: 1.2;
  font-weight: 500;
  letter-spacing: 0.4rpx;
}

.brand-subtitle {
  margin-top: 14rpx;
  color: #A0A0A0;
  font-size: 24rpx;
  line-height: 36rpx;
  font-weight: 400;
  letter-spacing: 0.2rpx;
}

.message-wrap {
  margin-top: -12rpx;
}

.unsafe-tip,
.error-box {
  margin-bottom: 20rpx;
  padding: 22rpx 24rpx;
  border-radius: 24rpx;
  border: 1px solid rgba(17, 17, 17, 0.06);
  background: rgba(255, 255, 255, 0.92);
  display: flex;
  align-items: flex-start;
  gap: 14rpx;
}

.unsafe-tip {
  color: #8A7451;
}

.error-box {
  color: var(--error);
}

.tip-icon {
  width: 28rpx;
  height: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 4rpx;
}

.tip-icon text,
.tip-text,
.error-text {
  font-size: 24rpx;
  line-height: 36rpx;
  font-weight: 400;
  letter-spacing: 0.4rpx;
}

.login-action-section {
  padding: 16rpx 0 36rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.btn-wechat {
  width: 100%;
  height: 88rpx;
  border: 0;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #0F1619 0%, #132126 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 12rpx 28rpx rgba(15, 22, 25, 0.12);
}

.btn-wechat::after {
  border: 0;
}

.btn-wechat:active {
  transform: translateY(2rpx);
  opacity: 0.94;
}

.btn-wechat[disabled] {
  opacity: 0.5;
}

.wechat-text {
  color: #FFFFFF;
  font-size: 28rpx;
  line-height: 40rpx;
  font-weight: 500;
  letter-spacing: 0.4rpx;
}

.login-hint {
  margin-top: 18rpx;
  color: #A0A0A0;
  font-size: 22rpx;
  line-height: 32rpx;
  text-align: center;
  letter-spacing: 0.2rpx;
}

.admin-legacy-page {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  box-sizing: border-box;
}

.admin-brand-section {
  flex: 1;
  min-height: 560rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: flex-end;
  padding-bottom: 48rpx;
}

.admin-brand-icon {
  width: 300rpx;
  height: 300rpx;
  margin-bottom: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.admin-gate-icon {
  width: 280rpx;
  height: 280rpx;
}

.admin-brand-title {
  color: var(--ink);
  font-family: "PingFang SC", -apple-system, BlinkMacSystemFont, sans-serif;
  font-size: 44rpx;
  line-height: 56rpx;
  font-weight: 500;
  letter-spacing: 0.5rpx;
}

.admin-brand-subtitle {
  margin-top: 14rpx;
  color: var(--ink);
  font-size: 24rpx;
  line-height: 34rpx;
  font-weight: 400;
  letter-spacing: 0.4rpx;
}

.admin-unsafe-tip,
.admin-error-box {
  margin-bottom: 28rpx;
  padding: 22rpx 24rpx;
  border-left: 3rpx solid var(--warning);
  background: var(--warning-bg);
  display: flex;
  align-items: flex-start;
  gap: 14rpx;
}

.admin-error-box {
  border-left-color: var(--error);
  background: var(--error-bg);
}

.admin-tip-icon {
  width: 28rpx;
  height: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.admin-tip-icon text,
.admin-tip-text {
  color: var(--warning);
  font-size: 24rpx;
  line-height: 34rpx;
  font-weight: 400;
  letter-spacing: 0.4rpx;
}

.admin-error-text {
  color: var(--error);
  font-size: 24rpx;
  line-height: 34rpx;
  font-weight: 400;
  letter-spacing: 0.4rpx;
}

.admin-form-section {
  padding-bottom: 34rpx;
}

.admin-field {
  margin-bottom: 24rpx;
}

.admin-field-label {
  display: block;
  margin-bottom: 12rpx;
  color: var(--text-secondary);
  font-size: 24rpx;
  line-height: 34rpx;
  letter-spacing: 0.4rpx;
}

.admin-input-wrap {
  position: relative;
}

.admin-input {
  width: 100%;
  height: 88rpx;
  padding: 0 28rpx;
  box-sizing: border-box;
  border: 1px solid var(--form-border);
  border-radius: 20rpx;
  background: var(--form-surface);
  color: var(--ink);
  font-size: 28rpx;
  line-height: 40rpx;
  letter-spacing: 0.03em;
  box-shadow: var(--form-shadow);
}

.admin-input:focus {
  border-color: var(--form-border-strong);
  box-shadow: var(--form-shadow-focus);
}

.admin-input-placeholder {
  color: #B7BBB8;
}

.admin-btn-submit {
  width: 100%;
  height: 88rpx;
  margin-top: 28rpx;
  border: 0;
  border-radius: 16rpx;
  background: #2F4F46;
  display: flex;
  align-items: center;
  justify-content: center;
}

.admin-btn-submit::after {
  border: 0;
}

.admin-btn-submit:active {
  opacity: 0.88;
}

.admin-btn-submit[disabled] {
  opacity: 0.46;
}

.admin-btn-text {
  color: #FFFFFF;
  font-size: 28rpx;
  font-weight: 500;
  letter-spacing: 0.4rpx;
}

.admin-switch-mode {
  margin-top: 28rpx;
  text-align: center;
}

.admin-switch-link {
  color: var(--text-soft);
  font-size: 24rpx;
  line-height: 34rpx;
  letter-spacing: 0.4rpx;
}
