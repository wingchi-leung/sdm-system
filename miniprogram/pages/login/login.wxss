/**
 * 登录页 - 极简奢华风格
 */

.page {
  min-height: 100vh;
  padding: 0 var(--space-2xl);
  background: var(--background);
  display: flex;
  flex-direction: column;
}

/* ─────────────────────────────────────────────────────────────
 * 品牌区域
 * ───────────────────────────────────────────────────────────── */
.brand-section {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: var(--space-3xl) 0 var(--space-2xl);
}

.brand-icon {
  width: 120rpx;
  height: 120rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: var(--space-2xl);
  opacity: 0;
  animation: fadeInUp 0.8s ease forwards;
}

@keyframes fadeInUp {
  from {
    opacity: 0;
    transform: translateY(20rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.gate-icon {
  width: 88rpx;
  height: 88rpx;
}

.brand-title {
  font-family: var(--font-display);
  font-size: 64rpx;
  font-weight: 300;
  color: var(--text-primary);
  letter-spacing: 0.12em;
  margin-bottom: var(--space-md);
  opacity: 0;
  animation: fadeInUp 0.8s ease 0.1s forwards;
}

.brand-subtitle {
  font-size: 24rpx;
  color: var(--text-tertiary);
  letter-spacing: 0.16em;
  font-weight: 400;
  text-transform: uppercase;
  opacity: 0;
  animation: fadeInUp 0.8s ease 0.2s forwards;
}

/* ─────────────────────────────────────────────────────────────
 * 安全提示
 * ───────────────────────────────────────────────────────────── */
.unsafe-tip {
  display: flex;
  align-items: flex-start;
  gap: var(--space-sm);
  margin-bottom: var(--space-xl);
  padding: var(--space-md);
  background: var(--warning-bg);
  border-left: 2px solid var(--warning);
}

.tip-icon {
  width: 32rpx;
  height: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.tip-icon text {
  font-size: 20rpx;
  color: var(--warning);
  font-weight: 600;
}

.tip-text {
  font-size: 22rpx;
  color: var(--warning);
  line-height: 1.5;
  letter-spacing: 0.02em;
}

/* ─────────────────────────────────────────────────────────────
 * 表单区域
 * ───────────────────────────────────────────────────────────── */
.form-section {
  padding-bottom: var(--space-2xl);
}

.field {
  margin-bottom: var(--space-lg);
}

.field-label {
  display: block;
  font-size: 22rpx;
  color: var(--text-tertiary);
  margin-bottom: var(--space-sm);
  font-weight: 500;
  letter-spacing: 0.08em;
  text-transform: uppercase;
}

.input-wrap {
  position: relative;
}

.input {
  width: 100%;
  height: 96rpx;
  padding: 0 var(--space-md);
  font-size: 30rpx;
  background: var(--background-warm);
  border: 1px solid var(--border);
  border-radius: var(--radius-md);
  box-sizing: border-box;
  color: var(--text-primary);
  transition: all 0.3s ease;
  letter-spacing: 0.02em;
}

.input:focus {
  border-color: var(--accent);
  box-shadow: 0 0 0 3px var(--accent-light);
}

.input-placeholder {
  color: var(--text-muted);
}

/* ─────────────────────────────────────────────────────────────
 * 错误提示
 * ───────────────────────────────────────────────────────────── */
.error-box {
  margin-bottom: var(--space-lg);
  padding: var(--space-md);
  background: var(--error-bg);
  border-left: 2px solid var(--error);
}

.error-text {
  font-size: 24rpx;
  color: var(--error);
  letter-spacing: 0.02em;
}

/* ─────────────────────────────────────────────────────────────
 * 提交按钮
 * ───────────────────────────────────────────────────────────── */
.btn-submit {
  width: 100%;
  height: 112rpx;
  background: linear-gradient(135deg, var(--primary) 0%, var(--primary-dark) 100%);
  border-radius: var(--radius-lg);
  border: none;
  transition: all 0.5s cubic-bezier(0.23, 1, 0.32, 1);
  margin-top: var(--space-xl);
  box-shadow: 0 8rpx 24rpx rgba(26, 26, 26, 0.15);
  position: relative;
  overflow: hidden;
}

.btn-submit::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(135deg, rgba(201, 169, 97, 0.15) 0%, transparent 100%);
  opacity: 0;
  transition: opacity 0.5s ease;
}

.btn-submit::after {
  border: none;
}

.btn-submit:active {
  transform: translateY(2rpx);
  box-shadow: 0 4rpx 12rpx rgba(26, 26, 26, 0.1);
}

.btn-submit:active::before {
  opacity: 1;
}

.btn-submit[disabled] {
  opacity: 0.4;
}

.btn-submit .btn-text {
  font-size: 32rpx;
  font-weight: 500;
  color: #FFFFFF;
  letter-spacing: 0.08em;
}

/* ─────────────────────────────────────────────────────────────
 * 微信登录按钮
 * ───────────────────────────────────────────────────────────── */
.btn-wechat {
  width: 100%;
  height: 112rpx;
  background: var(--background-card);
  border-radius: var(--radius-lg);
  border: 1px solid var(--border);
  display: flex;
  align-items: center;
  justify-content: center;
  gap: var(--space-sm);
  transition: all 0.5s cubic-bezier(0.23, 1, 0.32, 1);
  box-shadow: var(--shadow-xs);
}

.btn-wechat::after {
  border: none;
}

.btn-wechat:active {
  background: var(--background-warm);
  transform: translateY(2rpx);
  box-shadow: none;
}

.btn-wechat[disabled] {
  opacity: 0.4;
}

.wechat-icon {
  width: 44rpx;
  height: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.wechat-icon text {
  font-size: 32rpx;
  color: #07C160;
  font-weight: 700;
}

.wechat-text {
  font-size: 32rpx;
  font-weight: 500;
  color: var(--text-primary);
  letter-spacing: 0.04em;
}

/* ─────────────────────────────────────────────────────────────
 * 切换模式
 * ───────────────────────────────────────────────────────────── */
.switch-mode {
  margin-top: var(--space-xl);
  text-align: center;
}

.switch-link {
  font-size: 24rpx;
  color: var(--text-tertiary);
  letter-spacing: 0.06em;
  transition: color 0.2s ease;
}

.switch-link:active {
  color: var(--text-secondary);
}

/* ─────────────────────────────────────────────────────────────
 * 底部装饰
 * ───────────────────────────────────────────────────────────── */
.footer-decoration {
  padding: var(--space-2xl) 0;
  display: flex;
  justify-content: center;
}

.decoration-line {
  width: 40rpx;
  height: 1px;
  background: var(--border);
}

/* ─────────────────────────────────────────────────────────────
 * 登录分隔线
 * ───────────────────────────────────────────────────────────── */
.login-divider {
  display: flex;
  align-items: center;
  justify-content: center;
  margin: var(--space-xl) 0;
}

.divider-line {
  flex: 1;
  height: 1px;
  background: var(--border);
}

.divider-text {
  padding: 0 var(--space-md);
  font-size: 22rpx;
  color: var(--text-muted);
  letter-spacing: 0.05em;
}

/* ─────────────────────────────────────────────────────────────
 * 次要按钮
 * ───────────────────────────────────────────────────────────── */
.btn-secondary {
  width: 100%;
  height: 88rpx;
  background: transparent;
  border: 1px solid var(--border);
  border-radius: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}

.btn-secondary::after {
  border: none;
}

.btn-secondary:active {
  background: var(--background-subtle);
}

.btn-secondary[disabled] {
  opacity: 0.5;
}

.btn-secondary-text {
  font-size: 26rpx;
  font-weight: 400;
  color: var(--text-secondary);
  letter-spacing: 0.06em;
}