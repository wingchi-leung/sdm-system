.page {
  min-height: 100vh;
  padding-bottom: 140rpx;
  background: #FFFFFF;
}

.state-wrap,
.comment-empty {
  min-height: 45vh;
  padding: 80rpx 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  text-align: center;
}

.state-title,
.post-title,
.comment-title {
  color: var(--ink);
  font-size: 34rpx;
  line-height: 1.5;
  font-weight: 500;
}

.state-text,
.post-meta,
.comment-time,
.comment-empty-text,
.comment-count {
  color: var(--text-soft);
  font-size: 24rpx;
  line-height: 1.7;
}

.post-cover {
  width: 100%;
  height: 360rpx;
}

.post-card,
.comment-section {
  margin: 0 32rpx;
}

.post-card {
  padding: 32rpx 0;
}

.post-meta {
  display: block;
  margin-top: 10rpx;
}

.post-content {
  display: block;
  margin-top: 28rpx;
  color: var(--ink);
  font-size: 28rpx;
  line-height: 1.9;
  white-space: pre-wrap;
}

.comment-section {
  padding-top: 8rpx;
}

.comment-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.comment-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.comment-card {
  padding: 24rpx;
  border-radius: 16rpx;
  background: #F8F8F6;
}

.comment-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.comment-user {
  color: var(--ink);
  font-size: 26rpx;
  font-weight: 500;
}

.comment-content {
  display: block;
  margin-top: 12rpx;
  color: var(--ink);
  font-size: 25rpx;
  line-height: 1.8;
  white-space: pre-wrap;
}

.comment-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 20rpx 24rpx calc(20rpx + env(safe-area-inset-bottom));
  background: #FFFFFF;
  border-top: 1rpx solid #ECECE8;
}

.comment-input {
  flex: 1;
  height: 80rpx;
  padding: 0 24rpx;
  border-radius: 16rpx;
  background: #F8F8F6;
  font-size: 26rpx;
  color: var(--ink);
}

.comment-placeholder {
  color: var(--text-soft);
}

.comment-btn {
  width: 132rpx;
  height: 80rpx;
  margin: 0;
  border: 0;
  border-radius: 16rpx;
  background: #2F4F46;
  color: #FFFFFF;
  font-size: 24rpx;
  line-height: 80rpx;
}

.comment-btn::after {
  border: 0;
}

.comment-btn[disabled] {
  opacity: 0.6;
}
