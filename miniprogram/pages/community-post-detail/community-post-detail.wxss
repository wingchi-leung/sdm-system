.page {
  min-height: 100vh;
  padding-bottom: 156rpx;
  background: #FFFFFF;
}

.page-header-sticky {
  position: sticky;
  top: 0;
  z-index: 20;
  background: #ffffff;
}

.state-wrap,
.comment-empty {
  min-height: 45vh;
  padding: 80rpx 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  text-align: center;
}

.state-title,
.post-title,
.comment-title {
  color: var(--ink);
  font-size: 38rpx;
  line-height: 1.5;
  font-weight: 500;
}

.state-text,
.post-meta,
.comment-time,
.comment-empty-text,
.comment-count {
  color: var(--text-soft);
  font-size: 24rpx;
  line-height: 1.7;
}

.post-card,
.comment-section {
  margin: 0 32rpx;
}

.post-card {
  padding: 32rpx 0 12rpx;
}

.post-caption {
  display: block;
  color: var(--text-soft);
  font-size: 24rpx;
  line-height: 1.6;
  letter-spacing: 0.12em;
}

.post-meta {
  display: block;
  margin-top: 14rpx;
}

.post-content {
  display: block;
  margin-top: 30rpx;
  color: var(--ink);
  font-size: 28rpx;
  line-height: 2;
  white-space: pre-wrap;
}

.post-image-grid {
  margin-top: 20rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.post-image {
  width: calc((100% - 24rpx) / 3);
  height: 180rpx;
  border-radius: 12rpx;
}

.comment-section {
  padding-top: 24rpx;
}

.comment-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 22rpx;
}

.comment-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.comment-card {
  border: 1px solid var(--form-border);
  padding: 24rpx;
  border-radius: 20rpx;
  background: #FFFFFF;
  box-shadow: var(--form-shadow);
}

.comment-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.comment-user {
  color: var(--ink);
  font-size: 26rpx;
  font-weight: 500;
}

.comment-content {
  display: block;
  margin-top: 14rpx;
  color: var(--ink);
  font-size: 25rpx;
  line-height: 1.9;
  white-space: pre-wrap;
}

.comment-image-grid {
  margin-top: 12rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.comment-image {
  width: 180rpx;
  height: 180rpx;
  border-radius: 10rpx;
}

.comment-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  flex-direction: column;
  align-items: stretch;
  gap: 12rpx;
  padding: 20rpx 24rpx calc(20rpx + env(safe-area-inset-bottom));
  background: rgba(255, 255, 255, 0.98);
  border-top: 1rpx solid var(--border-light);
  backdrop-filter: blur(12rpx);
}

.comment-upload-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.comment-upload-item {
  width: 132rpx;
  height: 132rpx;
  border-radius: 10rpx;
  overflow: hidden;
  position: relative;
}

.comment-upload-preview {
  width: 100%;
  height: 100%;
}

.comment-upload-remove {
  position: absolute;
  top: 4rpx;
  right: 4rpx;
  width: 30rpx;
  height: 30rpx;
  line-height: 30rpx;
  text-align: center;
  border-radius: 50%;
  background: rgba(0, 0, 0, 0.6);
  color: #fff;
  font-size: 20rpx;
}

.comment-tool-row {
  display: flex;
  align-items: center;
}

.comment-add-image {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  height: 56rpx;
  padding: 0 20rpx;
  border-radius: 28rpx;
  border: 1px solid var(--form-border);
  color: var(--text-soft);
  font-size: 24rpx;
  background: #fff;
}

.comment-input-wrap {
  flex: 1;
  border: 1px solid var(--form-border);
  border-radius: 18rpx;
  background: var(--form-surface);
  box-shadow: var(--form-shadow);
}

.comment-action-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.comment-input {
  width: 100%;
  height: 80rpx;
  padding: 0 24rpx;
  box-sizing: border-box;
  border-radius: 18rpx;
  background: transparent;
  font-size: 26rpx;
  color: var(--ink);
}

.comment-placeholder {
  color: var(--text-soft);
}

.comment-btn {
  width: 132rpx;
  height: 80rpx;
  margin: 0;
  border: 0;
  border-radius: 16rpx;
  background: #000000;
  color: #FFFFFF;
  font-size: 24rpx;
  line-height: 80rpx;
}

.comment-btn::after {
  border: 0;
}

.comment-btn[disabled] {
  opacity: 0.6;
}

