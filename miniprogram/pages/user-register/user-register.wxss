.page {
  min-height: 100vh;
  padding: 48rpx 40rpx 64rpx;
  background: var(--background);
}

.form {
  background: #FFFFFF;
  border: 1px solid rgba(17, 17, 17, 0.04);
  border-radius: 32rpx;
  padding: 40rpx;
  box-shadow: none;
}

.field {
  margin-bottom: 32rpx;
}

.field-label {
  display: block;
  font-size: 24rpx;
  color: var(--text-secondary);
  margin-bottom: 14rpx;
}

.input {
  width: 100%;
  height: 88rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  background: var(--form-surface);
  border: 1px solid var(--form-border);
  border-radius: 20rpx;
  box-sizing: border-box;
  box-shadow: var(--form-shadow);
}

.input:focus {
  border-color: var(--form-border-strong);
  box-shadow: var(--form-shadow-focus);
}

.error-box {
  margin: 24rpx 0;
  padding: 24rpx;
  background: var(--error-bg);
  border-radius: 16rpx;
}

.error-text {
  font-size: 28rpx;
  color: var(--error);
}

.submit-btn {
  width: 100%;
  margin-top: 48rpx;
  padding: 32rpx;
  font-size: 32rpx;
}

/* 实名认证区域 */
.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 32rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid var(--form-border);
}

.realname-section {
  margin-bottom: 48rpx;
}

.realname-btn-wrap {
  margin-top: 32rpx;
  margin-bottom: 16rpx;
}

.realname-btn {
  width: 100%;
  padding: 24rpx;
  font-size: 28rpx;
  background: var(--theme-color, #07C160);
  color: #FFFFFF;
  border-radius: 20rpx;
  border: none;
}

.realname-btn[disabled] {
  background: #C8C8C8;
  color: #FFFFFF;
}

.realname-hint {
  font-size: 22rpx;
  color: var(--text-secondary);
  text-align: center;
  margin-bottom: 24rpx;
}

/* 已实名认证状态 */
.realname-success {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 32rpx;
  margin-bottom: 32rpx;
  background: #E8F8F0;
  border-radius: 20rpx;
}

.success-icon {
  width: 48rpx;
  height: 48rpx;
  line-height: 48rpx;
  text-align: center;
  background: #07C160;
  color: #FFFFFF;
  border-radius: 50%;
  font-size: 28rpx;
  font-weight: bold;
  margin-right: 16rpx;
}

.success-text {
  font-size: 28rpx;
  color: #07C160;
  font-weight: 500;
}