.page {
  min-height: 100vh;
  padding: 48rpx 40rpx 64rpx;
  background: var(--background);
}

.form {
  background: var(--form-surface-soft);
  border: 1px solid rgba(47, 79, 70, 0.06);
  border-radius: 32rpx;
  padding: 40rpx;
  box-shadow: 0 18rpx 48rpx rgba(47, 79, 70, 0.05);
}

.field {
  margin-bottom: 32rpx;
}

.field-label {
  display: block;
  font-size: 24rpx;
  color: var(--text-secondary);
  margin-bottom: 14rpx;
}

.input {
  width: 100%;
  height: 88rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  background: linear-gradient(180deg, var(--form-surface-soft) 0%, var(--form-surface) 100%);
  border: 1px solid var(--form-border);
  border-radius: 20rpx;
  box-sizing: border-box;
  box-shadow: var(--form-shadow);
}

.input:focus {
  border-color: var(--form-border-strong);
  box-shadow: var(--form-shadow-focus);
}

.error-box {
  margin: 24rpx 0;
  padding: 24rpx;
  background: var(--error-bg);
  border-radius: 16rpx;
}

.error-text {
  font-size: 28rpx;
  color: var(--error);
}

.submit-btn {
  width: 100%;
  margin-top: 48rpx;
  padding: 32rpx;
  font-size: 32rpx;
}
