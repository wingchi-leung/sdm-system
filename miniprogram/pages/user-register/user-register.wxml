<view class="page">
  <view class="form">
    <!-- 实名认证区域 -->
    <view class="section-title" wx:if="{{!realnameVerified}}">实名认证</view>
    <view class="realname-section" wx:if="{{!realnameVerified}}">
      <view class="field">
        <text class="field-label">姓名 *</text>
        <input class="input" placeholder="请输入姓名" value="{{name}}" bindinput="onNameInput" />
      </view>
      <view class="field">
        <text class="field-label">身份证号 *</text>
        <input class="input" placeholder="请输入身份证号" value="{{idNumber}}" bindinput="onIdNumberInput" />
      </view>
      <view class="field">
        <text class="field-label">手机号 *</text>
        <input class="input" type="number" placeholder="请输入手机号" value="{{phone}}" bindinput="onPhoneInput" />
      </view>
      <view class="field">
        <text class="field-label">密码 *</text>
        <input class="input" password placeholder="请输入密码" value="{{password}}" bindinput="onPasswordInput" />
      </view>
      <view class="field">
        <text class="field-label">邮箱（选填）</text>
        <input class="input" type="text" placeholder="请输入邮箱" value="{{email}}" bindinput="onEmailInput" />
      </view>

      <view class="realname-btn-wrap">
        <button class="btn-secondary realname-btn" disabled="{{!name || !idNumber || verifyingRealname}}" bindtap="startRealnameVerify">
          {{verifyingRealname ? '实名认证中…' : '微信支付实名认证'}}
        </button>
      </view>
      <view class="realname-hint">实名认证由微信支付提供，确保用户信息真实有效</view>
    </view>

    <!-- 已实名认证状态 -->
    <view class="realname-success" wx:if="{{realnameVerified}}">
      <view class="success-icon">✓</view>
      <text class="success-text">实名认证已通过</text>
    </view>

    <view class="field" wx:if="{{realnameVerified}}">
      <text class="field-label">姓名 *</text>
      <input class="input" placeholder="请输入姓名" value="{{name}}" bindinput="onNameInput" disabled="{{realnameVerified}}" />
    </view>
    <view class="field" wx:if="{{realnameVerified}}">
      <text class="field-label">手机号 *</text>
      <input class="input" type="number" placeholder="请输入手机号" value="{{phone}}" bindinput="onPhoneInput" />
    </view>
    <view class="field" wx:if="{{realnameVerified}}">
      <text class="field-label">密码 *</text>
      <input class="input" password placeholder="请输入密码" value="{{password}}" bindinput="onPasswordInput" />
    </view>
    <view class="field" wx:if="{{realnameVerified}}">
      <text class="field-label">邮箱（选填）</text>
      <input class="input" type="text" placeholder="请输入邮箱" value="{{email}}" bindinput="onEmailInput" />
    </view>

    <view class="error-box" wx:if="{{error}}">
      <text class="error-text">{{error}}</text>
    </view>

    <button class="btn-primary submit-btn" disabled="{{submitting || (!realnameVerified && !realnamePass)}}" bindtap="submit">
      {{submitting ? '注册中…' : '注册'}}
    </button>
  </view>
</view>