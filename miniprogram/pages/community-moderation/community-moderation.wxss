.page {
  min-height: 100vh;
  background: #f7f8fa;
  padding: 24rpx;
  box-sizing: border-box;
}

.state-wrap {
  min-height: 60vh;
  display: flex;
  align-items: center;
  justify-content: center;
}

.state-text {
  color: #888;
  font-size: 28rpx;
}

.group {
  margin-bottom: 28rpx;
  background: #fff;
  border-radius: 16rpx;
  padding: 20rpx;
}

.group-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.group-title {
  color: #111;
  font-size: 30rpx;
  font-weight: 600;
}

.group-count {
  color: #666;
  font-size: 24rpx;
}

.group-empty {
  color: #999;
  font-size: 24rpx;
  padding: 16rpx 0;
}

.card {
  border: 1rpx solid #eceef2;
  border-radius: 12rpx;
  padding: 16rpx;
  margin-top: 12rpx;
}

.card-title {
  display: block;
  color: #111;
  font-size: 28rpx;
  font-weight: 500;
  margin-bottom: 8rpx;
}

.card-content {
  display: block;
  color: #333;
  font-size: 26rpx;
  line-height: 1.5;
}

.card-meta {
  display: block;
  margin-top: 8rpx;
  color: #999;
  font-size: 22rpx;
}

.actions {
  margin-top: 12rpx;
  display: flex;
  gap: 12rpx;
}

.btn {
  min-width: 120rpx;
}

.pass {
  background: #12b76a !important;
  color: #fff !important;
}

.reject {
  background: #e5484d !important;
  color: #fff !important;
}
