.page {
  min-height: 100vh;
  background: #ffffff;
  color: #101828;
  padding-bottom: calc(132rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

.page-header-sticky {
  position: sticky;
  top: 0;
  z-index: 10;
  background: #ffffff;
}

.state-wrap {
  min-height: 40vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 60rpx 0;
  text-align: center;
}

.state-title {
  color: #101828;
  font-size: 32rpx;
  line-height: 1.4;
  font-weight: 500;
}

.state-text {
  margin-top: 16rpx;
  color: #6f6f6f;
  font-size: 24rpx;
  line-height: 1.6;
}

.content {
  padding: 0 28rpx;
}

.page-head {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  margin-top: 20rpx;
  padding: 12rpx 0 4rpx;
}

.page-copy {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.page-title {
  color: #101828;
  font-size: 40rpx;
  line-height: 1.2;
  font-weight: 600;
  letter-spacing: 0.02em;
}

.page-subtitle {
  color: #98a2b3;
  font-size: 22rpx;
  line-height: 1.5;
}

.head-actions {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.create-btn {
  min-height: 48rpx;
  padding: 0 22rpx;
  border-radius: 999rpx;
  background: #111111;
  color: #ffffff;
  font-size: 24rpx;
  line-height: 48rpx;
  font-weight: 500;
  letter-spacing: 0.02em;
  display: inline-flex;
  align-items: center;
  justify-content: center;
}

.head-accent {
  height: 1rpx;
  background: rgba(17, 17, 17, 0.08);
  margin: 18rpx 0 28rpx;
}

.ann-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.ann-card {
  background: #ffffff;
  border: 1rpx solid rgba(17, 17, 17, 0.06);
  border-radius: 16rpx;
  padding: 24rpx;
  box-sizing: border-box;
}

.ann-card-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.ann-title {
  flex: 1;
  min-width: 0;
  color: #101828;
  font-size: 30rpx;
  line-height: 1.4;
  font-weight: 600;
  letter-spacing: 0.01em;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.ann-more {
  width: 44rpx;
  height: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 2rpx;
  flex-shrink: 0;
}

.ann-more-dot {
  color: #6f6f6f;
  font-size: 24rpx;
  line-height: 1;
}

.ann-card-body {
  margin-top: 12rpx;
}

.ann-summary {
  display: block;
  color: #344054;
  font-size: 26rpx;
  line-height: 1.6;
  display: -webkit-box;
  -webkit-line-clamp: 3;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.ann-thumbs {
  display: flex;
  gap: 12rpx;
  flex-wrap: wrap;
  margin-top: 12rpx;
}

.ann-thumb {
  width: 160rpx;
  height: 160rpx;
  border-radius: 8rpx;
  background: #f2f4f7;
  object-fit: cover;
}

.ann-card-foot {
  display: flex;
  align-items: center;
  margin-top: 16rpx;
  gap: 8rpx;
  flex-wrap: wrap;
}

.ann-author-avatar {
  width: 36rpx;
  height: 36rpx;
  border-radius: 999rpx;
  background: #f2f4f7;
  margin-right: 4rpx;
  flex-shrink: 0;
}

.ann-author-name {
  color: #344054;
  font-size: 22rpx;
  line-height: 1.5;
}

.ann-time {
  color: #98a2b3;
  font-size: 22rpx;
  line-height: 1.5;
}

.ann-loadmore {
  display: flex;
  justify-content: center;
  padding: 32rpx 0;
}

.ann-loadmore-link {
  color: #101828;
  font-size: 24rpx;
  line-height: 1.5;
  text-decoration: underline;
  text-underline-offset: 6rpx;
}

.empty-box {
  min-height: 30vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 0;
  text-align: center;
}

.empty-title {
  color: #101828;
  font-size: 30rpx;
  line-height: 1.4;
  font-weight: 500;
}

.empty-text {
  margin-top: 12rpx;
  color: #98a2b3;
  font-size: 24rpx;
  line-height: 1.6;
}
