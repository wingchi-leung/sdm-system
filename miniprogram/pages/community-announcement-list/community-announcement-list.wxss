.page {
  min-height: 100vh;
  background: #ffffff;
  color: #101828;
  padding-bottom: calc(132rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

.header-actions {
  display: flex;
  align-items: center;
  justify-content: flex-end;
}
 

 

 
.state-wrap {
  min-height: 40vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 60rpx 0;
  text-align: center;
}

.state-title {
  color: #101828;
  font-size: 32rpx;
  line-height: 1.4;
  font-weight: 500;
}

.state-text {
  margin-top: 16rpx;
  color: #6f6f6f;
  font-size: 24rpx;
  line-height: 1.6;
}

.content {
  padding: 18rpx 24rpx 0;
}

.page-head {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 18rpx;
  padding: 10rpx 4rpx 0;
}

.page-copy {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.page-title {
  color: #101828;
  font-size: 40rpx;
  line-height: 1.15;
  font-weight: 700;
}

.page-subtitle {
  color: #98a2b3;
  font-size: 24rpx;
  line-height: 1.5;
}

.head-actions {
  flex-shrink: 0;
}

.create-btn {
  min-width: 40rpx;
  height: 66rpx;
  padding: 0 24rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  border-radius: 999rpx;
  border: 1rpx solid rgba(17, 24, 39, 0.12);
  background: rgba(255, 255, 255, 0.94);
  color: #344054;
  box-shadow: 0 10rpx 24rpx rgba(15, 23, 42, 0.05);
}

.create-btn-text {
  font-size: 24rpx;
  line-height: 1;
  font-weight: 500;
}

.page-divider {
  height: 1rpx;
  margin: 24rpx 4rpx 0;
  background: linear-gradient(90deg, rgba(17, 24, 39, 0), rgba(17, 24, 39, 0.08), rgba(17, 24, 39, 0));
}

.ann-list {
  display: flex;
  flex-direction: column;
  margin-top: 18rpx;
}

.ann-card {
  padding: 22rpx 4rpx 22rpx;
  box-sizing: border-box;
  border-top: 1rpx solid rgba(15, 23, 42, 0.08);
}

.ann-card:first-child {
  border-top: 0;
}

.ann-card-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.ann-top-left {
  flex: 1;
  min-width: 0;
}

.ann-badge {
  display: inline-flex;
  align-items: center;
  gap: 6rpx;
  padding: 4rpx 14rpx;
  border-radius: 999rpx;
  background: #f5f6f8;
  color: #667085;
  font-size: 22rpx;
  line-height: 1.4;
  font-weight: 500;
}

.ann-title {
  display: block;
  margin-top: 12rpx;
  color: #101828;
  font-size: 39rpx;
  line-height: 1.22;
  font-weight: 700;
  overflow: hidden;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.ann-time {
  flex-shrink: 0;
  color: #98a2b3;
  font-size: 24rpx;
  line-height: 1.5;
  white-space: nowrap;
}

.ann-card-body {
  margin-top: 14rpx;
}

.ann-summary {
  display: block;
  color: #475467;
  font-size: 26rpx;
  line-height: 1.7;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.ann-images-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 14rpx;
}

.ann-image-grid-item {
  width: 160rpx;
  height: 160rpx;
  border-radius: 12rpx;
  background: #f2f4f7;
  object-fit: cover;
}

.ann-card-foot {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  margin-top: 18rpx;
}

.ann-author-row {
  display: flex;
  align-items: center;
  gap: 10rpx;
  min-width: 0;
}

.ann-author-avatar {
  width: 40rpx;
  height: 40rpx;
  border-radius: 999rpx;
  background: #f2f4f7;
  flex-shrink: 0;
}

.ann-author-name {
  color: #344054;
  font-size: 24rpx;
  line-height: 1.5;
  white-space: nowrap;
}

.ann-foot-time {
  color: #98a2b3;
  font-size: 24rpx;
  line-height: 1.5;
  white-space: nowrap;
}

.ann-more {
  width: 44rpx;
  height: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 2rpx;
  flex-shrink: 0;
}

.ann-more-dot {
  color: #6f6f6f;
  font-size: 26rpx;
  line-height: 1;
}

.ann-loadmore {
  display: flex;
  justify-content: center;
  padding: 28rpx 0;
}

.ann-loadmore-link {
  color: #1d4ed8;
  font-size: 24rpx;
  line-height: 1.5;
  font-weight: 500;
}

.empty-box {
  min-height: 30vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 0;
  text-align: center;
}

.empty-title {
  color: #101828;
  font-size: 34rpx;
  line-height: 1.4;
  font-weight: 600;
}

.empty-text {
  margin-top: 12rpx;
  color: #98a2b3;
  font-size: 24rpx;
  line-height: 1.6;
}
