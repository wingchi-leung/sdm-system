.page {
  min-height: 100vh;
  background:
    radial-gradient(circle at top left, rgba(255, 213, 142, 0.18), transparent 34%),
    radial-gradient(circle at top right, rgba(170, 223, 255, 0.18), transparent 28%),
    #f6f7fb;
  color: #101828;
  padding-bottom: calc(132rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

.header-actions {
  display: flex;
  align-items: center;
  justify-content: flex-end;
}

.state-wrap {
  min-height: 40vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 60rpx 0;
  text-align: center;
}

.state-title {
  color: #101828;
  font-size: 32rpx;
  line-height: 1.4;
  font-weight: 500;
}

.state-text {
  margin-top: 16rpx;
  color: #6f6f6f;
  font-size: 24rpx;
  line-height: 1.6;
}

.content {
  padding: 24rpx 24rpx 0;
}

.page-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 8rpx 4rpx 0;
}

.page-copy {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.page-title {
  color: #101828;
  font-size: 44rpx;
  line-height: 1.15;
  font-weight: 600;
  letter-spacing: 0.01em;
}

.page-subtitle {
  color: #98a2b3;
  font-size: 24rpx;
  line-height: 1.5;
}

.page-divider {
  height: 1rpx;
  margin: 24rpx 4rpx 0;
  background: linear-gradient(90deg, rgba(17, 24, 39, 0), rgba(17, 24, 39, 0.08), rgba(17, 24, 39, 0));
}

.ann-list {
  display: flex;
  flex-direction: column;
  gap: 22rpx;
  margin-top: 22rpx;
}

.ann-card {
  background: #ffffff;
  border: 1rpx solid rgba(15, 23, 42, 0.06);
  border-radius: 28rpx;
  padding: 28rpx 24rpx 24rpx;
  box-sizing: border-box;
  box-shadow: 0 16rpx 42rpx rgba(15, 23, 42, 0.06);
}

.ann-card--featured {
  border-color: rgba(248, 180, 0, 0.18);
  box-shadow: 0 20rpx 52rpx rgba(15, 23, 42, 0.08);
}

.ann-card-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.ann-copy {
  flex: 1;
  min-width: 0;
}

.ann-badge {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  margin-bottom: 10rpx;
  padding: 4rpx 14rpx;
  border-radius: 999rpx;
  background: #f2f4f7;
  color: #667085;
  font-size: 20rpx;
  line-height: 1.4;
  font-weight: 500;
}

.ann-badge-dot {
  color: #98a2b3;
  font-size: 22rpx;
  line-height: 1;
}

.ann-badge-text {
  line-height: 1;
}

.ann-title {
  color: #101828;
  font-size: 38rpx;
  line-height: 1.28;
  font-weight: 700;
  letter-spacing: 0.01em;
  overflow: hidden;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.ann-more {
  width: 44rpx;
  height: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 2rpx;
  flex-shrink: 0;
}

.ann-more-dot {
  color: #6f6f6f;
  font-size: 26rpx;
  line-height: 1;
}

.ann-card-body {
  margin-top: 16rpx;
}

.ann-summary {
  display: block;
  color: #475467;
  font-size: 28rpx;
  line-height: 1.75;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.ann-image-single-wrap {
  margin-top: 18rpx;
}

.ann-image-single {
  width: 100%;
  height: 340rpx;
  border-radius: 24rpx;
  background: #f2f4f7;
  object-fit: cover;
}

.ann-images-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 12rpx;
  margin-top: 18rpx;
}

.ann-image-grid-item {
  width: 100%;
  height: 210rpx;
  border-radius: 20rpx;
  background: #f2f4f7;
  object-fit: cover;
}

.ann-card-foot {
  display: flex;
  align-items: center;
  margin-top: 20rpx;
  gap: 10rpx;
  flex-wrap: wrap;
}

.ann-author-avatar {
  width: 40rpx;
  height: 40rpx;
  border-radius: 999rpx;
  background: #f2f4f7;
  flex-shrink: 0;
}

.ann-author-name {
  color: #344054;
  font-size: 24rpx;
  line-height: 1.5;
}

.ann-time {
  color: #98a2b3;
  font-size: 24rpx;
  line-height: 1.5;
}

.ann-loadmore {
  display: flex;
  justify-content: center;
  padding: 32rpx 0;
}

.ann-loadmore-link {
  color: #1d4ed8;
  font-size: 24rpx;
  line-height: 1.5;
  font-weight: 500;
}

.empty-box {
  min-height: 30vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 0;
  text-align: center;
}

.empty-title {
  color: #101828;
  font-size: 34rpx;
  line-height: 1.4;
  font-weight: 600;
}

.empty-text {
  margin-top: 12rpx;
  color: #98a2b3;
  font-size: 24rpx;
  line-height: 1.6;
}

.header-create-btn {
  min-width: 112rpx;
  height: 64rpx;
  padding: 0 20rpx 0 16rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  box-sizing: border-box;
  border-radius: 999rpx;
  border: 1rpx solid rgba(17, 24, 39, 0.12);
  background: rgba(255, 255, 255, 0.92);
  color: #344054;
  box-shadow: 0 10rpx 24rpx rgba(15, 23, 42, 0.05);
}

.header-create-btn__icon {
  font-size: 28rpx;
  line-height: 1;
  font-weight: 300;
}

.header-create-btn__text {
  font-size: 24rpx;
  line-height: 1;
  font-weight: 500;
}
