<view class="page">
  <view class="page-header-sticky">
    <page-header title="公告"></page-header>
  </view>

  <view wx:if="{{loading}}" class="state-wrap">
    <text class="state-text">加载中…</text>
  </view>

  <view wx:elif="{{error}}" class="state-wrap">
    <text class="state-title">暂时无法查看公告</text>
    <text class="state-text">{{error}}</text>
  </view>

  <view wx:else class="content">
    <view class="page-head">
      <view class="page-copy">
        <text class="page-title">频道公告</text>
        <text class="page-subtitle">共 {{total}} 条</text>
      </view>
      <view class="head-actions">
        <view wx:if="{{showCreateButton}}" class="create-btn" bindtap="onCreateAnnouncement">+ 公告</view>
      </view>
    </view>

    <view class="head-accent"></view>

    <view wx:if="{{announcements.length > 0}}" class="ann-list">
      <view
        wx:for="{{announcements}}"
        wx:key="id"
        class="ann-card"
        data-id="{{item.id}}"
        bindtap="onOpenDetail"
      >
        <view class="ann-card-head">
          <text class="ann-title">{{item.title}}</text>
          <view wx:if="{{canDelete(item)}}" class="ann-more" catchtap="onMoreTap" data-id="{{item.id}}">
            <text class="ann-more-dot">·</text>
            <text class="ann-more-dot">·</text>
            <text class="ann-more-dot">·</text>
          </view>
        </view>

        <view wx:if="{{item.preview_blocks.length > 0}}" class="ann-card-body">
          <view wx:for="{{item.preview_blocks}}" wx:for-item="block" wx:key="index">
            <text wx:if="{{block.type === 'text'}}" class="ann-summary">{{block.text}}</text>
            <view wx:elif="{{block.type === 'images'}}" class="ann-thumbs">
              <image
                wx:for="{{block.images}}"
                wx:for-item="imgUrl"
                wx:for-index="imgIndex"
                wx:key="imgUrl"
                class="ann-thumb"
                src="{{imgUrl}}"
                mode="aspectFill"
                catchtap="onPreviewImage"
                data-id="{{item.id}}"
                data-url="{{imgUrl}}"
              />
            </view>
          </view>
        </view>

        <view class="ann-card-foot">
          <image class="ann-author-avatar" src="{{item.author_avatar_display_url}}" mode="aspectFill" />
          <text class="ann-author-name">{{item.author_name}}</text>
          <text class="ann-time">· {{item.create_time_display}}</text>
        </view>
      </view>
    </view>

    <view wx:if="{{hasMore}}" class="ann-loadmore">
      <text class="ann-loadmore-link" bindtap="onLoadMore">{{loadingMore ? '加载中…' : '加载更多公告'}}</text>
    </view>

    <view wx:elif="{{announcements.length === 0}}" class="empty-box">
      <text class="empty-title">该频道还没有公告</text>
      <text wx:if="{{showCreateButton}}" class="empty-text">点击右上角发布第一条公告</text>
      <text wx:else class="empty-text">管理员发布后，会在这里展示</text>
    </view>
  </view>
</view>
