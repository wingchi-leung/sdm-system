<view class="page">
  <page-header title="签到记录"></page-header>
  <!-- 加载状态 -->
  <view wx:if="{{loading}}" class="state-wrap">
    <view class="loading"></view>
  </view>

  <!-- 空状态 -->
  <view wx:elif="{{isEmpty}}" class="state-wrap empty">
    <text class="state-title">暂无签到记录</text>
  </view>

  <!-- 签到列表 -->
  <view wx:else>
    <!-- 表头 -->
    <view class="table-header">
      <text class="col-name">用户ID</text>
      <text class="col-phone">签到状态</text>
      <text class="col-time">签到时间</text>
    </view>

    <!-- 表格内容 -->
    <view class="table-body">
      <view wx:for="{{checkins}}" wx:key="id" class="table-row">
        <text class="col-name">{{item.user_id}}</text>
        <text class="col-phone">{{item.has_attend === 1 ? '已到场' : '未到场'}}</text>
        <text class="col-time">{{item.checkin_time}}</text>
      </view>
    </view>

    <!-- 刷新按钮 -->
    <view class="refresh-section">
      <view class="refresh-btn" bindtap="onRefresh">刷新</view>
    </view>
  </view>
</view>
