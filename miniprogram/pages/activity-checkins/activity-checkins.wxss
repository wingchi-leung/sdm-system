.container {
  padding: 20rpx;
  background-color: #f5f5f5;
  min-height: 100vh;
}

.loading {
  text-align: center;
  padding: 100rpx 0;
  color: #999;
}

.empty {
  text-align: center;
  padding: 100rpx 0;
}

.empty-text {
  color: #999;
  font-size: 28rpx;
}

.checkins-list {
  background-color: #fff;
  border-radius: 16rpx;
  overflow: hidden;
}

.list-header {
  display: flex;
  background-color: #f0f0f0;
  padding: 24rpx 20rpx;
  font-weight: bold;
  font-size: 28rpx;
}

.header-item {
  flex: 1;
  text-align: center;
}

.header-item:first-child {
  flex: 1.2;
  text-align: left;
}

.checkin-item {
  display: flex;
  padding: 24rpx 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
  font-size: 28rpx;
  align-items: center;
}

.checkin-item:last-child {
  border-bottom: none;
}

.item-name {
  flex: 1.2;
  text-align: left;
  color: #333;
}

.item-phone {
  flex: 1;
  text-align: center;
  color: #666;
}

.item-time {
  flex: 1;
  text-align: center;
  color: #999;
  font-size: 24rpx;
}

.refresh-btn {
  margin-top: 40rpx;
  text-align: center;
}
