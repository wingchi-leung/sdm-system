.page {
  min-height: 100vh;
  padding: 24rpx 32rpx;
  background: #ffffff;
  box-sizing: border-box;
  color: #111111;
  font-family: var(--font-body);
}

.state-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 50vh;
}

.state-title {
  font-size: 32rpx;
  font-weight: 500;
  color: #111111;
  letter-spacing: 0.04em;
}

.table-header {
  display: flex;
  padding: 0 0 12rpx;
  border-bottom: 1rpx solid var(--divider);
  margin-bottom: 8rpx;
}

.table-header text {
  font-size: 20rpx;
  font-weight: 500;
  color: #999999;
  letter-spacing: 0.08em;
}

.table-body {
  display: flex;
  flex-direction: column;
}

.table-row {
  display: flex;
  padding: 20rpx 0;
  border-bottom: 1rpx solid var(--divider);
}

.table-row:last-child {
  border-bottom: none;
}

.col-name {
  flex: 1.2;
  font-size: 26rpx;
  color: #111111;
}

.col-phone {
  flex: 1;
  font-size: 24rpx;
  color: #666666;
}

.col-time {
  flex: 1;
  font-size: 22rpx;
  color: #999999;
  text-align: right;
}

.refresh-section {
  display: flex;
  justify-content: flex-end;
  margin-top: 24rpx;
  padding-top: 24rpx;
  border-top: 1rpx solid var(--divider);
}

.refresh-btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 128rpx;
  min-height: 56rpx;
  padding: 0 28rpx;
  box-sizing: border-box;
  border: none;
  border-radius: 28rpx;
  background: #f7f7f5;
  color: #111111;
  font-size: 24rpx;
  font-weight: 500;
  letter-spacing: 0.04em;
}

.refresh-btn:active {
  background: #efefed;
}
