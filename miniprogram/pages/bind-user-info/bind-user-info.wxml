<view class="page">
  <view wx:if="{{loading}}" class="state-wrap">
    <view class="loading"></view>
    <text class="state-text">加载中…</text>
  </view>

  <view wx:else class="shell">
    <page-header title="完善信息" autoBack="{{false}}" bindback="onBack"></page-header>

    <view class="hero">
      <text class="hero-subtitle">首次登录请上传头像并绑定基础信息</text>
    </view>

    <view class="form">
      <view class="section">
        <text class="section-title">头像设置</text>

        <view class="avatar-section">
          <view class="avatar-preview-wrap" bindtap="onPreviewAvatar">
            <view wx:if="{{avatarDisplayUrl || avatarTemp || avatarUrl}}" class="avatar-preview-frame">
              <image class="avatar-preview" src="{{avatarDisplayUrl || avatarTemp || avatarUrl}}" mode="aspectFill" />
              <view class="avatar-overlay">
                <text class="avatar-overlay-text">点击可预览大图</text>
              </view>
            </view>
            <view wx:else class="avatar-placeholder">
              <text class="avatar-placeholder-icon">＋</text>
              <text class="avatar-placeholder-text">上传头像</text>
            </view>
          </view>

          <view class="avatar-actions">
            <button class="avatar-action avatar-action-primary" bindtap="onChooseAvatar">
              <text>{{avatarTemp || avatarUrl ? '修改头像' : '上传头像'}}</text>
            </button>
          </view>
        </view>
      </view>

      <view class="section">
        <text class="section-title">基础资料</text>

        <view class="field">
          <text class="field-label required">姓名</text>
          <view class="field-control {{focusedField === 'name' ? 'field-control--focused' : ''}}">
            <input
              class="input"
              placeholder="请输入真实姓名"
              placeholder-class="input-placeholder"
              value="{{formData.name}}"
              bindinput="onNameInput"
              data-field="name"
              bindfocus="onFieldFocus"
              bindblur="onFieldBlur"
            />
          </view>
        </view>

        <view class="field">
          <text class="field-label required">性别</text>
          <view class="sex-picker">
            <view
              class="sex-option {{formData.sex === 'male' ? 'is-active' : ''}}"
              data-value="male"
              bindtap="onSexChange"
            >
              <view class="sex-option-circle">
                <image class="sex-option-image" src="/assets/icons/man.png" mode="aspectFit" />
              </view>
              <text class="sex-option-label">男</text>
            </view>
            <view
              class="sex-option {{formData.sex === 'female' ? 'is-active' : ''}}"
              data-value="female"
              bindtap="onSexChange"
            >
              <view class="sex-option-circle">
                <image class="sex-option-image" src="/assets/icons/woman.png" mode="aspectFit" />
              </view>
              <text class="sex-option-label">女</text>
            </view>
          </view>
        </view>

        <view class="field">
          <text class="field-label required">年龄</text>
          <view class="field-control {{focusedField === 'age' ? 'field-control--focused' : ''}}">
            <input
              class="input"
              type="digit"
              maxlength="3"
              placeholder="请输入年龄"
              placeholder-class="input-placeholder"
              value="{{formData.age}}"
              bindinput="onAgeInput"
              data-field="age"
              bindfocus="onFieldFocus"
              bindblur="onFieldBlur"
            />
          </view>
        </view>

        <view class="field">
          <text class="field-label required">职业</text>
          <view class="field-control {{focusedField === 'occupation' ? 'field-control--focused' : ''}}">
            <input
              class="input"
              placeholder="请输入职业"
              placeholder-class="input-placeholder"
              value="{{formData.occupation}}"
              bindinput="onOccupationInput"
              data-field="occupation"
              bindfocus="onFieldFocus"
              bindblur="onFieldBlur"
            />
          </view>
        </view>

        <view class="field">
          <text class="field-label required">行业</text>
          <view class="field-control {{focusedField === 'industry' ? 'field-control--focused' : ''}}">
            <input
              class="input"
              placeholder="请输入所在行业"
              placeholder-class="input-placeholder"
              value="{{formData.industry}}"
              bindinput="onIndustryInput"
              data-field="industry"
              bindfocus="onFieldFocus"
              bindblur="onFieldBlur"
            />
          </view>
        </view>
      </view>

      <view class="section">
        <text class="section-title">联系方式</text>

        <view class="field">
          <text class="field-label required">手机号</text>
          <view class="field-control {{focusedField === 'phone' ? 'field-control--focused' : ''}}">
            <input
              class="input {{phoneReadonly ? 'input-readonly' : ''}}"
              type="digit"
              maxlength="11"
              placeholder="请输入11位手机号"
              placeholder-class="input-placeholder"
              value="{{formData.phone}}"
              disabled="{{phoneReadonly}}"
              bindinput="onPhoneInput"
              data-field="phone"
              bindfocus="onFieldFocus"
              bindblur="onFieldBlur"
            />
          </view>
          <text class="field-tip" wx:if="{{phoneReadonly}}">已使用微信授权手机号，首次绑定时不可修改</text>
        </view>

        <view class="field">
          <text class="field-label required">邮箱</text>
          <view class="field-control {{focusedField === 'email' ? 'field-control--focused' : ''}}">
            <input
              class="input"
              placeholder="请输入邮箱"
              placeholder-class="input-placeholder"
              value="{{formData.email}}"
              bindinput="onEmailInput"
              data-field="email"
              bindfocus="onFieldFocus"
              bindblur="onFieldBlur"
            />
          </view>
        </view>
      </view>

      <view wx:if="{{error}}" class="error-box">
        <text class="error-text">{{error}}</text>
      </view>
    </view>
  </view>

  <view wx:if="{{!loading}}" class="bottom-bar">
    <button class="btn-submit" disabled="{{submitting || avatarUploading}}" bindtap="submit">
      <text class="btn-text">{{avatarUploading ? '头像处理中…' : submitting ? '提交中…' : '确认并提交'}}</text>
      <text class="btn-arrow ui-chevron ui-chevron--md">›</text>
    </button>
  </view>
</view>
