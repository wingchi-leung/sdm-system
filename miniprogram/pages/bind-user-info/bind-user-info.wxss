/**
 * 绑定用户信息页 - 高级简约风格
 */

.page {
  min-height: 100vh;
  padding: var(--space-xl) var(--space-lg);
  background: var(--background);
}

/* ─────────────────────────────────────────────────────────────
 * 头部
 * ───────────────────────────────────────────────────────────── */
.header {
  text-align: left;
  margin-bottom: var(--space-2xl);
  padding: var(--space-xl) 0;
  border-bottom: 1px solid var(--divider);
}

.header-title {
  display: block;
  font-family: var(--font-display);
  font-size: 40rpx;
  font-weight: 500;
  color: var(--text-primary);
  letter-spacing: 0.06em;
  margin-bottom: var(--space-sm);
}

.header-subtitle {
  display: block;
  font-size: 22rpx;
  color: var(--text-tertiary);
  letter-spacing: 0.08em;
}

/* ─────────────────────────────────────────────────────────────
 * 表单卡片
 * ───────────────────────────────────────────────────────────── */
.form-card {
  animation: fadeIn 0.4s ease;
}

/* ─────────────────────────────────────────────────────────────
 * 表单字段
 * ───────────────────────────────────────────────────────────── */
.field {
  margin-bottom: var(--space-lg);
}

.field:last-child {
  margin-bottom: 0;
}

.field-label {
  display: block;
  font-size: 22rpx;
  color: var(--text-muted);
  margin-bottom: var(--space-sm);
  font-weight: 500;
  letter-spacing: 0.1em;
  text-transform: uppercase;
}

.field-label::after {
  content: '';
}

.field-label.optional::after {
  content: '';
}

.input {
  width: 100%;
  height: 88rpx;
  padding: 0 0;
  font-size: 28rpx;
  background: transparent;
  border: none;
  border-bottom: 1px solid var(--border);
  border-radius: 0;
  box-sizing: border-box;
  color: var(--text-primary);
  transition: all 0.3s ease;
  letter-spacing: 0.04em;
}

.input:focus {
  border-bottom-color: var(--text-primary);
}

.input-placeholder {
  color: var(--text-muted);
}

/* ─────────────────────────────────────────────────────────────
 * 选择器
 * ───────────────────────────────────────────────────────────── */
.picker-field {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 88rpx;
  padding: 0 0;
  border-bottom: 1px solid var(--border);
  transition: all 0.3s ease;
}

.picker-field:active {
  opacity: 0.6;
}

.picker-text {
  font-size: 28rpx;
  color: var(--text-primary);
  letter-spacing: 0.04em;
}

.picker-arrow {
  font-size: 20rpx;
  color: var(--text-muted);
  font-weight: 300;
}

/* ─────────────────────────────────────────────────────────────
 * 错误提示
 * ───────────────────────────────────────────────────────────── */
.error-box {
  margin: var(--space-lg) 0;
  padding: var(--space-md);
  background: var(--error-bg);
  border-left: 2px solid var(--error);
}

.error-text {
  font-size: 24rpx;
  color: var(--error);
  letter-spacing: 0.02em;
}

/* ─────────────────────────────────────────────────────────────
 * 提交按钮
 * ───────────────────────────────────────────────────────────── */
.btn-submit {
  width: 100%;
  height: 96rpx;
  background: var(--primary);
  border-radius: var(--radius-xs);
  border: none;
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  margin-top: var(--space-2xl);
}

.btn-submit::after {
  border: none;
}

.btn-submit:active {
  opacity: 0.85;
}

.btn-submit[disabled] {
  opacity: 0.5;
}

.btn-submit .btn-text {
  font-size: 28rpx;
  font-weight: 500;
  color: #FFFFFF;
  letter-spacing: 0.12em;
}

/* 视觉降噪：去掉资料页分割线，改用浅底输入块 */
.header {
  border-bottom: none;
}

.input,
.picker-value {
  padding: 0 var(--space-md);
  border-bottom: none;
  border-radius: 6rpx;
  background: #F8F8F6;
}

.input:focus {
  border-bottom-color: transparent;
}

/* Product UI refinement：资料页规格统一 */
.page {
  padding: 24rpx 32rpx;
}

.header {
  margin-bottom: 24rpx;
  padding: 0;
}

.header-title {
  font-size: 44rpx;
  line-height: 56rpx;
  font-weight: 500;
  letter-spacing: 0.4rpx;
}

.header-subtitle,
.field-label,
.tip-text,
.error-text {
  color: #999999;
  font-size: 24rpx;
  line-height: 34rpx;
  font-weight: 400;
  letter-spacing: 0.4rpx;
  text-transform: none;
}

.field {
  margin-bottom: 24rpx;
}

.input,
.picker-value {
  height: 88rpx;
  border-radius: 16rpx;
  font-size: 28rpx;
  line-height: 40rpx;
  letter-spacing: 0.4rpx;
}

.btn-submit {
  height: 88rpx;
  margin-top: 24rpx;
  border-radius: 16rpx;
  background: #2F4F46;
  box-shadow: none;
}

.btn-submit .btn-text {
  font-size: 28rpx;
  line-height: 40rpx;
  font-weight: 500;
  letter-spacing: 0.4rpx;
}
