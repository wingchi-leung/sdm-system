.page {
  min-height: 100vh;
  padding: 24rpx 32rpx;
  box-sizing: border-box;
  background: #ffffff;
  color: #111111;
  font-family: "PingFang SC", -apple-system, BlinkMacSystemFont, "Helvetica Neue", sans-serif;
}

.header {
  margin-bottom: 24rpx;
  padding: 0;
}

.header-title {
  display: block;
  color: #111111;
  font-size: 44rpx;
  line-height: 56rpx;
  font-weight: 500;
}

.header-subtitle {
  display: block;
  margin-top: 10rpx;
  color: #999999;
  font-size: 24rpx;
  line-height: 34rpx;
}

.form-card {
  animation: fadeIn 0.4s ease;
}

.field {
  margin-bottom: 24rpx;
}

.field:last-child {
  margin-bottom: 0;
}

.field-label {
  display: block;
  margin-bottom: 12rpx;
  color: #666666;
  font-size: 24rpx;
  line-height: 34rpx;
}

.input {
  width: 100%;
  height: 88rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  background: #ffffff;
  border: 1rpx solid rgba(17, 17, 17, 0.08);
  border-radius: 20rpx;
  box-sizing: border-box;
  color: #111111;
}

.input-placeholder {
  color: #bbbbbb;
}

.input-readonly {
  color: #666666;
  background: #f7f7f5;
}

.field-tip {
  display: block;
  margin-top: 12rpx;
  color: #999999;
  font-size: 22rpx;
  line-height: 32rpx;
}

.picker-field {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 88rpx;
  padding: 0 24rpx;
  border: 1rpx solid rgba(17, 17, 17, 0.08);
  border-radius: 20rpx;
  background: #ffffff;
  box-sizing: border-box;
}

.picker-field:active {
  border-color: rgba(17, 17, 17, 0.2);
}

.picker-text {
  font-size: 28rpx;
  color: #111111;
}

.picker-arrow {
  font-size: 20rpx;
  color: #999999;
  font-weight: 300;
}

.error-box {
  margin: 0 0 16rpx;
  padding: 16rpx 18rpx;
  border-radius: 16rpx;
  background: var(--error-bg);
}

.error-text {
  font-size: 24rpx;
  color: var(--error);
  line-height: 34rpx;
}

.btn-submit {
  width: 100%;
  height: 88rpx;
  margin-top: 24rpx;
  background: #111111;
  border-radius: 16rpx;
  border: none;
}

.btn-submit::after {
  border: none;
}

.btn-submit:active {
  opacity: 0.88;
}

.btn-submit[disabled] {
  opacity: 0.5;
}

.btn-submit .btn-text {
  font-size: 28rpx;
  font-weight: 500;
  color: #ffffff;
  letter-spacing: 0.04em;
}

