.page {
  min-height: 100vh;
  padding: 24rpx 32rpx calc(140rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
  background: #ffffff;
  color: #111111;
  font-family: var(--font-body);
}

.shell {
  min-height: 100vh;
  box-sizing: border-box;
}

.hero {
  margin-top: 72rpx;
}

.hero-title {
  display: block;
  color: #111111;
  font-size: 54rpx;
  line-height: 1.28;
  font-weight: 500;
  letter-spacing: 0.04em;
}

.hero-underline {
  width: 56rpx;
  height: 4rpx;
  margin-top: 24rpx;
  background: #111111;
  border-radius: 999rpx;
}

.hero-subtitle {
  display: block;
  margin-top: -40rpx;
  color: #171717;
  font-size: 20rpx;
  line-height: 1.65;
  font-weight: 400;
  letter-spacing: 0.03em;
}

.form {
  margin-top: 32rpx;
  animation: fadeIn 0.4s ease;
}

.section {
  padding: 24rpx 0 0;
}

.section + .section {
  margin-top: 30rpx;
}

.section-title {
  display: block;
  color: #111111;
  font-size: 28rpx;
  line-height: 1.5;
  font-weight: 500;
  letter-spacing: 0.02em;
}

.avatar-section {
  margin-top: 18rpx;
}

.avatar-preview-wrap {
  position: relative;
  width: 200rpx;
  height: 200rpx;
  overflow: hidden;
  border-radius: 50%;
  border: 1rpx solid #F0F1F4;
  box-sizing: border-box;
  background: linear-gradient(180deg, #fbfbfb 0%, #f2f2f2 100%);
  box-shadow: 0 10rpx 26rpx rgba(17, 17, 17, 0.06);
}

.avatar-preview-frame {
  position: relative;
  width: 100%;
  height: 100%;
  overflow: hidden;
  border-radius: 50%;
}

.avatar-preview {
  width: 100%;
  height: 100%;
  display: block;
  background: #ffffff;
}

.avatar-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
}

.avatar-placeholder-icon {
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: rgba(17, 17, 17, 0.04);
  color: #111111;
  font-size: 38rpx;
  line-height: 1;
  font-weight: 300;
}

.avatar-placeholder-text {
  color: #111111;
  font-size: 22rpx;
  line-height: 1.4;
  font-weight: 500;
}

.avatar-overlay {
  position: absolute;
  left: 16rpx;
  right: 16rpx;
  bottom: 16rpx;
  padding: 10rpx 14rpx;
  border-radius: 999rpx;
  background: rgba(17, 17, 17, 0.62);
  backdrop-filter: blur(6rpx);
}

.avatar-overlay-text {
  color: #ffffff;
  font-size: 20rpx;
  line-height: 1.4;
}

.avatar-copy {
  margin-top: 20rpx;
}

.avatar-title {
  display: block;
  color: #111111;
  font-size: 28rpx;
  line-height: 1.5;
  font-weight: 500;
}

.avatar-tip {
  display: block;
  margin-top: 10rpx;
  color: #888888;
  font-size: 22rpx;
  line-height: 1.6;
}

.avatar-actions {
  display: flex;
  justify-content: center;
  gap: 10rpx;
  margin-top: 14rpx;
}

.avatar-action {
  flex: 0 0 auto;
  width: 126rpx;
  min-height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 999rpx;
  box-sizing: border-box;
  font-size: 20rpx;
  line-height: 1;
  border: 1rpx solid transparent;
}

.avatar-action-primary {
  background: #ffffff;
  color: #111111;
  border-color: rgba(2, 2, 2, 0.08);
}

.avatar-action-ghost {
  background: #ffffff;
  color: #111111;
  border-color: rgba(17, 17, 17, 0.08);
}

.field {
  padding: 24rpx 0 0;
}

.field + .field {
  margin-top: 8rpx;
}

.field-label {
  display: block;
  color: #111111;
  font-size: 28rpx;
  line-height: 1.5;
}

.field-label.required::after {
  content: " *";
  color: #111111;
}

.field-control {
  position: relative;
  margin-top: 16rpx;
  padding-bottom: 8rpx;
}

.field-control::after {
  content: "";
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  height: 1rpx;
  background: rgba(17, 17, 17, 0.12);
}

.field-control::before {
  content: "";
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  height: 1rpx;
  background: #111111;
  transform: scaleX(0);
  transform-origin: left center;
  transition: transform 0.2s ease;
}

.field-control--focused::before {
  transform: scaleX(1);
}

.input {
  width: 100%;
  min-height: 58rpx;
  padding: 0;
  margin: 0;
  border: 0;
  background: transparent;
  box-sizing: border-box;
  color: #111111;
  font-size: 28rpx;
  line-height: 58rpx;
}

.input-placeholder {
  color: #bbbbbb;
}

.input-readonly {
  color: #999999;
}

.field-tip {
  display: block;
  margin-top: 14rpx;
  color: #999999;
  font-size: 22rpx;
  line-height: 1.7;
}

.picker-field {
  display: flex;
  align-items: center;
  justify-content: space-between;
  min-height: 58rpx;
  padding: 0 0 8rpx;
  border-bottom: 1rpx solid rgba(17, 17, 17, 0.12);
  box-sizing: border-box;
}

.sex-picker {
  display: flex;
  gap: 14rpx;
  margin-top: 20rpx;
}

.sex-option {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: flex-start;
  gap: 10rpx;
  padding: 6rpx 0 0;
  transition: border-color 0.18s ease, background 0.18s ease;
}

.sex-option.is-active {
  opacity: 1;
}

.sex-option-image {
  width: 28rpx;
  height: 28rpx;
}

.sex-option-circle {
  width: 84rpx;
  height: 84rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  border: 1rpx solid rgba(17, 17, 17, 0.08);
  background: #ffffff;
  box-shadow: inset 0 2rpx 0 rgba(255, 255, 255, 0.9);
}

.sex-option.is-active .sex-option-circle {
  border-color: #111111;
  background: rgba(17, 17, 17, 0.04);
}

.sex-option-label {
  color: #111111;
  font-size: 18rpx;
  line-height: 1.4;
  text-align: center;
}

.picker-field:active {
  border-bottom-color: #111111;
}

.picker-text {
  color: #111111;
  font-size: 28rpx;
  line-height: 58rpx;
}

.picker-arrow {
  font-size: 30rpx;
  color: #999999;
  font-weight: 300;
}

.error-box {
  margin-top: 20rpx;
  padding: 16rpx 18rpx;
  border-radius: 16rpx;
  background: var(--error-bg);
}

.error-text {
  color: var(--error);
  font-size: 22rpx;
  line-height: 1.7;
}

.bottom-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 20;
  display: flex;
  justify-content: flex-end;
  padding: 16rpx 32rpx calc(env(safe-area-inset-bottom) + 20rpx);
  background: linear-gradient(180deg, rgba(255, 255, 255, 0), rgba(255, 255, 255, 0.96) 28%, #ffffff 100%);
}

.btn-submit {
  display: inline-flex;
  align-items: center;
  justify-content: flex-end;
  gap: 12rpx;
  width: auto;
  min-height: 0;
  padding: 0;
  margin: 0;
  border: 0;
  background: transparent;
  border-radius: 0;
}

.btn-submit::after {
  border: none;
}

.btn-submit:active {
  opacity: 0.88;
}

.btn-submit[disabled] {
  opacity: 0.5;
}

.btn-text {
  color: #111111;
  font-size: 26rpx;
  line-height: 1;
}

.btn-arrow {
  color: #111111;
  font-size: 30rpx;
  line-height: 1;
  font-weight: 300;
}

.state-wrap {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 0 48rpx;
  box-sizing: border-box;
}

.loading {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  border: 2rpx solid rgba(17, 17, 17, 0.12);
  border-top-color: #111111;
  animation: spin 0.85s linear infinite;
}

.state-text {
  margin-top: 18rpx;
  color: #999999;
  font-size: 24rpx;
  line-height: 1.6;
}

@keyframes spin {
  to {
    transform: rotate(360deg);
  }
}

@keyframes fadeIn {
  from {
    opacity: 0;
    transform: translateY(8rpx);
  }

  to {
    opacity: 1;
    transform: translateY(0);
  }
}
