.page {
  min-height: 100vh;
  padding: 24rpx 32rpx calc(140rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
  background: #ffffff;
  color: #111111;
  font-family: "PingFang SC", -apple-system, BlinkMacSystemFont, "Helvetica Neue", sans-serif;
}

.shell {
  min-height: 100vh;
  box-sizing: border-box;
}

.hero {
  margin-top: 72rpx;
}

.hero-title {
  display: block;
  color: #111111;
  font-size: 54rpx;
  line-height: 1.28;
  font-weight: 500;
  letter-spacing: 0.04em;
}

.hero-underline {
  width: 56rpx;
  height: 4rpx;
  margin-top: 24rpx;
  background: #111111;
  border-radius: 999rpx;
}

.hero-subtitle {
  display: block;
  margin-top: 34rpx;
  color: #666666;
  font-size: 28rpx;
  line-height: 1.65;
  font-weight: 400;
  letter-spacing: 0.03em;
}

.form {
  margin-top: 32rpx;
  animation: fadeIn 0.4s ease;
}

.section {
  padding: 24rpx 0 0;
  border-top: 1rpx solid var(--divider);
}

.section + .section {
  margin-top: 30rpx;
}

.section-title {
  display: block;
  color: #111111;
  font-size: 28rpx;
  line-height: 1.5;
  font-weight: 500;
  letter-spacing: 0.02em;
}

.field {
  padding: 24rpx 0 0;
}

.field + .field {
  margin-top: 8rpx;
}

.field-label {
  display: block;
  color: #111111;
  font-size: 28rpx;
  line-height: 1.5;
}

.field-label.required::after {
  content: " *";
  color: #111111;
}

.field-control {
  position: relative;
  margin-top: 16rpx;
  padding-bottom: 8rpx;
}

.field-control::after {
  content: "";
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  height: 1rpx;
  background: rgba(17, 17, 17, 0.12);
}

.field-control::before {
  content: "";
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  height: 1rpx;
  background: #111111;
  transform: scaleX(0);
  transform-origin: left center;
  transition: transform 0.2s ease;
}

.field-control:active::before {
  transform: scaleX(1);
}

.input {
  width: 100%;
  min-height: 58rpx;
  padding: 0;
  margin: 0;
  border: 0;
  background: transparent;
  box-sizing: border-box;
  color: #111111;
  font-size: 28rpx;
  line-height: 58rpx;
}

.input-placeholder {
  color: #bbbbbb;
}

.input-readonly {
  color: #999999;
}

.field-tip {
  display: block;
  margin-top: 14rpx;
  color: #999999;
  font-size: 22rpx;
  line-height: 1.7;
}

.picker-field {
  display: flex;
  align-items: center;
  justify-content: space-between;
  min-height: 58rpx;
  padding: 0 0 8rpx;
  border-bottom: 1rpx solid rgba(17, 17, 17, 0.12);
  box-sizing: border-box;
}

.sex-picker {
  display: flex;
  gap: 20rpx;
  margin-top: 20rpx;
}

.sex-option {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  padding: 24rpx 0;
  border-radius: 16rpx;
  border: 1rpx solid rgba(17, 17, 17, 0.08);
  background: #ffffff;
  transition: border-color 0.18s ease, background 0.18s ease;
}

.sex-option.is-active {
  border-color: #111111;
  background: rgba(17, 17, 17, 0.04);
}

.sex-option-image {
  width: 64rpx;
  height: 64rpx;
}

.sex-option-label {
  color: #111111;
  font-size: 26rpx;
  line-height: 1.4;
}

.picker-field:active {
  border-bottom-color: #111111;
}

.picker-text {
  color: #111111;
  font-size: 28rpx;
  line-height: 58rpx;
}

.picker-arrow {
  font-size: 30rpx;
  color: #999999;
  font-weight: 300;
}

.error-box {
  margin-top: 20rpx;
  padding: 16rpx 18rpx;
  border-radius: 16rpx;
  background: var(--error-bg);
}

.error-text {
  color: var(--error);
  font-size: 22rpx;
  line-height: 1.7;
}

.bottom-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 20;
  display: flex;
  justify-content: flex-end;
  padding: 18rpx 32rpx calc(env(safe-area-inset-bottom) + 24rpx);
  background: linear-gradient(180deg, rgba(255, 255, 255, 0), rgba(255, 255, 255, 0.96) 28%, #ffffff 100%);
}

.btn-submit {
  display: inline-flex;
  align-items: center;
  justify-content: flex-end;
  gap: 16rpx;
  width: auto;
  min-height: 0;
  padding: 0;
  margin: 0;
  border: 0;
  background: transparent;
  border-radius: 0;
}

.btn-submit::after {
  border: none;
}

.btn-submit:active {
  opacity: 0.88;
}

.btn-submit[disabled] {
  opacity: 0.5;
}

.btn-text {
  color: #111111;
  font-size: 30rpx;
  line-height: 1;
}

.btn-arrow {
  color: #111111;
  font-size: 36rpx;
  line-height: 1;
  font-weight: 300;
}

.state-wrap {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 0 48rpx;
  box-sizing: border-box;
}

.loading {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  border: 2rpx solid rgba(17, 17, 17, 0.12);
  border-top-color: #111111;
  animation: spin 0.85s linear infinite;
}

.state-text {
  margin-top: 18rpx;
  color: #999999;
  font-size: 24rpx;
  line-height: 1.6;
}

@keyframes spin {
  to {
    transform: rotate(360deg);
  }
}

@keyframes fadeIn {
  from {
    opacity: 0;
    transform: translateY(8rpx);
  }

  to {
    opacity: 1;
    transform: translateY(0);
  }
}
