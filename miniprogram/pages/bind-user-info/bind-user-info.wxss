.page {
  min-height: 100vh;
  background-color: #FAFAF8;
  padding: 40rpx;
}

.header {
  text-align: center;
  margin-bottom: 60rpx;
}

.title {
  display: block;
  font-size: 48rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 16rpx;
}

.subtitle {
  display: block;
  font-size: 28rpx;
  color: #999;
}

.form {
  background-color: #fff;
  border-radius: 16rpx;
  padding: 32rpx;
}

.field {
  margin-bottom: 32rpx;
}

.label {
  display: block;
  font-size: 28rpx;
  color: #666;
  margin-bottom: 16rpx;
}

.label.required::before {
  content: '*';
  color: #ff4d4f;
  margin-right: 4rpx;
}

.input {
  width: 100%;
  height: 80rpx;
  border: 1rpx solid #e5e5e5;
  border-radius: 8rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.picker {
  height: 80rpx;
  border: 1rpx solid #e5e5e5;
  border-radius: 8rpx;
  padding: 0 24rpx;
  line-height: 80rpx;
  font-size: 28rpx;
  color: #333;
}

.error-box {
  margin: 32rpx 0;
  padding: 16rpx 24rpx;
  background-color: #fff2f0;
  border-radius: 8rpx;
}

.error-text {
  color: #ff4d4f;
  font-size: 24rpx;
}

.submit-btn {
  width: 100%;
  height: 88rpx;
  background-color: #4988FC;
  color: #fff;
  border-radius: 44rpx;
  font-size: 32rpx;
  margin-top: 48rpx;
}
