.page {
  min-height: 100vh;
  padding: 24rpx 32rpx calc(140rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
  background: #ffffff;
  color: #111111;
  font-family: var(--font-body);
}

.shell {
  min-height: 100vh;
  box-sizing: border-box;
}

.hero {
  margin-top: 72rpx;
}

.hero-title {
  display: block;
  color: #111111;
  font-size: 54rpx;
  line-height: 1.28;
  font-weight: 500;
  letter-spacing: 0.04em;
}

.hero-underline {
  width: 56rpx;
  height: 4rpx;
  margin-top: 24rpx;
  background: #111111;
  border-radius: 999rpx;
}

.hero-subtitle {
  display: block;
  margin-top: -40rpx;
  color: #171717;
  font-size: 20rpx;
  line-height: 1.65;
  font-weight: 400;
  letter-spacing: 0.03em;
}

.form {
  margin-top: 32rpx;
  animation: fadeIn 0.4s ease;
}

.section {
  padding: 24rpx 0 0;
}

.section + .section {
  margin-top: 30rpx;
}

.section-title {
  display: block;
  color: #111111;
  font-size: 28rpx;
  line-height: 1.5;
  font-weight: 500;
  letter-spacing: 0.02em;
}

.avatar-section {
  margin-top: 18rpx;
}

.avatar-preview-wrap {
  position: relative;
  width: 200rpx;
  height: 200rpx;
  overflow: hidden;
  border-radius: 50%;
  border: 1rpx solid #F0F1F4;
  box-sizing: border-box;
}

.avatar-preview-frame {
  position: relative;
  width: 100%;
  height: 100%;
  overflow: hidden;
  border-radius: 50%;
}

.avatar-preview {
  width: 100%;
  height: 100%;
  display: block;
  background: #ffffff;
}

.avatar-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
}

.avatar-placeholder-icon {
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: rgba(17, 17, 17, 0.04);
  color: #111111;
  font-size: 38rpx;
  line-height: 1;
  font-weight: 300;
}

.avatar-placeholder-text {
  color: #111111;
  font-size: 22rpx;
  line-height: 1.4;
  font-weight: 500;
}

.avatar-overlay {
  position: absolute;
  left: 16rpx;
  right: 16rpx;
  bottom: 16rpx;
  padding: 10rpx 14rpx;
  border-radius: 999rpx;
  background: rgba(17, 17, 17, 0.62);
  backdrop-filter: blur(6rpx);
}

.avatar-overlay-text {
  color: #ffffff;
  font-size: 20rpx;
  line-height: 1.4;
}

.avatar-actions {
  display: flex;
  justify-content: center;
  gap: 10rpx;
  margin-top: 14rpx;
}

.avatar-action {
  flex: 0 0 auto;
  width: 126rpx;
  min-height: 48rpx;
  padding: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 999rpx;
  box-sizing: border-box;
  font-size: 20rpx;
  line-height: 1;
  border: 1rpx solid transparent;
  background: transparent;
}

.avatar-action::after {
  border: 0;
}

.avatar-action-primary {
  background: #ffffff;
  color: #111111;
  border-color: rgba(2, 2, 2, 0.08);
}

.field {
  padding: 24rpx 0 0;
}

.field + .field {
  margin-top: 8rpx;
}

.field-label {
  display: block;
  color: #111111;
  font-size: 28rpx;
  line-height: 1.5;
}

.field-label.required::after {
  content: " *";
  color: #111111;
}

.field-control {
  position: relative;
  margin-top: 16rpx;
  padding-bottom: 8rpx;
}

.field-control::after {
  content: "";
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  height: 1rpx;
  background: rgba(17, 17, 17, 0.12);
}

.field-control::before {
  content: "";
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  height: 1rpx;
  background: #111111;
  transform: scaleX(0);
  transform-origin: left center;
  transition: transform 0.2s ease;
}

.field-control--focused::before {
  transform: scaleX(1);
}

.input {
  width: 100%;
  min-height: 58rpx;
  padding: 0;
  margin: 0;
  border: 0;
  background: transparent;
  box-sizing: border-box;
  color: #111111;
  font-size: 28rpx;
  line-height: 58rpx;
}

.input-readonly {
  color: #666666;
}

.field-tip {
  display: block;
  margin-top: 10rpx;
  color: #999999;
  font-size: 20rpx;
  line-height: 1.6;
}

.sex-picker {
  display: flex;
  gap: 20rpx;
  margin-top: 16rpx;
}

.sex-option {
  flex: 1;
  min-width: 0;
  height: 172rpx;
  border-radius: 28rpx;
  background: #f8f8f8;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  box-sizing: border-box;
  border: 1rpx solid transparent;
}

.sex-option.is-active {
  border-color: #111111;
  background: #ffffff;
}

.sex-option-circle {
  width: 76rpx;
  height: 76rpx;
  border-radius: 50%;
  background: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
}

.sex-option-image {
  width: 44rpx;
  height: 44rpx;
}

.sex-option-label {
  color: #111111;
  font-size: 26rpx;
  line-height: 1.3;
  font-weight: 500;
}

.error-box {
  margin-top: 24rpx;
  padding: 16rpx 18rpx;
  border-radius: 16rpx;
  background: var(--error-bg);
}

.error-text {
  color: var(--error);
  font-size: 24rpx;
  line-height: 34rpx;
}

.bottom-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 16rpx 32rpx calc(16rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
  background: linear-gradient(to top, #ffffff 76%, rgba(255, 255, 255, 0));
}

.btn-submit {
  width: 100%;
  height: 84rpx;
  margin: 0;
  border: 0;
  border-radius: 999rpx;
  background: #111111;
  color: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
}

.btn-submit::after {
  border: 0;
}

.btn-submit:disabled {
  opacity: 0.72;
}

.btn-text {
  font-size: 30rpx;
  line-height: 1;
  font-weight: 500;
}

.btn-arrow {
  color: currentColor;
}
