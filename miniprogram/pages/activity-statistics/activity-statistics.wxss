.page {
  min-height: 100vh;
  padding: 24rpx 32rpx;
  background: #ffffff;
  box-sizing: border-box;
  color: #111111;
  font-family: "PingFang SC", -apple-system, BlinkMacSystemFont, "Helvetica Neue", sans-serif;
}

.content {
  animation: fadeIn 0.4s ease;
}

.state-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 50vh;
}

.stats-section {
  display: flex;
  align-items: stretch;
  justify-content: space-between;
  gap: 12rpx;
  padding-bottom: 24rpx;
  border-bottom: 1rpx solid var(--divider);
  margin-bottom: 24rpx;
}

.stat-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.stat-value {
  font-size: 44rpx;
  line-height: 56rpx;
  font-weight: 500;
  color: #111111;
  letter-spacing: 0.02em;
}

.stat-value.highlight {
  color: #111111;
}

.stat-label {
  font-size: 20rpx;
  color: #999999;
  letter-spacing: 0.08em;
}

.stat-divider {
  width: 1rpx;
  height: 64rpx;
  background: var(--divider);
}

.info-section {
  margin-bottom: 24rpx;
}

.section-title {
  display: block;
  font-size: 20rpx;
  font-weight: 500;
  color: #999999;
  letter-spacing: 0.12em;
  margin-bottom: 12rpx;
}

.info-item {
  display: flex;
  align-items: baseline;
  padding: 16rpx 0;
  border-bottom: 1rpx solid var(--divider);
}

.info-item:last-child {
  border-bottom: none;
}

.info-label {
  width: 120rpx;
  font-size: 22rpx;
  color: #999999;
}

.info-value {
  flex: 1;
  font-size: 26rpx;
  color: #111111;
  word-break: break-word;
}

.info-value.status-1,
.info-value.status-2,
.info-value.status-3 {
  color: #111111;
}

.refresh-section {
  display: flex;
  justify-content: flex-end;
  padding-top: 24rpx;
  border-top: 1rpx solid var(--divider);
}

.refresh-btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 128rpx;
  min-height: 56rpx;
  padding: 0 28rpx;
  box-sizing: border-box;
  border: none;
  border-radius: 28rpx;
  background: #f7f7f5;
  color: #111111;
  font-size: 24rpx;
  font-weight: 500;
  letter-spacing: 0.04em;
}

.refresh-btn:active {
  background: #efefed;
}
