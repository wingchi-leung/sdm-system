<view class="page">
  <!-- 加载状态 -->
  <view wx:if="{{loading}}" class="state-wrap">
    <view class="loading"></view>
  </view>

  <!-- 统计内容 -->
  <view wx:elif="{{statistics}}" class="content">
    <!-- 核心数据 -->
    <view class="stats-section">
      <view class="stat-item">
        <text class="stat-value">{{statistics.total_participants}}</text>
        <text class="stat-label">报名人数</text>
      </view>
      <view class="stat-divider"></view>
      <view class="stat-item">
        <text class="stat-value">{{statistics.total_checkins}}</text>
        <text class="stat-label">签到人数</text>
      </view>
      <view class="stat-divider"></view>
      <view class="stat-item">
        <text class="stat-value highlight">{{checkinRate}}%</text>
        <text class="stat-label">签到率</text>
      </view>
    </view>

    <!-- 活动信息 -->
    <view class="info-section">
      <text class="section-title">活动信息</text>
      <view class="info-item">
        <text class="info-label">活动名称</text>
        <text class="info-value">{{statistics.activity_name}}</text>
      </view>
      <view class="info-item">
        <text class="info-label">活动状态</text>
        <text class="info-value status-{{statistics.status}}">{{getStatusText(statistics.status)}}</text>
      </view>
    </view>

    <!-- 刷新 -->
    <view class="refresh-section">
      <view class="refresh-btn" bindtap="onRefresh">刷新</view>
    </view>
  </view>
</view>