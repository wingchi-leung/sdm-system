<view class="container">
  <view wx:if="{{loading}}" class="loading">加载中...</view>

  <view wx:elif="{{statistics}}" class="statistics-content">
    <!-- 活动状态卡片 -->
    <view class="card status-card">
      <view class="card-title">活动状态</view>
      <view class="status-badge" style="background-color: {{getStatusColor(statistics.status)}}">
        {{getStatusText(statistics.status)}}
      </view>
    </view>

    <!-- 统计数据卡片 -->
    <view class="card stats-card">
      <view class="card-title">报名数据</view>
      <view class="stats-grid">
        <view class="stat-item">
          <text class="stat-label">报名人数</text>
          <text class="stat-value">{{statistics.total_participants}}</text>
        </view>
        <view class="stat-divider"></view>
        <view class="stat-item">
          <text class="stat-label">签到人数</text>
          <text class="stat-value">{{statistics.total_checkins}}</text>
        </view>
        <view class="stat-divider"></view>
        <view class="stat-item">
          <text class="stat-label">签到率</text>
          <text class="stat-value highlight">{{checkinRate}}%</text>
        </view>
      </view>
    </view>

    <!-- 活动信息 -->
    <view class="card info-card">
      <view class="card-title">活动信息</view>
      <view class="info-row">
        <text class="info-label">活动名称</text>
        <text class="info-value">{{statistics.activity_name}}</text>
      </view>
      <view class="info-row">
        <text class="info-label">活动状态</text>
        <text class="info-value">{{getStatusText(statistics.status)}}</text>
      </view>
      <view wx:if="{{statistics.is_active !== undefined}}" class="info-row">
        <text class="info-label">是否活跃</text>
        <text class="info-value">{{statistics.is_active ? '是' : '否'}}</text>
      </view>
    </view>
  </view>

  <view class="refresh-btn">
    <button bindtap="onRefresh" size="mini">刷新</button>
  </view>
</view>
