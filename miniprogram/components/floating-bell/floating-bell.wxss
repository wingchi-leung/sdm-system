.floating-bell {
  position: fixed;
  z-index: 100;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--background-card);
  border-radius: var(--radius-full);
  box-shadow: 0 2rpx 16rpx rgba(17, 17, 17, 0.12);
}

.bell-icon {
  width: 58%;
  height: 58%;
}

/* 未读角标 */
.badge {
  position: absolute;
  top: -8rpx;
  right: -8rpx;
  min-width: 34rpx;
  height: 34rpx;
  background: var(--error);
  border-radius: var(--radius-full);
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 8rpx;
  box-sizing: border-box;
}

/* 仅小红点模式 */
.badge-dot {
  min-width: 16rpx;
  height: 16rpx;
  top: -4rpx;
  right: -4rpx;
  padding: 0;
}

.badge-text {
  color: #ffffff;
  font-size: 18rpx;
  font-weight: 600;
  line-height: 1;
}
