.calendar-shell {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  padding: 24rpx;
  border-radius: 32rpx;
  background: linear-gradient(180deg, #ffffff 0%, #f7fafc 100%);
  border: 1rpx solid rgba(15, 26, 23, 0.06);
  box-shadow: 0 24rpx 48rpx rgba(15, 26, 23, 0.06);
}

.calendar-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.calendar-nav {
  width: 72rpx;
  height: 72rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(15, 26, 23, 0.04);
  color: #0f1a17;
}

.calendar-nav-icon {
  font-size: 36rpx;
  line-height: 1;
}

.calendar-title-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.calendar-title {
  font-size: 34rpx;
  line-height: 1.2;
  font-weight: 600;
  color: #0f1a17;
}

.calendar-subtitle {
  font-size: 22rpx;
  color: rgba(15, 26, 23, 0.54);
}

.calendar-week-row,
.calendar-week {
  display: grid;
  grid-template-columns: repeat(7, 1fr);
  gap: 8rpx;
}

.calendar-week-row {
  margin-top: 8rpx;
}

.calendar-week-cell {
  text-align: center;
  font-size: 22rpx;
  color: rgba(15, 26, 23, 0.46);
}

.calendar-grid {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.calendar-day-wrap {
  display: flex;
  justify-content: center;
}

.calendar-day {
  position: relative;
  width: 84rpx;
  height: 84rpx;
  border-radius: 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(15, 26, 23, 0.03);
  color: #0f1a17;
  transition: transform 0.15s ease, background-color 0.15s ease;
}

.calendar-day--out {
  opacity: 0.28;
}

.calendar-day--weekend .calendar-day-text {
  color: #4f7084;
}

.calendar-day--today {
  border: 2rpx solid #2f6fe8;
  background: rgba(47, 111, 232, 0.08);
}

.calendar-day--selected {
  background: #2f6fe8;
  color: #ffffff;
}

.calendar-day--event::after {
  content: '';
  position: absolute;
  left: 50%;
  bottom: 10rpx;
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  background: #f79009;
  transform: translateX(-50%);
}

.calendar-day--selected.calendar-day--event::after {
  background: #ffffff;
}

.calendar-day-text {
  position: relative;
  z-index: 1;
  font-size: 28rpx;
  line-height: 1;
  font-weight: 500;
}

.calendar-footer {
  display: flex;
  justify-content: center;
}

.calendar-today-btn {
  padding: 16rpx 24rpx;
  border-radius: 999rpx;
  background: rgba(47, 111, 232, 0.08);
  color: #2f6fe8;
}

.calendar-today-btn__text {
  font-size: 24rpx;
  font-weight: 600;
}
