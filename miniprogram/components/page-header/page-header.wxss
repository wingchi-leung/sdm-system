.page-header {
  width: 100vw;
  margin-left: calc(50% - 50vw);
  box-sizing: border-box;
}

.page-header__spacer {
  width: 100%;
}

.page-header__bar {
  position: relative;
  min-height: 92rpx;
  padding: 15rpx 28rpx 16rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-sizing: border-box;
}

.page-header__left,
.page-header__right {
  flex: 0 0 auto;
  display: flex;
  align-items: center;
  width: 68rpx;
  position: relative;
  z-index: 1;
}

.page-header__right {
  justify-content: flex-end;
}

.page-header__title {
  position: absolute;
  left: 50%;
  top: 50%;
  max-width: calc(100% - 200rpx);
  overflow: hidden;
  transform: translate(-50%, -50%);
  color: #111111;
  font-size: 36rpx;
  line-height: 1.2;
  font-weight: 500;
  text-align: center;
  white-space: nowrap;
  text-overflow: ellipsis;
  box-sizing: border-box;
  pointer-events: none;
}

.page-header__back {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 999rpx;
  box-sizing: border-box;
}

.page-header__back--active {
  background: rgba(17, 17, 17, 0.06);
}

.page-header__back-icon {
  color: #111111;
}
