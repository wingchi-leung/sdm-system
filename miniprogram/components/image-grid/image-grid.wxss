/* image-grid:三种排布(单图 / 2 列 / 3 列),统一圆角与间距 */
.image-grid {
  width: 100%;
  box-sizing: border-box;
}

/* 单图:宽 100%,高度按 widthFix 自适应 */
.image-grid__single {
  position: relative;
  width: 100%;
  border-radius: 22rpx;
  overflow: hidden;
}

.image-grid__single .image-grid__item {
  width: 100%;
  height: auto;
  display: block;
  border-radius: 22rpx;
}

.image-grid__add--single {
  margin-top: var(--space-xs);
  width: 100%;
  height: 192rpx;
  border-radius: 22rpx;
}

/* 2 列网格 */
.image-grid--grid-2 {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: var(--space-xs);
}

/* 3 列网格 */
.image-grid--grid-3 {
  display: grid;
  grid-template-columns: 1fr 1fr 1fr;
  gap: var(--space-xs);
}

/* 网格单元:1:1 方形 + 圆角 */
.image-grid__cell {
  position: relative;
  width: 100%;
  aspect-ratio: 1 / 1;
  border-radius: 22rpx;
  overflow: hidden;
  box-sizing: border-box;
}

.image-grid__item {
  width: 100%;
  height: 100%;
  display: block;
  border-radius: 22rpx;
  background-color: #f8fafc;
}

/* edit 模式 + 占位 */
.image-grid__add {
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: #fbfdff;
  border: 1rpx dashed #d8e0ea;
  border-radius: 22rpx;
  box-sizing: border-box;
  transition: opacity 0.2s ease;
}

.image-grid__add:active {
  opacity: 0.6;
}

.image-grid__add-icon {
  font-size: 54rpx;
  font-weight: 300;
  color: #8f99a8;
  line-height: 1;
}

/* edit 模式:右上角删除按钮 */
.image-grid__remove {
  position: absolute;
  top: 10rpx;
  right: 10rpx;
  width: 28rpx;
  height: 28rpx;
  line-height: 26rpx;
  text-align: center;
  font-size: 24rpx;
  color: #ffffff;
  background-color: rgba(0, 0, 0, 0.6);
  border-radius: 50%;
  z-index: 2;
  font-weight: 300;
}

.image-grid__remove:active {
  background-color: rgba(0, 0, 0, 0.85);
}
